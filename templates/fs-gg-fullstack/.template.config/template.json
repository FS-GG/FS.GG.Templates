{
  "$schema": "http://json.schemastore.org/template",
  "author": "FS-Skia-UI Contributors",
  "classifications": [
    "F#",
    "Skia",
    "Elmish",
    "Template"
  ],
  "identity": "FS.GG.Templates.FullStack",
  "name": "FS.GG Full-Stack (SDD + Rendering + Governance)",
  "shortName": "fs-gg-fullstack",
  "sourceName": "Product",
  "preferNameDirectory": true,
  "symbols": {
    "governanceProfile": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "standard",
      "replaces": "GOV_DEFAULT_PROFILE",
      "description": "Default FS.GG.Governance profile written to .fsgg/policy.yml.",
      "choices": [
        {
          "choice": "light",
          "description": "Lightest gate set."
        },
        {
          "choice": "standard",
          "description": "Standard gate set (default)."
        },
        {
          "choice": "strict",
          "description": "Strictest gate set."
        }
      ]
    },
    "profile": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "app",
      "description": "V3 product profile to generate.",
      "choices": [
        {
          "choice": "app",
          "description": "Default V3 product app with Scene, SkiaViewer, Elmish, KeyboardInput, Layout, Controls, product tests, and product governance."
        },
        {
          "choice": "headless-scene",
          "description": "Headless Scene-only V3 product for scene/widget authoring."
        },
        {
          "choice": "governed",
          "description": "Governed V3 product with Scene plus Testing helpers."
        },
        {
          "choice": "sample-pack",
          "description": "Sample-oriented V3 product with Scene, SkiaViewer, Elmish, and sample-pack content."
        }
      ]
    },
    "designSystem": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "wcag",
      "description": "Governing color policy for the generated product. 'wcag' (default) is byte-identical to today; 'ant' imprints the Ant design language and Ant contrast policy. Unknown values are rejected.",
      "choices": [
        {
          "choice": "wcag",
          "description": "WCAG 2.x contrast governance (default; no diff vs today's template)."
        },
        {
          "choice": "ant",
          "description": "Ant Design contrast expectations over the Ant-derived tokens."
        }
      ]
    },
    "rootNamespace": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "Product",
      "description": "Compatibility parameter accepted by the template; generated project names are derived from --name."
    },
    "packagePrefix": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "FS.GG.UI",
      "description": "Package prefix reserved for future generated product packages."
    },
    "authors": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "FS-Skia-UI Contributors",
      "replaces": "FS-Skia-UI Contributors",
      "description": "Generated product authors."
    },
    "repositoryUrl": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "https://github.com/FS-Skia-UI/FS-Skia-UI",
      "replaces": "https://github.com/FS-Skia-UI/FS-Skia-UI",
      "description": "Generated product repository URL."
    },
    "targetFramework": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "net10.0",
      "replaces": "net10.0",
      "description": "Target framework for generated projects."
    },
    "skipGitInit": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Skip automatic Git repository initialization after template creation."
    },
    "feedback": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "description": "Capture per-phase Spec Kit feedback into specs/<feature>/feedback/ (adds the after_* feedback hooks and the fs-gg-feedback-capture skill). Default false induces no diff."
    },
    "projectSlug": {
      "type": "generated",
      "generator": "casing",
      "parameters": {
        "source": "name",
        "toLower": true
      },
      "replaces": "fs-gg-ui"
    }
  },
  "sources": [
    {
      "source": "template/fsgg/",
      "target": "./",
      "comment": "FS.GG.Templates: layer the SDD lifecycle skeleton (.fsgg/project.yml, sdd.yml, agents.yml, work/, readiness/) and FS.GG.Governance config (.fsgg/policy.yml, capabilities.yml, tooling.yml) on top of the rendering product."
    },
    {
      "source": "template/base/",
      "target": "./",
      "exclude": [
        "bin/**",
        "obj/**",
        "**/bin/**",
        "**/obj/**"
      ],
      "comment": "Feature 060 (FR-003): the emitted docs/api-surface/**/*.fsi tree is the authoritative framework contract surface; copy it verbatim so the sourceName ('Product') substitution does not rewrite framework signatures (e.g. ProductDefect) in the generated reference. Feature 062 (FR-003/005/006): the generated docs/evidence-formats.md and docs/skillist-reference.md references and the authored docs/scaffold-map.md are copied verbatim (no sourceName substitution) so their governance tokens are not rewritten. Feature 108 (FR-020): docs/interactive-readiness.md is copied verbatim for the same reason (its skill names / readiness tokens must not be rewritten).",
      "copyOnly": [
        "docs/api-surface/**",
        "docs/evidence-formats.md",
        "docs/skillist-reference.md",
        "docs/scaffold-map.md",
        "docs/interactive-readiness.md"
      ]
    },
    {
      "source": ".specify/",
      "target": ".specify/",
      "copyOnly": [
        "**/*"
      ],
      "exclude": [
        "feature.json",
        "memory/constitution.md",
        "extensions/evidence/scripts/**"
      ]
    },
    {
      "source": ".agents/skills/",
      "target": ".agents/skills/",
      "copyOnly": [
        "**/*"
      ]
    },
    {
      "source": ".agents/skills/",
      "target": ".claude/skills/",
      "copyOnly": [
        "**/*"
      ]
    },
    {
      "source": ".template.config/generated/",
      "target": "./"
    },
    {
      "condition": "(profile == \"app\" || profile == \"headless-scene\" || profile == \"governed\" || profile == \"sample-pack\")",
      "source": "template/product-skills/fs-gg-scene/",
      "target": ".agents/skills/fs-gg-scene/"
    },
    {
      "condition": "(profile == \"app\" || profile == \"headless-scene\" || profile == \"governed\" || profile == \"sample-pack\")",
      "source": "template/product-skills/fs-gg-scene/",
      "target": ".claude/skills/fs-gg-scene/"
    },
    {
      "condition": "(profile == \"app\" || profile == \"sample-pack\")",
      "source": "template/product-skills/fs-gg-skiaviewer/",
      "target": ".agents/skills/fs-gg-skiaviewer/"
    },
    {
      "condition": "(profile == \"app\" || profile == \"sample-pack\")",
      "source": "template/product-skills/fs-gg-skiaviewer/",
      "target": ".claude/skills/fs-gg-skiaviewer/"
    },
    {
      "condition": "(profile == \"app\" || profile == \"sample-pack\")",
      "source": "template/product-skills/fs-gg-elmish/",
      "target": ".agents/skills/fs-gg-elmish/"
    },
    {
      "condition": "(profile == \"app\" || profile == \"sample-pack\")",
      "source": "template/product-skills/fs-gg-elmish/",
      "target": ".claude/skills/fs-gg-elmish/"
    },
    {
      "condition": "(profile == \"app\")",
      "source": "template/product-skills/fs-gg-keyboard-input/",
      "target": ".agents/skills/fs-gg-keyboard-input/"
    },
    {
      "condition": "(profile == \"app\")",
      "source": "template/product-skills/fs-gg-keyboard-input/",
      "target": ".claude/skills/fs-gg-keyboard-input/"
    },
    {
      "condition": "(profile == \"app\")",
      "source": "template/product-skills/fs-gg-ui-widgets/",
      "target": ".agents/skills/fs-gg-ui-widgets/"
    },
    {
      "condition": "(profile == \"app\")",
      "source": "template/product-skills/fs-gg-ui-widgets/",
      "target": ".claude/skills/fs-gg-ui-widgets/"
    },
    {
      "condition": "(profile == \"governed\")",
      "source": "template/product-skills/fs-gg-testing/",
      "target": ".agents/skills/fs-gg-testing/"
    },
    {
      "condition": "(profile == \"governed\")",
      "source": "template/product-skills/fs-gg-testing/",
      "target": ".claude/skills/fs-gg-testing/"
    },
    {
      "condition": "(profile == \"sample-pack\")",
      "source": "template/fragments/samples/",
      "target": "samples/",
      "exclude": [
        "skill/**"
      ]
    },
    {
      "condition": "(profile == \"sample-pack\")",
      "source": "template/fragments/samples/skill/",
      "target": ".agents/skills/fs-gg-samples/"
    },
    {
      "condition": "(profile == \"sample-pack\")",
      "source": "template/fragments/samples/skill/",
      "target": ".claude/skills/fs-gg-samples/"
    },
    {
      "condition": "(feedback == true)",
      "source": "template/feedback/skill/",
      "target": ".agents/skills/fs-gg-feedback-capture/"
    },
    {
      "condition": "(feedback == true)",
      "source": "template/feedback/skill/",
      "target": ".claude/skills/fs-gg-feedback-capture/"
    },
    {
      "condition": "(feedback == true)",
      "source": "template/feedback/extensions/",
      "target": ".specify/extensions/feedback/"
    },
    {
      "condition": "(designSystem == \"ant\")",
      "source": "template/design-system/ant/",
      "target": "./",
      "comment": "Feature 128 (F3): the ant-only design-system overlay (the feedback no-diff precedent). Fires ONLY for designSystem == \"ant\"; no entry fires for wcag, so the default scaffold stays byte-identical to today (FR-003/SC-001). Copies a self-describing policy record + the Ant imprint as data; template/base/ is untouched."
    }
  ]
}
