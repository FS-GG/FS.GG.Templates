{
  "$schema": "http://json.schemastore.org/template",
  "author": "FS-GG",
  "classifications": [ "FS.GG", "Governance", "Config" ],
  "identity": "FS.GG.Templates.Governance",
  "name": "FS.GG Governance overlay",
  "shortName": "fs-gg-governance",
  "tags": { "type": "item" },
  "description": "Drops the optional FS.GG.Governance config (.fsgg/policy.yml, capabilities.yml, tooling.yml) into an existing SDD-managed project to activate Governance.",
  "symbols": {
    "defaultProfile": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "standard",
      "replaces": "GOV_DEFAULT_PROFILE",
      "description": "Default Governance profile.",
      "choices": [
        { "choice": "light", "description": "Lightest gate set." },
        { "choice": "standard", "description": "Standard gate set (default)." },
        { "choice": "strict", "description": "Strictest gate set." }
      ]
    }
  }
}
