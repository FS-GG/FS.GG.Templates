#!/usr/bin/env bash
# fsgg-coord — GraphQL-budget-thrifty client for the FS-GG "Coordination" Projects v2 board.
#
# WHY THIS EXISTS. The cross-repo-coordination skill drives an org-level Projects v2 board, and
# Projects v2 is GraphQL-only. GitHub's GraphQL *primary* rate limit (5,000 points/hr) is metered
# by the NUMBER OF NODES A QUERY REQUESTS — not by the number of HTTP calls — so batching requests
# saves nothing on it. The only levers that lower primary consumption are: (1) DON'T RE-FETCH
# static data, (2) ask for FEWER NODES, (3) move reads that don't need Projects v2 onto REST
# (a separate 5,000-*requests*/hr budget, 1 point each, and ETag 304s cost nothing). This helper
# is those three levers made concrete:
#
#   1. CACHE THE STATIC BOARD MAP. Field ids and single-select option ids are stable for the life
#      of the field; the project number/node-id never change. `bootstrap` introspects them ONCE
#      into a user-level cache; every later `set-field` reads ids from cache instead of paying a
#      `field-list` (and, worse, an all-items `item-list`) scan per session.
#   2. NARROW ITEM LOOKUP. Resolve an issue's board item via issue -> projectItems (a handful of
#      nodes) instead of scanning the whole board's items x fields (cost grows with the board).
#   3. REST-FIRST READS. `issues` fetches cross-repo issues over REST with a stored ETag, so an
#      unchanged list returns 304 at zero cost and never touches the GraphQL budget at all.
#   4. THRIFTY WHOLE-BOARD READ. Picking "the next item to start" needs the WHOLE board, which is a
#      GraphQL-only full scan (Projects v2 has no server-side item filter). `ready`/`next` keep it
#      cheap by selecting only two fields per item via `fieldValueByName` (a RESOLVER field, no node
#      multiplication) — vs. `gh project item-list`, which nests `fieldValues(first:100)` inside
#      `items(first:N)` for O(items × 100). Measured on the live 640-item board: a thrifty full scan
#      is 7 pages × 1 pt = 7 pts, while `gh project item-list` costs 6 pts to read FIVE items.
#   5. THE BUDGET IS SHARED, SO SPEND IT ONCE PER TTL, NOT ONCE PER WORKER (#418). N parallel workers
#      authenticate as ONE account and share ONE 5,000-pt/hr budget. Five of them looping `take`/`next`
#      re-scanned the whole board every round and drained it in ~15 minutes — and the first thing an
#      exhausted budget kills is the WRITES. So the scan is cached to the shared cache dir for
#      FSGG_COORD_SCAN_TTL_SEC (90s): the scheduling reads (`next`/`take`/`batch`) pay for ONE scan
#      between all workers in a window; the reconciling reads (`ready`/`lint`/`who`) always scan fresh,
#      because a cached "truth" is how a reconciler reports drift that was already fixed. `--fresh`
#      forces a rescan; the claim CAS still reads its markers over REST and is NEVER cached.
#   6. EXHAUSTION IS A NAMED CONDITION, NOT A MYSTERY 500 (#418). A rate-limited call exits EX_RATE
#      (75) with the reset time — the signal a worker loop BACKS OFF on. And a board write refused by
#      the budget is QUEUED (`flush`), not swallowed: swallowing it is what left the board saying
#      `Backlog` while a worker held the item — the CLAIM-STATUS-LAG drift /check-board reconciles.
#
# Every GraphQL call also asks for `rateLimit { cost remaining }`; set FSGG_COORD_DEBUG=1 to log it
# (and use `budget` to read the meters directly) so you can VERIFY the drop instead of guessing.
#
# It is deliberately a thin `gh` wrapper (no daemon, no state beyond a JSON cache) matching the
# house style of scripts/apply-labels.sh / scripts/skill-union-assert.sh. The cache holds ONLY
# stable identifiers (field/option/project/item ids) — never field *values* — so the worst
# staleness a wrong cache can cause is "board schema changed": fixed by `bootstrap --refresh`.
#
# Usage:
#   fsgg-coord bootstrap [--refresh]          # introspect + cache the board map (ids only)
#   fsgg-coord board [--refresh]              # print the cached board map (bootstraps if absent)
#   fsgg-coord field-id  <Field>              # print a field's node id (from cache)
#   fsgg-coord option-id <Field> <Option>     # print a single-select option's id (from cache)
#   fsgg-coord item-id   <issue> [--refresh]  # resolve an issue's board item id (narrow, cached)
#   fsgg-coord set-field <issue> <Field> <Value> [--refresh]
#                                             # set a board field, resolving all ids from cache,
#                                             # auto-routing by the field's dataType. `Blocked by`
#                                             # additionally takes ONLY issue refs (comma-separated,
#                                             # canonicalized to owner/repo#n); prose is refused.
#   fsgg-coord set-field --batch <issue> Field=Value [Field=Value …] [--refresh]
#                                             # the SAME writes, aliased into ONE GraphQL document:
#                                             # N fields cost ONE request (~6x on a placement pass,
#                                             # #448). A partial failure is reported as PARTIAL
#                                             # (exit 4), never as success — the aliases run serially,
#                                             # so the ones before an error have already landed.
#   fsgg-coord landable <pr> [--repo R]       # is this PR SAFE TO MERGE? prints
#                                             # green|pending|red|conflicted|unknown; exit 0 on green,
#                                             # 3 on pending (the only one worth retrying), 1 otherwise.
#                                             # Scores WORKFLOW RUNS with the supersession rule (#720) —
#                                             # do NOT hand-roll this in a recipe (#724).
#   fsgg-coord issues <repo> [--label L] [--state open|closed|all] [--refresh] [--jq EXPR]
#                                             # list issues over REST with ETag revalidation
#   fsgg-coord ready [--repo R] [--status S] [--phase P] [--all] [--json|--jq EXPR]
#                                             # list actionable board items (not Done by default);
#                                             # thrifty full-board scan (2 fields/item). --repo takes
#                                             # a registry short-id (sdd/rendering/governance/
#                                             # templates/.github), owner/repo, or a literal repo name
#   fsgg-coord next  [--repo R] [--ignore-blocked] [--fresh]
#                                             # print the one most-startable item (Ready, else
#                                             # Backlog), SKIPPING items whose `Blocked by` refs are
#                                             # still open (or unverifiable), with the reason on
#                                             # stderr. --ignore-blocked restores the old behaviour.
#                                             # Rides the shared scan cache (see lever 5); --fresh
#                                             # forces a rescan.
#   fsgg-coord flush [--dry-run]              # replay board writes that an exhausted GraphQL budget
#                                             # refused. Queued by `claim`, drained automatically by
#                                             # the next board-writing command; this is the manual
#                                             # handle. --dry-run lists the queue.
#   fsgg-coord child <parent> <issue>         # link <issue> as a native SUB-ISSUE of <parent> — the
#                                             # ONLY edge `done --flip` rolls up over. A title
#                                             # convention or a comment is not a link.
#   fsgg-coord done  <issue> [--pr N] [--flip]
#                                             # verify an item is finished (PR merged AND board
#                                             # Status=Done) and print an EARNED green DONE stamp;
#                                             # red stamp + non-zero exit if a check fails (--flip
#                                             # also sets Status=Done once the PR is merged, and rolls
#                                             # the completion up to any parent epic whose children
#                                             # are now all Done — refusing to roll up an epic whose
#                                             # BODY declares a child the sub-issue graph lacks).
#   fsgg-coord lint  [--repo R] [--json] [--strict]
#                                             # assert the board's EPIC invariants: no OPEN `[epic]`
#                                             # with zero sub-issues (the orphaned epic), none the
#                                             # board calls Done over an open child, none with children
#                                             # the scan cannot see, none whose body declares a child
#                                             # that is not linked. Exit 1 on any error. `Status: Done`
#                                             # on a still-open issue is a NOTE (fatal under --strict).
#   fsgg-coord budget                         # print GraphQL + REST rate-limit meters, the queued-write
#                                             # count, and a WARNING while there is still budget left
#                                             # to act on (free — rate_limit does not meter itself)
#
# THE SHADOW (ADR-0034 Phase 2). The coordination domain is moving to a typed F# core, and this tool
# schedules the work that rewrites this tool — so nothing is cut over on faith. BOTH engines decide
# every `batch`/`next`/`take`, BASH'S ANSWER IS THE ONE RETURNED, and every disagreement is logged.
# `--engine fs` is now OPEN (ADR-0038): the flip is gated on the DEFECT CORPUS, not on a fleet clock
# that could never tick (#728). THE DEFAULT DOES NOT MOVE — it is `auto`, and `auto` returns BASH'S
# ANSWER. You get the typed core's answer only by asking for it.
#
# IT IS ON BY DEFAULT WHEREVER AN ENGINE EXISTS (`--engine auto`), and off wherever one does not — so
# a repo without the engine on its coordination path is byte-for-byte unaffected, and a repo with it
# starts contributing evidence without anybody remembering to opt in. A shadow nobody switches on is
# not a cautious shadow; it is a decoration — and now that the shadow is TELEMETRY rather than the
# gate, an observer that cannot move an answer costs its caller nothing.
#
#   fsgg-coord --engine bash next             # the escape hatch: never shadow
#   fsgg-coord --engine shadow next           # insist on it; a missing engine is a logged skip
#   fsgg-coord --engine fs next               # THE ENGINE'S ANSWER IS THE ANSWER (ADR-0038). No
#                                             # fallback: every failure here is FATAL, where in every
#                                             # other mode it is a logged skip
#   fsgg-coord divergence [--json] [--since T] [--clear]
#                                             # the acceptance test for the port. Reports OUTCOME
#                                             # divergences (the engines disagree about what may be
#                                             # HANDED OUT — the release blocker) apart from REASON
#                                             # divergences (they agree it is unschedulable and name a
#                                             # different fact — a decision to record, not a bug). An
#                                             # empty log exits 3, NOT 0: a shadow that never ran
#                                             # reports zero divergence, and zero divergence is exactly
#                                             # what success looks like (#266).
#   fsgg-coord divergence --publish           # send YOUR evidence to the fleet ledger (#634). One
#                                             # summary per (worker, day, engine), rewritten in place —
#                                             # over REST, so it never touches the GraphQL budget. Your
#                                             # local log lives in a CACHE dir on ONE machine; until it
#                                             # is published it is not evidence, and the three-day clock
#                                             # does not move for it. Run it when your loop is done.
#   fsgg-coord divergence --fleet             # THE cut-over gate (ADR-0034 §5). Folds the whole ledger
#                                             # in the typed core and answers the one question the flip
#                                             # is conditional on: has the shadow agreed with bash,
#                                             # across the LIVE FLEET, on THIS engine build, for three
#                                             # consecutive days? 0 green · 1 they disagreed · 3 no
#                                             # verdict (absent, thin, one-worker, or another build's
#                                             # evidence). An empty ledger is NEVER green.
#
# EXIT CODES: 0 ok · 1 error · 3 the issue is not on the board · 75 (EX_RATE) the GraphQL budget is
# exhausted — TRY AGAIN LATER. A worker loop must treat 75 as "back off until the reset", never as a
# protocol failure, and never by retrying immediately.
#
# Parallel intra-repo work (ADR-0021, revised by ADR-0027). N workers share ONE GitHub account, so
# the LOCK, the IDENTITY, and the CHANNEL are all keyed on a WORKER ID, never on the login:
#
#   fsgg-coord whoami                         # this worker's id, which rule derived it, and the
#                                             # harness/session it belongs to (provenance)
#   fsgg-coord claim <issue> [--force]        # take the item's lock. Posts an `fsgg:claim` marker
#                                             # comment, then re-reads: the LOWEST live claim
#                                             # comment id wins (GitHub ids are a server-side total
#                                             # order, so every racer computes the same winner).
#                                             # A loser deletes its own marker and says so. Also
#                                             # assigns @me + Status=In progress, and prints the
#                                             # worktree/branch to isolate on. --force steals.
#   fsgg-coord heartbeat <issue>              # renew this worker's lease on a claim
#   fsgg-coord release <issue> [--status S] [--force]
#                                             # drop the lock: delete the marker, unassign, and reset
#                                             # the `In progress` claim set -> Ready. Any OTHER status
#                                             # the caller chose (Blocked, Backlog, ...) is PRESERVED;
#                                             # --status S overrides. See release_cmd.
#   fsgg-coord who [--repo R] [--local] [--json]
#                                             # WHO holds WHAT, right now: worker, age, lease
#                                             # health, declared paths, branch. Finds work by its
#                                             # claim MARKER, so it sees an item the board never
#                                             # heard of (or whose Status flip failed). --local joins
#                                             # the local `git worktree list` so you never have to go
#                                             # spelunking through worktrees to see what's running.
#   fsgg-coord reap [--repo R] [--apply]      # find claims whose lease expired (a worker died);
#                                             # dry-run by default, --apply releases them. REFUSES a
#                                             # claim whose work is still alive (an open item/<n> PR),
#                                             # and never advises closing one that is green (#697).
#   fsgg-coord adopt <issue>                  # take over an ORPHAN: a DEAD claim whose PR is GREEN
#                                             # and MERGEABLE — i.e. finished work whose worker died
#                                             # between "green" and "merge". Verifies the PR is
#                                             # landable, transfers the claim, and hands you the merge.
#                                             # It REFUSES a live claim (that is a steal), an item with
#                                             # no PR (nothing to land), and any PR that is not green
#                                             # and mergeable (that is authoring, not landing).
#   fsgg-coord take [--repo R] [--tries N]    # pick + claim the next SCHEDULABLE item in one step,
#                                             # retrying on a lost race so a worker never idles.
#   fsgg-coord batch [--repo R] [-n N] [--json] [--include-backlog]
#   fsgg-coord lanes [--repo R] [--json]      # partition the board into LANES — connected components
#                                             # of the item-overlap graph. Items in DIFFERENT lanes can
#                                             # never collide, so they are PROVABLY safe to run at once.
#                                             # Prints the CEILING (how many workers this board can
#                                             # actually absorb — fan out wider and the extras are handed
#                                             # nothing), names the CHOKEPOINT lanes, and lists the items
#                                             # that cannot be laned at all: the ones invisible to every
#                                             # worker who asks for work. DERIVED from the touch-sets in
#                                             # the typed core, never asserted by anyone (#428, #485).
#                                             # the scheduler: a maximal set of Ready items whose
#                                             # touch-sets are disjoint from EACH OTHER and from
#                                             # every in-flight claim. Hand one to each worker.
#   fsgg-coord overlap <a> <b>                # can items <a> and <b> run in parallel? Compares
#                                             # their declared `Paths:` touch-sets (issue body,
#                                             # ADR-0021) as subtrees. DISJOINT -> exit 0 (safe to
#                                             # parallelize); OVERLAP -> exit 1 + the conflicting
#                                             # tokens (sequence them with the board's `Blocked by`).
#                                             # Exit 2 if either item declares no `Paths:`, or one
#                                             # that can never match a file (see the grammar below).
#   fsgg-coord overlap <a> --active           # ...or against EVERY in-flight claim at once.
#   fsgg-coord widen <issue> --paths "<paths>"
#                                             # re-declare a touch-set mid-flight, re-check it
#                                             # against live claims, and NOTIFY the workers it now
#                                             # collides with (ADR-0021 says re-check; this does it).
#   fsgg-coord say <issue> [--to <worker>] <message>
#                                             # the channel: post an `fsgg:msg` addressed to a
#                                             # worker (default `*` = anyone working the item).
#   fsgg-coord inbox [--repo R] [--peek] [--json]
#                                             # messages addressed to this worker across every live
#                                             # claim, since last read (--peek does not advance).
#   fsgg-coord verify-paths --pr N [--repo R] [--issue REF] [--warn]
#                                             # did the PR stay inside the issue's declared `Paths:`?
#                                             # Reports drift; exit 1 (or 0 with --warn, for CI).
#                                             # --warn downgrades the VERDICT, not a failure to reach
#                                             # one: if the PR's issue cannot be resolved, it still
#                                             # exits non-zero rather than reporting SKIP (#322).
#                                             # --issue DECIDES the repo: --pr resolves in the issue's
#                                             # repo, not the checkout's. A --repo that disagrees is
#                                             # refused, never silently preferred — a verdict is only
#                                             # ever printed when PR and issue are in ONE repo (#479).
#
#   <issue> is a full URL, `owner/repo#n`, or `repo#n` (owner defaults to FS-GG).
#   A global `--worker <id>` may precede any subcommand.
#
# Env:
#   FSGG_COORD_OWNER    board owner org           (default: FS-GG)
#   FSGG_COORD_PROJECT  board title               (default: Coordination)
#   FSGG_COORD_CACHE    cache dir                 (default: ${XDG_CACHE_HOME:-~/.cache}/fsgg-coord)
#   FSGG_COORD_BOARD_TTL_MIN  board-map freshness (default: 1440 min = 24h; schema changes are rare)
#   FSGG_COORD_SCAN_TTL_SEC   hot-read board-scan cache, shared across workers (default: 90; 0 = off)
#   FSGG_COORD_DEBUG    =1 -> log each GraphQL call's rateLimit cost/remaining to stderr
#   FSGG_WORKER         this worker's id          (default: derived — run `whoami` to see how)
#   FSGG_CLAIM_LEASE_MIN  claim lease in minutes  (default: 120; past it a claim is reapable)
#
# See docs/coordination/graphql-budget.md for the cost model and when to reach for this,
# and docs/coordination/parallel-work.md for the protocol these subcommands implement.

set -euo pipefail

# `die` must be FATAL from anywhere — including inside a `$( )`. `exit` in a command substitution
# only unwinds that subshell, and `set -e` does NOT propagate the substitution's non-zero status
# across a bare `out="$(...)"` assignment (verified on bash 5.x). So a `die` two subshells deep used
# to leave the caller with an empty string and rc 0, and an UNREADABLE board would render as a
# confident, empty one (#344). `die` therefore signals the top-level shell, whose trap turns any
# die — at any nesting depth — into a real `exit 1`.
#
# The exception: a FEW callers deliberately run a command in a subshell so its `die` stays LOCAL —
# a best-effort board write whose failure must NOT unwind a claim the lock already holds, and the
# soft read `item_status` feeds release/reap. They set `SOFT_DIE=1` in that subshell's environment;
# `die` then skips the signal and just exits the subshell, so the caller's `if (…)` / `|| return`
# catches it exactly as before. Unmarked dies stay fatal, which is the whole point.
#
# WHY THE EXIT CODE IS CARRIED THROUGH A FILE (#418). A soft caller must be able to tell WHY a board
# write failed — "this issue is not on the board" and "the GraphQL budget is exhausted" are opposite
# facts that used to be one indistinguishable `exit 1`, and `claim` reported the first when the truth
# was the second (see claim_cmd). So dies carry a code. `exit <rc>` inside `$( )` cannot hand that
# code to the top-level shell, and neither can a variable — the subshell's assignment dies with it —
# so a fatal die writes the code to RC_FILE and the TERM trap exits with it.
EX_RATE=75        # EX_TEMPFAIL: the GraphQL budget is exhausted. TRY AGAIN LATER — not a protocol error.
EX_OFFBOARD=3     # the issue is not an item on the board at all. A different fact, and permanent.
# A `--batch` document that applied SOME of its writes and failed others (#448). Its own fact, and the
# one a batched write can produce that a single write cannot: GraphQL executes the aliases in a
# mutation SERIALLY, so an error at alias 4 leaves 1-3 ALREADY WRITTEN on the server. Reporting that as
# a plain failure would say "nothing happened" about a board that is now half-written — the #266 class
# exactly — and reporting it as success is what the issue that asked for batching forbade in as many
# words. It is never queued: replaying a document whose failing half can never succeed would rewrite
# the half that already did.
EX_PARTIAL=4
# AN EMPTY RC_FILE IS NOT A ZERO (#344, reopened through the shadow).
#
# `exit $(cat "$RC_FILE" || echo 1)` guards only the case where `cat` FAILS — a missing file. It does
# not guard an EMPTY one, and `soft_run` truncates RC_FILE (`: >"$RC_FILE"`) before every attempt, so
# empty is a state this trap actually reaches. `cat` then succeeds with no output, the `|| echo 1`
# never fires, and the trap degenerates to a BARE `exit` — which exits with `$?` of whatever command
# ran last, not with the code the fatal die meant to report.
#
# That is a fail-OPEN, and the shadow makes it reachable on the hot path: when
# `divergence_publish_throttled` fires (once per window — so, on the FIRST call in any fresh cache: a
# new worktree, a fresh container, a CI runner), the last thing to run before the trap is the publish
# lock's own `rm -rf`, which succeeds. A rate-limited `next` — an unreadable board, i.e. exactly what
# #418 makes routine — then exits 0 with no verdict, and a worker reads "nothing to do" off a board it
# never managed to read. #344 is the rule that a read which did not happen must never render as a
# confident empty answer; this is that same fail-open, one layer down, and it defeats the surface's own
# first rule: the observer may not change bash's answer, its exit code, or its life.
#
# So: unknown code => 1. Fail CLOSED. (Found by the tiered fixture — the monolith could not see it, as
# it only ever reached the #344 assertions after hundreds of prior calls had spent the publish window.)
trap 'rc_at_term="$(cat "$RC_FILE" 2>/dev/null)"; exit "${rc_at_term:-1}"' TERM

# Scratch files this process owns, swept on ANY exit — including the TERM a fatal `die` raises, which
# is how a rate-limited scan used to strand them in $CACHE. It tracks PATHS, not a `$CACHE/.foo.*`
# glob, precisely because N workers share that cache: a pattern sweep would delete a CONCURRENT
# worker's live scratch, which is the failure this protocol exists to avoid, one level down.
TMPFILES=()
trap 'rm -f "${TMPFILES[@]+"${TMPFILES[@]}"}"' EXIT

OWNER="${FSGG_COORD_OWNER:-FS-GG}"
TITLE="${FSGG_COORD_PROJECT:-Coordination}"
# The ONLY Status a claim writes. Undoing a claim (`release`, `reap`) resets this column and no
# other — see unclaim_status.
CLAIM_STATUS="In progress"
CACHE="${FSGG_COORD_CACHE:-${XDG_CACHE_HOME:-$HOME/.cache}/fsgg-coord}"
BOARD_TTL_MIN="${FSGG_COORD_BOARD_TTL_MIN:-1440}"
CLAIM_LEASE_MIN="${FSGG_CLAIM_LEASE_MIN:-120}"

# The two machine-readable markers this client writes into issue comments. They live in an HTML
# comment so GitHub renders nothing, `grep` finds everything, and the human prose underneath is free
# to change without breaking a parser.
CLAIM_MARK='fsgg:claim'
MSG_MARK='fsgg:msg'

RC_FILE="${TMPDIR:-/tmp}/.fsgg-coord-rc.$$"
trap 'rm -f "$RC_FILE"' EXIT

# die_rc <rc> <message…> — the general form. `die` is `die_rc 1`, which is every existing caller.
#
# The code is written to RC_FILE on BOTH paths, and that is load-bearing for the soft one. A soft die
# fires from wherever it happens to be — routinely two levels down, inside a `$( )` inside the
# SOFT_DIE subshell (item_id, called from set_field). `exit 3` there only unwinds the SUBSTITUTION,
# and per this file's own opening note `set -e` does not propagate that across `item="$(…)"` — so the
# code the caller finally reads is whatever the *next* failing command returns, not the one the die
# meant. That is how an off-board claim first reported itself as a failed write. RC_FILE carries the
# real code out; `soft_run` reads it back.
die_rc() {
  local rc="$1"; shift
  echo "fsgg-coord: $*" >&2
  # FIRST die wins. A soft die unwinds only its own `$( )`, so the code that follows may blunder on
  # and die AGAIN for a downstream reason — item_id dies "budget exhausted", set_field carries on with
  # an empty item id, and the malformed board write dies "write failed". The LAST code to be written
  # is the least informative one, and reporting it is how a rate-limit gets reported as "not on board".
  # soft_run truncates RC_FILE before each run, so "first" always means "first within this attempt".
  [ -s "$RC_FILE" ] || printf '%s' "$rc" > "$RC_FILE" 2>/dev/null || true
  [ -n "${SOFT_DIE:-}" ] && exit "$rc"          # local: unwinds only to the SOFT_DIE subshell
  kill -s TERM $$ 2>/dev/null                   # fatal: the trap exits the top-level shell with rc
  exit "$rc"
}
die() { die_rc 1 "$@"; }

# The die already happened one substitution down, and already printed its message. Carry its code out
# without inventing a second one — the caller cannot see it, and a guessed cause is worse than none.
die_relay() {
  local rc; rc="$(cat "$RC_FILE" 2>/dev/null)"; [ -n "$rc" ] || rc=1
  [ -n "${SOFT_DIE:-}" ] && exit "$rc"
  kill -s TERM $$ 2>/dev/null
  exit "$rc"
}

# soft_run <cmd…> — run a command whose `die` must NOT unwind the caller, and get the code the die
# actually chose (EX_RATE / EX_OFFBOARD / 1), however deeply nested it fired. Callers redirect.
soft_run() {
  : > "$RC_FILE"
  local rc=0
  ( SOFT_DIE=1; "$@" ) || rc=$?
  if [ -s "$RC_FILE" ]; then rc="$(cat "$RC_FILE")"; : > "$RC_FILE"; fi
  return "$rc"
}
dbg() { [ -n "${FSGG_COORD_DEBUG:-}" ] && echo "fsgg-coord: $*" >&2 || true; }

# ---- the budget is SHARED, so exhausting it is a first-class, NAMED condition (#418) --------------
# N parallel workers authenticate as ONE GitHub account and therefore share ONE 5,000-point/hr
# GraphQL budget. Exhaustion is not a transient 5xx and must never be handled like one: it is
# predictable, it lasts a known length of time, and — this is the part that bit us — it hits the
# WRITES, not just the reads. A swallowed rate-limit on `claim`'s board write is exactly the
# CLAIM-STATUS-LAG drift `/check-board` then has to reconcile: the lock is held, the board says
# otherwise, and `next` hands the item to nobody.
#
# So: recognise it, name it, and exit EX_RATE (75) — the signal a worker loop backs off on.
is_rate_limited() {  # <combined stdout+stderr of a failed gh call>
  printf '%s' "$1" | grep -qiE 'rate limit (already )?exceeded|API rate limit|secondary rate limit|was submitted too quickly'
}

# Seconds until the GraphQL budget resets. `gh api rate_limit` does NOT itself consume the budget,
# so asking is free — which is what makes "back off until the reset" a strategy and not a guess.
rate_reset_in() {
  local reset now
  reset="$(gh api rate_limit --jq '.resources.graphql.reset' 2>/dev/null || echo "")"
  [ -n "$reset" ] || { printf 'unknown'; return 0; }
  now="$(date -u +%s)"
  local secs=$(( reset - now )); [ "$secs" -lt 0 ] && secs=0
  printf '%dm%02ds' $(( secs / 60 )) $(( secs % 60 ))
}

die_rate() {  # the one place that reports exhaustion, so every command reports it the same way
  die_rc "$EX_RATE" "GraphQL budget EXHAUSTED (5,000 pts/hr, shared by every worker on this account) — resets in $(rate_reset_in).
  This is not a protocol error: back off and retry, do not re-run in a loop. Reads that do not need
  Projects v2 still work — REST has its own budget (\`fsgg-coord budget\`). Board WRITES are queued:
  see \`fsgg-coord flush\`."
}

command -v gh >/dev/null 2>&1 || die "gh not found (GitHub CLI is required)."
command -v jq >/dev/null 2>&1 || die "jq not found (required for JSON handling)."

mkdir -p "$CACHE"

# Filesystem-safe slug of the board identity, so multiple owners/boards don't collide in the cache.
slug() { printf '%s' "$1" | tr 'A-Z' 'a-z' | tr -c 'a-z0-9' '-' | sed 's/-\{2,\}/-/g; s/^-//; s/-$//'; }
trim() { local s="$1"; s="${s#"${s%%[![:space:]]*}"}"; printf '%s' "${s%"${s##*[![:space:]]}"}"; }
BOARD_FILE="$CACHE/board-$(slug "$OWNER")-$(slug "$TITLE").json"

# ---- worker identity: WHICH of the N parallel workers am I? --------------------------------------
# ADR-0021 made the ISSUE ASSIGNEE the claim lock. That silently fails the one case the lock exists
# for. When N agents fan out under ONE `gh` login, `@me` names the same principal for all of them, so
# an item a sibling already holds reads back as "assigned to me" — and `claim`'s "is anyone ELSE
# holding this?" test passes. Both workers proceed. The assignee is an ACCOUNT; the thing that must be
# excluded is a WORKER. They are not the same thing, and no amount of care with assignees fixes that.
#
# So every worker carries a stable, human-readable id, and the lock (claim markers), the channel
# (messages), and attribution (git config + commit trailer) are all keyed on it. Resolution order —
# `whoami` prints which rule fired, because a surprising id is a lock bug waiting to happen:
#
#   1. --worker <id>       explicit; wins everything.
#   2. $FSGG_WORKER        how an orchestrator names the agents it spawns.
#   3. the worktree name   ADR-0021 gives each item its own git worktree, so the worktree IS an
#                          identity — unique per worker, stable across that worker's invocations,
#                          and free. Only LINKED worktrees qualify (see rule 4).
#   4. the HARNESS SESSION ID, if the agent harness exports one (see below), hashed into a memorable
#      name. Deterministic, so it needs no persistence.
#   5. generated, persisted per checkout — the last resort. A checkout shared by several workers gives
#      them one id, which is precisely the same-account collapse this mechanism exists to prevent.
#
# WHY THE SESSION ID IS RULE 4 AND NOT RULE 1. Agent harnesses do export a session identifier, but
# there is NO cross-harness convention, and — worse — the same name means different things:
#
#   claude-code  CLAUDE_CODE_SESSION_ID   ONE id per session, SHARED by every subagent it spawns
#                                         (anthropics/claude-code#7881). Keying the lock on it would
#                                         collapse an N-agent fan-out onto one worker id — the exact
#                                         bug ADR-0027 removed, one level down. Hence: WARN.
#   opencode     OPENCODE_SESSION_ID      subagents run as CHILD SESSIONS with their own ids
#                                         (sst/opencode task tool sets parentID), so it IS per-worker.
#   codex        —                        exports no session/conversation id at all.
#   gemini-cli   —                        exports only GEMINI_CLI=1.
#
# A per-subagent id exists in Claude Code only as `agent_id` inside HOOK JSON — not in the environment
# a Bash tool sees. So the session id is a good *fallback* (it separates concurrent sessions sharing a
# checkout, which rule 5 cannot) and good *provenance* (it points at the transcript that made a claim),
# but it is not an identity. The worktree — rule 3 — remains the thing that is actually per-worker.
# See docs/coordination/agent-session-identifiers.md for the evidence behind this table.
WORKER_OVERRIDE=""
WORKER_ID=""
WORKER_FROM=""
WORKER_SHARED_WHY=""     # non-empty => this id may name more than one worker; warn on every claim
HARNESS_NAME=""
HARNESS_SESSION=""
_WORKER_WORDS=(finch heron wren swift kite tern rook crake snipe plover
               merlin godwit curlew dunlin teal smew osprey shrike avocet brant)

# A genuinely random id. Both halves come from /dev/urandom, INCLUDING the word: `$RANDOM` is seeded
# from the pid+time, so N agents a harness fans out within the same second draw the SAME word (#419).
# The suffix is 4 hex chars, not 2 — 20 words x 65,536 is a space a dozen concurrent workers do not
# meaningfully collide in, and the id is still short enough to read in a `who` table.
# The $RANDOM branch is a fallback for a system with no /dev/urandom, and is NOT collision-safe under
# a same-second fan-out — it is strictly better than dying, and nothing more.
gen_worker() {
  local w h bytes
  bytes="$(head -c 3 /dev/urandom 2>/dev/null | od -An -tx1 | tr -d ' \n')"
  if [ "${#bytes}" -eq 6 ]; then
    w="${_WORKER_WORDS[$(( 16#${bytes:0:2} % ${#_WORKER_WORDS[@]} ))]}"
    h="${bytes:2:4}"
  else
    w="${_WORKER_WORDS[$((RANDOM % ${#_WORKER_WORDS[@]}))]}"
    h="$(printf '%04x' "$((RANDOM % 65536))")"
  fi
  printf '%s-%s' "$w" "$h"
}

# A memorable name derived deterministically from a seed, so the same session always names the same
# worker without persisting anything. UUIDs are unusable as an identity a human reads in a `who`
# table, types into `say --to`, or greps a branch for.
name_from_seed() {
  local h idx
  h="$(printf '%s' "$1" | sha256sum | cut -c1-8)"
  idx=$(( 16#${h:0:2} % ${#_WORKER_WORDS[@]} ))
  printf '%s-%s' "${_WORKER_WORDS[$idx]}" "${h:2:3}"
}

# Detect the agent harness and its session id. Sets HARNESS_NAME/HARNESS_SESSION (empty if none).
# `FSGG_AGENT_SESSION_ID` is the escape hatch for a harness we do not know about — set it and the
# fallback identity and the claim's provenance both start working, with no change here.
harness_session() {
  if   [ -n "${CLAUDE_CODE_SESSION_ID:-}" ]; then
    HARNESS_NAME="claude-code"; HARNESS_SESSION="$CLAUDE_CODE_SESSION_ID"
  elif [ -n "${OPENCODE_SESSION_ID:-}" ]; then
    HARNESS_NAME="opencode";    HARNESS_SESSION="$OPENCODE_SESSION_ID"
  elif [ -n "${FSGG_AGENT_SESSION_ID:-}" ]; then
    HARNESS_NAME="${FSGG_AGENT_HARNESS:-unknown}"; HARNESS_SESSION="$FSGG_AGENT_SESSION_ID"
  else
    HARNESS_NAME=""; HARNESS_SESSION=""
  fi
}

# Does one session id name one worker, on this harness? Only where subagents get their own session.
session_is_per_worker() {
  case "$1" in
    opencode) return 0 ;;   # subagents are child sessions with distinct ids
    *)        return 1 ;;   # claude-code shares one id across subagents; unknown harnesses: assume shared
  esac
}

git_toplevel() { git rev-parse --show-toplevel 2>/dev/null || true; }
# A LINKED worktree has a per-worktree git dir distinct from the shared common dir; the primary
# checkout has them equal. Only the former is per-worker, so only the former names a worker.
is_linked_worktree() {
  local gd cdir
  gd="$(git rev-parse --absolute-git-dir 2>/dev/null || true)"
  cdir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true)"
  [ -n "$gd" ] && [ -n "$cdir" ] && [ "$gd" != "$cdir" ]
}

# Sets WORKER_ID/WORKER_FROM as globals *and* echoes the id. Call it as `worker >/dev/null` and read
# $WORKER_ID — `w="$(worker)"` runs it in a subshell, where WORKER_FROM (and so the shared-identity
# warning that depends on it) dies with the subshell.
worker() {
  [ -n "$WORKER_ID" ] && { printf '%s' "$WORKER_ID"; return 0; }
  local top; top="$(git_toplevel)"
  harness_session                       # always resolved: even an explicit id wants provenance
  if [ -n "$WORKER_OVERRIDE" ]; then
    WORKER_ID="$WORKER_OVERRIDE"; WORKER_FROM="--worker flag"
  elif [ -n "${FSGG_WORKER:-}" ]; then
    WORKER_ID="$FSGG_WORKER"; WORKER_FROM="\$FSGG_WORKER"
  elif [ -n "$top" ] && is_linked_worktree; then
    WORKER_ID="$(basename "$top")"; WORKER_FROM="git worktree name ($top)"
  elif [ -n "$HARNESS_SESSION" ]; then
    WORKER_ID="$(name_from_seed "$HARNESS_SESSION")"
    WORKER_FROM="$HARNESS_NAME session id ($HARNESS_SESSION)"
    session_is_per_worker "$HARNESS_NAME" \
      || WORKER_SHARED_WHY="every subagent of this $HARNESS_NAME session shares this session id"
  else
    local f; f="$CACHE/worker-$(slug "${top:-$PWD}")"
    if [ -f "$f" ]; then WORKER_ID="$(cat "$f")"
    else WORKER_ID="$(gen_worker)"; printf '%s' "$WORKER_ID" >"$f"; fi
    WORKER_FROM="generated, persisted per-checkout ($f)"
    WORKER_SHARED_WHY="every worker sharing this checkout gets this same id"
  fi
  WORKER_ID="$(slug "$WORKER_ID")"
  [ -n "$WORKER_ID" ] || die "could not derive a worker id — set FSGG_WORKER."
  printf '%s' "$WORKER_ID"
}

# Rules 4 and 5 can each hand the same id to several workers — for different reasons. Say which one,
# loudly, at every point a claim depends on it: a lock that cannot separate two workers is not a lock.
#
# The remedy must be a command to RUN, never an id to INVENT. "set FSGG_WORKER explicitly" is what
# this warning used to say, and #419 is what came back: an LLM agent told to make up an id does not
# make up a unique one. Eight live workers, not one of them using its derived id, drawn from four of
# the twenty words — two of them independently picking the suffix `7c2`. Any literal a worker can
# copy (the skill's `finch-a3f`) is a collision attractor, so this prints none.
warn_shared_identity() {
  [ -n "$WORKER_SHARED_WHY" ] || return 0
  echo "fsgg-coord: WARNING — worker id '$WORKER_ID' may not be unique to this worker:" >&2
  echo "  $WORKER_SHARED_WHY." >&2
  echo "  The claim lock cannot separate workers that share an id. Give each worker its own git" >&2
  echo "  worktree (the identity ADR-0021 already mandates), or mint an id — do NOT invent one:" >&2
  echo "" >&2
  echo "      eval \"\$(fsgg-coord whoami --mint)\"" >&2
  echo "" >&2
}

# Stamp the worker into the worktree itself, so "who edited these files?" is a `git config` read
# rather than mtime forensics. Best-effort: a claim made outside a checkout still holds.
# `git config --worktree` only writes per-worktree when `extensions.worktreeConfig` is set, which is
# NOT the default. Without it both keys land in the shared config that every linked worktree reads,
# so the last claim overwrites all the others and `who --local` attributes every worktree to one
# worker — the misattribution this stamp exists to prevent. We do not silently enable the extension
# on someone's repo; we say what happened so it is fixable.
stamp_worktree() {
  git rev-parse --git-dir >/dev/null 2>&1 || return 0
  local scoped=1
  git config --worktree fsgg.worker "$1" 2>/dev/null && git config --worktree fsgg.item "$2" 2>/dev/null || scoped=0
  if [ "$scoped" -eq 0 ]; then
    git config fsgg.worker "$1" 2>/dev/null || true
    git config fsgg.item   "$2" 2>/dev/null || true
    if [ "$(git rev-parse --git-dir 2>/dev/null)" != "$(git rev-parse --git-common-dir 2>/dev/null)" ]; then
      echo "fsgg-coord: NOTE — stamped worker '$1' into this repo's SHARED git config, not this worktree's." >&2
      echo "  Linked worktrees share it, so 'who --local' will show the last claimer for all of them." >&2
      echo "  Fix: git config extensions.worktreeConfig true" >&2
    fi
  fi
}

whoami_cmd() {
  # `--mint` is the executable remedy the warning points at. It prints ONE shell line and nothing
  # else on stdout, so `eval "$(fsgg-coord whoami --mint)"` is the whole ritual — the worker runs a
  # command instead of inventing a name, which is the entire fix for #419. Commentary goes to stderr
  # so it survives the eval. It deliberately does NOT consult the current identity: minting is for
  # the case where the derived id is known to be shared, and reusing it would defeat the point.
  if [ "${1:-}" = "--mint" ]; then
    local id; id="$(gen_worker)"
    printf 'export FSGG_WORKER=%s\n' "$id"
    echo "fsgg-coord: minted worker id '$id' — eval this line, or export it, in EACH worker's shell." >&2
    return 0
  fi
  [ -z "${1:-}" ] || die "whoami: unknown argument '$1' (only --mint is accepted)."

  worker >/dev/null; local w="$WORKER_ID"
  printf 'worker  %s\n' "$w"
  printf 'source  %s\n' "$WORKER_FROM"
  printf 'lease   %sm\n' "$CLAIM_LEASE_MIN"
  if [ -n "$HARNESS_SESSION" ]; then
    printf 'harness %s\n' "$HARNESS_NAME"
    printf 'session %s%s\n' "$HARNESS_SESSION" \
      "$(session_is_per_worker "$HARNESS_NAME" && printf ' (per-worker)' || printf ' (shared by subagents)')"
  fi
  warn_shared_identity
}

# ---- issue comments: the substrate for the lock (claim markers) and the channel (messages) --------
# Both are ordinary issue comments carrying an HTML-comment marker. One REST fetch serves both
# parsers, so a caller that needs claims AND messages pays for one round trip, not two.
now_iso() { date -u +%Y-%m-%dT%H:%M:%SZ; }

# A failed READ and an item with NO comments must never look alike. As a pipeline under `pipefail`,
# a transient gh failure (rate limit, 5xx, network) produced empty output *and* a non-zero status that
# aborted the caller mid-flight — in `claim`'s case, after posting the marker but before the back-off
# delete, orphaning a live claim nobody was working. Capture first, then decide.
issue_comments() {  # $1=owner $2=repo $3=num -> JSON array of raw comments; non-zero iff the READ failed
  local out
  out="$(gh api "repos/$1/$2/issues/$3/comments?per_page=100" --paginate --jq '.[]' 2>/dev/null)" \
    || return 1
  printf '%s' "$out" | jq -s '.'
}

# Read + parse the claim markers on an item, or DIE. Guessing the lock state from a failed read is the
# one thing a lock may never do: an empty answer would read as "nobody holds this".
claims_of() {  # $1=owner $2=repo $3=num -> JSON array of claim records, lowest comment id first
  local raw
  raw="$(issue_comments "$1" "$2" "$3")" \
    || die "cannot read the claim markers on $2#$3 (rate limit? network?) — refusing to guess the lock state."
  parse_claims <<<"$raw"
}

# Claim markers, oldest COMMENT ID first. The id is the lock's ordering key: GitHub assigns comment
# ids from a single server-side sequence, so two racers that both post and then both re-read compute
# the SAME winner (lowest id) with no coordination. `stale` marks a lease the holder stopped renewing
# — a dead worker's claim, which `reap` clears and the lock ignores.
# ANCHORED at the start of the body (`^<!--`), because a marker matched anywhere would let any
# free-form `say` message whose text merely quotes `<!-- fsgg:claim worker=ghost -->` forge a lock.
# A marker we cannot parse a worker out of becomes `unparsed-marker` — a claim held by nobody, which
# BLOCKS the item rather than vanishing. A half-written lock must fail closed, not fail open.
#
# NOTE: `ageSec` compares the client's clock (`now`) with GitHub's (`updated_at`). The lease is
# therefore only as good as clock agreement; the 120m default is orders of magnitude above realistic
# NTP skew, but a badly-skewed client can reap live claims. `who` shows the age it computed.
parse_claims() {
  jq --argjson lease "$((CLAIM_LEASE_MIN * 60))" '
    map(select(.body | test("^<!--\\s*fsgg:claim\\s")))
    | map(. as $c
        | (($c.body | [capture("^<!--\\s*fsgg:claim\\s+worker=(?<w>[^\\s>]+)")] | first) // null) as $m
        | (($c.body | [capture("^<!--[^>]*\\sprev=(?<p>[^\\s>]*)")] | first) // null) as $p
        | (($c.body | [capture("^<!--[^>]*\\ssession=(?<s>[^\\s>]+)")] | first) // null) as $x
        | { id: $c.id, worker: ($m.w // "unparsed-marker"), user: $c.user.login,
            updatedAt: $c.updated_at,
            session: ($x.s // ""),
            prev: (($p.p // "") | gsub("%20"; " ") | gsub("%25"; "%")),
            ageSec: ((now - ($c.updated_at | fromdateiso8601)) | floor) })
    | map(. + { stale: (.ageSec > $lease) })
    | sort_by(.id)'
}

parse_msgs() {
  jq '
    map(select(.body | test("^<!--\\s*fsgg:msg\\s")))
    | map(. as $c
        | ($c.body | capture("^<!--\\s*fsgg:msg\\s+from=(?<f>[^\\s>]+)\\s+to=(?<t>[^\\s>]+)")) as $m
        | { id: $c.id, from: $m.f, to: $m.t, at: $c.created_at,
            text: ($c.body | sub("^<!--[^>]*-->\\s*"; "") | sub("^\\*\\*[^*]*\\*\\*\\s*"; "")
                           | sub("\\s+$"; "")) })
    | sort_by(.id)'
}

# ---- assignment: REST, not `gh issue edit` (#418) -------------------------------------------------
# `gh issue edit --add-assignee @me` costs 4 GraphQL points (measured). The REST assignees endpoint
# does the same job for 0 — on the OTHER budget, the one that is still alive when GraphQL is not.
# Claim + release used to hand back 8 points per item for nothing. Still best-effort: an assignee is
# a courtesy to human readers, never the lock (ADR-0027 — N workers share one account, so the
# assignee CANNOT identify the holder).
me_login() {  # cached: the login never changes for the life of the token
  local f="$CACHE/login"
  [ -s "$f" ] || gh api user --jq '.login' > "$f" 2>/dev/null || true
  cat "$f" 2>/dev/null
}
assign_me()   { local me; me="$(me_login)"; [ -n "$me" ] || return 0
                gh api -X POST   "repos/$1/$2/issues/$3/assignees" -f "assignees[]=$me" >/dev/null 2>&1 || true; }
unassign_me() { local me; me="$(me_login)"; [ -n "$me" ] || return 0
                gh api -X DELETE "repos/$1/$2/issues/$3/assignees" -f "assignees[]=$me" >/dev/null 2>&1 || true; }

post_comment()   { gh api "repos/$1/$2/issues/$3/comments" -f body="$4" --jq '.id'; }
patch_comment()  { gh api -X PATCH  "repos/$1/$2/issues/comments/$3" -f body="$4" >/dev/null; }
# Returns non-zero when the comment is still THERE afterwards. Callers must not claim they cleaned up
# otherwise: a surviving marker by a worker that walked away blocks the item for a full lease.
# A 404 is SUCCESS, not failure — "already gone" is the goal state of every caller, and two workers
# collecting the same expired marker must not turn the loser's benign 404 into a hard error.
delete_comment() {
  local out rc=0
  out="$(gh api -X DELETE "repos/$1/$2/issues/comments/$3" 2>&1)" || rc=$?
  if [ "$rc" -eq 0 ]; then return 0; fi
  case "$out" in *404*|*"Not Found"*) return 0 ;; esac
  return 1
}

# Tell a worker whose marker we removed. Both `reap` and `claim` collect dead claims; neither may do
# it silently — a worker that is merely slow needs to learn its item was taken.
notify_reaped() {  # $1=owner $2=repo $3=num $4=reaped-worker $5=age-min $6=by-worker
  post_comment "$1" "$2" "$3" "$(printf '<!-- %s from=%s to=%s -->\n**reaped** — the claim by worker `%s` idled %sm, past its %sm lease, and was released. Re-claim if you are still alive; do NOT keep working this item.\n' \
    "$MSG_MARK" "$6" "$4" "$4" "$5" "$CLAIM_LEASE_MIN")" >/dev/null || true
}

# A claim OVERWRITES the Status column, so it must remember what it overwrote (#481). `unclaim_status`
# could once derive the reset target — `Ready` — because `claim` was reachable only from `Ready`. #440
# gave `take` a Backlog fallback and broke that invariant, and a value nobody recorded cannot be
# recovered afterwards: by the time `release` looks, the column says `In progress`, which is the
# claim's own footprint. So the marker carries it. The marker is the right home for it precisely
# because the marker IS the claim — it is created, stolen, inherited and destroyed with the lease.
#
# Marker keys are SPACE-separated and Status names are not (`In progress`, `In review`), so the value
# is percent-encoded. `%` first on the way in — and therefore LAST on the way out, or the escape eats
# its own escapes. The matching decode is in `parse_claims`, which is the only reader.
enc_status() { local s="${1//%/%25}"; printf '%s' "${s// /%20}"; }

# The claim marker. `renewed` changes on every heartbeat so the edit always moves `updated_at` —
# the lease clock is the comment's own mtime, which no worker can forge without touching the comment.
# `worker=` stays the FIRST key after the marker, because that is what parse_claims anchors on. The
# rest is PROVENANCE, not identity: the harness + session id say WHICH agent transcript made this
# claim. That is the question FS-GG/.github#255 could only answer with file mtimes and `ps`.
#
# `prev=` is the exception: it is not provenance but STATE — the one fact about the pre-claim board
# that only this claim knows. Every rewrite of this body (`heartbeat`, `say`, a re-claim) must carry
# it forward, or the lease renews itself into amnesia and `release` is back to guessing `Ready`.
claim_body() {  # $1=worker $2=branch $3=ts $4=ref $5=prev-status (optional)
  local prov="" provline="" prev=""
  if [ -n "$HARNESS_SESSION" ]; then
    prov=" harness=$HARNESS_NAME session=$HARNESS_SESSION"
    provline=$'\n'"<sub>agent: \`$HARNESS_NAME\` · session \`$HARNESS_SESSION\`</sub>"
  fi
  [ -n "${5:-}" ] && prev=" prev=$(enc_status "$5")"
  cat <<EOF
<!-- $CLAIM_MARK worker=$1 lease=$CLAIM_LEASE_MIN$prov$prev -->
🔒 **Claimed** by worker \`$1\` · lease ${CLAIM_LEASE_MIN}m · renewed \`$3\`

Isolated on branch \`$2\`. Renew with \`fsgg-coord heartbeat $4\`, drop with \`fsgg-coord release $4\`.${5:+ Was \`$5\` before this claim.}$provline
EOF
}

branch_for() {  # $1=owner $2=repo $3=num -> item/<n>-<title-slug>
  local title s
  title="$(gh api "repos/$1/$2/issues/$3" --jq '.title' 2>/dev/null || echo "")"
  s="$(printf '%s' "$title" | tr 'A-Z' 'a-z' | tr -c 'a-z0-9' '-' \
       | sed 's/-\{2,\}/-/g; s/^-//; s/-$//' | cut -c1-40 | sed 's/-$//')"
  printf 'item/%s%s' "$3" "${s:+-$s}"
}

# $7 is the marker's OWN `prev`, read back off the comment we are about to overwrite. A heartbeat
# rewrites the whole body, so anything not passed here is DROPPED — and a claim that beats for two
# hours would forget the column it overwrote long before it ever released it (#481).
heartbeat_comment() {  # $1=owner $2=repo $3=num $4=commentId $5=worker $6=ref $7=prev-status
  patch_comment "$1" "$2" "$4" \
    "$(claim_body "$5" "$(branch_for "$1" "$2" "$3")" "$(now_iso)" "$6" "${7:-}")"
}

# ---- GraphQL wrapper: run a query, log its rateLimit cost when FSGG_COORD_DEBUG=1 ----------------
# Every query passed here MUST select `rateLimit { cost remaining }` so the meter is observable.
# Extra `-f k=v` / `-F k=v` variable bindings are forwarded to `gh api graphql`.
gql() {
  local query="$1"; shift
  local out rc=0
  # stderr is CAPTURED, not passed through: a rate-limit failure has to be told apart from every
  # other failure (#418), and `gh` only says so on stderr. It is re-emitted below if we cannot
  # classify it, so nothing is swallowed.
  out="$(gh api graphql -f query="$query" "$@" 2>&1)" || rc=$?
  if [ "$rc" -ne 0 ]; then
    is_rate_limited "$out" && die_rate
    printf '%s\n' "$out" >&2
    die "GraphQL call failed (see gh output above)."
  fi
  if [ -n "${FSGG_COORD_DEBUG:-}" ]; then
    dbg "graphql cost=$(jq -r '.data.rateLimit.cost // "?"' <<<"$out")" \
        "remaining=$(jq -r '.data.rateLimit.remaining // "?"' <<<"$out")"
  fi
  printf '%s' "$out"
}

# `gh project item-edit` is the ONE board write that does not go through `gql` (it is a `gh project`
# subcommand, not a raw query) — so it needs the same classification, or a rate-limited write lands
# back in the "indistinguishable exit 1" hole this change exists to fill.
project_write() {  # <gh project args…>
  local out rc=0
  out="$(gh "$@" 2>&1)" || rc=$?
  if [ "$rc" -ne 0 ]; then
    is_rate_limited "$out" && die_rate
    printf '%s\n' "$out" >&2
    die "board write failed (see gh output above)."
  fi
  printf '%s' "$out"
}

# ---- bootstrap: introspect project number/id + field/option ids, cache the map (ids only) -------
bootstrap() {
  local refresh="${1:-}"
  if [ -z "$refresh" ] && [ -n "$(find "$BOARD_FILE" -mmin -"$BOARD_TTL_MIN" 2>/dev/null)" ]; then
    return 0   # cached board map is present and fresh
  fi
  dbg "bootstrap: introspecting board '$TITLE' under '$OWNER' (this is the once-per-$BOARD_TTL_MIN-min cost)"

  # (1) cheap: number + node id, by title. Only number/title/id selected -> few nodes.
  local projq='query($owner:String!){
    organization(login:$owner){ projectsV2(first:50){ nodes{ number title id } } }
    rateLimit{ cost remaining }
  }'
  local projs num pid
  projs="$(gql "$projq" -f owner="$OWNER")"
  num="$(jq -r --arg t "$TITLE" '.data.organization.projectsV2.nodes[]? | select(.title==$t) | .number' <<<"$projs" | head -1)"
  pid="$(jq -r --arg t "$TITLE" '.data.organization.projectsV2.nodes[]? | select(.title==$t) | .id'     <<<"$projs" | head -1)"
  [ -n "$num" ] && [ -n "$pid" ] \
    || die "board '$TITLE' not found under '$OWNER' (create it, or set FSGG_COORD_PROJECT/FSGG_COORD_OWNER)."

  # (2) fields + single-select options for THAT project number. dataType lets set-field auto-route.
  local fieldsq='query($owner:String!, $number:Int!){
    organization(login:$owner){ projectV2(number:$number){ fields(first:50){ nodes{
      __typename
      ... on ProjectV2FieldCommon { id name dataType }
      ... on ProjectV2SingleSelectField { options { id name } }
    } } } }
    rateLimit{ cost remaining }
  }'
  local fields
  fields="$(gql "$fieldsq" -f owner="$OWNER" -F number="$num")"

  jq --arg owner "$OWNER" --arg title "$TITLE" --argjson number "$num" --arg id "$pid" '
    .data.organization.projectV2.fields.nodes as $nodes
    | { owner:$owner, title:$title, number:$number, id:$id,
        fields: ( $nodes | map(select(.name != null) | { (.name): {
                    id: .id, dataType: .dataType,
                    options: ( (.options // []) | map({ (.name): .id }) | add // {} ) } })
                  | add // {} ) }
  ' <<<"$fields" > "$BOARD_FILE"
  dbg "bootstrap: cached $(jq '.fields | length' "$BOARD_FILE") field(s) -> $BOARD_FILE"
}

# Ensure a fresh-enough board map exists, then echo its path.
ensure_board() { bootstrap "${1:-}"; printf '%s' "$BOARD_FILE"; }

board_get()  { jq -r "$1" "$BOARD_FILE"; }   # read a jq expression from the cached board map

field_id() {
  ensure_board >/dev/null
  local id; id="$(board_get ".fields[\"$1\"].id // empty")"
  [ -n "$id" ] || die "no field named '$1' on board '$TITLE' (fields: $(board_get '.fields | keys | join(", ")'))."
  printf '%s\n' "$id"
}

option_id() {
  ensure_board >/dev/null
  local oid; oid="$(board_get ".fields[\"$1\"].options[\"$2\"] // empty")"
  [ -n "$oid" ] || die "field '$1' has no option '$2' (options: $(board_get ".fields[\"$1\"].options | keys | join(\", \")"))."
  printf '%s\n' "$oid"
}

# ---- parse an issue ref into R_OWNER / R_REPO / R_NUM --------------------------------------------
# HAZARD — parse_ref writes THREE unscoped globals (R_OWNER / R_REPO / R_NUM), and so does every
# helper that calls it (item_id, set_field, canon_blocked_by, child, claim, done, …). They hold the
# LAST-parsed ref only, and any intervening helper call silently overwrites them. Read them into
# locals IMMEDIATELY after the call, before invoking any other helper:
#     parse_ref "$ref"; local o="$R_OWNER" r="$R_REPO" n="$R_NUM"
# Reading R_* after an intervening helper returns THAT call's issue, not yours (see .github#389).
# (A structured return would remove the footgun; kept as globals here to avoid churning 16 call
#  sites in live coordination tooling — the hazard is documented instead, per .github#389.)
parse_ref() {
  local ref="$1"
  if   [[ "$ref" =~ ^https?://github\.com/([^/]+)/([^/]+)/issues/([0-9]+) ]]; then
    R_OWNER="${BASH_REMATCH[1]}"; R_REPO="${BASH_REMATCH[2]}"; R_NUM="${BASH_REMATCH[3]}"
  elif [[ "$ref" =~ ^([^/#]+)/([^/#]+)#([0-9]+)$ ]]; then
    R_OWNER="${BASH_REMATCH[1]}"; R_REPO="${BASH_REMATCH[2]}"; R_NUM="${BASH_REMATCH[3]}"
  elif [[ "$ref" =~ ^([^/#]+)#([0-9]+)$ ]]; then
    R_OWNER="$OWNER"; R_REPO="${BASH_REMATCH[1]}"; R_NUM="${BASH_REMATCH[2]}"
  else
    die "unrecognized issue ref '$ref' (use a URL, owner/repo#n, or repo#n)."
  fi
}

# ---- Blocked by: canonicalize a dependency edge into refs, or refuse the write --------------------
# `Blocked by` is TEXT only because Projects v2 has no typed dependency field. Unvalidated it drifts
# into a resolution log ("RESOLVED: #18 closed, shipped @sha") or an inverted edge ("blocks #14") —
# both unreadable by any "what is blocking this?" query. Canonicalize every ref to `owner/repo#n` on
# write so a consumer parses one form. Sets CANON_BLOCKED_BY; dies (in the CALLER's shell, so an
# invalid value can never reach the mutation) on anything else. Prose belongs in an issue comment;
# "this item is blocked" belongs in Status. An empty value clears the field — the blocker is gone.
CANON_BLOCKED_BY=""
canon_blocked_by() {
  local raw="$1" self_owner="$2" self_repo="$3" ref="${4:-<issue>}"
  local -a parts=() refs=()
  local part o r n
  raw="$(trim "$raw")"
  CANON_BLOCKED_BY=""
  [ -n "$raw" ] || return 0

  local oldifs="$IFS"; IFS=','; read -r -a parts <<<"$raw"; IFS="$oldifs"
  for part in "${parts[@]}"; do
    part="$(trim "$part")"
    [ -n "$part" ] || continue
    if   [[ "$part" =~ ^https?://github\.com/([^/]+)/([^/]+)/issues/([0-9]+)$ ]]; then
      o="${BASH_REMATCH[1]}"; r="${BASH_REMATCH[2]}"; n="${BASH_REMATCH[3]}"
    elif [[ "$part" =~ ^([^/#[:space:]]+)/([^/#[:space:]]+)#([0-9]+)$ ]]; then
      o="${BASH_REMATCH[1]}"; r="${BASH_REMATCH[2]}"; n="${BASH_REMATCH[3]}"
    elif [[ "$part" =~ ^([^/#[:space:]]+)#([0-9]+)$ ]]; then
      o="$OWNER"; r="${BASH_REMATCH[1]}"; n="${BASH_REMATCH[2]}"
    elif [[ "$part" =~ ^#([0-9]+)$ ]]; then           # bare #n -> the blocked item's own repo
      o="$self_owner"; r="$self_repo"; n="${BASH_REMATCH[1]}"
    elif [[ "${part,,}" =~ ^(-+|—|–|none|n/?a|tbd|todo)$ ]]; then
      # "-" and friends mean "nothing blocks this". Say it with an empty value, so a reader never has
      # to guess whether a placeholder is a blocker it cannot parse.
      echo "fsgg-coord: 'Blocked by' has no placeholder value — '$part' is not a ref." >&2
      echo "  to record that nothing blocks this item, CLEAR the field:" >&2
      echo "      fsgg-coord set-field $ref 'Blocked by' ''" >&2
      exit 1
    else
      echo "fsgg-coord: 'Blocked by' takes issue refs, not prose — rejected: '$part'" >&2
      echo "  want: a comma-separated list of owner/repo#n, repo#n, #n, or issue URLs" >&2
      echo "        (e.g. 'FS-GG/FS.GG.SDD#8, #33')" >&2
      echo "  note: the field records what blocks THIS item — 'blocks X' is the inverse edge," >&2
      echo "        and it is not a delivery log. Put narrative in an issue comment; mark the" >&2
      echo "        item blocked with: fsgg-coord set-field <issue> Status Blocked" >&2
      exit 1
    fi
    refs+=("$o/$r#$n")
  done

  local joined="" ref
  for ref in "${refs[@]}"; do
    case ", $joined," in *", $ref,"*) continue ;; esac   # de-dupe, preserving first-seen order
    joined="${joined:+$joined, }$ref"
  done
  CANON_BLOCKED_BY="$joined"
}

# ---- item-id: narrow issue -> projectItems resolution, cached per issue (item ids are stable) ---
item_id() {
  local ref="$1" refresh="${2:-}"
  parse_ref "$ref"
  ensure_board >/dev/null
  local boardnum; boardnum="$(board_get '.number')"
  local itemfile="$CACHE/item-$(slug "$OWNER")-$(slug "$TITLE")-$(slug "$R_OWNER")-$(slug "$R_REPO")-$R_NUM.json"
  if [ -z "$refresh" ] && [ -f "$itemfile" ]; then
    jq -r '.itemId' "$itemfile"; return 0
  fi
  local q='query($owner:String!, $repo:String!, $num:Int!){
    repository(owner:$owner, name:$repo){ issue(number:$num){ id title
      projectItems(first:20){ nodes{ id project{ number title } } } } }
    rateLimit{ cost remaining }
  }'
  # AN UNREACHABLE SUBJECT IS NOT AN ABSENT ONE (#421, the #266 class). `gql` dies inside this `$( )`,
  # and under SOFT_DIE that die unwinds only the substitution — leaving `out` EMPTY and this function
  # free to carry on and conclude, from a payload it never received, that the issue is "not on board".
  # It then printed a remediation (`gh project item-add …`) that would have created a DUPLICATE board
  # item for an issue that was on the board all along. The read failing and the item being absent are
  # different facts; only the second one may be reported here.
  local out iid
  out="$(gql "$q" -f owner="$R_OWNER" -f repo="$R_REPO" -F num="$R_NUM")" || die_relay
  [ -n "$out" ] || die_relay
  iid="$(jq -r --argjson pn "$boardnum" \
    '.data.repository.issue.projectItems.nodes[]? | select(.project.number==$pn) | .id' <<<"$out" | head -1)"
  # EX_OFFBOARD, not a bare 1: "this issue is not on the board" is a PERMANENT fact a caller acts on
  # differently from "the budget is gone, try later" (#418). `claim` tells the two apart on this code.
  [ -n "$iid" ] && [ "$iid" != "null" ] \
    || die_rc "$EX_OFFBOARD" "issue $R_OWNER/$R_REPO#$R_NUM is not on board '$TITLE' — add it first: fsgg-coord add $R_REPO#$R_NUM"
  jq -n --arg itemId "$iid" '{itemId:$itemId}' > "$itemfile"
  printf '%s\n' "$iid"
}

# ---- add: put an issue ON the board --------------------------------------------------------------
# THE VERB THAT WAS MISSING, and its absence is why every recipe reached PAST the tool (#587).
# `check-board`, `pnext-item`, `cross-repo-coordination` — and this tool's own "add it first" message,
# two lines up — all told a worker to run `gh project item-add`. That is a Projects v2 call on the
# GraphQL budget that is SHARED BY THE WHOLE FLEET, and going around the client means nothing meters
# it, nothing caches it, and nothing queues it when the budget is gone. A rule you cannot obey is not
# a rule, it is a reprimand — so the monopoly needed this verb before it could need a gate.
add_item() {  # <issue> -> prints the board item id (idempotent)
  local ref="$1"
  parse_ref "$ref"
  ensure_board >/dev/null
  local boardnum; boardnum="$(board_get '.number')"

  # Already there? Say so and print the id, rather than creating a twin.
  local existing rc=0
  existing="$(soft_run item_id "$ref" --refresh 2>/dev/null)" || rc=$?
  if [ "$rc" = 0 ] && [ -n "$existing" ]; then
    echo "fsgg-coord: $R_REPO#$R_NUM is already on board '$TITLE'." >&2
    printf '%s\n' "$existing"
    return 0
  fi
  # EX_OFFBOARD is the EXPECTED path — not being on the board is why we are here. Any other code is a
  # FAILED READ, and adding on a failed read is exactly how you create a duplicate board item: #421's
  # lesson, one verb along. A lookup that could not run is not an absence.
  [ "$rc" = "$EX_OFFBOARD" ] || die_rc "$rc" \
    "add: could not determine whether $R_REPO#$R_NUM is already on the board — REFUSING to add. A failed lookup is not an absence (#421); adding on one creates a duplicate item."

  local url="https://github.com/$R_OWNER/$R_REPO/issues/$R_NUM"
  local out iid
  out="$(project_write project item-add "$boardnum" --owner "$OWNER" --url "$url" --format json)"
  iid="$(jq -r '.id // empty' <<<"$out")"
  [ -n "$iid" ] || die "add: the board accepted $R_REPO#$R_NUM but returned no item id."
  # Cache it, so the set-field that always follows does not pay for another lookup.
  local itemfile="$CACHE/item-$(slug "$OWNER")-$(slug "$TITLE")-$(slug "$R_OWNER")-$(slug "$R_REPO")-$R_NUM.json"
  jq -n --arg itemId "$iid" '{itemId:$itemId}' > "$itemfile"
  echo "fsgg-coord: added $R_REPO#$R_NUM to board '$TITLE'." >&2
  printf '%s\n' "$iid"
}

# ---- the item's CURRENT Status, read fresh (never cached — `release` decides on it) -------------
# Deliberately NOT folded into `item_id`: that caches its answer to a file, and a stale Status is
# worse than none. One narrow query, no blocker resolution.
#
# Echoes the Status name — empty when the item is on the board with no Status set.
#   rc 0 -> read it    rc 1 -> the read failed    rc 2 -> the issue is not on this board
#
# Callers must invoke this in a command substitution: `gql`/`ensure_board` `die` on failure, and the
# substitution's subshell is what turns that into rc 1 rather than killing the caller mid-release.
item_status() {
  local ref="$1"
  parse_ref "$ref"
  ensure_board >/dev/null
  local boardnum out node
  boardnum="$(board_get '.number')"
  local q='query($owner:String!, $repo:String!, $num:Int!){
    repository(owner:$owner, name:$repo){ issue(number:$num){
      projectItems(first:20){ nodes{
        project{ number }
        status: fieldValueByName(name:"Status"){ ... on ProjectV2ItemFieldSingleSelectValue{ name } }
      } } } }
    rateLimit{ cost remaining }
  }'
  # Check the read EXPLICITLY, and mark it SOFT. This caller is the deliberate exception to #344's
  # fail-closed rule: `release`/`reap` must still drop a lease when the board is unreadable, so here a
  # failed read is rc 1 (handled), not a fatal abort. `SOFT_DIE=1` keeps `gql`'s `die` from escalating
  # to the whole command, so `|| return 1` catches it. An empty payload yields no board node,
  # indistinguishable from "not on this board" (rc 2) unless we catch it first — so we catch it.
  out="$(SOFT_DIE=1 gql "$q" -f owner="$R_OWNER" -f repo="$R_REPO" -F num="$R_NUM")" || return 1
  [ -n "$out" ] || return 1
  node="$(jq -c --argjson pn "$boardnum" \
    '[ .data.repository.issue.projectItems.nodes[]? | select(.project.number == $pn) ] | first // empty' \
    <<<"$out")" || return 1
  [ -n "$node" ] || return 2
  jq -r '.status.name // ""' <<<"$node"
}

# ---- what Status should an item carry once its claim is UNDONE? (#331) --------------------------
# `release` and `reap` are the two ways a claim goes away, so they owe the board the same answer —
# and both used to force `Ready`. But "the lease is gone" and "this item is startable" are DIFFERENT
# claims. A claim's only Status footprint is the `$CLAIM_STATUS` it wrote; that is the one column
# undoing it may reset. `Blocked`, `Backlog`, `In review`, `Done` were each chosen by somebody, and
# overwriting them is how the board came to assert `Ready` on rows whose `Blocked by` named an open
# issue — silently, every time a worker followed the documented blocked-item sequence.
#
# And a Status we could not READ is not a Status we may overwrite: guessing `Ready` over an unknown
# column is the same fail-open one turn in (#266).
#
# RESTORING the claim's column is not the same as guessing `Ready` for it (#481). Undoing a write
# means putting back what was there, and $2 — the `prev=` the claim recorded in its own marker — is
# the only witness to that. #331 reset to `Ready` and was right to, but only because `claim` was then
# reachable only FROM `Ready`; #440's Backlog fallback made `Ready` a promotion, and every undo path
# (`release`, `take`'s lost-race retry, `reap`) quietly drained Backlog into the queue humans read as
# triaged work.
#
# `Ready` survives only as the fallback for a claim that recorded NOTHING — a marker minted before
# this change, or one whose pre-claim column could not be read. That is the old behaviour, now scoped
# to the one case where there is genuinely nothing to restore.
#
# Echoes one TAB-separated verdict; always rc 0, because every outcome here is a decision:
#   write<TAB><name>  restore the column this claim overwrote (`Ready` if it recorded none)
#   keep<TAB><name>   leave a deliberately-chosen column alone
#   offboard<TAB>     the item is on no board; there is nothing to reset
#   unreadable<TAB>   the read failed; do not touch the column
unclaim_status() {  # $1=ref $2=prev-status recorded by the claim (may be empty)
  local cur rc=0 prev="${2:-}"
  # A claim that recorded `In progress` recorded its own footprint, not a column anybody chose —
  # restoring it would leave the item looking claimed with no claim on it. Treat it as unrecorded.
  [ "$prev" = "$CLAIM_STATUS" ] && prev=""
  cur="$(item_status "$1" 2>/dev/null)" || rc=$?
  case "$rc" in
    0) if [ -z "$cur" ] || [ "$cur" = "$CLAIM_STATUS" ]; then printf 'write\t%s\n' "${prev:-Ready}"
       else printf 'keep\t%s\n' "$cur"; fi ;;
    2) printf 'offboard\t\n' ;;
    *) printf 'unreadable\t\n' ;;
  esac
}

# ---- set-field: resolve project/field/item/option ids from cache, one narrow mutation -----------
set_field() {
  local ref="$1" field="$2" value="$3" refresh="${4:-}"
  ensure_board "$refresh" >/dev/null
  local pid dtype fid item
  pid="$(board_get '.id')"
  dtype="$(board_get ".fields[\"$field\"].dataType // empty")"
  [ -n "$dtype" ] || die "no field named '$field' on board '$TITLE' (fields: $(board_get '.fields | keys | join(", ")'))."
  fid="$(field_id "$field")"

  # Canonicalize BEFORE resolving the item: a rejected value must cost zero GraphQL.
  if [ "$field" = "Blocked by" ]; then
    parse_ref "$ref"                                   # the blocked item's repo, for bare `#n` refs
    canon_blocked_by "$value" "$R_OWNER" "$R_REPO" "$ref"
    value="$CANON_BLOCKED_BY"
  fi

  # If item_id died (off-board, or the budget is gone), STOP HERE. Letting an empty item id fall
  # through to `gh project item-edit --id ''` is what turned a precise diagnosis into a generic
  # "board write failed" — the stub's non-empty --id guard is the backstop, not the plan.
  item="$(item_id "$ref" "$refresh")" || die_relay
  [ -n "$item" ] || die_relay

  # An empty value CLEARS the field. `gh project item-edit --text ''` is not a clear — it is a no-op
  # ("no changes to make"), so an empty write would silently leave the old value in place.
  local -a vflag
  if [ -z "$value" ]; then
    vflag=(--clear)
  else
    case "$dtype" in
      SINGLE_SELECT) vflag=(--single-select-option-id "$(option_id "$field" "$value")") ;;
      TEXT)          vflag=(--text   "$value") ;;
      NUMBER)        vflag=(--number "$value") ;;
      DATE)          vflag=(--date   "$value") ;;
      ITERATION)     vflag=(--iteration-id "$value") ;;
      *)             die "field '$field' has unsupported dataType '$dtype'." ;;
    esac
  fi
  dbg "set-field $ref $field='$value' -> item=$item field=$fid ($dtype)"
  project_write project item-edit --id "$item" --project-id "$pid" --field-id "$fid" "${vflag[@]}" >/dev/null
  # Keep the hot-read scan cache honest about OUR OWN write, rather than dropping it. Invalidating
  # would send the very next `take` back to a full-board scan — and a claim is always followed by a
  # take — so the cache would never survive the loop it exists for. Patching costs nothing.
  scan_cache_patch "$ref" "$field" "$value"
}

# ---- set-field --batch: N field writes, ONE GraphQL document (#448) ------------------------------
# GitHub bills `cost = max(1, nodes/100)` — a 1-point FLOOR per request. A Projects v2 field mutation
# returns ~1 node, so it hits the floor, and the cost of a placement pass therefore tracks the REQUEST
# COUNT and nothing else. Six fields on one item is six requests and six points; aliased into one
# document it is one request and ONE point. #421's session (~66 set-field calls) would have cost ~11.
#
# That budget is shared by every worker on the account (#418), and this write path is what a placement
# pass and `/check-board --apply` spend it on — so this is not a micro-optimisation, it is the
# difference between a fan-out that can afford to place its findings and one that cannot.
#
# `docs/coordination/graphql-budget.md` claimed the opposite ("batching does nothing for the primary
# budget"). That is true of QUERIES, whose cost scales with the nodes they return; it is false of these
# mutations, which are pinned to the floor. The doc is corrected separately (it is not in this item's
# touch-set) — measurement is in #448.

# A GraphQL string literal, escaped by jq rather than by hand. GraphQL string syntax is JSON string
# syntax, so `@json` is exactly right — and it is why a value containing a quote, a newline or a
# backslash cannot break out of the document it is interpolated into.
gql_str() { jq -n --arg s "$1" '$s'; }

# The `ProjectV2FieldValue` literal for one field, routed by the SAME dataType map the single-write
# path routes on — one table, so the two paths cannot drift apart on what a `NUMBER` means.
field_value_literal() {  # $1=field $2=dtype $3=value -> {text: "…"} | {number: 3} | …
  local field="$1" dtype="$2" value="$3"
  case "$dtype" in
    SINGLE_SELECT)
      # `option_id` DIES on an unknown option, and its die must be RELAYED, not interpolated. Inlined
      # as `$(gql_str "$(option_id …)")`, that die unwinds only the INNERMOST substitution (see
      # die_rc) — `printf` then runs anyway and emits `{singleSelectOptionId: ""}`, which is perfectly
      # VALID GraphQL. So the guard never fires, the document is sent, and the server rejects it with
      # "The single select option Id does not belong to the field": a point spent to be told, in the
      # API's words, what the cached board map knew before the call. The empty string is the whole
      # trap — a syntactically valid literal carrying a value that cannot exist.
      local oid; oid="$(option_id "$field" "$value")" || die_relay
      printf '{singleSelectOptionId: %s}' "$(gql_str "$oid")" ;;
    TEXT)          printf '{text: %s}'        "$(gql_str "$value")" ;;
    DATE)          printf '{date: %s}'        "$(gql_str "$value")" ;;
    ITERATION)     printf '{iterationId: %s}' "$(gql_str "$value")" ;;
    NUMBER)
      # Unquoted in the document, so it must BE a number. And the check must be a REAL numeric parse,
      # not a character-class filter: `1.2.3`, `e`, `+` and `--` are all built from legal characters
      # and all emit a document GraphQL cannot parse — which fails the WHOLE batch, including the
      # fields that were fine, and reports a syntax error instead of the reason this guard exists to
      # give. jq decides what a number is, exactly as it decides what a string is above.
      jq -e -n --arg v "$value" '($v | tonumber) | true' >/dev/null 2>&1 \
        || die "field '$field': '$value' is not a NUMBER."
      printf '{number: %s}' "$value" ;;
    *) die "field '$field' has unsupported dataType '$dtype'." ;;
  esac
}

# Every pair is RESOLVED AND VALIDATED before a single mutation is emitted — an unknown field, an
# unknown option, a `Blocked by` that is not a ref, a NUMBER that is not a number. That is the same
# invariant the single write holds ("a rejected value must cost zero GraphQL"), and here it is load
# bearing twice over: a bad pair caught late would not merely waste a point, it would fail the
# document AFTER its earlier aliases had already been written to the board.
set_field_batch() {  # <ref> <refresh> <Field=Value>…
  local ref="$1" refresh="${2:-}"; shift 2
  [ "$#" -gt 0 ] || die "set-field --batch: at least one Field=Value pair required."
  ensure_board "$refresh" >/dev/null
  local pid item
  pid="$(board_get '.id')"
  item="$(item_id "$ref" "$refresh")" || die_relay
  [ -n "$item" ] || die_relay

  # Loop-invariant, and escaped ONCE: the project and the item are the same for every alias in the
  # document, so re-escaping them per field would fork jq 2N times to recompute two constants.
  local pid_s item_s
  pid_s="$(gql_str "$pid")"; item_s="$(gql_str "$item")"

  local -a al=() fl=() vl=()
  local doc="" pair field value dtype fid fid_s lit a i=0
  for pair in "$@"; do
    case "$pair" in
      *=*) ;;
      *)   die "set-field --batch: '$pair' is not a Field=Value pair (field names may contain spaces: 'Repo Scope=sdd')." ;;
    esac
    field="${pair%%=*}"; value="${pair#*=}"     # FIRST '=' only: a value may contain one
    dtype="$(board_get ".fields[\"$field\"].dataType // empty")"
    [ -n "$dtype" ] || die "no field named '$field' on board '$TITLE' (fields: $(board_get '.fields | keys | join(", ")'))."
    fid="$(field_id "$field")"
    if [ "$field" = "Blocked by" ]; then
      parse_ref "$ref"
      canon_blocked_by "$value" "$R_OWNER" "$R_REPO" "$ref"
      value="$CANON_BLOCKED_BY"
    fi
    fid_s="$(gql_str "$fid")"
    a="f$i"
    if [ -z "$value" ]; then
      # An empty value CLEARS, and `update` with an empty text is a no-op, not a clear — the same trap
      # the single path documents. There is a distinct mutation for it, so use it.
      doc="$doc
  $a: clearProjectV2ItemFieldValue(input:{projectId: $pid_s, itemId: $item_s, fieldId: $fid_s}){ projectV2Item{ id } }"
    else
      # RESOLVED INTO A VARIABLE, and its failure RELAYED — never interpolated straight into the
      # document. `field_value_literal` dies on an unknown single-select option or a bad NUMBER, and a
      # `die` inside a `$( )` only unwinds THE SUBSTITUTION (see die_rc): interpolated inline, that die
      # would leave `value: ` empty, let this loop carry on, and SEND a document already known to be
      # invalid — spending a GraphQL point to be told, in a parse error, what we knew before the call.
      # `|| die_relay` is the idiom set_field already uses on item_id for exactly this hazard.
      lit="$(field_value_literal "$field" "$dtype" "$value")" || die_relay
      doc="$doc
  $a: updateProjectV2ItemFieldValue(input:{projectId: $pid_s, itemId: $item_s, fieldId: $fid_s, value: $lit}){ projectV2Item{ id } }"
    fi
    al+=("$a"); fl+=("$field"); vl+=("$value"); i=$((i+1))
  done
  # NO `rateLimit` selection: it is a field of the QUERY root, not the Mutation root, so selecting it
  # here is a document that does not parse. The batch is therefore the one call whose cost `gql`'s
  # meter cannot read — which is fine, because its cost is the thing this function makes constant.
  doc="mutation {$doc
}"
  dbg "set-field --batch $ref: $i field(s) -> item=$item, ONE document"

  local out err rc=0 errf k
  errf="$(mktemp "$CACHE/.gqlb.XXXXXX")"; TMPFILES+=("$errf")
  out="$(gh api graphql -f query="$doc" 2>"$errf")" || rc=$?
  err="$(cat "$errf" 2>/dev/null)"; rm -f "$errf"

  if [ "$rc" -ne 0 ]; then
    # An exhausted budget refuses the document OUTRIGHT — nothing was applied — so the whole batch is
    # deferrable, and the caller queues every pair. This must be tested BEFORE the partial arm below,
    # or a rate limit would be misreported as a half-written board.
    is_rate_limited "$out
$err" && die_rate

    # A GraphQL error arrives as HTTP 200 with a body carrying BOTH `data` and `errors`, and
    # `errors[].path[0]` names the failing ALIAS. So the body says exactly which writes landed — and
    # since mutations execute serially, the ones before the failure DID land. Say so.
    if [ -n "$out" ] && jq -e 'has("errors")' >/dev/null 2>&1 <<<"$out"; then
      local applied=0 failed=0 why
      for k in "${!al[@]}"; do
        if [ "$(jq -r --arg a "${al[$k]}" '.data[$a] // "null"' <<<"$out")" != "null" ]; then
          applied=$((applied+1))
          scan_cache_patch "$ref" "${fl[$k]}" "${vl[$k]}"
          echo "  APPLIED  ${fl[$k]}='${vl[$k]}'" >&2
        else
          failed=$((failed+1))
          why="$(jq -r --arg a "${al[$k]}" \
                   '[.errors[]? | select((.path // [])[0] == $a) | .message] | join("; ")' <<<"$out")"
          echo "  FAILED   ${fl[$k]}='${vl[$k]}' — ${why:-no reason given}" >&2
        fi
      done
      [ "$applied" -eq 0 ] \
        && die "set-field --batch: the document failed and NOTHING was applied — $failed field(s) rejected (see above)."
      die_rc "$EX_PARTIAL" "set-field --batch: PARTIALLY APPLIED — $applied of $((applied+failed)) field(s) were WRITTEN, $failed failed.
  The board is now half-written. This is NOT queued: replaying the document would rewrite the half that
  already landed. Re-run the failed field(s) above once you have fixed them."
    fi
    printf '%s\n' "$err" >&2
    die "set-field --batch: the GraphQL document failed (see gh output above)."
  fi

  # Success. Patch the hot-read scan cache for every pair, exactly as the single write does.
  for k in "${!al[@]}"; do scan_cache_patch "$ref" "${fl[$k]}" "${vl[$k]}"; done
}

# ---- the deferred-write queue: a board write the budget refused is QUEUED, never lost (#418) ------
# The failure this closes: `claim` takes the lock (REST comments — a different budget, still working)
# and then cannot write `Status: In progress` because GraphQL is exhausted. The old code swallowed
# that and printed "not on board". The board then said `Backlog`/`Blocked` while a worker held the
# item, `next` skipped it for everyone, and `/check-board` later reported it as CLAIM-STATUS-LAG.
#
# The lock is REST-backed and already held, so the right move is neither to fail the claim nor to
# pretend it wrote: RECORD the write and tell the caller, in the same breath, that it is pending.
# `flush` replays the queue; every board-writing command tries a flush first, so the queue drains on
# its own the moment the budget comes back.
PENDING="$CACHE/pending.jsonl"

defer_write() {  # <ref> <field> <value>
  jq -cn --arg ref "$1" --arg field "$2" --arg value "$3" --arg at "$(now_iso)" --arg w "$(worker)" \
    '{ref:$ref, field:$field, value:$value, at:$at, worker:$w}' >> "$PENDING"
  dbg "deferred board write: $1 $2='$3'"
}

pending_count() { [ -s "$PENDING" ] && wc -l <"$PENDING" | tr -d ' ' || echo 0; }

# ---- board_write: the ONE board write, and it QUEUES (#510) ---------------------------------------
# EVERY board write goes through here. Nothing else may call `set_field` directly.
#
# The defect this closes: `claim` deferred its write. NOTHING ELSE DID — and yet `die_rate` told every
# caller, in the same breath, "Board WRITES are queued: see `fsgg-coord flush`". So a `set-field` (or
# a `done --flip`) that met an exhausted budget PRINTED THE PROMISE AND DROPPED THE WRITE; `flush`
# then found an empty queue and reported success, CONFIRMING the lie. A finding filed mid-recipe
# landed on the board with no Status, no Phase and no Repo Scope — and the worker who read the
# message did the correct thing, trusted it, and carried on (#510; family: epic #416).
#
# So the promise in that message is now true of every board write, because there is only one.
#
# The one thing that is NOT queued is a write to something that is not on the board: that write can
# never land (flush drops it too, permanently), so queueing it would be a second unkeepable promise —
# which is the defect, not the cure. Say so, loudly, and return EX_OFFBOARD.
#
# Sets BOARD_WRITE_NOTE, a caller-printable phrase. Returns:
#   0            written
#   EX_OFFBOARD  permanent — not on the board. NOT queued.
#   EX_RATE      QUEUED behind an exhausted budget.
#   other        QUEUED behind a transient failure.
# ONLY EX_RATE IS QUEUED, and that is the whole subtlety. A write can fail three ways and they are
# three different facts — collapsing them is the defect this command exists to fix, one level down:
#
#   EX_RATE      TRANSIENT.  The budget will come back and the same write will then succeed. QUEUE it.
#   EX_OFFBOARD  PERMANENT.  There is no board item to write to. A queued write here can NEVER land
#                (flush drops it too), so queueing it is a second unkeepable promise.
#   anything else  REFUSED.  `set_field` rejected the write — an unknown field, an unknown option, a
#                `Blocked by` value that is not a ref (it canonicalises BEFORE spending any GraphQL,
#                precisely so a bad value costs nothing). Queueing a REFUSED write would replay a
#                write that can never succeed, forever, and swallow the refusal that says why.
#                So: never queued, and `set_field`'s own message is carried out in BOARD_WRITE_ERR.
BOARD_WRITE_NOTE=""
BOARD_WRITE_ERR=""
board_write() {  # <ref> <field> <value> [refresh]
  local ref="$1" field="$2" value="$3" refresh="${4:-}" rc=0
  # A SUBSHELL, not just a redirect: set_field's `die` is an `exit`. soft_run carries out the code the
  # die actually chose (EX_RATE / EX_OFFBOARD / 1), however deeply nested it fired. Its stderr is
  # CAPTURED, not discarded — a refusal that nobody can read is a refusal that did not happen.
  BOARD_WRITE_ERR=""
  BOARD_WRITE_ERR="$(soft_run set_field "$ref" "$field" "$value" "$refresh" 2>&1 1>/dev/null)" || rc=$?
  case "$rc" in
    0)              BOARD_WRITE_NOTE="board: ${value:-<cleared>}" ;;
    "$EX_OFFBOARD") BOARD_WRITE_NOTE="note: not on board '$TITLE' — NOT queued (a queued write to a non-item can never land); add it, then rerun" ;;
    "$EX_RATE")     defer_write "$ref" "$field" "$value"
                    BOARD_WRITE_NOTE="board: DEFERRED — GraphQL budget exhausted, resets in $(rate_reset_in). The write is QUEUED; run 'fsgg-coord flush' (or any board write auto-flushes)." ;;
    *)              BOARD_WRITE_NOTE="board: WRITE REFUSED (rc=$rc) — NOT queued; the value or the field was rejected, and replaying it would never succeed" ;;
  esac
  dbg "board_write $ref $field='$value' -> rc=$rc"
  return "$rc"
}

# The batched write, through the SAME queue contract as the single one (#448). Three outcomes, and the
# only new one is EX_PARTIAL:
#
#   EX_RATE      the document was refused outright, so NOTHING was applied. Every pair is queued —
#                individually, in the existing per-(ref,field,value) queue, so `flush` replays them
#                with the single-write path and needs to know nothing about batching.
#   EX_PARTIAL   some aliases WROTE and some failed. Never queued (see EX_PARTIAL), and never success.
#   EX_OFFBOARD  no board item to write to. Permanent, as before.
board_write_batch() {  # <ref> <refresh> <Field=Value>…
  local ref="$1" refresh="${2:-}"; shift 2
  local rc=0 pair
  BOARD_WRITE_ERR=""
  BOARD_WRITE_ERR="$(soft_run set_field_batch "$ref" "$refresh" "$@" 2>&1 1>/dev/null)" || rc=$?
  case "$rc" in
    0)              BOARD_WRITE_NOTE="board: $# field(s) written in ONE request" ;;
    "$EX_OFFBOARD") BOARD_WRITE_NOTE="note: not on board '$TITLE' — NOT queued (a queued write to a non-item can never land); add it, then rerun" ;;
    "$EX_RATE")
        for pair in "$@"; do defer_write "$ref" "${pair%%=*}" "${pair#*=}"; done
        BOARD_WRITE_NOTE="board: DEFERRED — GraphQL budget exhausted, resets in $(rate_reset_in). All $# write(s) are QUEUED; run 'fsgg-coord flush' (or any board write auto-flushes)." ;;
    "$EX_PARTIAL")  BOARD_WRITE_NOTE="board: PARTIALLY APPLIED — NOT queued. Some fields were written and some were not; see above." ;;
    *)              BOARD_WRITE_NOTE="board: WRITE REFUSED (rc=$rc) — NOT queued; the value or the field was rejected, and replaying it would never succeed" ;;
  esac
  dbg "board_write_batch $ref ($# pairs) -> rc=$rc"
  return "$rc"
}

# Replay the queue. Each entry is retried ONCE per flush: a success drops it, another rate-limit
# stops the whole flush (the budget is gone; the rest would fail identically), and a PERMANENT
# failure (EX_OFFBOARD — the item is not on the board) drops the entry with a loud note rather than
# retrying it forever. Quiet when there is nothing to do, so it can sit in front of every write.
flush_pending() {  # [--quiet]
  local quiet="${1:-}"
  [ -s "$PENDING" ] || { [ -n "$quiet" ] || echo "flush: nothing pending."; return 0; }
  local kept; kept="$(mktemp "$CACHE/.pending.XXXXXX")"
  local line ref field value rc stopped="" done_n=0 drop_n=0
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    if [ -n "$stopped" ]; then printf '%s\n' "$line" >>"$kept"; continue; fi
    ref="$(jq -r '.ref' <<<"$line")"; field="$(jq -r '.field' <<<"$line")"; value="$(jq -r '.value' <<<"$line")"
    rc=0; soft_run set_field "$ref" "$field" "$value" >/dev/null 2>&1 || rc=$?
    case "$rc" in
      0)  done_n=$((done_n+1)); echo "flush: $ref $field='$value' — written." ;;
      "$EX_RATE")
          stopped=1; printf '%s\n' "$line" >>"$kept"
          echo "flush: GraphQL still exhausted (resets in $(rate_reset_in)) — $ref and the rest stay queued." >&2 ;;
      "$EX_OFFBOARD")
          drop_n=$((drop_n+1))
          echo "flush: DROPPED $ref $field='$value' — that issue is not on board '$TITLE' (add it, then set the field by hand)." >&2 ;;
      *)  printf '%s\n' "$line" >>"$kept"
          echo "flush: $ref $field='$value' failed (rc=$rc) — kept queued." >&2 ;;
    esac
  done < "$PENDING"
  if [ -s "$kept" ]; then mv "$kept" "$PENDING"; else rm -f "$kept" "$PENDING"; fi
  [ -n "$quiet" ] || printf 'flush: %d written, %d dropped, %d still queued.\n' "$done_n" "$drop_n" "$(pending_count)"
  [ -z "$stopped" ]
}

# Every board-writing command calls this first: a queue that only drains when a human remembers to
# run `flush` is a queue that stays full.
autoflush() { [ -s "$PENDING" ] && flush_pending --quiet >/dev/null 2>&1 || true; }

flush_cmd() {
  case "${1:-}" in
    "")       ;;
    --dry-run) [ -s "$PENDING" ] && jq -r '"pending  \(.ref)  \(.field)=\"\(.value)\"  (queued \(.at) by \(.worker))"' "$PENDING" \
                 || echo "flush: nothing pending."; return 0 ;;
    *)        die "flush: unknown arg '$1' (want --dry-run)." ;;
  esac
  flush_pending
}

# ---- the hot-read scan cache: N workers looping must not cost N full-board scans (#418) -----------
# Measured on the live 640-item Coordination board: one thrifty full scan = 7 pages × 1 pt = 7 pts.
# Cheap once. But `take`/`next` are what a worker loop calls, and five workers polling them burn
# 5 × 7 pts a round — which is how a 5,000-pt budget disappears in a quarter of an hour, mid-protocol,
# taking the WRITES down with it.
#
# So the scan is cached to the (user-level, therefore SHARED-between-workers) cache dir with a short
# TTL: N workers in a TTL window pay for ONE scan between them.
#
# WHY THIS IS SAFE FOR SCHEDULING AND NOT FOR RECONCILING — the line the TTL is drawn on:
#   * `next`/`take`/`batch` (SCHEDULING) read it. A stale scan can only hand out an item somebody
#     else just claimed, and the claim CAS — which reads MARKERS over REST, never this cache — is
#     what actually decides who holds it. The loser retries (`take --tries`). Staleness costs a retry;
#     it cannot cost a double-claim.
#   * `ready`/`lint`/`who`/`overlap --active` (RECONCILING, and the /check-board snapshot) always
#     scan FRESH. Their whole job is to say what is true right now, and a cached "truth" is how a
#     reconciler reports drift that was already fixed. `--fresh` forces a rescan anywhere.
# THE LOCK IS NEVER READ FROM A CACHE. That rule (see `who`) is unchanged and this does not touch it.
SCAN_TTL_SEC="${FSGG_COORD_SCAN_TTL_SEC:-90}"
# Keyed on the board, like every other cache file here: FSGG_COORD_OWNER/PROJECT can point this client
# at a different board, and serving one board's items for another is not a stale answer — it is a wrong
# one, and nothing downstream would notice.
SCAN_FILE="$CACHE/scan-$(slug "$OWNER")-$(slug "$TITLE").json"

scan_cache_get() {  # echoes the cached scan iff it is fresh; non-zero otherwise
  [ "$SCAN_TTL_SEC" -gt 0 ] 2>/dev/null || return 1
  [ -s "$SCAN_FILE" ] || return 1
  local age; age=$(( $(date -u +%s) - $(mtime "$SCAN_FILE") ))
  [ "$age" -lt "$SCAN_TTL_SEC" ] || return 1
  dbg "scan cache HIT (${age}s old, ttl ${SCAN_TTL_SEC}s) — zero GraphQL"
  cat "$SCAN_FILE"
}

scan_cache_put() { printf '%s' "$1" > "$SCAN_FILE"; }

# Fold our own board write into the cached scan, so the cache stays true without being thrown away.
scan_cache_patch() {  # <ref> <field> <value>
  [ -s "$SCAN_FILE" ] || return 0
  local key; case "$2" in Status) key=status ;; Phase) key=phase ;; "Blocked by") key=blockedBy ;; *) return 0 ;; esac
  parse_ref "$1" || return 0
  local tmp; tmp="$(mktemp "$CACHE/.scan.XXXXXX")"
  jq -c --arg repo "$R_OWNER/$R_REPO" --argjson num "$R_NUM" --arg key "$key" --arg val "$3" \
    'map(if (.repo == $repo and .number == $num) then (.[$key] = (if $val == "" then null else $val end)) else . end)' \
    "$SCAN_FILE" > "$tmp" 2>/dev/null && mv "$tmp" "$SCAN_FILE" || rm -f "$tmp"
  dbg "scan cache patched: $R_REPO#$R_NUM $key='$3'"
}

mtime() { stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null || echo 0; }

# ---- issues: REST list with ETag revalidation (GraphQL-budget-free; 304s are free) --------------
issues() {
  local repo="" label="" state="open" refresh="" jqexpr=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --label)   label="${2:?--label needs a value}"; shift 2 ;;
      --state)   state="${2:?--state needs a value}"; shift 2 ;;
      --jq)      jqexpr="${2:?--jq needs a value}"; shift 2 ;;
      --refresh) refresh=1; shift ;;
      -*)        die "issues: unknown flag '$1'." ;;
      *)         [ -z "$repo" ] && repo="$1" || die "issues: unexpected argument '$1'."; shift ;;
    esac
  done
  [ -n "$repo" ] || die "issues: a repo is required (registry short-id, owner/repo, or a repo name)."
  # resolve_repo, like every other repo-taking command (#446). This was the ONE that took the bare
  # name verbatim — so `issues game` asked for `repos/FS-GG/game` and 404'd, while `--repo game`
  # worked everywhere else. That is worse than a typo-class bug: `issues` is the command both skills
  # advertise as THE way to read issues without spending GraphQL, so the natural recovery from its
  # 404 is `gh issue list` — 2 points a call, which is precisely the budget the command exists to
  # save (#418).
  local O R
  if [[ "$repo" == */* ]]; then O="${repo%%/*}"; R="${repo#*/}"; else O="$OWNER"; R="$(resolve_repo "$repo")"; fi

  local path="repos/$O/$R/issues?state=$state&per_page=100"
  [ -n "$label" ] && path="$path&labels=$(printf '%s' "$label" | jq -sRr @uri | sed 's/%0A$//')"
  local key; key="$(slug "$path")"
  local bodyfile="$CACHE/issues-$key.body" etagfile="$CACHE/issues-$key.etag"

  local etag=""
  [ -z "$refresh" ] && [ -f "$etagfile" ] && [ -f "$bodyfile" ] && etag="$(cat "$etagfile")"

  local errf raw rc=0; errf="$(mktemp "$CACHE/.gh-err.XXXXXX")"
  # shellcheck disable=SC2086
  raw="$(gh api --include ${etag:+-H "If-None-Match: $etag"} "$path" 2>"$errf")" || rc=$?

  if [ "$rc" -ne 0 ]; then
    if { printf '%s' "$raw"; cat "$errf"; } | grep -qE 'HTTP[^0-9]*304|304 Not Modified'; then
      rm -f "$errf"
      [ -f "$bodyfile" ] || die "got 304 but no cached body for $O/$R — rerun with --refresh."
      dbg "issues $O/$R: 304 Not Modified — served from cache (0 REST cost)."
      emit_issues "$bodyfile" "$jqexpr"; return 0
    fi
    local msg; msg="$(tail -n1 "$errf" 2>/dev/null)"; rm -f "$errf"
    die "gh api failed for $path: $msg"
  fi
  rm -f "$errf"

  # Split gh --include output: headers, one blank (or bare-CR) line, then the JSON body.
  local newetag body
  newetag="$(printf '%s\n' "$raw" | grep -i '^etag:' | head -1 | sed 's/^[^:]*:[[:space:]]*//; s/[[:space:]]*$//')"
  body="$(printf '%s\n' "$raw" | sed '1,/^\r\{0,1\}$/d')"
  printf '%s' "$body" > "$bodyfile"
  [ -n "$newetag" ] && printf '%s' "$newetag" > "$etagfile"
  dbg "issues $O/$R: 200 OK — cached body + etag ($newetag)."
  emit_issues "$bodyfile" "$jqexpr"
}

# Print an issues body, optionally projected through a jq expression (trims context/tokens).
emit_issues() {
  local file="$1" expr="$2"
  if [ -n "$expr" ]; then jq -r "$expr" "$file"; else cat "$file"; fi
}

# ---- board_items: paginate the board, emit a normalized JSON array (thrifty per-item selection) --
# Projects v2 has NO server-side filter on the items connection, so "list the board" is inherently
# a full scan — but the node COST is set by what we select PER ITEM. `gh project item-list` nests
# `fieldValues(first:100){ ...fragments }` INSIDE `items(first:N)`, so its cost is O(items × 100)
# (≈ 2,500 points for a ~100-item board) — a few of those exhaust the 5,000-pt/hr primary budget.
# `fieldValueByName` is a RESOLVER field, not a connection: it returns ONE value with no node
# multiplication. We read just the three fields a "what's next" decision needs (Status, Phase,
# Blocked by) that way, plus the issue's own repository/number/title/state — a small constant per
# item. A 100-item page costs ~1 point (a full board ~3), and the result is normalized once here.
#
# `Blocked by` rides along for free: because the scan already carries every board item's `state`,
# a blocker's open/closed status is resolved CLIENT-SIDE against the same page set (board_annotate)
# — no per-blocker issue lookup, so blocked-awareness adds ZERO GraphQL calls.
board_items() {
  # CACHED=1 lets a SCHEDULING read (next/take/batch) reuse a scan another worker paid for, within
  # SCAN_TTL_SEC. Every other caller scans fresh — see the scan-cache note above for why that line
  # is where it is. FRESH=1 (`--fresh`) overrides from anywhere.
  if [ -n "${CACHED:-}" ] && [ -z "${FRESH:-}" ]; then
    local hit; if hit="$(scan_cache_get)"; then printf '%s' "$hit"; return 0; fi
  fi
  ensure_board >/dev/null
  local num; num="$(board_get '.number')"
  local q='query($owner:String!, $number:Int!, $cursor:String){
    organization(login:$owner){ projectV2(number:$number){
      items(first:100, after:$cursor){
        pageInfo{ hasNextPage endCursor }
        nodes{
          status: fieldValueByName(name:"Status"){ ... on ProjectV2ItemFieldSingleSelectValue{ name } }
          phase:  fieldValueByName(name:"Phase"){  ... on ProjectV2ItemFieldSingleSelectValue{ name } }
          blockedBy: fieldValueByName(name:"Blocked by"){ ... on ProjectV2ItemFieldTextValue{ text } }
          content{
            __typename
            ... on Issue{ number title url state repository{ nameWithOwner } }
            ... on PullRequest{ number title url state repository{ nameWithOwner } }
            ... on DraftIssue{ title }
          }
        }
      }
    } }
    rateLimit{ cost remaining }
  }'
  local cursor="" hasNext="true" out tmp
  tmp="$(mktemp "$CACHE/.items.XXXXXX")"; : > "$tmp"
  while [ "$hasNext" = "true" ]; do
    if [ -n "$cursor" ]; then
      out="$(gql "$q" -f owner="$OWNER" -F number="$num" -f cursor="$cursor")"
    else
      out="$(gql "$q" -f owner="$OWNER" -F number="$num")"
    fi
    jq -c '.data.organization.projectV2.items.nodes[]?
      | { number:(.content.number // null), repo:(.content.repository.nameWithOwner // null),
          title:(.content.title // null),   url:(.content.url // null),
          state:(.content.state // null),   type:(.content.__typename // null),
          status:(.status.name // null),    phase:(.phase.name // null),
          blockedBy:(.blockedBy.text // null) }' <<<"$out" >> "$tmp"
    hasNext="$(jq -r '.data.organization.projectV2.items.pageInfo.hasNextPage' <<<"$out")"
    cursor="$(jq -r '.data.organization.projectV2.items.pageInfo.endCursor // empty' <<<"$out")"
    [ "$hasNext" = "true" ] && [ -z "$cursor" ] && break   # defensive: stop if a page lies
  done
  # Annotate in two steps (#485 leg e): the scan can only resolve blockers that are ON the board, and a
  # PR never is — so those refs used to resolve to UNKNOWN and block their item FOREVER. Resolve them
  # server-side first, in ONE batched query, then annotate with that map in hand. Both the resolution
  # and the annotation are paid for once per scan and stored in the shared cache below, so this is one
  # query per TTL across every worker — not one per read.
  local raw extra scan
  raw="$(jq -s '.' "$tmp")"; rm -f "$tmp"
  extra="$(resolve_offboard_blockers "$raw")"
  scan="$(board_annotate "$extra" <<<"$raw")"
  # Store the ANNOTATED scan — every reader wants the blocker resolution, and re-deriving it per read
  # would make the cache a half-measure. Stored on every scan, whoever paid for it: the next worker
  # through the door reads it for free (that is the point — the cache dir is user-level, not per-worker).
  #
  # NEVER cache an EMPTY scan. `gql`'s die fires inside a `$( )` and signals the top-level shell, but
  # this subshell keeps running long enough to reach here with a zero-item board in hand — so a failed
  # read would write "the board is empty" into the cache and hand it, confidently, to the next 90
  # seconds of workers. That is #344's confident-empty-board, laundered through the cache. A genuinely
  # empty board just re-scans; that is the right price.
  [ "$(jq 'length' <<<"$scan")" -gt 0 ] 2>/dev/null && scan_cache_put "$scan"
  printf '%s' "$scan"
}

# ---- board_annotate: resolve each item's `Blocked by` refs against the scan itself ----------------
# Adds `.blockers` ([{ref,state}]) and `.blocked` (bool) to every item, spending no extra GraphQL:
# the scan already carries each board item's OPEN/CLOSED `state`, so a blocker that is itself a board
# item resolves from an in-memory index. States:
#   OPEN        -> still blocking.
#   CLOSED      -> resolved; does not block.
#   UNKNOWN     -> the ref is a real issue but is not ON the board, so we cannot see its state.
#   UNPARSEABLE -> legacy prose (the pre-gate resolution logs on Done cards), or a hand-edited value.
# UNKNOWN and UNPARSEABLE both count as blocking: refusing to hand out work whose prerequisite we
# cannot verify is the safe failure, and `next` says which it hit rather than silently skipping.
#
# Placeholder values ("-", "none", "n/a", "TBD") are read as NO BLOCKER: people typed them to mean
# "nothing blocks this" before the field meant anything, and reading them as UNPARSEABLE would make
# `next` refuse work that is in fact startable. Only the READ side is forgiving — `set-field` still
# refuses to write one (it tells you to clear the field instead), so they cannot spread.
board_annotate() {
  # $1 (optional): a JSON map of refs the SCAN could not resolve, resolved server-side —
  # {"FS-GG/.github#449": "MERGED", ...}. See resolve_offboard_blockers.
  #
  # RESOLVED MEANS CLOSED *OR* MERGED (#485 leg e, was #476). This used to be
  #
  #     blocked: ($blockers | any(.state != "CLOSED"))
  #
  # which is exactly right for an Issue — `IssueState` is only OPEN|CLOSED — and silently wrong for a
  # PullRequest, whose state is OPEN|CLOSED|**MERGED**. So a `Blocked by` naming a PR unblocked when
  # that PR was ABANDONED (closed unmerged) and stayed blocked FOREVER once it was MERGED. The gate
  # opened precisely when the blocking work was thrown away, and shut precisely when it was finished.
  #
  # `board_items` really does select `... on PullRequest { state }`, so MERGED genuinely reaches here.
  # Live on a critical path: FS.GG.SDD#350 is `Blocked by: FS-GG/.github#449` — the PR carrying the very
  # ADR that resolves it. Adding MERGED is strictly safe for issues, which are never MERGED.
  local extra="${1:-{\}}"
  jq --argjson extra "$extra" "$JQ_BLOCKER_RULE"'
    def placeholder: test("^(-+|—|–|none|n/?a|tbd|todo)$"; "i");
    def canon($owner; $selfrepo):
      if   test("^https?://github\\.com/[^/]+/[^/]+/issues/[0-9]+$")
      then (capture("^https?://github\\.com/(?<o>[^/]+)/(?<r>[^/]+)/issues/(?<n>[0-9]+)$") | "\(.o)/\(.r)#\(.n)")
      elif test("^[^/#[:space:]]+/[^/#[:space:]]+#[0-9]+$") then .
      elif test("^[^/#[:space:]]+#[0-9]+$")                 then "\($owner)/\(.)"
      elif test("^#[0-9]+$")                                then "\($selfrepo)\(.)"
      else null end;

    . as $all
    | ( $all | map(select(.number != null and .repo != null))
             | map({ key: "\(.repo)#\(.number)", value: (.state // "UNKNOWN") })
             | from_entries ) as $idx
    | $all
    | map(
        . as $it
        | ($it.repo // "")                            as $selfrepo
        | (($it.repo // "") | split("/") | first // "") as $owner
        | ( [ ($it.blockedBy // "") | split(",")[] | sub("^\\s+";"") | sub("\\s+$";"")
              | select(length > 0) | select(placeholder | not) ]
            | map( canon($owner; $selfrepo) as $c
                   | if $c == null then { ref: ., state: "UNPARSEABLE" }
                     # The board scan first, then the server-resolved map for refs the board never had
                     # (a PR is never a board item, so it could ONLY ever resolve to UNKNOWN — which
                     # counts as blocking, i.e. blocked-forever). UNKNOWN survives only when BOTH miss,
                     # and it still blocks: an unresolvable blocker is the safe direction.
                     else { ref: $c, state: ($idx[$c] // $extra[$c] // "UNKNOWN") } end )
            | unique_by(.ref) ) as $blockers
        | $it + { blockers: $blockers,
                  blocked: ([ $blockers[] | unresolved ] | length > 0) }
      )'
}

# ---- resolve_offboard_blockers: the refs the SCAN cannot see (#485 leg e) -------------------------
#
# `board_annotate` resolves a blocker against the scan, and the scan is THE BOARD. Two whole classes of
# blocker are therefore unresolvable by construction, and both starve the item forever:
#
#   * a PULL REQUEST — never a board item, so it can never appear in the index. This is the normal way
#     to reference blocking work, and it was the one guaranteed never to resolve.
#   * an ISSUE THAT IS NOT ON THE BOARD — filed but never placed (which is #485 leg c's whole subject).
#
# Both resolve to UNKNOWN, and UNKNOWN blocks. That is the right default for a thing you cannot see —
# but the fix is to LOOK, not to keep guessing.
#
# OVER REST, DELIBERATELY. GraphQL has `issueOrPullRequest`, which would answer this in one batched
# query — and that is the wrong budget. GraphQL is the scarce one, shared by every worker and drained
# by exactly this loop (#418); REST has its own, and `gh api repos/O/R/issues/N` serves PULL REQUESTS
# TOO (a PR is an issue in REST), carrying `pull_request.merged_at` — so one cheap call per unresolved
# ref answers both kinds AND distinguishes MERGED from CLOSED. Resolution is paid for once per scan and
# stored in the shared cache with it, so it is a handful of REST calls per TTL across every worker.
#
# $1: the raw (unannotated) scan.  stdout: {"owner/repo#n": "STATE", ...}, or {} if nothing to do.
resolve_offboard_blockers() {
  local raw="$1"
  # Two-pass: annotate with an empty map to reuse `canon` (ONE ref grammar, not two — re-deriving it
  # here would be a second implementation of the very thing this item is about), then take the refs it
  # could not resolve.
  local unknown
  unknown="$(board_annotate '{}' <<<"$raw" \
    | jq -r '[ .[].blockers[]? | select(.state == "UNKNOWN") | .ref ] | unique | .[]' 2>/dev/null || true)"
  [ -n "$unknown" ] || { printf '{}'; return 0; }

  # BOUND THE COST, AND SAY SO IF IT BITES. A board with hundreds of dangling refs must not turn one
  # scan into hundreds of reads — but a SILENT cap would leave the overflow blocked-forever with no
  # trace, which is the exact failure this function exists to remove (#266: no silent caps).
  local total; total="$(printf '%s\n' "$unknown" | grep -c . || true)"
  if [ "${total:-0}" -gt 60 ]; then
    printf 'fsgg-coord: %s off-board blocker refs; resolving the first 60. The rest stay UNKNOWN — which BLOCKS, so nothing is handed out wrongly, but those items need placing on the board.\n' "$total" >&2
    unknown="$(printf '%s\n' "$unknown" | head -60)"
  fi

  local ref o r num st merged out="{}"
  while IFS= read -r ref; do
    [ -n "$ref" ] || continue
    o="${ref%%/*}"; r="${ref#*/}"; num="${r##*#}"; r="${r%%#*}"
    case "$num" in ''|*[!0-9]*) continue ;; esac
    # A failed lookup must NOT become "unblocked": skip it, leaving the ref UNKNOWN, which blocks. That
    # is the same safe direction the old code reached by never looking at all.
    st="$(gh api "repos/$o/$r/issues/$num" \
            --jq 'if (.pull_request.merged_at // null) != null then "MERGED"
                  elif .state == "closed" then "CLOSED" else "OPEN" end' 2>/dev/null)" || continue
    [ -n "$st" ] || continue
    out="$(jq -c --arg k "$ref" --arg v "$st" '. + {($k): $v}' <<<"$out")"
  done <<<"$unknown"
  printf '%s' "$out"
}

# Resolve a --repo value to the actual GitHub repo name the board items carry. Accepts the registry
# short-id used everywhere else in the roster (sdd/rendering/governance/templates/game/audio, and
# .github via the literal fall-through — see registry/repos.yml), an `owner/repo`, or the literal
# repo name. Without this, `--repo templates` would silently match nothing (the repo is
# `FS.GG.Templates`, not `templates`) — a quiet footgun.
#
# This map is EMBEDDED, not read from registry/repos.yml at run time, because fsgg-coord is a
# `kind: client` kit item mirrored into every receiver repo (the four skills + this script) WITHOUT
# the roster — a worker in FS.GG.Rendering running `--repo game` has no registry/repos.yml to read.
# So the roster short-ids are duplicated here, and tests/fsgg-coord/ carries a coherence check
# that reads repos.yml (present in the .github checkout where CI runs) and FAILS if this case handles
# fewer ids than the roster rosters — turning "added a repo, forgot this map" from a silent empty
# queue (.github#381) into a red check. Adding a repo is a data change to repos.yml PLUS a one-line
# case here, and the guard makes forgetting the second half impossible.
resolve_repo() {
  case "$1" in
    */*)        printf '%s' "${1#*/}" ;;      # owner/repo -> repo part
    sdd)        printf '%s' "FS.GG.SDD" ;;
    rendering)  printf '%s' "FS.GG.Rendering" ;;
    governance) printf '%s' "FS.GG.Governance" ;;
    templates)  printf '%s' "FS.GG.Templates" ;;
    game)       printf '%s' "FS.GG.Game" ;;
    audio)      printf '%s' "FS.GG.Audio" ;;
    *)          printf '%s' "$1" ;;           # .github or an already-literal repo name
  esac
}

# Filter the normalized board array by repo/status/phase. Repo matches the issue's OWN repository:
# a value with '/' is matched against `owner/repo` exactly; a bare value against the repo part
# (both case-insensitive), so `--repo .github` selects `FS-GG/.github`.
board_filter() {
  local repo="$1" status="$2" phase="$3" exclude_done="$4"
  jq --arg repo "$repo" --arg status "$status" --arg phase "$phase" --arg xd "$exclude_done" '
    def repo_match($f): ($f|ascii_downcase) as $q
      | (.repo // "" | ascii_downcase) as $r
      | ($q=="") or ($r==$q) or (($r|split("/")|last // "")==$q);
    map(
      select($repo=="" or repo_match($repo))
      | select($status=="" or ((.status // "")|ascii_downcase)==($status|ascii_downcase))
      | select($phase=="" or ((.phase // "")|ascii_downcase|contains($phase|ascii_downcase)))
      | select(($xd!="1") or ((.status // "")!="Done"))
    )'
}

# Pretty TSV: STATUS | ITEM (repo#num, owner stripped) | PHASE | BLOCKED BY | TITLE. Draft items show
# `draft`/`-`. BLOCKED BY lists only the refs still holding the item (closed blockers are noise).
board_table() {
  jq -r "$JQ_BLOCKER_RULE"'.[]
    | ((.status // "—")) as $s
    | (if .number then ((.repo // "" | sub("^[^/]+/";"")) + "#" + (.number|tostring)) else "draft" end) as $item
    | ( [ (.blockers // [])[] | unresolved | (.ref | sub("^[^/]+/";"")) ]
        | if length == 0 then "—" else join(", ") end ) as $b
    | [ $s, $item, (.phase // "—"), $b, (.title // "") ] | @tsv' \
  | { printf "STATUS\tITEM\tPHASE\tBLOCKED BY\tTITLE\n"; cat; } | column -t -s $'\t'
}

# ---- ready: list board items that are actionable (not Done by default), thrifty full-board read --
ready() {
  local repo="" status="" phase="" all="" json="" jqexpr="" cached=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)    repo="${2:?--repo needs a value}"; shift 2 ;;
      --status)  status="${2:?--status needs a value}"; shift 2 ;;
      --phase)   phase="${2:?--phase needs a value}"; shift 2 ;;
      --all)     all=1; shift ;;
      --json)    json=1; shift ;;
      --jq)      jqexpr="${2:?--jq needs a value}"; shift 2 ;;
      --cached)  cached=1; shift ;;   # opt IN to the hot-read cache; `ready` is a truth read by default
      --fresh)   shift ;;             # accepted for symmetry with next/take — ready is already fresh
      -*)        die "ready: unknown flag '$1'." ;;
      *)         die "ready: unexpected argument '$1'." ;;
    esac
  done
  [ -n "$repo" ] && repo="$(resolve_repo "$repo")"
  local xd="1"; { [ -n "$all" ] || [ -n "$status" ]; } && xd="0"   # --all / --status widen past 'not Done'
  local items; items="$(CACHED="$cached" board_items | board_filter "$repo" "$status" "$phase" "$xd")"
  if   [ -n "$jqexpr" ]; then jq -r "$jqexpr" <<<"$items"
  elif [ -n "$json" ];   then jq '.' <<<"$items"
  else board_table <<<"$items"
  fi
}

# ---- next: print the single most-startable item (Ready, else Backlog), optionally repo-scoped ----
next() {
  local repo="" ignore_blocked="" fresh=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)            repo="${2:?--repo needs a value}"; shift 2 ;;
      --ignore-blocked)  ignore_blocked=1; shift ;;
      --fresh)           fresh=1; shift ;;    # bypass the hot-read cache (see the scan-cache note)
      -*)     die "next: unknown flag '$1'." ;;
      *)      die "next: unexpected argument '$1'." ;;
    esac
  done
  # "Why was each candidate skipped?" is a question about THIS repo's queue (#480). A `next` that
  # answers it over the whole org explains a queue the worker is not standing in — and is the very
  # command the recipe reaches for when `take` says there is nothing to do.
  repo="$(scope_repo "$repo")"
  [ -n "$repo" ] && repo="$(resolve_repo "$repo")"
  # ONE ANSWER TO "WHAT CAN I START?" (#485 leg a, was #431).
  #
  # `next` used to decide schedulability ITSELF, and it decided it DIFFERENTLY from `batch`: it filtered
  # on Status and `.blocked`, and nothing else. It never called `paths_of`, never called
  # `conflicts_between`, and never read a live claim marker. So it recommended items that `batch` — the
  # thing `take` actually schedules from — passes over as unschedulable, and it recommended them to the
  # one audience with no way to check: a human asking "what should I do next".
  #
  # Live, 6 workers in flight: every FS.GG.Rendering candidate was undeclared, so `take` reported "no
  # schedulable item" while `next` recommended #436 — which OVERLAPPED #453, held by a LIVE claim. It
  # was not merely optimistic; it pointed a worker at a collision the tool had already detected.
  #
  # So it is not a second implementation any more. `batch` IS the predicate — blockers, undeclared
  # touch-sets, unmatchable tokens, live claims, batch-mate overlaps — and `next` is its presentation
  # layer, exactly as `take` is its claiming layer. Ready first, then Backlog: the same two-step `take`
  # performs, so the two commands a worker treats as "what do I do next" can no longer disagree.
  local -a repoflag=(); [ -n "$repo" ] && repoflag=(--repo "$repo")
  local -a ignflag=();  [ -n "$ignore_blocked" ] && ignflag=(--ignore-blocked)
  local pickid
  # SCHEDULING read: a scan another worker paid for within the TTL is good enough, because the claim
  # CAS — not this list — is what decides who gets the item (#418).
  #
  # --fresh BUYS EXACTLY ONE SCAN. Spend it here, up front, and let everything below read the cache it
  # writes. `batch_cmd` reaches `board_items` TWICE — once for its candidates and once inside
  # `active_claims` — and the Ready/Backlog split is a CLIENT-SIDE filter over the same bytes, so
  # handing FRESH down into either call would rescan the whole board again. `next --fresh` would then
  # silently cost two or three full scans of the one budget #418 exists to protect.
  [ -n "$fresh" ] && CACHED=1 FRESH=1 board_items >/dev/null

  pickid="$(CACHED=1 batch_cmd "${repoflag[@]+"${repoflag[@]}"}" \
              "${ignflag[@]+"${ignflag[@]}"}" -n 1 --json | jq -r '.[0] // empty')"
  if [ -z "$pickid" ]; then
    pickid="$(CACHED=1 batch_cmd "${repoflag[@]+"${repoflag[@]}"}" \
                "${ignflag[@]+"${ignflag[@]}"}" --include-backlog -n 1 --json | jq -r '.[0] // empty')"
  fi
  # `batch --json` hands back the ID (`repo#n`) — that is the contract `take` reads. `next` prints a
  # human line, so resolve the id back to its board row through the SAME cached scan batch just used.
  local pick=""
  if [ -n "$pickid" ]; then
    pick="$(CACHED=1 board_items \
            | jq -c --arg id "$pickid" 'map(select(((.repo // "" | sub("^[^/]+/";"")) + "#" + ((.number // 0)|tostring)) == $id)) | .[0] // empty')"
  fi
  if [ -z "$pick" ]; then
    # `batch` has already said, on stderr and per item, WHY each candidate was passed over — in the
    # words of the check that actually passed it over (#440). Restating that as a guess is what the
    # old "every candidate was blocked" line did, and it was frequently just wrong.
    echo "fsgg-coord: no startable item (Ready/Backlog)${repo:+ for repo '$repo'} on board '$TITLE'." >&2
    return 0
  fi
  jq -r '"→ " + ((.repo // "" | sub("^[^/]+/";"")) + (if .number then "#"+(.number|tostring) else "" end))
    + "  [" + (.status // "—") + (if .phase then " · "+.phase else "" end) + "]\n  "
    + (.title // "") + (if .url then "\n  "+.url else "" end)' <<<"$pick"
}

# ---- lint_items: a board scan carrying each epic's CHILDREN, for the epic invariants -------------
# Separate from `board_items` on purpose: `ready`/`next` must stay as thin as possible, and only the
# lint needs sub-issue state. Cost is still 1 point per 100-item page — `subIssues` inside `items` does
# raise nodeCount (200 -> ~10,100 per page), but it buys every child's state in the SAME pagination,
# where the alternative is one follow-up query per epic. `first:100` on the children can truncate, so
# `totalCount` rides along and EPIC-CHILDREN-TRUNCATED fires rather than silently under-counting.
lint_items() {
  ensure_board >/dev/null
  local num; num="$(board_get '.number')"
  local q='query($owner:String!, $number:Int!, $cursor:String){
    organization(login:$owner){ projectV2(number:$number){
      items(first:100, after:$cursor){
        pageInfo{ hasNextPage endCursor }
        nodes{
          status: fieldValueByName(name:"Status"){ ... on ProjectV2ItemFieldSingleSelectValue{ name } }
          content{
            __typename
            ... on Issue{ number title state url body repository{ nameWithOwner }
              subIssues(first:100){ totalCount nodes{ number state repository{ nameWithOwner } } } }
          }
        }
      }
    } }
    rateLimit{ cost remaining }
  }'
  local cursor="" hasNext="true" out tmp
  tmp="$(mktemp "$CACHE/.lint.XXXXXX")"; : > "$tmp"
  while [ "$hasNext" = "true" ]; do
    if [ -n "$cursor" ]; then
      out="$(gql "$q" -f owner="$OWNER" -F number="$num" -f cursor="$cursor")"
    else
      out="$(gql "$q" -f owner="$OWNER" -F number="$num")"
    fi
    jq -c '.data.organization.projectV2.items.nodes[]?
      | select(.content.__typename == "Issue")
      | { repo:.content.repository.nameWithOwner, number:.content.number,
          title:(.content.title // ""), url:(.content.url // null),
          state:(.content.state // null), status:(.status.name // null),
          body:(.content.body // ""),
          childTotal:(.content.subIssues.totalCount // 0),
          children:[ .content.subIssues.nodes[]?
                     | { ref:"\(.repository.nameWithOwner)#\(.number)", state:.state } ] }' <<<"$out" >> "$tmp"
    hasNext="$(jq -r '.data.organization.projectV2.items.pageInfo.hasNextPage' <<<"$out")"
    cursor="$(jq -r '.data.organization.projectV2.items.pageInfo.endCursor // empty' <<<"$out")"
    [ "$hasNext" = "true" ] && [ -z "$cursor" ] && break
  done
  jq -s '.' "$tmp"; rm -f "$tmp"
}

# ---- lint: assert the board's epic invariants ----------------------------------------------------
# An "epic" is a card whose TITLE carries `[epic]` — Projects v2 issue types are unset across this
# board, so the title is the only marker the convention actually uses (docs/coordination README, the
# cross-repo-coordination skill: "Epics are the Phase parents; use sub-issues so progress rolls up").
#
#   EPIC-NO-CHILDREN        an OPEN `[epic]` with zero sub-issues. Nothing rolls up, and `next` will
#                           hand the epic itself out as work. This is the orphaned epic. Scoped to
#                           open epics because both harms need live work: rollup is how an epic
#                           REACHES Done, and `next` selects only open Ready/Backlog cards. A closed
#                           childless epic is finished work, not an orphan — linting it can never be
#                           acted on, and a check that stays red on completed work is not a gate.
#   EPIC-DONE-OPEN-CHILD    an epic the board calls Done while a child issue is still OPEN. The board
#                           claims finished work that is not finished. Deliberately NOT scoped to open
#                           epics: a CLOSED epic over an open child is the sharpest form of the bug.
#   EPIC-CHILDREN-TRUNCATED an epic with more than 100 children — the scan cannot see them all, so
#                           EPIC-DONE-OPEN-CHILD cannot be trusted for it. Fail loudly, never guess.
#   EPIC-UNLINKED-CHILD     an epic whose BODY declares a child (a `- [ ]`/`- [x]` line naming an
#                           issue) that is not in its sub-issue graph. Rollup reads the graph, so such
#                           a child is invisible to it and the epic can complete over an open child.
#                           Scoped to epics whose child list is not truncated — otherwise the missing
#                           children are an artifact of the scan, not of the link. A body ref that
#                           resolves to a PULL REQUEST is skipped, not flagged: GitHub refuses to link
#                           a PR as a sub-issue, so citing the PR that closed a checklist line is not
#                           an unlinked child (FS-GG/.github#346). Deliberately NOT scoped to OPEN
#                           epics (unlike EPIC-NO-CHILDREN): a CLOSED epic whose body declares an
#                           unlinked child that is itself still open is the one case EPIC-DONE-OPEN-
#                           CHILD cannot catch, because that child is absent from the graph it reads.
#                           Fix: `coord child`.
#
# A NOTE (not a failure) is printed for `Status: Done` on an issue that is still open: it is how the
# board legitimately looks between "the PR merged" and "someone closed the epic", so it fails only
# under --strict. `epic_rollup` no longer manufactures it (it requires children CLOSED, not merely
# board-Done), but a human flipping Status by hand still can.
lint() {
  local repo="" json="" strict=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)   repo="${2:?--repo needs a value}"; shift 2 ;;
      --json)   json=1; shift ;;
      --strict) strict=1; shift ;;
      -*)       die "lint: unknown flag '$1'." ;;
      *)        die "lint: unexpected argument '$1'." ;;
    esac
  done
  [ -n "$repo" ] && repo="$(resolve_repo "$repo")"

  local items findings
  items="$(lint_items)"
  findings="$(jq --arg repo "$repo" "$JQ_BODY_CHILD_REFS"'
    # touchset_decl (#496) -> null if the body declares NO touch-set at all (the omission NO-TOUCH-SET
    # fires on), "none" for the sentinel, otherwise the declared token string.
    #
    # It must skip FENCED lines, exactly as `paths_from_body` does. A `Paths:` line quoted inside a
    # ``` block is invisible to the scheduler — so an item whose only declaration is fenced really
    # does declare nothing, and a checker that counted it would report the item healthy while `take`
    # kept refusing it. That is the gate failing open on the one state it exists to catch (#277 is the
    # same trap on the write side). Same rule, both sides.
    def unfenced:
      (. // "") | split("\n")
      | reduce .[] as $l ({f:false, out:[]};
          if ($l | test("^\\s{0,3}(```|~~~)")) then .f = (.f | not)
          elif .f then .
          else .out += [$l] end)
      | .out;
    # THE SAME GRAMMAR THE SCHEDULER ENFORCES (#485 thesis, applied to the touch-set). `batch`
    # refuses a token that can match no file — a leading `**/`, a `*` in the middle — because a token
    # that matches nothing CONFLICTS with nothing, and would read as DISJOINT against every other
    # worker: the ADR-0021 failure, one level down. `lint` never applied that rule. It asked only
    # whether a `Paths:` line EXISTED. So an item whose every token is unmatchable reported
    # 0 error(s) from the one surface whose job is board health, while `batch` skipped it forever.
    #
    # That is #496 — lint was GREEN over a DEAD queue — reopened for the unmatchable case. The
    # distinction is machine-readable in BOTH surfaces now, because it is the same rule.
    def unmatchable: test("^\\*\\*/") or (test("[*?\\[]") and (test("/\\*\\*$") or test("/\\*$") | not));
    def touchset_decl:
      ( unfenced | map(select(test("^ {0,3}[Pp]aths:"))) ) as $lines
      | if ($lines | length) == 0 then null
        else ( $lines | map(sub("^ *[Pp]aths:\\s*"; "")) | join(" ")
               | gsub("`"; "") | gsub(","; " ") | ascii_downcase
               | gsub("\\s+"; " ") | ltrimstr(" ") | rtrimstr(" ") )
             | if . == "" then null else . end
        end;

    def repo_match($f): ($f|ascii_downcase) as $q
      | (.repo // "" | ascii_downcase) as $r
      | ($q=="") or ($r==$q) or (($r|split("/")|last // "")==$q);
    def short: sub("^[^/]+/";"");
    def is_epic: (.title // "") | test("\\[epic\\]"; "i");

    map(select($repo=="" or repo_match($repo)))
    | map(. + {id:"\(.repo)#\(.number)"})
    | [
        ( .[] | select(is_epic and .state == "OPEN" and .childTotal == 0)
          | { code:"EPIC-NO-CHILDREN", severity:"error", id:.id, status:.status, url:.url,
              detail:"open [epic] with zero sub-issues — nothing rolls up" } ),
        ( .[] | select(is_epic and .childTotal > (.children|length))
          | { code:"EPIC-CHILDREN-TRUNCATED", severity:"error", id:.id, status:.status, url:.url,
              detail:"\(.childTotal) sub-issues, only \(.children|length) visible — cannot verify rollup" } ),
        ( .[] | select(is_epic and .status == "Done" and (.children | any(.state == "OPEN")))
          | { code:"EPIC-DONE-OPEN-CHILD", severity:"error", id:.id, status:.status, url:.url,
              detail:"board says Done, but open child: \([.children[]|select(.state=="OPEN")|.ref|short]|join(", "))" } ),
        ( .[] | select(is_epic and .childTotal == (.children|length))
          | . as $e
          | ($e.body | body_child_refs($e.repo)) as $declared
          | ($declared - [ $e.children[].ref ]) as $unlinked
          | select($unlinked | length > 0)
          | { code:"EPIC-UNLINKED-CHILD", severity:"error", id:.id, status:.status, url:.url,
              unlinked:$unlinked,
              detail:"body declares child(ren) absent from the sub-issue graph, so rollup cannot see them: \([$unlinked[]|short]|join(", "))" } ),
        ( .[] | select(.status == "Done" and .state == "OPEN")
          | { code:"DONE-STATUS-OPEN-ISSUE", severity:"note", id:.id, status:.status, url:.url,
              detail:"board Status is Done but the issue is still open" } ),

        # NO-TOUCH-SET (#496) — the rule whose absence let `lint` report 0 errors over a DEAD queue.
        #
        # Every other rule here validates the epic ROLL-UP GRAPH. Not one asked the only question a
        # worker actually has: CAN ANYONE PICK THIS UP? A Ready/Backlog item with no `Paths:` is
        # refused by `batch`/`take` — correctly, an undeclared touch-set cannot be proven disjoint —
        # so it sits on the board looking like work and is invisible to every worker who asks for
        # work. Nine such items had accumulated in `.github` while this surface said `0 error(s)`.
        # That is the #266 shape (a gate green on a missing subject) in the one place whose whole
        # job is board health.
        #
        # `Paths: none` is the out, and it is the POINT: a touch-set-less item (an epic, a decision,
        # an investigation whose scope IS the question) is legitimate, but it must SAY so. Before the
        # sentinel, "deliberately undeclared" and "somebody forgot" rendered identically and no gate
        # could tell them apart — so no gate could be written at all.
        ( .[] | select(.number != null)
          | select(.state == "OPEN")
          | select(.status == "Ready" or .status == "Backlog")
          | select((.body | touchset_decl) == null)
          | { code:"NO-TOUCH-SET", severity:"error", id:.id, status:.status, url:.url,
              detail:"\(.status) but declares no `Paths:` — `batch`/`take` cannot schedule it, so no worker can ever pick it up. Declare a touch-set, or `Paths: none` if it genuinely has none (an epic, a decision item)." } ),
        # ...and an item that DECLARED a touch-set the scheduler cannot use is just as dead, and was
        # green. Same condition — "no worker can ever pick this up" — so it is the same severity.
        ( .[] | select(.number != null)
          | select(.state == "OPEN")
          | select(.status == "Ready" or .status == "Backlog")
          | select((.body | touchset_decl) != null)
          | select((.body | touchset_decl) != "none")
          | ( (.body | touchset_decl) | split(" ") | map(select(length > 0)) ) as $toks
          | ( $toks | map(select(unmatchable)) ) as $bad
          | select(($bad | length) > 0 and ($bad | length) == ($toks | length))
          | { code:"BAD-TOUCH-SET", severity:"error", id:.id, status:.status, url:.url,
              detail:"\(.status), and EVERY declared `Paths:` token is unmatchable: \($bad | join(", ")). A token that matches no file conflicts with nothing, so `batch` refuses it and no worker can ever pick this up — the item is as dead as one with no touch-set at all. Not a glob language: exact paths, directory prefixes, and a TRAILING `/**` or `/*`." } )
      ]' <<<"$items")"

  # A body-declared ref that resolves to a PR is not an unlinked child — a PR can never be a
  # sub-issue. Drop those before counting or printing, so the gate stops going red on an epic that
  # merely cites the PR that closed a checklist line (FS-GG/.github#346). Also strips the internal
  # `unlinked` scratch field, restoring the finding schema.
  findings="$(prune_pr_unlinked "$findings")"

  if [ -n "$json" ]; then jq '.' <<<"$findings"; else
    jq -r '.[] | "FSGG-LINT \(.severity|ascii_upcase)  \(.code)  \(.id|sub("^[^/]+/";""))  — \(.detail)"' <<<"$findings"
  fi

  local errors notes
  errors="$(jq '[.[] | select(.severity=="error")] | length' <<<"$findings")"
  notes="$(jq  '[.[] | select(.severity=="note")]  | length' <<<"$findings")"
  [ -n "$json" ] || printf 'fsgg-coord: %s error(s), %s note(s)%s\n' \
    "$errors" "$notes" "${repo:+ for repo '$repo'}" >&2
  { [ "$errors" -gt 0 ] || { [ -n "$strict" ] && [ "$notes" -gt 0 ]; }; } && return 1
  return 0
}

# ---- budget: read the GraphQL + REST meters. `gh api rate_limit` does not consume the core budget.
# It also reports what the meters cannot: how many board writes are QUEUED behind an exhausted budget
# (#418), and a WARNING while there is still budget left to act on. A meter you only read after the
# crash is an autopsy; the warning is the part that lets a fan-out stand down in time.
budget() {
  local out; out="$(gh api rate_limit --jq '{
    graphql: { remaining: .resources.graphql.remaining, limit: .resources.graphql.limit, resetAt: (.resources.graphql.reset|todate) },
    rest:    { remaining: .resources.core.remaining,    limit: .resources.core.limit,    resetAt: (.resources.core.reset|todate) }
  }')"
  local pend; pend="$(pending_count)"
  jq --argjson pending "$pend" '. + { pendingBoardWrites: $pending }' <<<"$out"

  local rem; rem="$(jq -r '.graphql.remaining' <<<"$out")"
  # 500 points ~= 70 full-board scans' worth of headroom on a 640-item board, or one worker's next
  # few minutes. Below it, a fan-out of workers is minutes from taking the writes down with it.
  if [ "$rem" -lt 500 ] 2>/dev/null; then
    echo "fsgg-coord: WARNING — GraphQL budget LOW ($rem/5000, resets in $(rate_reset_in))." >&2
    echo "  Stop fanning out workers. Reads that do not need Projects v2 have their own (REST) budget:" >&2
    echo "  'issues' over 'gh issue list', 'gh api repos/…' over 'gh pr view'. See docs/coordination/graphql-budget.md." >&2
  fi
  [ "$pend" -gt 0 ] && echo "fsgg-coord: $pend board write(s) QUEUED behind the budget — 'fsgg-coord flush' when it resets." >&2
  return 0
}

# ---- done: verify an item is truly finished (PR merged AND board Status=Done) and stamp it -------
# The green stamp is EARNED, not asserted: it prints ONLY after BOTH facts are confirmed in one
# thrifty query — the merge via issue -> closedByPullRequestsReferences, the board state via the
# issue's projectItems -> Status `fieldValueByName` resolver (no node multiplication). Any failing
# check prints a RED counter-stamp and exits non-zero, so a half-finished item can never masquerade
# as "still working" by printing nothing. `--flip` also sets Status=Done once the PR is merged (the
# step-4 "Land + record" close-out); the default is read-only verification. Both stamp lines carry a
# greppable sentinel (FSGG-DONE / FSGG-NOT-DONE) so scrollback and logs are searchable, not just
# eyeball-able by colour — and the banner degrades to plain (still greppable) when stdout is not a
# TTY or NO_COLOR is set.
banner() {   # $1=done|fail  $2=line1  $3=line2  — two full-width rows
  local kind="$1" l1="$2" l2="$3" cols on="" off=""
  cols="$(tput cols 2>/dev/null || echo 72)"; case "$cols" in ''|*[!0-9]*) cols=72 ;; esac
  [ "$cols" -ge 24 ] || cols=72
  if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    off=$'\033[0m'
    case "$kind" in done) on=$'\033[1;30;42m' ;; *) on=$'\033[1;97;41m' ;; esac   # black-on-green / white-on-red
  fi
  printf '%s%-*s%s\n' "$on" "$cols" "  $l1" "$off"
  printf '%s%-*s%s\n' "$on" "$cols" "  $l2" "$off"
}

# ---- body_child_refs: the epic's OTHER record of its children -------------------------------------
# `epic_rollup` and `lint` both need to ask "which children does this epic's BODY claim?", and two
# hand-copied regexes in two engines is precisely the drift surface this file warns about elsewhere.
# One definition, injected into both jq programs.
#
# A child is declared by a markdown TASK-LIST line — `- [ ]` / `- [x]` — that names an issue. The
# FIRST ref on the line is the child, so `- [x] (b) #268 — matched by substring (cf. #100)` declares
# #268 and not #100; prose, tables and links elsewhere in the body declare nothing. A ref may be
# `#n`, `owner/repo#n`, or a full issue URL, and all three canonicalize to `owner/repo#n` against
# the epic's own repo — the same form `lint_items` builds for the sub-issue graph, so the two sets
# are directly comparable.
#
# All THREE markdown bullets are accepted (`-`, `*`, `+`). GitHub renders a task list for each, so a
# matcher that knows only `-` would read an epic written with `+` as declaring NO children — and the
# gate below would wave it through. A gate that fails open on a formatting choice is the bug this
# whole epic is about.
# THE ONE BLOCKER RULE (#476, #485 leg e, #520). A blocker is RESOLVED iff it is CLOSED or MERGED.
#
# It was written out by hand in FOUR places, and after #476 fixed two of them, TWO STILL CARRIED THE
# PRE-#476 FORM (`state != "CLOSED"`, no MERGED clause): `board_table`'s BLOCKED BY column, and
# `take`'s "a BLOCKED queue, not an empty one" diagnostic. So `.blocked` computed false while the
# display and the diagnostic both named a MERGED pull request as the reason — sending a worker to go
# and look at FINISHED work, which is the exact reader-harm the blocker naming exists to prevent.
#
# That is #485's thesis one level down: a rule spelled out in N places agrees in N-1 at best. It is
# spelled ONCE now, and every site consumes this definition.
JQ_BLOCKER_RULE='def unresolved: select(.state != "CLOSED" and .state != "MERGED");'

JQ_BODY_CHILD_REFS='
def body_child_refs($self):
  (. // "") | split("\n")
  | map(select(test("^[ \t]{0,3}[-*+][ \t]+\\[[ xX]\\][ \t]")))
  | map([ scan("([A-Za-z0-9._-]+/[A-Za-z0-9._-]+)#([0-9]+)|https?://github\\.com/([^/[:space:]]+)/([^/[:space:]]+)/issues/([0-9]+)|#([0-9]+)") ] | first)
  | map(select(. != null))
  | map( if   .[0] then "\(.[0])#\(.[1])"
         elif .[2] then "\(.[2])/\(.[3])#\(.[4])"
         else "\($self)#\(.[5])" end )
  | unique;
'

# ---- ref_is_pr / drop_pr_refs / prune_pr_unlinked: a body-declared "child" that is really a PR ----
# `lint` (EPIC-UNLINKED-CHILD) and `epic_rollup` both take the epic's body refs MINUS its sub-issue
# graph and treat the remainder as unlinked children. But GitHub refuses to link a PULL REQUEST as a
# sub-issue, so a task-list line citing the PR that closed it — `- [x] … (PR #243)` — declares a ref
# the graph can NEVER hold. Left alone it wedges the gate red forever on genuinely-complete work, and
# a gate that is red on correct work is one people learn to ignore (FS-GG/.github#346, arriving at
# #266 from the other side). So re-resolve the OTHERWISE-UNLINKED refs — only that set, typically
# empty, so a healthy board pays nothing — and drop the ones GitHub reports as PRs.
#
# A ref that will not resolve (404, network, rate-limit) is KEPT, not dropped: per FS-GG/.github#266
# an unverifiable subject must not clear a gate, and "I could not check" is not "it is a PR". One
# REST call each (the separate 5,000/hr budget), and only for refs that would otherwise fail the gate.
ref_is_pr() {  # <owner/repo#n> — exit 0 iff GitHub confirms the ref is a pull request
  local ref="$1" o r n pr
  [[ "$ref" =~ ^([^/]+)/([^#]+)#([0-9]+)$ ]] || return 1
  o="${BASH_REMATCH[1]}"; r="${BASH_REMATCH[2]}"; n="${BASH_REMATCH[3]}"
  pr="$(gh api "repos/$o/$r/issues/$n" --jq '.pull_request.url // empty' 2>/dev/null)" || return 1
  [ -n "$pr" ]
}
drop_pr_refs() {  # filter refs on stdin (one per line) to those that are NOT pull requests
  local ref
  while IFS= read -r ref; do
    [ -n "$ref" ] || continue
    ref_is_pr "$ref" && continue
    printf '%s\n' "$ref"
  done
}
# Rewrite a lint findings array: drop PR refs from every EPIC-UNLINKED-CHILD, delete a finding left
# with no genuine unlinked child, and rebuild its detail line. Each ref is probed at most once.
prune_pr_unlinked() {  # <findings-json> -> findings-json
  local findings="$1" refs ref prs="" prjson
  refs="$(jq -r '[.[] | select(.code=="EPIC-UNLINKED-CHILD") | .unlinked[]] | unique[]?' <<<"$findings")"
  [ -n "$refs" ] || { printf '%s' "$findings"; return 0; }
  while IFS= read -r ref; do
    [ -n "$ref" ] || continue
    ref_is_pr "$ref" && prs="$prs$ref"$'\n'
  done <<<"$refs"
  prjson="$(printf '%s' "$prs" | jq -R -s 'split("\n") | map(select(length > 0))')"
  jq --argjson prs "$prjson" '
    def short: sub("^[^/]+/";"");
    map( if .code == "EPIC-UNLINKED-CHILD"
         then (.unlinked - $prs) as $u
              | if ($u | length) == 0 then empty
                else .unlinked = $u
                     | .detail = "body declares child(ren) absent from the sub-issue graph, so rollup cannot see them: " + ([$u[] | short] | join(", "))
                end
         else . end )
    | map(del(.unlinked))' <<<"$findings"
}

# ---- epic_rollup: after a child flips to Done, walk parents UPWARD and flip each epic whose children
# are now ALL board-Done AND CLOSED, stamping each one that rolls up. One thrifty query per level (subIssues +
# a Status resolver each); runs only from `done --flip`. Bounded to 10 levels as a cycle backstop.
# An already-Done epic is walked THROUGH silently (no re-stamp); a not-yet-complete epic prints a
# one-line progress note and stops the climb.
#
# The graph is AUTHORITATIVE for what rolls up; the body is the cross-check that the graph is not
# missing anyone. A child named in the body but absent from `subIssues` means the roll-up is counting
# fewer children than the epic itself claims to have — "all children Done" is then a statement about
# a set we know to be incomplete, and per FS-GG/.github#266 an unverifiable subject must not report
# green. We refuse, and name the unlinked children (FS-GG/.github#325).
epic_rollup() {
  local child="$1" boardnum depth=0 cur="$1"
  boardnum="$(board_get '.number')"
  local q='query($owner:String!, $repo:String!, $num:Int!){
    repository(owner:$owner, name:$repo){ issue(number:$num){
      parent{
        number url body repository{ nameWithOwner }
        projectItems(first:20){ nodes{ project{ number }
          status: fieldValueByName(name:"Status"){ ... on ProjectV2ItemFieldSingleSelectValue{ name } } } }
        subIssues(first:100){ totalCount nodes{ number state repository{ nameWithOwner }
          projectItems(first:20){ nodes{ project{ number }
            status: fieldValueByName(name:"Status"){ ... on ProjectV2ItemFieldSingleSelectValue{ name } } } } } }
      }
    } }
    rateLimit{ cost remaining }
  }'
  while [ "$depth" -lt 10 ]; do
    depth=$((depth + 1))
    parse_ref "$cur"
    local out; out="$(gql "$q" -f owner="$R_OWNER" -f repo="$R_REPO" -F num="$R_NUM")"
    jq -e '.data.repository.issue.parent != null' <<<"$out" >/dev/null 2>&1 || break

    local p_or p_num p_lbl
    p_or="$(jq -r '.data.repository.issue.parent.repository.nameWithOwner' <<<"$out")"
    p_num="$(jq -r '.data.repository.issue.parent.number' <<<"$out")"
    p_lbl="${p_or#*/}#$p_num"

    local p_onboard p_status total done
    p_onboard="$(jq -r --argjson pn "$boardnum" \
      '[.data.repository.issue.parent.projectItems.nodes[]? | select(.project.number==$pn)] | length' <<<"$out")"
    if [ "$p_onboard" = "0" ]; then
      printf '  epic %s: not on board — cannot roll up\n' "$p_lbl"; break
    fi
    p_status="$(jq -r --argjson pn "$boardnum" \
      '[.data.repository.issue.parent.projectItems.nodes[]? | select(.project.number==$pn) | .status.name] | first // ""' <<<"$out")"
    # A child counts as finished only when BOTH facts hold: the board says Done AND the issue is
    # actually CLOSED. Board-Done alone is not enough — `done --flip` sets Status=Done as soon as the
    # PR merges, and a merged PR does not necessarily close its issue. Trusting Status alone is what
    # flipped an epic to Done over a still-open child (FS-GG/.github#235).
    total="$(jq -r '[.data.repository.issue.parent.subIssues.nodes[]?] | length' <<<"$out")"
    local seen; seen="$(jq -r '.data.repository.issue.parent.subIssues.totalCount // 0' <<<"$out")"
    done="$(jq -r --argjson pn "$boardnum" \
      '[.data.repository.issue.parent.subIssues.nodes[]?
        | select(.state == "CLOSED")
        | ([.projectItems.nodes[]? | select(.project.number==$pn) | .status.name] | first // "")
        | select(. == "Done")] | length' <<<"$out")"
    # Truncation first: a child list the query could not see whole would make every set comparison
    # below (and the `unlinked` one especially) a guess.
    if [ "$seen" != "$total" ]; then
      printf '  epic %s: %s sub-issues, only %s visible — not rolling up (cannot verify)\n' \
        "$p_lbl" "$seen" "$total"; break
    fi
    # Now the graph is known-whole, so the body's claim can be checked against it. Declared-but-not-
    # linked means the roll-up would count a set it already knows is short. Refuse, and say who.
    local unlinked
    unlinked="$(jq -r --arg self "$p_or" "$JQ_BODY_CHILD_REFS"'
      .data.repository.issue.parent as $p
      | ($p.body | body_child_refs($self)) as $declared
      | [ $p.subIssues.nodes[]? | "\(.repository.nameWithOwner)#\(.number)" ] as $linked
      | ($declared - $linked)[]' <<<"$out")"
    # A body ref that is really a PR can never be a sub-issue, so it is not a missing child — dropping
    # it lets an epic that cites the PR which delivered a checklist line still roll up (.github#346).
    # An unresolvable ref is kept, so the rollup still refuses rather than guessing (#266).
    unlinked="$(printf '%s\n' "$unlinked" | drop_pr_refs)"
    if [ -n "$unlinked" ]; then
      # `paste -sd', '` would CYCLE the two delimiters (a,b c,d). Join on ',' and space it after.
      printf '  epic %s: body declares %s child(ren) the sub-issue graph does not contain — not rolling up: %s\n' \
        "$p_lbl" "$(printf '%s\n' "$unlinked" | wc -l | tr -d ' ')" \
        "$(printf '%s\n' "$unlinked" | paste -sd, - | sed 's/,/, /g')"
      printf '  link them, then re-run:  fsgg-coord child %s <issue>\n' "$p_lbl"
      break
    fi
    [ "$total" = "0" ] && break

    if [ "$done" != "$total" ]; then
      printf '  epic %s: %s/%s children Done+closed — holding (not rolling up)\n' "$p_lbl" "$done" "$total"; break
    fi
    if [ "$p_status" = "Done" ]; then
      dbg "epic_rollup: $p_lbl already Done — walking up"
    else
      # #510: a rolled-up epic whose board write the budget refused is QUEUED, and the banner says so
      # rather than asserting a `board: Done` that never landed.
      local erc=0
      board_write "$p_or#$p_num" Status Done || erc=$?
      banner done "✓✓ FSGG-DONE   $p_lbl (epic)" "all $total children Done + closed  ·  $BOARD_WRITE_NOTE"
      [ "$erc" = 0 ] || break   # the climb rests on THIS epic being Done; if it is only queued, stop.
    fi
    cur="$p_or#$p_num"
  done
}

# ---- child: link an issue as a native SUB-ISSUE of a parent --------------------------------------
# The edge `epic_rollup` walks is the sub-issue graph, and NOTHING else creates it. A `(j) child of
# #266` title, a `Child of #266` comment, a body checklist line — all of them LOOK like a link and
# none of them is one. That is how an epic got stamped Done thirty minutes after an open child of it
# was filed (FS-GG/.github#325).
#
# Two traps live in this endpoint, so they live in exactly one place. It wants the child's REST
# **id** (a large integer), not its issue number; and `gh api -f` would send that id as a JSON
# string, which the API rejects with a 422 — it must be `-F`, which types the value.
child_cmd() {
  local parent="" child=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -*) die "child: unknown flag '$1'." ;;
      *)  if   [ -z "$parent" ]; then parent="$1"
          elif [ -z "$child" ];  then child="$1"
          else die "child: unexpected argument '$1'."; fi; shift ;;
    esac
  done
  [ -n "$parent" ] && [ -n "$child" ] \
    || die "child: <parent> <issue> required (URL, owner/repo#n, or repo#n)."

  parse_ref "$parent"; local po="$R_OWNER" pp="$R_REPO" pn="$R_NUM"
  parse_ref "$child";  local co="$R_OWNER" cp="$R_REPO" cn="$R_NUM"

  local cid
  cid="$(gh api "repos/$co/$cp/issues/$cn" --jq '.id' 2>/dev/null)" \
    || die "child: cannot read $co/$cp#$cn — does it exist?"
  [ -n "$cid" ] || die "child: cannot read $co/$cp#$cn — does it exist?"

  # Idempotent by ID, not by number: two repos can each have an issue #7. Re-linking is success, so
  # a worker re-running the close-out never has to reason about whether the edge already exists.
  #
  # The read's exit status is KEPT. `2>/dev/null`-ing it would make "I could not reach the API" look
  # exactly like "the edge is not there" — we would POST, collect a 422, and blame the token. That is
  # the #266 defect (and #320's, precisely) reappearing inside the fix for it: an unreachable subject
  # must not be reported as an absent one.
  local existing rc=0
  existing="$(gh api "repos/$po/$pp/issues/$pn/sub_issues" --paginate --jq '.[].id')" || rc=$?
  [ "$rc" -eq 0 ] \
    || die "child: cannot read $pp#$pn's sub-issues (rc=$rc) — refusing to guess whether $cp#$cn is already linked."
  if printf '%s\n' "$existing" | grep -qx "$cid"; then
    printf 'child: %s#%s is already a sub-issue of %s#%s — nothing to do\n' "$cp" "$cn" "$pp" "$pn"
    return 0
  fi

  # Surface gh's own diagnosis rather than guessing one: a 422 (already linked, or a cross-repo link
  # GitHub refuses) and a 403 (no `issues: write`) are different problems with different fixes.
  local err
  err="$(gh api "repos/$po/$pp/issues/$pn/sub_issues" -F sub_issue_id="$cid" 2>&1 >/dev/null)" \
    || die "child: could not link $cp#$cn under $pp#$pn — $err"
  printf 'linked %s#%s as a sub-issue of %s#%s  ·  `done --flip` can now see it\n' "$cp" "$cn" "$pp" "$pn"
}

done_cmd() {
  local ref="" pr="" flip=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --pr)   pr="${2:?--pr needs a value}"; shift 2 ;;
      --flip) flip=1; shift ;;
      -*)     die "done: unknown flag '$1'." ;;
      *)      [ -z "$ref" ] && ref="$1" || die "done: unexpected argument '$1'."; shift ;;
    esac
  done
  [ -n "$ref" ] || die "done: <issue> required (URL, owner/repo#n, or repo#n)."
  [ -z "$pr" ] || case "$pr" in *[!0-9]*) die "done: --pr must be a number." ;; esac
  parse_ref "$ref"
  ensure_board >/dev/null
  local boardnum; boardnum="$(board_get '.number')"

  # ONE query gets every fact the stamp needs: the merge, what GitHub says CLOSED the issue, the
  # item's own children, and the board Status.
  #
  # `timelineItems(CLOSED_EVENT).closer` — WHAT ACTUALLY CLOSED THIS ISSUE, per GitHub (#558/#543).
  #   `closingIssuesReferences` is populated ONLY from the PR BODY, and ONLY while the PR is open.
  #   `gh pr create --fill` — which pnext-item §5 prescribes — maps the commit SUBJECT to the PR
  #   TITLE, so the near-universal `fix: the thing (closes #165)` convention puts the keyword exactly
  #   where that field never looks. The squash commit still closes the issue (GitHub honours it), so
  #   the work lands, the PR merges, the issue closes, the board flips — and the stamp goes RED.
  #   Permanently: editing the merged PR's body does NOT backfill the link; the window shuts at merge.
  #   A red stamp that fires reproducibly on correct, merged, green work, from a standard commit
  #   convention, is the fastest way to teach every worker that red stamps are noise. `closer` is
  #   GitHub's OWN record of the closing act — a STRONGER signal than a body reference, not a weaker
  #   one, and it needs no regex over a commit message.
  #
  # `subIssues` — THE ITEM'S OWN CHILDREN (#583). `epic_rollup` walks the graph of the item's PARENT
  #   and never asks the same question of the item in hand. So `done --flip` stamped an item Done and
  #   closed it over an OPEN sub-issue carrying one of its own acceptance criteria — the #322 failure,
  #   in the command written to prevent it. It fires on the COMMON case: pnext-item §4 tells a worker
  #   to split off what they cannot land and `child`-link it, so the more faithfully a worker splits
  #   their work, the more reliably they close a parent over it. A green stamp over unfinished work is
  #   a board that lies, which the recipe names as the one thing worse than an unstamped item.
  local q='query($owner:String!, $repo:String!, $num:Int!){
    repository(owner:$owner, name:$repo){ issue(number:$num){
      number title url state
      closedByPullRequestsReferences(first:10, includeClosedPrs:true){
        nodes{ number url merged mergedAt mergeCommit{ abbreviatedOid }
          closingIssuesReferences(first:10){ nodes{ number repository{ nameWithOwner } } } }
      }
      timelineItems(last:10, itemTypes:[CLOSED_EVENT]){
        nodes{ ... on ClosedEvent { closer{
          __typename
          ... on PullRequest{ number }
          ... on Commit{ oid associatedPullRequests(first:5){ nodes{ number } } }
        } } }
      }
      subIssues(first:100){ totalCount nodes{ number state repository{ nameWithOwner } } }
      projectItems(first:20){ nodes{
        project{ number title }
        status: fieldValueByName(name:"Status"){ ... on ProjectV2ItemFieldSingleSelectValue{ name } }
      } }
      parent{ number }
    } }
    rateLimit{ cost remaining }
  }'
  local out; out="$(gql "$q" -f owner="$R_OWNER" -f repo="$R_REPO" -F num="$R_NUM")"
  jq -e '.data.repository.issue != null' <<<"$out" >/dev/null 2>&1 \
    || die "issue $R_OWNER/$R_REPO#$R_NUM not found (or no read access)."

  local item_lbl="$R_REPO#$R_NUM"

  # board membership + Status (empty if the issue isn't on THIS board)
  local onboard status
  onboard="$(jq -r --argjson pn "$boardnum" \
    '[.data.repository.issue.projectItems.nodes[]? | select(.project.number==$pn)] | length' <<<"$out")"
  status="$(jq -r --argjson pn "$boardnum" \
    '[.data.repository.issue.projectItems.nodes[]? | select(.project.number==$pn) | .status.name] | first // ""' <<<"$out")"

  # THE CLOSING PR — ONE definition of provenance, and BOTH paths use it.
  #
  # `closedByPullRequestsReferences` also lists PRs that merely MENTION the issue in prose (our
  # "Filed, not fixed: #N" convention is exactly this), and GitHub returns them lowest-number-first —
  # so taking the first merged one stamped the wrong commit, or stamped green off an unrelated merge
  # that never touched the work (.github#342). Provenance, not just outcome.
  #
  # A PR CLOSES this issue if EITHER of GitHub's own records says so. Both are records of the closing
  # act; neither is a mention:
  #
  #   (A) its `closingIssuesReferences` contains THIS issue — the `Closes #N` in the PR BODY; or
  #   (B) GitHub's own CLOSED_EVENT names it as the `closer` — directly, or as the PR associated with
  #       the commit that closed it. This is the leg that was missing (#558/#543): the recipe's own
  #       `gh pr create --fill` routes a closing keyword in the commit SUBJECT to the PR TITLE, where
  #       (A) cannot see it — so a correctly-merged, correctly-closed item was PERMANENTLY unstampable,
  #       and the worker was told (correctly) not to hand-set Status to fix it.
  #
  # `--pr` USED TO SKIP THIS ENTIRELY — it selected by NUMBER alone (#543 leg 2), so the documented
  # escape hatch from the bug above was a soundness hole that reintroduced #342: point it at any
  # merged PR that merely mentions the issue and the stamp went green. It is a HUMAN OVERRIDE OF WHICH
  # PR, NEVER OF WHETHER IT CLOSED THE ISSUE. Same predicate, both paths.
  local JQ_CLOSERS='
    def closer_prs:
      [ .data.repository.issue.timelineItems.nodes[]?
        | .closer
        | select(. != null)
        | if .__typename == "PullRequest" then .number
          elif .__typename == "Commit" then (.associatedPullRequests.nodes[]?.number)
          else empty end ];
    def closes_this($num; $repo): . as $pr
      | ( [ $pr.closingIssuesReferences.nodes[]?
            | select(.number==$num and .repository.nameWithOwner==$repo) ] | length > 0 );'

  local prsel
  if [ -n "$pr" ]; then
    prsel="$(jq -c --argjson prn "$pr" --argjson num "$R_NUM" --arg repo "$R_OWNER/$R_REPO" "$JQ_CLOSERS"'
      (closer_prs) as $closers
      | [ .data.repository.issue.closedByPullRequestsReferences.nodes[]?
          | select(.number==$prn)
          | select( (. | closes_this($num; $repo)) or ([$closers[] | select(. == $prn)] | length > 0) ) ]
      | first // null' <<<"$out")"
  else
    prsel="$(jq -c --argjson num "$R_NUM" --arg repo "$R_OWNER/$R_REPO" "$JQ_CLOSERS"'
      (closer_prs) as $closers
      | [ .data.repository.issue.closedByPullRequestsReferences.nodes[]?
          | select(.merged==true)
          | . as $p
          | select( ($p | closes_this($num; $repo)) or ([$closers[] | select(. == $p.number)] | length > 0) ) ]
      | sort_by(.mergedAt) | last // null' <<<"$out")"
  fi
  local merged prnum prsha prday
  merged="$(jq -r '.merged // false' <<<"$prsel")"
  prnum="$(jq -r '.number // ""' <<<"$prsel")"
  prsha="$(jq -r '.mergeCommit.abbreviatedOid // ""' <<<"$prsel")"
  prday="$(jq -r '(.mergedAt // "")[0:10]' <<<"$prsel")"

  # decide — every non-Done outcome is a red stamp + non-zero exit
  if [ "$onboard" = "0" ]; then
    banner fail "✗✗ FSGG-NOT-DONE   $item_lbl" \
                "not on board '$TITLE' — add it, then rerun"; return 1
  fi
  if [ "$merged" != "true" ]; then
    local why="no merged PR closes this issue"
    [ -n "$pr" ] && why="PR #$pr does not close this issue (it must be merged, and either name it in the PR body or be what GitHub recorded as closing it)"
    banner fail "✗✗ FSGG-NOT-DONE   $item_lbl" \
                "$why  ·  board: ${status:-unset}"; return 1
  fi

  # THIS ITEM'S OWN CHILDREN (#583). `epic_rollup` asks this of the item's PARENT and never of the
  # item in hand, so a worker who followed pnext-item §4 — split off what you cannot land, `child`-link
  # it — closed the parent over the split-out criterion, with a green ✓✓ actively saying otherwise.
  # A red stamp is a finding; a GREEN stamp over unfinished work is a board that lies.
  local kids_seen kids_total kids_open
  kids_total="$(jq -r '[.data.repository.issue.subIssues.nodes[]?] | length' <<<"$out")"
  kids_seen="$(jq -r '.data.repository.issue.subIssues.totalCount // 0' <<<"$out")"
  # Truncation FIRST: a child list we could not see whole makes "no open children" a statement about a
  # set we already know is incomplete — an unverifiable subject must not report green (#266).
  if [ "$kids_seen" != "$kids_total" ]; then
    banner fail "✗✗ FSGG-NOT-DONE   $item_lbl" \
                "$kids_seen sub-issue(s), only $kids_total visible — cannot verify they are finished"
    return 1
  fi
  kids_open="$(jq -r '[.data.repository.issue.subIssues.nodes[]? | select(.state != "CLOSED")
                       | "\(.repository.nameWithOwner | sub("^[^/]+/";""))#\(.number)"] | join(", ")' <<<"$out")"
  if [ -n "$kids_open" ]; then
    banner fail "✗✗ FSGG-NOT-DONE   $item_lbl" \
                "merged PR #$prnum, but this item has OPEN sub-issue(s): $kids_open"
    printf '  the work is not finished until they are. Close them, or move them out from under this\n' >&2
    printf '  item (`Blocked by` sequences; a sub-issue is a PART OF).\n' >&2
    return 1
  fi

  if [ "$status" != "Done" ]; then
    if [ -n "$flip" ]; then
      dbg "done: PR #$prnum merged — flipping board Status -> Done"
      # The stamp attests the WORK; the board write is a separate fact. If the budget refused the
      # write it is now QUEUED (#510) — so keep the stamp green (the work IS done and saying otherwise
      # is how a red stamp becomes noise, #558) but say plainly that the board does not know yet, and
      # exit EX_RATE so a worker loop backs off and flushes instead of believing the board.
      local wrc=0
      board_write "$ref" Status Done || wrc=$?
      if [ "$wrc" = 0 ]; then
        status="Done"
      else
        banner done "✓✓ FSGG-DONE   $item_lbl" \
                    "merged PR #$prnum @ ${prsha:-?}${prday:+ ($prday)}  ·  $BOARD_WRITE_NOTE"
        return "$wrc"
      fi
    else
      banner fail "✗✗ FSGG-NOT-DONE   $item_lbl" \
                  "merged PR #$prnum @ ${prsha:-?}  ·  board: '${status:-unset}' != Done  ->  rerun with --flip"
      return 1
    fi
  fi
  # A COMPLETED ITEM MUST NOT KEEP ITS LOCK (#533). `done --flip` verified the merge, set Status,
  # and rolled up the epic — and never touched the claim marker. `release` was the only path that
  # dropped it, and `release` REWRITES Status, so running it on an item you just stamped Done clobbers
  # the stamp you just earned. `pnext-item` §6 removes the worktree and never mentions the claim; the
  # only place `release` appears in the recipe is the ABANDON path. So on the SUCCESS path there was
  # no action, in the tool or in the recipe, that dropped the lock.
  #
  # The marker stayed live for the rest of the 120m lease, and a live marker's `Paths:` keep reserving
  # its touch-set. The items most likely to overlap a just-finished item are its own FOLLOW-UP
  # findings — the ones §4 tells you to file precisely BECAUSE you were standing in those files. So
  # the recipe reliably produced an item its own author had locked out for two hours, and `take`
  # reported a dead queue over it. The worker who filed #533 cleared it by hand-deleting their own
  # marker comment over REST: a hand-fix of protocol state that no worker should have to invent.
  #
  # The claim's lifetime is the WORK's lifetime. The work is done, so the claim is done.
  # BEST-EFFORT, and deliberately so. The stamp is EARNED — the PR merged, the children are closed,
  # the board write landed. A claim marker we could not read or delete is a cleanup we owe, not a
  # reason to retract a verdict we already reached. `soft_run` keeps `claims_of`'s fail-closed `die`
  # (correct in its own right: an unreadable claim set must never read as "nobody holds this") from
  # unwinding a legitimately earned stamp.
  local done_claim done_holder
  done_claim="$(soft_run claims_of "$R_OWNER" "$R_REPO" "$R_NUM" 2>/dev/null | jq -c 'map(select(.stale | not)) | .[0] // empty' 2>/dev/null || true)"
  if [ -n "$done_claim" ]; then
    done_holder="$(jq -r '.worker' <<<"$done_claim")"
    if [ "$done_holder" = "$(worker)" ]; then
      if delete_comment "$R_OWNER" "$R_REPO" "$(jq -r '.id' <<<"$done_claim")" 2>/dev/null; then
        dbg "done: dropped our own claim marker on $item_lbl (#533)"
      else
        echo "fsgg-coord: WARNING — the item is Done but its claim marker could NOT be deleted. It will keep reserving $(jq -r '.paths // [] | join(" ")' <<<"$done_claim") until the lease expires. Drop it with: fsgg-coord release $ref --status Done" >&2
      fi
    else
      # Not ours to delete. Say so — a finished item held by somebody else is worth a human look.
      echo "fsgg-coord: note — $item_lbl is Done, but worker '$done_holder' still holds its claim; their touch-set stays reserved until the lease expires. If that is stale, run: fsgg-coord reap --repo $R_REPO --apply" >&2
    fi
  fi

  banner done "✓✓ FSGG-DONE   $item_lbl" \
              "merged PR #$prnum @ ${prsha:-?}${prday:+ ($prday)}  ·  board: Done"
  # Roll the completion up: if this item is a sub-issue and --flip is in play, flip any parent epic
  # whose children are now ALL board-Done (and its parent, transitively). Only bother when a parent
  # exists (cheap probe above) so non-epic items pay nothing.
  local has_parent; has_parent="$(jq -r '.data.repository.issue.parent.number // ""' <<<"$out")"
  [ -n "$flip" ] && [ -n "$has_parent" ] && epic_rollup "$ref"

  # PUBLISH THE SHADOW EVIDENCE HERE, BECAUSE ASKING DID NOT WORK (#656).
  #
  # The kit asked every worker to run `divergence --publish` at the end of its loop — in the canonical
  # doc and in both skill roots. Measured against a live fleet of 28 workers and 597 compared
  # item-verdicts: it was run ZERO times. Not once, by anybody, including by the worker who wrote it.
  # ASKING IS NOT A MECHANISM. A request at the end of a long recipe, competing with the worker actual
  # job, is what an 0% hit rate looks like.
  #
  # So it happens HERE — in the one command every worker runs when it finishes an item. No new step in
  # the recipe, no discipline required, nothing to remember.
  #
  # AND IT MAY NEVER COST A WORKER THEIR DONE-STAMP. This runs AFTER the green banner and after the
  # roll-up: the stamp is already earned and printed. A publish that fails — no network, an exhausted
  # REST budget, a ledger issue somebody renamed — is a publish that failed, and it is not a reason to
  # tell a worker that their merged, green, rolled-up work is not done. Advisory, silent on the happy
  # path, and its failure is swallowed on purpose.
  #
  # Idempotent by construction: the ledger row is keyed on (worker, day, engine) and REWRITTEN in place,
  # so publishing on every `done` costs one REST call and cannot double-count a day.
  done_publish_evidence

  return 0
}

# The shadow evidence, published as a side effect of finishing work (#656). Never fails its caller.
#
# Silent unless it did something. A worker with no evidence — no engine, or a shadow that never compared
# anything — has nothing to say, and saying so on every `done` is noise that trains people to stop reading
# the output of the one command that carries their DONE-STAMP.
done_publish_evidence() {
  [ -s "$DIVERGENCE_LOG" ] || return 0

  # `soft_run`, NOT a bare `$( )`. A `die` in this tool is FATAL BY DEFAULT — `die_rc` ends in
  # `kill -s TERM $$`, which takes the whole shell down, and a command substitution does NOT contain it.
  # `soft_run` sets SOFT_DIE=1 so the die unwinds only its own subshell and its chosen exit code comes
  # back as an ordinary rc. That is the mechanism this file already uses everywhere a die must be
  # survived (`soft_run claim_cmd`, `soft_run set_field`).
  #
  # Getting this wrong is not academic: the ledger issue being unreadable would have killed the worker
  # `done` MID-STAMP — the exact thing the comment above promises it cannot do. It did, until this line.
  local out rc=0
  out="$(soft_run divergence_publish 2>&1)" || rc=$?
  case "$rc" in
    0) printf '%s\n' "$out" | grep -E '^fsgg-coord: published' || true ;;
    3) : ;;                                   # nothing worth publishing. The honest answer, and not news.
    *) echo "fsgg-coord: note — could not publish the shadow divergence evidence to the fleet ledger." >&2
       echo "  Your work is DONE and stamped; this is bookkeeping. The evidence is still in your local" >&2
       echo "  log, and the next done will republish it. To see why: fsgg-coord divergence --publish" >&2
       ;;
  esac
  return 0
}

# ---- claim: the intra-repo work lock, keyed on the WORKER (ADR-0027 supersedes ADR-0021 §1) -------
# ADR-0021 locked on the issue ASSIGNEE. Under same-account fan-out that lock is a no-op: `@me` is one
# principal for every agent, so a sibling's claim reads back as our own and both workers proceed. The
# assignee remains — it is what a HUMAN sees on the board — but it is no longer the lock.
#
# The lock is a `fsgg:claim` marker comment, resolved by COMMENT-ORDER COMPARE-AND-SWAP:
#
#   1. read the live markers; refuse (or --force steal) if another worker holds one
#   2. post our own marker
#   3. RE-READ, and take the LOWEST live marker id as the winner
#   4. if that isn't us, delete our marker and back off
#
# Step 3 is why this is a real lock and the assignee never was. GitHub issues comment ids from one
# server-side sequence, so the "lowest id" is a TOTAL ORDER every racer observes identically: a
# simultaneous claim has exactly ONE winner, and the losers know they lost. ADR-0021's assignee
# protocol could only make both racers back off (livelock) or, same-account, let both through.
#
# The lease (`updated_at` on the marker, vs FSGG_CLAIM_LEASE_MIN) makes a dead worker's claim
# collectable — see `reap`. The Status flip stays best-effort: an item not yet on the board still
# claims, because the marker, not the board, is the lock.
claim_cmd() {
  local ref="" force=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --force) force=1; shift ;;
      -*)      die "claim: unknown flag '$1'." ;;
      *)       [ -z "$ref" ] && ref="$1" || die "claim: unexpected argument '$1'."; shift ;;
    esac
  done
  [ -n "$ref" ] || die "claim: <issue> required (URL, owner/repo#n, or repo#n)."
  parse_ref "$ref"
  worker >/dev/null; local w="$WORKER_ID"

  # Refuse to take the lock on an item whose declared touch-set reserves nothing. Holding it would
  # make our own files invisible to every other worker's overlap check — the collision this protocol
  # exists to prevent, entered voluntarily. An item with NO `Paths:` stays claimable (it declares
  # nothing and claims nothing); one that declares an unmatchable token is claiming to have declared.
  #
  # ASSIGN FIRST, then validate. `paths_of` fails closed by calling `die` when the body read fails —
  # but `die` is an `exit`, and an `exit` inside `$( )` kills only the substitution subshell. Passing
  # `"$(paths_of …)"` straight as an argument would print "refusing to schedule against an unknown
  # touch-set" on stderr and then claim the item anyway, exit 0 — reintroducing, in the guard itself,
  # the fail-open this guard exists to close. The assignment form propagates the exit under `set -e`,
  # which is how `overlap` (`pa="$(paths_for_ref …)"`) already gets it right.
  local declared_paths; declared_paths="$(paths_of "$R_OWNER" "$R_REPO" "$R_NUM")"
  die_on_invalid_paths "$declared_paths" "claim: $R_REPO#$R_NUM"

  # ORDER MATTERS. The item-level refusal above comes FIRST: "this item is unclaimable BY ANYONE"
  # is a stronger and cheaper statement than "you already hold something", and a worker who is told
  # the second when the first is also true will fix the wrong thing.
  # AT MOST ONE ITEM PER WORKER (#516). The CAS is keyed on the ITEM, so it guarantees at most one
  # worker per item. NOTHING guaranteed the converse — and the protocol's whole cost model assumes it.
  #
  # This is #419/ADR-0027 turned inside out. That family is N workers colliding on ONE id; this is one
  # id holding N items, and the remedy for the first ("give every worker its own id") does nothing for
  # the second. The lock's asymmetry is the point: the CAS protects the item, so the item is what it
  # protects. Nobody was protecting the worker.
  #
  # And it is not untidy bookkeeping. A claim RESERVES A TOUCH-SET (parallel-work.md §3), so a second,
  # unattended claim is a live lock on files nobody is editing, held for the full lease, and `batch`
  # will refuse to schedule anything overlapping it. One worker's slip silently costs every OTHER
  # worker two hours of a contended path — and in this repo `scripts/fsgg-coord` IS that path (#428).
  # It also makes `who` — which reads as "who is working what, right now" — simply wrong.
  #
  # The worker who found it found it BY DOING IT: two `take`s, both succeeded, neither said a word.
  if [ -z "$force" ]; then
    local held_elsewhere
    # CACHED=1: ride the shared scan cache. `active_claims` needs a board scan to enumerate repos, and
    # a claim is on the HOT path — #418 is the whole reason this client exists, and paying a fresh
    # board scan per claim is exactly the burn it was written to stop. Under `take` the scan is already
    # paid (batch just did it), so this costs ZERO; a bare `claim` rides the 90s window like `next`.
    # A stale-by-90s claim set cannot cause a double-hold here: it can only fail to notice OUR OWN
    # very recent second claim, and the CAS on the item still protects the item itself.
    held_elsewhere="$(CACHED=1 soft_run active_claims "$R_OWNER/$R_REPO" 2>/dev/null \
      | jq -r --arg w "$w" --argjson n "$R_NUM" '
          [ .[] | select(.worker == $w) | select(.state == "held") | select(.number != $n)
            | "\(.repo | sub("^[^/]+/";""))#\(.number)" ] | join(", ")' 2>/dev/null || true)"
    if [ -n "$held_elsewhere" ]; then
      die "claim: worker '$w' ALREADY HOLDS $held_elsewhere. A claim reserves a touch-set, so a second one locks files nobody is editing for the rest of the lease (${CLAIM_LEASE_MIN}m) — and \`batch\` will refuse every item that overlaps it (#516).
  Finish or drop the item you hold:  fsgg-coord done <issue> --flip   (or: fsgg-coord release <issue>)
  If you genuinely mean to hold two, say so:  fsgg-coord claim $ref --force"
    fi
  fi


  local claims live stale mine others
  claims="$(claims_of "$R_OWNER" "$R_REPO" "$R_NUM")"

  # The pre-claim Status this item's EXISTING claim (if any) already recorded — read BEFORE the GC
  # below deletes those markers, because it deletes the record along with the comment (#481). Without
  # this, `claim` over an expired claim reads a column that already says `In progress`, concludes
  # nothing was overwritten, and the Backlog the FIRST claim overwrote is lost for good — so a
  # reaped-then-reclaimed item still comes back `Ready`. Lowest marker id first: `parse_claims` sorts
  # by id, and the oldest claim is the one that did the overwriting. Inherited by a `--force` steal
  # and a re-claim for exactly the same reason.
  local prev_claimed
  prev_claimed="$(jq -r 'map(select(.prev != "")) | .[0].prev // ""' <<<"$claims")"

  # GARBAGE-COLLECT dead markers before deciding anything. A stale marker that is merely *ignored*
  # survives, and `heartbeat` would later renew it back to life underneath whoever claimed next —
  # two live markers, two workers, one item. Collect it here (telling its worker), so that after this
  # point "live" and "exists" mean the same thing. This also covers our OWN stale marker, so a slow
  # worker re-claiming renews a single marker instead of minting a second.
  stale="$(jq -c 'map(select(.stale))' <<<"$claims")"
  if [ "$(jq 'length' <<<"$stale")" -gt 0 ]; then
    local sid sw sage fresh
    while read -r sid sw sage; do
      [ -n "$sid" ] || continue
      # RE-VERIFY against a fresh read, exactly as `reap` does. `claims` is a snapshot, and the holder
      # may have heartbeated since. Deleting a marker because it USED TO BE stale evicts a worker that
      # is alive and believes its lease was renewed — the double-hold this GC exists to prevent.
      fresh="$(claims_of "$R_OWNER" "$R_REPO" "$R_NUM" \
               | jq -c --argjson id "$sid" 'map(select(.id == $id)) | first // empty')"
      if [ -z "$fresh" ]; then
        echo "fsgg-coord: worker '$sw' expired marker on $R_REPO#$R_NUM was already collected." >&2
        continue
      fi
      if [ "$(jq -r '.stale' <<<"$fresh")" != "true" ]; then
        die "claim: worker '$sw' renewed its lease on $R_REPO#$R_NUM while we were collecting it ($(jq -r '.ageSec / 60 | floor' <<<"$fresh")m ago) — it is alive. Retry, or use --force to steal."
      fi
      if delete_comment "$R_OWNER" "$R_REPO" "$sid"; then
        [ "$sw" = "$w" ] || notify_reaped "$R_OWNER" "$R_REPO" "$R_NUM" "$sw" "$sage" "$w"
        echo "fsgg-coord: collected worker '$sw' expired claim on $R_REPO#$R_NUM (idle ${sage}m)." >&2
      else
        die "claim: cannot remove worker '$sw' expired marker (comment $sid) on $R_REPO#$R_NUM — refusing to claim over a marker that is still there."
      fi
    done < <(jq -r '.[] | "\(.id) \(.worker) \(.ageSec / 60 | floor)"' <<<"$stale")
    claims="$(jq -c 'map(select(.stale | not))' <<<"$claims")"
  fi

  live="$(jq -c 'map(select(.stale | not))' <<<"$claims")"

  # THE TWIN BACKSTOP (#419). A marker bearing our worker id is not proof it is OURS — and `mine`
  # below cannot tell the difference, so a twin's lock gets silently adopted by the heartbeat path.
  # The marker has carried `session=` since ADR-0027; nothing ever read it. Now it does: same worker
  # id + a DIFFERENT session is two workers on one id, which is the failure the whole lock exists to
  # prevent. Refuse, loudly, and hand over the one remedy that resolves it.
  #
  # Both sessions must be non-empty to conclude anything: a marker with no `session=` (a human, a
  # harness that exports none, a pre-#419 marker) is genuinely indistinguishable from ours, so it
  # keeps the old behaviour — treated as ours, and warned about — rather than failing on old data.
  #
  # NOT overridable with --force. `--force` steals another WORKER's item; this is not a contested
  # item, it is a broken identity, and the fix for a broken identity is a new identity, never a
  # steal — stealing here would delete a marker that our own twin is actively working behind.
  local twin=""
  if [ -n "$HARNESS_SESSION" ]; then
    twin="$(jq -c --arg w "$w" --arg s "$HARNESS_SESSION" \
              'map(select(.worker == $w and .session != "" and .session != $s)) | first // empty' <<<"$live")"
  fi
  if [ -n "$twin" ]; then
    die "claim: worker id '$w' is ALREADY held on $R_REPO#$R_NUM by a DIFFERENT session — two workers share one id.
  theirs: session $(jq -r '.session' <<<"$twin") (claimed $(jq -r '.ageSec / 60 | floor' <<<"$twin")m ago)
  ours:   session $HARNESS_SESSION
  The claim lock keys on the worker id, so it cannot separate you from them: renewing that marker
  would put TWO workers on this item, which is the exact failure this lock exists to prevent.
  Do NOT --force (that steals a marker your twin is working behind). Take a unique id and retry:

      eval \"\$(fsgg-coord whoami --mint)\"
"
  fi

  mine="$(jq -c --arg w "$w" 'map(select(.worker == $w)) | first // empty' <<<"$live")"
  others="$(jq -c --arg w "$w" 'map(select(.worker != $w))' <<<"$live")"

  # --force evicts the holders first, so the CAS below sees a clear field.
  if [ -n "$force" ] && [ "$(jq 'length' <<<"$others")" -gt 0 ]; then
    local oid ow
    while read -r oid ow; do
      [ -n "$oid" ] || continue
      delete_comment "$R_OWNER" "$R_REPO" "$oid" \
        || die "claim --force: could not evict worker '$ow' (comment $oid) — it still holds $R_REPO#$R_NUM."
      echo "fsgg-coord: --force — evicted worker '$ow' from $R_REPO#$R_NUM." >&2
    done < <(jq -r '.[] | "\(.id) \(.worker)"' <<<"$others")
    others='[]'
  fi

  # Re-claiming what we already hold is a heartbeat, not an error: `take` retries must be idempotent.
  # CAREFUL: a marker bearing our id is not proof it is OURS. Identity rules 4/5 can hand one id to
  # several workers, and this path bypasses the CAS entirely — so it is exactly where a same-id
  # sibling silently adopts another worker's lock. Warn here too; the success path's warning at the
  # bottom of this function is never reached from this early return.
  if [ -n "$mine" ]; then
    heartbeat_comment "$R_OWNER" "$R_REPO" "$R_NUM" "$(jq -r '.id' <<<"$mine")" "$w" "$ref" "$prev_claimed"
    stamp_worktree "$w" "$R_REPO#$R_NUM"
    printf 'held %s by worker %s (lease renewed)\n' "$R_REPO#$R_NUM" "$w"
    if [ -n "$WORKER_SHARED_WHY" ]; then
      echo "fsgg-coord: NOTE — this renewed an EXISTING marker for worker '$w' without running the" >&2
      echo "  claim CAS. If another worker shares this id, you have just adopted ITS lock." >&2
    fi
    warn_shared_identity
    return 0
  fi
  if [ "$(jq 'length' <<<"$others")" -gt 0 ]; then
    die "$R_REPO#$R_NUM is held by worker '$(jq -r '.[0].worker' <<<"$others")' ($(jq -r '.[0].ageSec / 60 | floor' <<<"$others")m ago). Use --force to steal, or 'reap' if its lease has expired."
  fi

  # Read the column we are about to overwrite, and record it in the marker (#481). This is the ONLY
  # moment it is knowable: one line further down the board says `In progress` and the answer is gone.
  #
  # A read that FAILS records nothing rather than guessing — an unrecorded claim releases to `Ready`,
  # which is exactly the pre-#481 behaviour, so a flaky read degrades to the old defect instead of
  # inventing a column. It must not abort the claim: the pre-claim status is bookkeeping, and the CAS
  # below is the lock.
  local prev=""
  prev="$(item_status "$ref" 2>/dev/null)" || prev=""
  # Already `In progress`, or blank? Then it is not a column somebody chose — it is a claim's leftover
  # footprint (a `--force` steal, or a re-claim after `reap` cleared the marker but not the board).
  # Inherit what the superseded claim recorded; re-reading here would only re-read that footprint.
  if [ -z "$prev" ] || [ "$prev" = "$CLAIM_STATUS" ]; then prev="$prev_claimed"; fi

  local branch myid
  branch="$(branch_for "$R_OWNER" "$R_REPO" "$R_NUM")"
  myid="$(post_comment "$R_OWNER" "$R_REPO" "$R_NUM" \
            "$(claim_body "$w" "$branch" "$(now_iso)" "$ref" "$prev")")"
  [ -n "$myid" ] || die "claim: could not post the claim marker on $R_REPO#$R_NUM."

  # The CAS. Lowest LIVE marker id wins; a loser removes its own marker so the item stays clean.
  # Our marker is already posted, so EVERY exit from here must either keep it (we won) or remove it
  # (we lost / we cannot tell) — never abort in between and leave it orphaned.
  local recheck winner wid ww
  if ! recheck="$(issue_comments "$R_OWNER" "$R_REPO" "$R_NUM")"; then
    delete_comment "$R_OWNER" "$R_REPO" "$myid" \
      || die "claim: could not re-read $R_REPO#$R_NUM after posting, AND could not remove our own marker (comment $myid). Delete it by hand — it is holding the item."
    die "claim: could not re-read the markers on $R_REPO#$R_NUM after posting — removed our marker, nothing was claimed. Retry."
  fi
  winner="$(parse_claims <<<"$recheck" | jq -c 'map(select(.stale | not)) | first // empty')"
  wid="$(jq -r '.id // empty' <<<"$winner")"
  ww="$(jq -r '.worker // empty' <<<"$winner")"
  # NO live marker at all means our OWN marker is missing from the re-read: a peer's --force/reap/GC
  # deleted it under us, or the read has not caught up with our POST. We cannot show we hold the lock,
  # so we do not hold it. "We cannot tell" is a LOSS — treating it as a win is how two workers both
  # proceed holding nothing.
  if [ -z "$wid" ]; then
    delete_comment "$R_OWNER" "$R_REPO" "$myid" || true
    die "claim: our marker vanished from $R_REPO#$R_NUM between posting and re-reading it (a concurrent --force/reap, or a read that lagged the write) — nothing was claimed. Retry ('fsgg-coord take')."
  fi
  if [ "$wid" != "$myid" ]; then
    delete_comment "$R_OWNER" "$R_REPO" "$myid" \
      || die "lost the claim race on $R_REPO#$R_NUM to worker '$ww', but could NOT remove our own marker (comment $myid). Delete it by hand — it is blocking the item."
    die "lost the claim race on $R_REPO#$R_NUM to worker '$ww' — backed off cleanly. Try another item ('fsgg-coord take')."
  fi

  # The lock is held. Everything below is bookkeeping a human or a later reader benefits from.
  assign_me "$R_OWNER" "$R_REPO" "$R_NUM"
  stamp_worktree "$w" "$R_REPO#$R_NUM"
  # A SUBSHELL, not just a redirect: set_field's `die` is an `exit`, and the board flip is strictly
  # best-effort — the lock is already held, so a board that rejects the write must not unwind a claim.
  # SOFT_DIE=1 keeps that `die` from escalating to the whole command under #344's fatal-die rule.
  #
  # But best-effort is NOT the same as don't-care (#418). This used to be one `if`, so EVERY failure
  # printed "not on board" — including a rate-limit 403, which is how the board came to say `Blocked`
  # while a worker held the item and `next` hid it from everyone else (the CLAIM-STATUS-LAG drift
  # /check-board reconciles). The three outcomes are now three outcomes:
  local boardnote rc=0
  board_write "$ref" Status "$CLAIM_STATUS" || rc=$?
  boardnote="$BOARD_WRITE_NOTE"
  # One claim-specific wording: off-board is not a failure HERE, because the marker is the lock and it
  # is already held. Everywhere else off-board means the write is lost; here it means only that the
  # item cannot be SEQUENCED until someone adds it.
  [ "$rc" = "$EX_OFFBOARD" ] && boardnote="note: not on board '$TITLE' (the marker is the lock; add it to sequence it)"
  printf 'claimed %s by worker %s  ·  %s\n' "$R_REPO#$R_NUM" "$w" "$boardnote"
  # `origin/main` is not decoration. `git worktree add -b <new>` with no commit-ish branches from the
  # shared checkout's HEAD, and this protocol's premise is that N workers pass through that checkout —
  # so its HEAD is routinely some other worker's unmerged branch. Branching off it silently carries
  # that branch's commits into this item's PR (.github#319).
  printf '  isolate:  git worktree add ../%s-%s -b %s origin/main\n' "$R_REPO" "$R_NUM" "$branch"
  printf '  attribute: git commit --trailer "FSGG-Worker: %s"\n' "$w"
  lane_note "$R_OWNER/$R_REPO#$R_NUM"
  warn_shared_identity
}

# ---- heartbeat: renew this worker's lease. Any long-running claim must beat, or `reap` collects it.
# Renewing is only legal for the CURRENT holder — the lowest LIVE marker. Renewing anything else is
# how a worker whose lease expired resurrects its marker underneath the worker that legitimately
# claimed next, leaving two live markers and two workers on one item. So:
#   * my marker is stale  -> REFUSE. The lease is the promise; it lapsed. Re-claim (which re-runs the
#     CAS) or stop. Renewing it here would be a lock taken without ever winning one.
#   * someone else holds  -> REFUSE, loudly, and tell the worker to STOP. It is no longer working an
#     item it owns, and it needs to hear that from the tool, not from a merge conflict.
heartbeat_cmd() {
  local ref="${1:-}"
  [ -n "$ref" ] || die "heartbeat: <issue> required."
  parse_ref "$ref"
  worker >/dev/null; local w="$WORKER_ID"
  local claims holder mine
  claims="$(claims_of "$R_OWNER" "$R_REPO" "$R_NUM")"
  holder="$(jq -c 'map(select(.stale | not)) | first // empty' <<<"$claims")"
  mine="$(jq -c --arg w "$w" 'map(select(.worker == $w)) | first // empty' <<<"$claims")"

  [ -n "$mine" ] || die "heartbeat: worker '$w' holds no claim on $R_REPO#$R_NUM."
  if [ -n "$holder" ] && [ "$(jq -r '.worker' <<<"$holder")" != "$w" ]; then
    # Someone else holds it. Naming them is the actionable fact — say that before anything about us.
    local why=""
    [ "$(jq -r '.stale' <<<"$mine")" = "true" ] && why=" (our lease had expired)"
    die "heartbeat: worker '$w' no longer holds $R_REPO#$R_NUM — worker '$(jq -r '.worker' <<<"$holder")' does$why. STOP working it."
  fi
  if [ -z "$holder" ] || [ "$(jq -r '.stale' <<<"$mine")" = "true" ]; then
    # AN EXPIRED LEASE WHOSE WORK IS DEMONSTRABLY ALIVE IS RENEWABLE (#581, item 4).
    #
    # The sharp edge this closes: an expired lease could not be renewed — correctly, in the general
    # case — so a worker whose long build outran the lease could not recover their OWN claim. They
    # had to re-`claim` and race a `take` that was, by then, actively offering their item to someone
    # else. The remedy for overrunning was to enter a race you might lose to a stranger.
    #
    # But an open PR on `item/<n>-*` is proof the work is alive, and it is proof of WHOSE work: this
    # marker is ours. Renewing our own lease over our own live PR is not a steal — nobody else can
    # hold this item, because a live PR now blocks `batch` and `reap` from touching it too.
    local alive; alive="$(pr_alive "$R_OWNER" "$R_REPO" "$R_NUM")"
    if [ -z "$alive" ]; then
      die "heartbeat: worker '$w' lease on $R_REPO#$R_NUM EXPIRED ($(jq -r '.ageSec / 60 | floor' <<<"$mine")m > ${CLAIM_LEASE_MIN}m), and no open PR on 'item/$R_NUM-*' shows the work is still alive. STOP working it. Re-take it with 'fsgg-coord claim $ref'."
    fi
    echo "fsgg-coord: the lease had EXPIRED ($(jq -r '.ageSec / 60 | floor' <<<"$mine")m > ${CLAIM_LEASE_MIN}m), but PR $alive is open — the work is alive, so the claim is yours to renew (#581)." >&2
  fi
  heartbeat_comment "$R_OWNER" "$R_REPO" "$R_NUM" "$(jq -r '.id' <<<"$mine")" "$w" "$ref" \
    "$(jq -r '.prev // ""' <<<"$mine")"
  printf 'renewed %s for worker %s (lease %sm)\n' "$R_REPO#$R_NUM" "$w" "$CLAIM_LEASE_MIN"
}

# ---- adopt: take over an ORPHAN — a stale claim whose PR is FINISHED — and land it (#697) --------
# THE ROW THE PROTOCOL USED TO BIN. `reap` refuses a stale claim whose PR is open (#581, correct) and
# then offers one exit: *close it, then reap*. For a PR that is green, reviewed and mergeable that
# exit DESTROYS the best work on the board — and it is the path of least resistance, so a worker who
# follows the tool's own advice literally does it. FS.GG.Rendering#681 sat done-and-green for 18
# hours behind a dead worker; it was landed only because a human overruled the tool. It should not
# take a human overruling the tool to keep finished work.
#
# So a worker MAY land another worker's orphaned PR — through ONE verified command that cannot be
# talked into landing anything else.
#
# WHAT MAKES THIS SAFE IS THE GATE, NOT THE TRANSFER. Each refusal below is a state in which "adopt"
# would mean something other than *finish somebody's finished work*:
#   * a LIVE claim  -> not an orphan. Its worker is alive, and taking their item is a STEAL. Talk.
#   * no open PR    -> nothing to land. The claim is merely dead: reap it and claim normally.
#   * a PR that is not GREEN AND MERGEABLE -> not finished. Rebasing a conflicted PR or fixing a red
#     one is AUTHORING, not landing, and it belongs to whoever claims the item the ordinary way.
# `unknown` refuses too: adopting on a guess is how a "verified" command launders an unverified one,
# and the act it would be laundering is the destructive one this command exists to replace.
#
# THE TRANSFER ITSELF IS `claim`'s, ON PURPOSE. `claim` already garbage-collects the expired marker,
# NOTIFIES the worker it collected, carries that marker's `prev` across so a later `release` restores
# the column the FIRST claim overwrote (#481), and posts one marker under the same comment-id CAS as
# every other lock. Re-implementing that here would be a SECOND lock implementation, and the second
# one is always the one with the bug. `adopt` is a GATE IN FRONT OF `claim`, not a rival to it.
#
# ATTRIBUTION: the original author's commits keep their author and their `FSGG-Worker:` trailer. The
# adopter is the LANDER, and says so on the channel — so the orphan's worker is told their work was
# adopted and merged, not collected and binned.
adopt_cmd() {
  local ref=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -*) die "adopt: unknown flag '$1'." ;;
      *)  [ -z "$ref" ] && ref="$1" || die "adopt: unexpected argument '$1'."; shift ;;
    esac
  done
  [ -n "$ref" ] || die "adopt: <issue> required (URL, owner/repo#n, or repo#n)."
  parse_ref "$ref"
  worker >/dev/null; local w="$WORKER_ID"

  local claims live stale ow oage
  claims="$(claims_of "$R_OWNER" "$R_REPO" "$R_NUM")"

  # 1. A LIVE claim is not an orphan.
  live="$(jq -c 'map(select(.stale | not)) | first // empty' <<<"$claims")"
  if [ -n "$live" ]; then
    die "adopt: $R_REPO#$R_NUM is held by a LIVE claim — worker '$(jq -r '.worker' <<<"$live")', renewed $(jq -r '.ageSec / 60 | floor' <<<"$live")m ago (lease ${CLAIM_LEASE_MIN}m). A worker that is alive is not an orphan, and taking their item is a steal, not an adoption.
  Talk to them:  fsgg-coord say $ref --to $(jq -r '.worker' <<<"$live") '<message>'
  If you genuinely mean to take it anyway, that is a steal, and the flag says so:  fsgg-coord claim $ref --force"
  fi

  # 2. There must be an EXPIRED claim to adopt.
  stale="$(jq -c 'map(select(.stale)) | first // empty' <<<"$claims")"
  if [ -z "$stale" ]; then
    die "adopt: $R_REPO#$R_NUM carries no expired claim — there is no orphan here to adopt.
  If it is simply unclaimed, take it the ordinary way:  fsgg-coord claim $ref"
  fi
  ow="$(jq -r '.worker' <<<"$stale")"
  oage="$(jq -r '.ageSec / 60 | floor' <<<"$stale")"

  # 3. There must be FINISHED WORK: an open PR on the item's branch. That is what `adopt` lands, and
  #    with no PR there is nothing to land — the claim is merely dead, and `reap` is the right tool.
  local alive pnum
  alive="$(pr_alive "$R_OWNER" "$R_REPO" "$R_NUM")"
  if [ -z "$alive" ]; then
    die "adopt: worker '$ow' claim on $R_REPO#$R_NUM is expired (idle ${oage}m), but there is NO open PR on 'item/$R_NUM-*' — so there is no finished work to adopt. That claim is simply dead.
  Collect it and take the item normally:  fsgg-coord reap --repo $R_REPO --apply && fsgg-coord claim $ref"
  fi
  pnum="${alive%% *}"; pnum="${pnum#\#}"

  # 4. THE GATE. `adopt` lands FINISHED work and nothing else.
  local land; land="$(pr_landable "$R_OWNER" "$R_REPO" "$pnum")"
  case "$land" in
    green) ;;
    conflicted)
      die "adopt: PR #$pnum on $R_REPO#$R_NUM is OPEN but CONFLICTED with its base — so it is not landable as it stands, and it is not finished work. Rebasing it is AUTHORING, not landing; and note GitHub gives a conflicted PR no CI at all (it cannot build refs/pull/$pnum/merge), so nothing about it has been verified since the conflict appeared.
  Take the item the ordinary way and finish the job:  fsgg-coord reap --repo $R_REPO --apply && fsgg-coord claim $ref" ;;
    pending)
      die "adopt: PR #$pnum on $R_REPO#$R_NUM still has checks RUNNING — it is not finished yet, and a pending check is not a passing one. Let CI settle, then adopt." ;;
    red)
      die "adopt: PR #$pnum on $R_REPO#$R_NUM is NOT green — either a check failed, or it has NO check runs at all. Both are one verdict here: a missing subject is a finding, not a pass (#606), and CI that never started has proved nothing. A red PR is not finished work.
  If it is genuinely abandoned, close the PR and reap the claim. If it is salvageable, take the item and finish it:  fsgg-coord reap --repo $R_REPO --apply && fsgg-coord claim $ref" ;;
    *)
      die "adopt: could NOT determine the state of PR #$pnum on $R_REPO#$R_NUM (rate limit? network? GitHub computes mergeability lazily and may not have done so yet). REFUSING to adopt on a guess — an 'adopt' that lands an unverified PR is exactly the destructive act this command exists to replace. Look at the PR, or re-run in a moment." ;;
  esac

  # A PRECONDITION REPORT, NOT A SUCCESS BANNER — and the wording has to say so, because `claim_cmd`
  # below can still refuse: an unmatchable `Paths:`, a lost CAS race, the holder heartbeating mid-GC,
  # or #516's one-item-per-worker guard. Announcing "ADOPTED" here and then dying would leave the
  # operator unable to tell whether the lock was taken.
  echo "fsgg-coord: PR #$pnum on 'item/$R_NUM-*' is GREEN and MERGEABLE — worker '$ow' FINISHED this work and died before landing it (idle ${oage}m). Taking the claim..." >&2

  # 5. Take the lock. `claim` does the transfer: collects the expired marker, tells its worker,
  #    carries the original `prev` across (#481), and posts ours under the same CAS. It DIES on a lost
  #    race rather than returning, so nothing below runs unless the lock is really ours.
  claim_cmd "$ref"

  # 6. Tell the orphan's worker what actually happened. `claim`'s GC has already told them their
  #    marker was collected — which, alone, reads exactly like the reaping this command exists to
  #    prevent. And if they are in fact alive, this is their cue to stop us before the merge.
  say_cmd "$ref" --to "$ow" "Your claim on $R_REPO#$R_NUM was ADOPTED by worker '$w', not reaped: PR #$pnum is green and mergeable, so your work is being LANDED, not discarded. Your commits keep their author and their FSGG-Worker trailer — I am only the lander. If you are alive and still working this, say so NOW, before it merges."

  cat >&2 <<EOF
fsgg-coord: ADOPTED $R_REPO#$R_NUM from worker '$ow' — the claim is now yours.
  The work is FINISHED. Do NOT rebuild it, and do NOT close PR #$pnum. Land it:
    gh api -X PUT repos/$R_OWNER/$R_REPO/pulls/$pnum/merge -f merge_method=squash
    fsgg-coord done $ref --flip
EOF
}

# ---- release: drop the lock. Delete our marker, unassign, and return the item to the pool. --------
# Releasing a claim held by ANOTHER worker needs --force: an accidental release is how two workers end
# up on one item, which is the failure this protocol exists to prevent.
# ---- release: "drop the lease" and "this item is startable" are two different claims (#331) ------
# `claim` sets Status=In progress. Releasing the lease undoes THAT, and only that. Every other status
# on the item was chosen deliberately — Blocked, Backlog, In review, Done — and a release that forced
# `Ready` over it silently reverted its author. The documented blocked-item sequence
#
#     set-field <i> 'Blocked by' <ref>;  set-field <i> Status Blocked;  release <i>
#
# therefore could not produce its own documented end state: the board ended up asserting `Ready` on a
# row whose `Blocked by` named an open issue. Self-contradicting, and regenerated every time a worker
# followed the protocol. (Not a scheduler fail-open — `batch` derives blockedness from `Blocked by`,
# not from `Status` — but the board is a record humans read, and `check-board` had to keep repairing
# what `release` kept breaking.)
#
# A status we could not READ is not a status we may overwrite: forcing `Ready` over an unknown one is
# the same defect a turn further in. An unreadable Status writes nothing and says so.
#
# And undoing the claim's own column means RESTORING it, not guessing `Ready` for it (#481) — the
# marker recorded what the claim overwrote, so we read it back off the marker we are about to delete.
#
# `--status S` still wins outright. That is the caller stating the end state, rather than release
# guessing it.
release_cmd() {
  local ref="" status="" explicit="" force=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --status) status="${2:?--status needs a value}"; explicit=1; shift 2 ;;
      --force)  force=1; shift ;;
      -*)       die "release: unknown flag '$1'." ;;
      *)        [ -z "$ref" ] && ref="$1" || die "release: unexpected argument '$1'."; shift ;;
    esac
  done
  [ -n "$ref" ] || die "release: <issue> required (URL, owner/repo#n, or repo#n)."
  parse_ref "$ref"
  worker >/dev/null; local w="$WORKER_ID"
  local claims mine
  claims="$(claims_of "$R_OWNER" "$R_REPO" "$R_NUM")"
  mine="$(jq -c --arg w "$w" 'map(select(.worker == $w)) | first // empty' <<<"$claims")"

  if [ -z "$mine" ] && [ -z "$force" ]; then
    local holder; holder="$(jq -r '.[0].worker // empty' <<<"$claims")"
    [ -n "$holder" ] \
      && die "release: $R_REPO#$R_NUM is held by worker '$holder', not '$w' — pass --force to release it anyway."
  fi

  # What did the claim we are dropping overwrite? Read it off the marker BEFORE the loop below deletes
  # it — afterwards the only witness to the pre-claim column is gone (#481). Same selector as the
  # delete, so a `--force` release restores what the EVICTED claim recorded, not what we imagine.
  local prev_claimed
  prev_claimed="$(jq -r --arg w "$w" --arg f "${force:-}" \
    'map(select(($f != "" or .worker == $w) and .prev != "")) | .[0].prev // ""' <<<"$claims")"

  local id
  while read -r id; do
    [ -n "$id" ] || continue
    delete_comment "$R_OWNER" "$R_REPO" "$id" \
      || die "release: could not remove marker (comment $id) on $R_REPO#$R_NUM — it still holds the item."
  done < <(jq -r --arg w "$w" --arg f "${force:-}" '.[] | select($f != "" or .worker == $w) | .id' <<<"$claims")

  unassign_me "$R_OWNER" "$R_REPO" "$R_NUM"

  # The marker is gone by here, so the lease is ALREADY dropped. Nothing below may abort the release
  # — a board that cannot be read or written leaves the column alone and reports that, exactly as it
  # has always done for a board write that failed.
  local boardnote="" restored=""
  if [ -z "$explicit" ]; then
    local act val
    IFS=$'\t' read -r act val < <(unclaim_status "$ref" "$prev_claimed")
    case "$act" in
      # An `if`, not an `&&` chain: this is the LAST command of the branch, so under `set -e` a false
      # test would make the `case` — and the `if` wrapping it — exit non-zero on the ordinary path.
      write) status="$val"
             if [ -n "$prev_claimed" ] && [ "$val" = "$prev_claimed" ]; then restored=1; fi ;;
      keep)  boardnote="board: $val (preserved — release resets only the '$CLAIM_STATUS' claim set)" ;;
      offboard) boardnote="note: not on board '$TITLE'" ;;
      # The column is unreadable, so we write nothing — but we still KNOW what this claim overwrote,
      # and the repair we hand the operator must say so. Hardcoding `Ready` here would reintroduce
      # #481's promotion in the ADVICE on the one path where the marker can still prove it wrong.
      *)     boardnote="note: Status unchanged — could not read it"
             echo "fsgg-coord: release: could not read $R_REPO#$R_NUM Status. The lease IS dropped; the board column is untouched." >&2
             echo "  set it yourself if it still says '$CLAIM_STATUS': fsgg-coord set-field $ref Status ${prev_claimed:-Ready}" >&2 ;;
    esac
  fi

  if [ -z "$boardnote" ]; then
    # The board write is best-effort (the lease is already dropped) but it is NOT don't-care: this
    # used to report "not on board" for EVERY failure, so an exhausted budget silently DROPPED the
    # restore and left the item sitting in the column the claim overwrote, with no claim on it —
    # #418's defect, still live in `release` (#510). board_write queues it instead.
    local rrc=0
    board_write "$ref" Status "$status" || rrc=$?
    case "$rrc" in
      0)           boardnote="board: $status${restored:+ (restored — the column this claim overwrote)}" ;;
      "$EX_RATE")  boardnote="$BOARD_WRITE_NOTE" ;;
      *)           boardnote="note: not on board '$TITLE'" ;;
    esac
  fi
  printf 'released %s (worker %s)  ·  %s\n' "$R_REPO#$R_NUM" "$w" "$boardnote"
}

# ---- overlap: can two items run in parallel? Compare their declared `Paths:` touch-sets (ADR-0021).
# Each item declares the files it touches as a `Paths:` line in its issue body — exact paths and
# directory prefixes, NOT globs (see TOUCHSET_GRAMMAR below), e.g.
#   Paths: src/Scene/**, tests/Scene/**
# We read both bodies over REST (cheap, no GraphQL budget) and treat each token as a SUBTREE: two
# tokens conflict when they are equal or one is a path-prefix of the other. This is deliberately
# file-existence-INDEPENDENT (a new feature adding files still has a declared touch-set) and
# CONSERVATIVE — it errs toward reporting overlap. Disjoint -> exit 0; overlap -> exit 1 (+ the
# conflicting tokens); no declaration on either side -> exit 2, as does a declaration the matcher
# cannot honour (.github#273) — an unmatchable token must never be answered `DISJOINT`.
# NO declaration is a normal, expected answer ("this item cannot be scheduled yet"), not an error:
# `grep` exits 1 on no match, and under `set -o pipefail` that would abort every caller at exactly the
# item they need to report on. Return empty, exit 0, and let the caller decide what an empty set means.
#
# But an EMPTY answer must mean "this item declared no touch-set", never "the read failed". A failed
# read that returns empty reads as `disjoint` to `conflicts_between`, so the scheduler would hand out
# work that overlaps a held item — the same fail-open `claims_of` refuses for the lock itself. So the
# body is read on its own line and a read failure DIES; only `grep`'s no-match is absorbed below.
#
# The detect and the strip must also agree on case, or a mis-cased `PATHS:` line survives grep and
# keeps its prefix as a bogus `PATHS:` touch-set token. `widen` rewrites on `[Pp]aths:` too, so that
# is the one spelling the whole tool recognizes.
#
# A DECLARATION IS A LINE THE AUTHOR WROTE AS ONE — not any line that looks like one (.github#277).
# Scanning the raw body meant an issue that merely *quotes* a `Paths:` line — in a reproduction, in a
# suggested `widen` command — silently acquired it as its own touch-set, and every matching line was
# unioned, so a body with a real declaration and a quoted one reserved both. This is the #273
# fail-open one turn further in: an unmatchable token reserves nothing and is loudly refused, but a
# FABRICATED one reserves the *wrong* files and passes every check, because each token is well-formed.
# `#261` is the live instance — its only `Paths:` line sits inside a fence, quoting another repo, so
# it reserved Rendering's files and none of the file it edits.
#
# A code block is not prose: fenced blocks are stripped before scanning, and markdown's own rule
# settles the indented case — 4+ leading spaces (or a tab) is a code block, so a declaration is a
# `Paths:` line indented at most 3, the same bound that decides whether a fence is a fence. A body
# whose only `Paths:` line was fenced now declares NOTHING, and an undeclared touch-set is already
# refused everywhere. That is the fail-CLOSED direction: unschedulable beats mis-scheduled.
#
# WHAT SURVIVES IS UNIONED, not `head -1`ed — deliberately, against #277's suggested fix. Both stop a
# FENCED quote from widening a real declaration, but only because the strip already deleted it; they
# differ on a quote that ESCAPES the strip (a bare one at column 0 — which #277 itself records as how
# #273 "infected itself with its own reproduction"). Taking the first line then reserves the QUOTE and
# silently DROPS the real declaration below it: under-reserving, so two workers are told DISJOINT on a
# file they both edit. That is ADR-0021's own failure mode — the one this file exists to prevent, and
# the one a fix for #277 must not reintroduce. Unioning reserves a SUPERSET instead: the cost is a
# false OVERLAP, which is loud, investigable, and spends only parallelism. Over-reserve on ambiguity;
# never under-reserve. `widen` COLLAPSES the duplicates, so the two sides stay coherent.
FENCE_AWK='
function fence_delim(line,   t, lead, ch, n, rest) {
  t = line; lead = 0
  while (lead < 3 && substr(t, 1, 1) == " ") { t = substr(t, 2); lead++ }
  if (t !~ /^(```|~~~)/) return 0
  ch = substr(t, 1, 1); n = 0
  while (substr(t, n + 1, 1) == ch) n++
  rest = substr(t, n + 1)
  if (!IN_FENCE) {
    if (ch == "`" && index(rest, "`")) return 0   # an opening ``` info string carries no backtick
    IN_FENCE = 1; FENCE_CH = ch; FENCE_N = n; return 1
  }
  gsub(/[ \t]/, "", rest)                         # a closer: same char, at least as long, nothing else
  if (ch == FENCE_CH && n >= FENCE_N && rest == "") { IN_FENCE = 0; return 1 }
  return 0
}
'
# `widen` REWRITES the lines this reads. Both must agree on which lines are declarations, or `widen`
# patches a quoted line inside a fence and the reader never sees the new touch-set — so both sides
# share `FENCE_AWK` and the same `^ {0,3}[Pp]aths:` bound.
paths_from_body() {  # $1=issue body -> one normalized touch-set token per line (possibly none)
  # BACKTICKS ARE STRIPPED BEFORE ANYTHING ELSE (#485 leg b, was #435). A `Paths:` line written the way
  # everyone naturally writes one — ``Paths: `src/Foo/**`, `tests/Foo/**` `` — used to normalize to
  # tokens with the backticks STILL ATTACHED, and the trailing-glob strip below is anchored at
  # end-of-string. The token ends in a backtick, not `*`, so `/\*\*$` never matched: the `**` survived,
  # `invalid_paths` flagged the token as unmatchable, and the item was refused.
  #
  # The refusal itself was CORRECT and fail-closed (#273: an unmatchable token must never answer
  # DISJOINT). The defect was that a GRAMMAR-LEGAL declaration was rejected for its markdown, and the
  # item then vanished from `batch` while `take` reported an empty queue — a well-formed touch-set
  # made invisible by a formatting character. FS.GG.Audio#29 and #31 were both filed this way.
  #
  # A touch-set token can never legitimately contain a backtick (it is not a path character anyone
  # means), so stripping is unambiguous — and `widen` shares this function, so both sides stay coherent.
  # `Paths: none` is the SENTINEL, not a directory called `none` (#496). It is how an epic, a decision
  # item, or an investigation whose scope IS the question says "this item deliberately has no
  # touch-set" — in a form a machine can read. Emit NOTHING for it: it declares no files, so it
  # reserves no files, and `batch` still (correctly) refuses to schedule it. The difference the
  # sentinel buys is not schedulability, it is INTENT — `lint` can now tell an epic from an omission,
  # which it could not do while both rendered as "no 'Paths:' declared".
  #
  # Recognised only when it is the WHOLE declaration. `Paths: none src/Foo` is NOT a sentinel: `none`
  # stays an ordinary token (it matches no file, so it reserves nothing and conflicts with nothing),
  # and the item schedules on its real paths. That is the safe reading of a contradictory declaration
  # — "I have no touch-set, and here it is" cannot be honoured as written, and the alternative
  # (treating the whole line as the sentinel) would silently DISCARD a declared path and hand two
  # workers the same files. Half-honouring it errs toward reserving too much, never too little.
  local toks
  toks="$(printf '%s\n' "$1" \
    | awk "$FENCE_AWK"'{ if (fence_delim($0)) next; if (!IN_FENCE) print }' \
    | grep -E '^ {0,3}[Pp]aths:' \
    | sed -E 's/^ *[Pp]aths:[[:space:]]*//' \
    | tr -d '`' \
    | tr ',' ' ' | tr '\t' ' ' | tr -s ' ' '\n' | sed '/^$/d' \
    | sed -E 's#^\./##; s#/\*\*$##; s#/\*$##; s#/+$##' \
    || true)"                                # normalize: strip backticks, ./ prefix, /** /* and trailing /
  if [ "$(printf '%s' "$toks" | tr '[:upper:]' '[:lower:]')" = "$NO_TOUCHSET" ]; then return 0; fi
  printf '%s' "$toks"
  [ -n "$toks" ] && echo
  return 0
}

# The machine-readable "this item deliberately has no touch-set" declaration (#496).
#
# The protocol always DEPENDED on this distinction — the recipe asks a filer to write "no touch-set:
# declare at claim time with `widen`" in the body — but it asked for it as PROSE, and nothing read
# prose. So an epic and an omission rendered identically ("no 'Paths:' declared"), the distinction
# existed only in the filer's head, a real omission hid among the legitimate ones, and no gate could
# be written to catch it: there was nothing to check against. Nine items of real work sat on the board
# looking like work and invisible to every worker who asked for work, while `lint` said 0 errors.
NO_TOUCHSET='none'

# 0 iff the body carries the sentinel as its whole `Paths:` declaration.
declares_no_touchset() {  # $1=issue body
  local raw
  raw="$(printf '%s\n' "$1" \
    | awk "$FENCE_AWK"'{ if (fence_delim($0)) next; if (!IN_FENCE) print }' \
    | grep -E '^ {0,3}[Pp]aths:' \
    | sed -E 's/^ *[Pp]aths:[[:space:]]*//' \
    | tr -d '`' | tr ',' ' ' | tr '\t' ' ' | tr -s ' ' '\n' | sed '/^$/d' \
    | tr '[:upper:]' '[:lower:]' || true)"
  [ "$raw" = "$NO_TOUCHSET" ]
}

# The touch-set grammar the matcher ACTUALLY implements — and the refusal that keeps the gap between
# grammar and matcher from becoming a silent parallel collision (FS-GG/.github#273).
#
# `conflicts_between` and `verify_paths` compare tokens by EXACT EQUALITY and SUBTREE CONTAINMENT.
# There is no glob engine behind either. `paths_from_body` strips a *trailing* `/**` or `/*` and
# nothing else, so any other wildcard — a leading `**/`, an interior `*` — survives as a literal path
# segment and matches NO file, ever. And a token that matches nothing CONFLICTS WITH NOTHING: overlap
# reports `DISJOINT`, `batch` hands the item out, and two workers edit the same files while the tool
# tells them both they are disjoint. That is ADR-0021's own failure — a lock that succeeds under
# exactly the conditions it exists to prevent — one level down, in the touch-set instead of the claim.
#
# So an unmatchable token is not a near-miss to be tolerated: it is an UNKNOWN touch-set, and it is
# refused everywhere an unknown touch-set already is. `paths_of` dies rather than "schedule against an
# unknown touch-set" when the body read fails; this is the same rule for a body that read fine and
# declared something the matcher cannot honour.
TOUCHSET_GRAMMAR="supported: an exact path ('src/Foo.fs'), or a directory prefix ('src/Foo', 'src/Foo/*', 'src/Foo/**'). There is no glob matcher: a leading '**/' or an interior '*' matches nothing — spell the paths out."

# The tokens in a normalized touch-set that can never match a file. Empty output = every token is
# honourable. `[*?[]` is a bracket expression of the three shell-pattern metacharacters; `[` is
# literal inside it.
invalid_paths() {  # $1=normalized token list -> the unmatchable tokens, one per line
  [ -n "$1" ] || return 0
  printf '%s\n' "$1" | grep -E '[*?[]' || true
}

fmt_bad_paths() { printf '%s' "$1" | tr '\n' ' ' | sed -E 's/ +$//'; }

# The same predicate as `invalid_paths`, over a CLAIMS array rather than a token list: which live
# claims declare a touch-set that reserves nothing? Kept as ONE filter, called by `overlap --active`,
# `batch`, and `widen`, because three hand-copied `test("[*?\\[]")` regexes in two different engines
# (jq here, `grep -E` above) is a drift surface: widen the shell char class later and the jq copies
# silently do not follow, reopening the fail-open on exactly the in-flight-claim guards that need it
# most.
#
# `$self` excludes the item doing the asking ("" excludes nothing). `widen` normally cannot see its
# own stale tokens — it PATCHes before it re-checks — but a read-after-write lag on that re-read would
# serve the pre-PATCH body and make an item refuse on account of the very declaration it just fixed,
# stranding the one worker who is doing the right thing. Defence; the fixture cannot reproduce the lag.
JQ_CLAIMS_WITH_UNMATCHABLE_PATHS='
  [ .[]
    | select("\(.repo)#\(.number)" != $self)
    | select(any(.paths[]?; test("[*?\\[]")))
    | "\(.repo | sub("^[^/]+/"; ""))#\(.number)"
  ] | join(", ")'

claims_with_unmatchable_paths() {  # $1=claims JSON [$2=self ref to exclude] -> "repo#n, repo#n" or ""
  jq -r --arg self "${2:-}" "$JQ_CLAIMS_WITH_UNMATCHABLE_PATHS" <<<"$1"
}

# Refuse, loudly, with the tokens named and the grammar quoted. Callers that must not abort the whole
# command (the schedulers, which merely pass the item over) use `invalid_paths` directly instead.
die_on_invalid_paths() {  # $1=normalized tokens $2=what declared them (e.g. 'FS.GG.SDD#74')
  local bad; bad="$(invalid_paths "$1")"
  [ -n "$bad" ] || return 0
  die "$2 declares touch-set token(s) that can never match a file: $(fmt_bad_paths "$bad") — $TOUCHSET_GRAMMAR"
}

# The issue body, or a hard failure. Split out of `paths_of` (#496) so a caller that needs BOTH the
# touch-set and whether it is the `Paths: none` sentinel reads the body ONCE. Two reads per item would
# have doubled the REST cost of the scheduling loop — on the hot path, for a distinction that is free
# to compute from bytes already in hand.
body_of() {  # $1=owner $2=repo $3=num -> the issue body (dies if unreadable)
  gh api "repos/$1/$2/issues/$3" --jq '.body // ""' 2>/dev/null \
    || die "cannot read the touch-set on $2#$3 (rate limit? network?) — refusing to schedule against an unknown touch-set."
}

paths_of() {  # $1=owner $2=repo $3=num -> one normalized touch-set token per line (possibly none)
  paths_from_body "$(body_of "$1" "$2" "$3")"
}
# The comparison core, shared by `overlap`, `batch`, `take`, and `widen`. Two newline-separated token
# lists in; the conflicting pairs out (empty = disjoint). Subtree containment in either direction.
#
# CONTRACT — both token lists MUST come from the SAME repo. `Paths:` tokens are repo-relative, so
# `scripts/fsgg-coord` in repo A and `scripts/fsgg-coord` in repo B name two different files; this
# function cannot see the repo and will happily report them as colliding (#353). Every caller is
# therefore responsible for confining its inputs to one repo before calling: `batch`/`widen`/`overlap
# --active` pass that repo to `active_claims` so the compared claims are same-repo, and the pairwise
# `overlap a b` short-circuits to DISJOINT when its two refs resolve to different repos. Hand this
# cross-repo token lists and it invents collisions.
conflicts_between() {
  local a="$1" b="$2"
  [ -n "$a" ] && [ -n "$b" ] || return 0
  local -a pa pb; mapfile -t pa <<<"$a"; mapfile -t pb <<<"$b"
  local x y
  for x in "${pa[@]}"; do
    [ -n "$x" ] || continue
    for y in "${pb[@]}"; do
      [ -n "$y" ] || continue
      if [ "$x" = "$y" ] || [ "${y#"$x"/}" != "$y" ] || [ "${x#"$y"/}" != "$x" ]; then
        printf '%s  ⇄  %s\n' "$x" "$y"
      fi
    done
  done | sort -u
}

paths_for_ref() { parse_ref "$1"; paths_of "$R_OWNER" "$R_REPO" "$R_NUM"; }

# The worker holding a live claim on an item, WITH the age of that claim. The MARKER is the lock; the
# board's `Status` is a projection of it that `claim` writes best-effort and can therefore lag (or
# fail). Any scheduler decision that asks "is this taken?" must read the marker, never the column.
#
# Holder and age come back TOGETHER, in ONE comment read: the scheduler calls this per candidate, so
# splitting them across two `claims_of` calls would double the REST cost of the hot loop. (It replaces
# `live_claim_worker`, which returned the holder alone and had no other caller.)
#
# `batch` needs the age as much as the holder (#428). "Already claimed" tells a worker to go away;
# "already claimed, lease frees in ~12m" tells them whether going away is even the right move. The
# lock already knew this — it simply was not on the line the worker reads.
live_claim_holder() {  # $1=owner $2=repo $3=num -> "worker<TAB>ageSec" (empty iff no LIVE claim)
  claims_of "$1" "$2" "$3" \
    | jq -r 'map(select(.stale | not)) | .[0] // empty | "\(.worker // "—")\t\(.ageSec // -1)"'
}

# What is left of a claim's lease, in the words the blocked worker's next decision is made in (#428).
# That decision is WAIT or GO ELSEWHERE, and a holder's name alone cannot inform it.
#
# An UNKNOWN age says so rather than guessing a window: `claim` has always recorded a timestamp, but a
# hand-written or truncated marker may not, and inventing "frees in ~120m" from a missing field is the
# class of confident-but-unfounded sentence #440 and #488 were both closed for.
lease_window() {  # $1=ageSec (empty, or -1 = unknown) -> a human phrase, never empty
  local age="${1:-}"
  case "$age" in ''|*[!0-9]*) printf 'lease unknown'; return 0 ;; esac
  local left=$(( CLAIM_LEASE_MIN - age / 60 ))
  if [ "$left" -le 0 ]; then
    # An expired lease is not a wait — it is a REAP. Saying "frees in ~-180m" (or rounding it to zero
    # and implying "any moment now") would send a worker off to wait for a holder that is very likely
    # dead. `batch` still reserves its touch-set, correctly, because only `reap` may break a lock.
    printf 'lease EXPIRED — reapable'
  else
    printf 'lease frees in ~%sm' "$left"
  fi
}

# Which live claim RESERVED a given touch-set token — the join that turns a path collision into a
# PERSON (#428). `conflicts_between` reports which paths clash; a worker blocked by one needs to know
# whose they are, because every remedy in the protocol (wait, `say`, take other work) is addressed to
# a worker, not to a file.
#
# The token is matched EXACTLY: `reserved_in` emits the claims' own tokens verbatim, so the colliding
# token on the reserved side of a `⇄` pair is, by construction, one of these. Same-repo only — a
# `Paths:` token is repo-relative, so the caller has already confined both sides to one repo (see
# `conflicts_between`'s contract), and this must not widen that.
#
# The worker may be EMPTY, and that is a real state, not a gap: `active_claims` also reserves the
# touch-set of an item the board says is `In progress` with NO claim marker on it. Something is
# reserving those files and the protocol cannot name it — so the caller must say exactly that rather
# than dress it up as a holder. There is no lease on a claim that does not exist, and no one to `say`
# to; advertising "held by — (lease unknown)" would invite a worker to wait for a marker that is never
# coming.
# SEPARATED BY US (\x1f), NOT BY TAB, and that is load-bearing. Tab is an IFS *whitespace* character,
# so `read -r a b c` with IFS=$'\t' silently COLLAPSES a leading empty field: on the markerless case
# above — where the worker is deliberately empty — `a` would be handed the ITEM and `b` the age, and
# the item ref would then be printed as the holder's name. A non-whitespace separator preserves empty
# fields positionally, which is the whole reason the empty worker can be trusted to mean something.
claim_reserving() {  # $1=active-claims JSON  $2=owner/repo  $3=token -> "worker<US>item<US>ageSec"
  jq -r --arg r "$2" --arg t "$3" '
    [ .[] | select(.repo == $r) | select((.paths // []) | any(. == $t)) ] | first
    | if . == null then empty
      else "\(.worker // "")\((.repo // "" | sub("^[^/]+/"; "")))#\(.number)\(.ageSec // -1)" end' <<<"$1"
}

# The holder of an EXPIRED marker. `live_claim_worker` deliberately ignores these — an expired lease
# is not a lock. But it is not proof of abandonment either, and telling the two apart is what
# `pr_alive` below is for (#581).
stale_claim_worker() {  # $1=owner $2=repo $3=num
  claims_of "$1" "$2" "$3" | jq -r 'map(select(.stale)) | .[0].worker // empty'
}

# ---- PROOF OF LIFE: an open PR on the item's branch ----------------------------------------------
# THE LEASE IS EVIDENCE OF ABANDONMENT. IT IS NOT PROOF (#581).
#
# Its false-positive mode is systematic, not incidental: WORK THAT TAKES LONGER THAN THE LEASE. And
# the protocol's own remedy — heartbeat — is precisely what a busy worker forgets when the work is
# long, i.e. exactly when the lease is most likely to lapse. `take --repo rendering` handed out
# FS.GG.Rendering#429 while its worker was actively on it WITH PR #433 OPEN, because a loaded box
# (five workers, 40+ dotnet processes, an FSI OutOfMemoryException from contention) stretched one
# build past 120 minutes.
#
# It then happened AGAIN, to the worker fixing #485 — the claim lapsed mid-test-cycle and was reaped
# with the work uncommitted. It survived only because the reaping worker chose to preserve the
# worktree as a WIP commit. That is generosity, not a guarantee.
#
# "Workers should heartbeat" is true and insufficient. ADR-0027's whole argument is that THE LOCK,
# not worker diligence, prevents collisions. A lock that releases itself while the holder is
# demonstrably still working is a lock with a liveness bug, and the fix belongs in the scheduler.
#
# A far stronger, cheap, SERVER-SIDE signal sits right there: an open PR whose head is `item/<n>-*`.
# The worktree protocol (§2) mandates that branch name, so this is not a heuristic — it is the
# protocol's own artifact.
#
# COST IS THE DESIGN QUESTION (#581 says so explicitly). So: REST, never GraphQL — a different budget
# from the one that is routinely exhausted (#418) — and only on the ONE item about to be offered or
# reaped, never on every candidate in the scan. In practice that means only items carrying an EXPIRED
# marker, which is rare.
#
# Prints "#<pr> <branch>" if the work is demonstrably alive; nothing otherwise.
pr_alive() {  # $1=owner $2=repo $3=num
  gh api "repos/$1/$2/pulls?state=open&per_page=100" --paginate \
    --jq ".[] | select(.head.ref | startswith(\"item/$3-\")) | \"#\(.number) \(.head.ref)\"" 2>/dev/null | head -1
}

# ---- IS THE ORPHANED WORK FINISHED? (#697) -------------------------------------------------------
# `pr_alive` answers ONE question — *does a PR exist* — and stops. It never reads what the PR SAYS.
# That blind spot points the tool's own remedy at the best work on the board: `reap` refuses a stale
# claim whose PR is open (right, #581) and then offers exactly one exit — **"close it, then reap"**.
# For a PR that is green, reviewed and mergeable, that exit DESTROYS the work and makes the next
# worker rebuild it from nothing. It is also the path of least resistance: a worker who follows the
# tool's own advice literally does it. FS.GG.Rendering#681 sat done-and-green for 18 hours behind a
# dead worker and was landed only because a human overruled the tool.
#
# The third state below is not a corner case. It is the SUCCESS path of a worker whose harness died
# between "the PR is green" and "merge", and that window is minutes long on every item this protocol
# produces. The better the work, the more expensive the loss.
#
#   open, still being worked         -> leave it             (#581: proof of life)
#   open, abandoned mid-flight       -> close it, then reap  (#581)
#   open, FINISHED: green+mergeable  -> LAND IT: `adopt`     (THIS — the row the tool used to bin)
#
# Cost is the design question, exactly as it is for `pr_alive`: REST (a different budget from the
# GraphQL one that is routinely gone, #418), and only for a claim that is ALREADY stale and ALREADY
# has an open PR — which is rare. THREE reads: the PR, its head SHA's WORKFLOW RUNS, and that SHA's
# CHECK RUNS. The third is not redundant — each of the last two sees a failure the other cannot (see
# the rollup below), and the runs are also what tell us which check-runs are SUPERSEDED (#720).
#
# TWO TRAPS. BOTH FAIL CLOSED HERE, DELIBERATELY:
#
#   * `mergeable` is computed LAZILY, on demand. The first read of a PR GitHub has not yet tested
#     comes back **null**, and only a later read carries the real answer. `null` is UNKNOWN — it is
#     not "conflicted", and it is emphatically not "mergeable". So we ask a second time, and if it is
#     still null we say `unknown` and advise nothing. This is not hypothetical: while this very item
#     was being worked, PR #692 read back `mergeable=null` and resolved to `dirty` a minute later. A
#     tool that believed the first read would have called a conflicted PR landable.
#
#   * ZERO check runs is NOT green (#606). "Every check passed" and "CI never started" are the SAME
#     EMPTY SET — and a conflicted PR gets no CI at all, because GitHub cannot build
#     `refs/pull/N/merge` while it conflicts, so no workflow ever starts and the head commit has zero
#     check runs forever. An absent subject is a FINDING, not a pass (epic #266). Hence `red`, never
#     `green`, for a PR with no checks.
#
# And note what is NOT used to read `mergeable`: jq's `//`. `.mergeable // "null"` collapses **false
# into the fallback** — `//` takes its RHS when the LHS is false OR null — so a CONFLICTED PR would
# report as `unknown`, and the one state we most need to name would be the one we could never see.
# `tostring` tells all three apart.
#
# SUPERSESSION, as one expression, because it is applied to TWO things (the runs, and the check-runs
# of the runs it kills) and the two must never drift apart. Splits the runs on a head SHA into:
#
#   .live — the runs that still mean something
#   .dead — the check_suite_id of every run a later run of its OWN concurrency group replaced
#
# `cgroup` is the key `cancel-in-progress` actually cancels on. See the note at the call site for why
# matching it exactly — rather than on `.path` — is what stops the drop rule becoming a hole (#703).
SUPERSEDE_JQ='
  def cgroup: [.path, .event, .head_branch, ([.pull_requests[]?.number] | sort)];
  . as $all
  | def replaced($r): [$all[] | select(cgroup == ($r|cgroup) and .run_number > $r.run_number)] | length > 0;
    { live: [ $all[] | . as $r | select($r.conclusion != "cancelled" or (replaced($r) | not)) ],
      dead: [ $all[] | . as $r | select($r.conclusion == "cancelled" and replaced($r)) | .check_suite_id ] }'

# Prints exactly one of: green | conflicted | red | pending | unknown
# `pr_landable` keeps its one-word contract for its three callers (`adopt`, `who`, `reap`). The PROBE
# underneath also publishes PR_LAND_N — the number of SUBJECTS it actually scored (live runs + live
# check-runs) — because `landable --wait` cannot do its job without it. `green` and `red` both mean
# something DIFFERENT at N=0: not "clean" and not "failed", but "CI has not started yet", which is the
# normal state for the first 20-60s after a push. A waiter that cannot see N cannot tell a PR whose
# workflows have not registered from one that has none at all (#606), and would either merge a partial
# rollup or reject a perfectly good PR for being early.
#
# It publishes through a GLOBAL rather than stdout because `$(pr_landable …)` is a SUBSHELL: anything
# the function sets there is lost. `landable --wait` therefore calls the probe DIRECTLY, in the current
# shell, and reads both values back.
pr_landable() {  # $1=owner $2=repo $3=pr -> green|conflicted|red|pending|unknown
  pr_landable_probe "$@"
  printf '%s\n' "$PR_LAND_V"
}

PR_LAND_V=""; PR_LAND_N=0
pr_landable_probe() {  # $1=owner $2=repo $3=pr -> sets PR_LAND_V (verdict) and PR_LAND_N (subjects scored)
  local pr m sha runs live checks total pend bad try
  PR_LAND_V="unknown"; PR_LAND_N=0
  # THE RETRY HAS TO WAIT, OR IT IS NOT A RETRY. GitHub computes mergeability in a BACKGROUND JOB and
  # returns `null` until it lands; the documented remedy is to poll again *after a delay*. A second
  # read fired microseconds after the first cannot have observed a job that had not finished when the
  # first one asked — so a zero-delay retry is a no-op dressed as diligence, and every freshly-touched
  # PR would collapse to `unknown`. That is the exact case this function exists for: the observed #692
  # took ~1 minute to resolve from `null` to `dirty`. Bounded (3 tries, ~3s) — this runs on the
  # interactive path, and `unknown` is a safe answer, so we wait a little and then say we do not know.
  for try in 1 2 3; do
    pr="$(gh api "repos/$1/$2/pulls/$3" 2>/dev/null)"         || { PR_LAND_V=unknown; return 0; }
    m="$(jq -r '.mergeable | tostring' <<<"$pr" 2>/dev/null)" || { PR_LAND_V=unknown; return 0; }
    [ "$m" = "null" ] || break
    [ "$try" -eq 3 ] || sleep 1
  done
  if [ "$m" = "false" ]; then PR_LAND_V=conflicted; return 0; fi
  if [ "$m" != "true"  ]; then PR_LAND_V=unknown;    return 0; fi

  sha="$(jq -r '.head.sha // ""' <<<"$pr")"
  if [ -z "$sha" ]; then PR_LAND_V=unknown; return 0; fi

  # THE ROLLUP IS OVER WORKFLOW RUNS, NOT CHECK RUNS (#720). SUPERSESSION IS A PROPERTY OF THE RUN —
  # it is what `concurrency: cancel-in-progress` replaces — and it is NOT VISIBLE ON A CHECK RUN AT
  # ALL. The same workflow can run TWICE on one SHA (a second trigger starts a fresh run and cancels
  # the first), and BOTH runs' check-runs stay attached to that SHA forever. Aggregating them raw —
  # which is what this function used to do — sees `cancelled` and calls a GREEN PR red.
  #
  # That is not cosmetic here. `adopt` (#697) uses this verdict to tell FINISHED work from abandoned
  # work, and its whole population is PRs whose author was iterating when their harness died — i.e.
  # FORCE-PUSHED PRs, which are exactly the ones that carry superseded runs. The tool would point at
  # a green, mergeable, finished PR and refuse to land it, which is #697's remedy failing precisely
  # where #697 was aimed. Measured on .github#718: 20 check-runs, 4 `cancelled` from two superseded
  # suites, while GitHub itself said `mergeable_state=clean`.
  #
  # DO NOT "FIX" THIS BY DEDUPING CHECK-RUNS BY NAME. Six workflows in this repo name their job
  # `fixture`; collapsing by name lets one workflow's success mask another's failure. The obvious fix
  # is the wrong one, which is why it is written down. (#703 found the same trap in the recipe.)
  #
  # --paginate: this org runs ~30 workflows and the endpoint pages at 30. A truncated read reports a
  # clean page 1 while the run that would have stopped us sits on page 2 (#547).
  runs="$(gh api "repos/$1/$2/actions/runs?head_sha=$sha&per_page=100" --paginate --slurp 2>/dev/null \
          | jq -c '[.[].workflow_runs[]]' 2>/dev/null)" || { PR_LAND_V=unknown; return 0; }
  if [ -z "$runs" ]; then PR_LAND_V=unknown; return 0; fi

  # SUPERSEDED runs, and NOTHING else: a cancelled run that a LATER run of its OWN concurrency group
  # replaced. A cancelled run nobody re-ran is still a finding, and a FAILED run is never dropped —
  # so this cannot fail open.
  #
  # `cgroup` is the group `cancel-in-progress` actually keys on. Matching it EXACTLY is what stops
  # the drop rule being a hole: keying on `.path` alone would let a run from a DIFFERENT group
  # license the drop. A `workflow_dispatch` run on the same branch shares the SHA and the path and
  # carries a HIGHER run_number, but it is a different `github.ref` — it supersedes nothing — and a
  # gate job that is `if: github.event_name == 'pull_request'` SKIPS in it and still concludes
  # `success`. Dropping the cancelled PR run in its favour would count a vacuous green (#703).
  #
  # This yields BOTH the live runs and the check SUITES of the dead ones, because a superseded run's
  # check-runs stay attached to the SHA and have to be dropped with it.
  local dead
  live="$(jq -c "$SUPERSEDE_JQ | .live"  <<<"$runs" 2>/dev/null)" || { PR_LAND_V=unknown; return 0; }
  dead="$(jq -c "$SUPERSEDE_JQ | .dead"  <<<"$runs" 2>/dev/null)" || { PR_LAND_V=unknown; return 0; }
  if [ -z "$live" ] || [ -z "$dead" ]; then PR_LAND_V=unknown; return 0; fi

  # SCORE THE CHECK RUNS TOO — the union, not either alone. Each sees a failure the other cannot:
  #
  #   * A run can fail with NO CHECK RUNS AT ALL. `startup_failure` (malformed workflow YAML) concludes
  #     the RUN as `failure` and never creates a job, so a check-runs-only rollup sees nothing and
  #     calls it green. Same for a run still `queued`: its check-runs do not exist yet, so the checks
  #     that DO exist can all be complete and green while a workflow has not started.
  #   * A CHECK RUN can fail while its run SUCCEEDS. A job-level `continue-on-error: true` concludes
  #     the job's check-run `failure` and the workflow run `success` — and branch protection scores
  #     CHECK RUNS, so GitHub would block a merge this function had called green. (Step-level
  #     continue-on-error does not diverge; only the job-level form does.)
  #   * And check-runs are the ONLY place a non-Actions app appears at all. This function used to read
  #     them, so scoring runs alone would silently drop third-party coverage — #266's signature,
  #     introduced by the fix for it. A foreign app's suite is never in the runs list, so it is never
  #     in `dead`, so it is never dropped: it is scored by construction, with no special case.
  #
  # `--paginate`, again, and for the same reason (#547).
  checks="$(gh api "repos/$1/$2/commits/$sha/check-runs" --paginate --slurp 2>/dev/null \
            | jq -c --argjson dead "$dead" '[.[].check_runs[] | select([.check_suite.id] - $dead | length > 0)]' 2>/dev/null)" \
    || { PR_LAND_V=unknown; return 0; }
  if [ -z "$checks" ]; then PR_LAND_V=unknown; return 0; fi

  # #606: an EMPTY subject is a FINDING, not a pass. "Every check passed" and "CI never started" are
  # the same empty set, and a CONFLICTED PR is permanently in it — GitHub cannot build
  # refs/pull/N/merge while it conflicts, so no workflow ever starts and the head SHA has zero runs
  # forever. One jq over both lists rather than six.
  #
  # THE TWO LISTS GO IN ON STDIN, NOT THROUGH `--argjson`. Linux caps a SINGLE argv string at 128KB
  # (MAX_ARG_STRLEN — a much lower ceiling than the ~2MB ARG_MAX everyone quotes), and a workflow_run
  # carries whole `repository` / `head_repository` / `head_commit` objects, so ELEVEN real runs are
  # already ~150KB. `--argjson` therefore died with "Argument list too long" on essentially every real
  # PR in this repo, and returned `unknown` — while every unit test passed, because a fixture's runs
  # are three fields long. Caught only by driving it against a live PR. stdin has no such ceiling, so
  # this cannot come back as the payload grows.
  local roll
  roll="$(printf '%s\n%s\n' "$live" "$checks" | jq -rs '
      (.[0] + .[1]) as $all
      | [ ($all | length),
          ([$all[] | select(.status != "completed")] | length),
          ([$all[] | select(.status == "completed"
                            and .conclusion != "success" and .conclusion != "skipped")] | length) ]
      | @tsv' 2>/dev/null)" || { PR_LAND_V=unknown; return 0; }
  read -r total pend bad <<<"$roll"
  [ -n "${bad:-}" ] || { PR_LAND_V=unknown; return 0; }

  # Publish the subject count. `--wait` needs it to tell "CI has not started YET" (normal for 20-60s
  # after a push) from "this PR has no checks at all" (#606's finding) — the two are the same empty
  # set, and only TIME tells them apart.
  PR_LAND_N="$total"

  if [ "$total" -eq 0 ]; then PR_LAND_V=red;     return 0; fi
  if [ "$pend"  -gt 0 ]; then PR_LAND_V=pending; return 0; fi
  if [ "$bad"   -gt 0 ]; then PR_LAND_V=red;     return 0; fi
  PR_LAND_V=green
}

# `landable <pr>` — pr_landable's verdict, as a COMMAND (#724).
#
# WHY THIS EXISTS AT ALL. This gate has now been written FOUR times, in four copies: `/pnext-item` §5
# (fixed for pagination in #547, for zero-checks in #606, for supersession in #703), the
# skill-registry autofix bot (#710 — it read its OWN superseded runs as RED and refused to merge the
# PR it had just pushed), and this function (#720). Every one of those fixes edited a COPY. Nothing
# executes a recipe, so nothing tests one — and the result was backwards: the copy that IS testable
# was the copy still carrying the bug, while the untested prose was right.
#
# A recipe should NAME the command, not EMBED the logic. That is also what makes protocol staleness
# harmless: a recipe is copied into an agent's context at session start and never refreshed, so a
# worker can execute a gate the org fixed hours earlier (measured: .github#718 was red-lit by a
# nine-commit-stale snapshot of §5, and the worker then re-filed the fixed bug as #719). A recipe that
# CALLS this reads the CURRENT tool off disk at run time. The prose may drift; the behaviour cannot.
# That is #609's "an import cannot drift by construction", applied to the protocol itself.
#
# The verdict goes to STDOUT and the DECISION goes to the exit code, so a poll loop can tell "keep
# waiting" from "stop" without parsing prose:
#
#   0  green        — mergeable, and every live run/check passed
#   3  pending      — checks still running. RETRY; this is the only verdict worth waiting on.
#   1  red | conflicted | unknown — do not merge, and do not wait: none of these clear by waiting.
landable_cmd() {
  local repo="" pr="" v wait="" tries=30 interval=20
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)  repo="${2:?--repo needs a value}"; shift 2 ;;
      --wait)  wait=1; shift ;;
      --tries) tries="${2:?--tries needs a value}"; shift 2 ;;
      --interval) interval="${2:?--interval needs a value}"; shift 2 ;;
      -*)      die "landable: unknown flag '$1'" ;;
      *)       pr="$1"; shift ;;
    esac
  done
  [ -n "$pr" ] || die "landable: <pr> required (the PULL number — not the item number)"
  case "$pr" in ''|*[!0-9]*) die "landable: '$pr' is not a pull number. This takes the PR number, not an issue ref." ;; esac

  # scope_repo, not `gh repo view`: it reads the git remote — free, offline, and it cannot misreport
  # an exhausted GraphQL budget as "you are in the wrong directory" (#430).
  local scope O R
  scope="$(scope_repo "$repo")"
  [ -n "$scope" ] || die "landable: could not determine which repo PR #$pr is in — no --repo given, and no readable 'origin' remote here. Pass --repo FS-GG/<repo>."
  if [[ "$scope" == */* ]]; then O="${scope%%/*}"; R="${scope#*/}"
  else O="$OWNER"; R="$(resolve_repo "$scope")"; fi

  if [ -z "$wait" ]; then
    v="$(pr_landable "$O" "$R" "$pr")"
  else
    # --wait: poll until the verdict SETTLES. Two things must be true before a `green` can be believed,
    # and a naive "poll until not pending" gets BOTH of them wrong:
    #
    #  1. THE SUBJECT MUST EXIST. For the first 20-60s after a push there are ZERO runs, which scores
    #     as `red` (#606 — an empty subject is a finding). Reporting that would reject every PR for the
    #     crime of being new. So while N==0 we WAIT; only if it never registers does the red stand, and
    #     then it is the honest #606 finding: CI never started (a conflicted PR is the usual cause, and
    #     it short-circuits to `conflicted` above before ever reaching here).
    #
    #  2. THE SUBJECT MUST STOP GROWING. GitHub schedules a PR's workflows over 20-60s, so the set
    #     GROWS: an early poll can legitimately see "2 runs, both green" while six more have not been
    #     CREATED yet. Breaking there hands the gate a PARTIAL rollup and calls it complete — #606's
    #     defect at one remove, and it merges a PR most of whose checks never ran. So a `green` is only
    #     believed once the COUNT HAS BEEN STABLE across two consecutive polls. It costs one extra
    #     interval on the happy path, which is the cheapest insurance in this tool.
    #
    # `red` (with subjects), `conflicted` and `unknown` are returned IMMEDIATELY: none of them clear by
    # waiting, and spinning on them just delays the bad news.
    local prev=-1 i
    v="unknown"
    for i in $(seq "$tries"); do
      pr_landable_probe "$O" "$R" "$pr"          # direct call: a subshell would lose PR_LAND_N
      v="$PR_LAND_V"
      # `|| :` on every arm, because this file runs under `set -e`: a bare `[ … ] && break` whose test
      # is FALSE returns non-zero as the arm's last command, and would kill the whole tool mid-poll
      # instead of looping. The trailing `:` makes "keep waiting" an explicit success.
      case "$v" in
        conflicted) break ;;
        unknown)    break ;;
        # red at N=0 is "CI has not started YET", not "CI failed" — keep waiting for it to register.
        red)   { [ "$PR_LAND_N" -eq 0 ] || break; } || : ;;
        green) { [ "$PR_LAND_N" -gt 0 ] && [ "$PR_LAND_N" -eq "$prev" ] && break; } || : ;;
      esac
      prev="$PR_LAND_N"
      [ "$i" -lt "$tries" ] && sleep "$interval" || :
    done
  fi

  echo "$v"
  case "$v" in
    green)   return 0 ;;
    pending) return 3 ;;
    *)       return 1 ;;
  esac
}

# Every OPEN issue in a repo that could possibly hold a claim, with the body its touch-set is
# declared in. A claim marker IS a comment, so `comments == 0` cannot hold a lock: that prune is
# sound and free, straight off the list payload. Pull requests are excluded — a PR is neither
# claimable nor schedulable.
#
# --paginate, NOT the ETag-revalidated `issues` command, for two reasons, both load-bearing:
#   * `issues` asks for ONE page of 100. A repo's 101st open issue would silently never be a
#     candidate, so a live claim on it would be invisible and — via `batch` — its touch-set would be
#     handed to a second worker. The lock may not have a size limit.
#   * A lock may never be read from a CACHE. A 304 serving a body captured before the claim was
#     posted would report `comments: 0` and hide a live marker — the exact blind spot this exists to
#     close. Going direct means there is no ETag to be stale.
# A read we cannot complete DIES, exactly as `claims_of` and `paths_of` do: an unreadable repo may be
# holding claims, and answering "nothing is running" for it is how the scheduler double-books work.
open_claim_candidates() {  # $1=owner/repo -> JSON array of {number,title,url,body}
  local o="${1%%/*}" r="${1#*/}" out json
  out="$(gh api --paginate "repos/$o/$r/issues?state=open&per_page=100" \
           --jq '.[] | select(.pull_request == null) | select(.comments > 0)
                 | {number, title, url: .html_url, body: (.body // "")}' 2>/dev/null)" \
    || die "cannot list the open issues of $o/$r (rate limit? network? no access?) — refusing to guess which of its items are claimed."
  # A non-zero `gh` is not the only way this read fails (#461). A malformed or truncated page exits 0
  # and hands back bytes that are not JSON; `jq -s` then errors, and the caller — running under a
  # `set -e` that is SUPPRESSED in any `if`/`&&`/`$( )`-in-condition context — can carry on with an
  # empty candidate list. Name it and die, per this function's own contract above.
  json="$(printf '%s' "$out" | jq -s '.' 2>/dev/null)" \
    || die "the open-issue list for $o/$r came back malformed — refusing to guess which of its items are claimed."
  printf '%s' "$json"
}

# ---- active_claims: the one view of "what is actually running right now" -------------------------
# Everything that needs to reason about in-flight work — who, reap, batch, take, overlap --active,
# widen, inbox — reads it from here.
#
# THE MARKER IS THE LOCK, so the marker — not the board column — defines the candidate set. `claim`
# writes `Status: In progress` strictly best-effort (a subshell that swallows a Projects v2 5xx, and
# an item that is not on the board at all never gets a column). Seeding this set from the column
# alone therefore lost exactly the claims it most needed to see (FS-GG/.github#257): `who` could not
# report them, `reap` could not collect a dead worker off them, `inbox` dropped their messages, and —
# worse than the issue supposed — `batch` never RESERVED their touch-sets, so it would cheerfully
# schedule a Ready item overlapping an item somebody was already holding.
#
# So the candidates are a UNION of two arms:
#   A. board `Status: In progress` — an item here with NO marker is the state the FS-GG/.github
#      incident was found in: someone working outside the protocol, nothing recording who. We surface
#      that as `unclaimed` rather than pretending the item is free. Only this arm can produce it.
#   B. OPEN issues carrying at least one comment. A claim marker IS a comment, so `comments == 0`
#      cannot hold a lock — a sound, free prune straight off the list payload. This arm is what sees
#      a claim the board lost track of, wherever it sits (Ready, Backlog, or off-board entirely).
#
# Cost: the board scan is already paid for. Arm B adds one REST issue-list per repo (PAGINATED, see
# open_claim_candidates), which also carries each issue's body — so a touch-set costs zero extra
# reads. Each surviving candidate then costs one comments read.
#
# ---- scope_repo: the repo a WORKER command defaults to — the one you are standing in (#480) -------
#
# `take`/`batch`/`next`/`who` answer "what do I work on HERE" and "who else is HERE", and the protocol
# has always documented their default as the current checkout (pnext-item: *"Default: the repo you are
# standing in"*). It was never implemented. They initialised `repo=""` — and every board read treats
# an empty repo as THE WHOLE ORG — so a bare `take` in the `.github` checkout claimed FS.GG.Game#141,
# walked past four schedulable `.github` items, and printed
#
#     git worktree add ../FS.GG.Game-141 -b item/141-... origin/main
#
# where `origin/main` is `.github`'s. Follow that and you get a worktree of the WRONG REPOSITORY and
# start "working" an item whose files are not in it. Not a useless command — one that silently
# succeeds at the wrong thing: the #416 silent-no-op shape, one level up, in the dispatcher itself.
#
# NOT APPLIED TO EVERY --repo COMMAND, and the exceptions are the point:
#   * `ready` / `lint` are org-wide RECONCILERS. /check-board runs a BARE `ready --all` and `lint` to
#     reconcile the whole board; defaulting them to the checkout would silently shrink the reconciler
#     to one repo — trading this scope bug for a worse one, in the tool that exists to catch it.
#   * `inbox` is a MAILBOX. Another worker can `say` to you on any repo's issue — a cross-repo request
#     you filed, most obviously. Narrowing it to the checkout would silently HIDE mail. That is a drop,
#     not a scope.
#
# RESOLVED FROM THE GIT REMOTE, NOT `gh repo view`. The remote is free and offline; the API call costs
# budget and, worse, FAILS ON AN EXHAUSTED ONE — which `verify-paths` then reports as "not inside a
# GitHub checkout" (#430), a wrong cause stated with total confidence. A scheduling command that ran
# out of GraphQL must not tell the worker they are in the wrong directory.
scope_repo() {
  local repo="${1:-}"
  [ -n "$repo" ] && { printf '%s' "$repo"; return 0; }
  local url
  url="$(git config --get remote.origin.url 2>/dev/null || true)"
  # https://github.com/FS-GG/.github(.git) | git@github.com:FS-GG/.github(.git) | ssh://…/FS-GG/x.git
  case "$url" in
    *github.com[:/]*)
      repo="${url##*github.com}"; repo="${repo#[:/]}"; repo="${repo%.git}"; repo="${repo%/}"
      # Must look like owner/repo. Anything else (a bare host, a nested path) is not a scope.
      case "$repo" in */*/*|*/) repo="" ;; */*) : ;; *) repo="" ;; esac
      ;;
    *) repo="" ;;
  esac
  printf '%s' "$repo"
}

# KNOWN BOUND: with no --repo, the repos to scan are derived from the board. A claim in a repo with
# ZERO board items is therefore invisible to an org-wide `who`/`reap`. Pass --repo to reach it.
active_claims() {
  local repo="${1:-}"
  local board inprog repos cand n=0 i=0 tmp armA armB

  board="$(board_items)"
  inprog="$(board_filter "$repo" "In progress" "" "0" <<<"$board")"

  # Which repos could hold an off-board claim? Derive `owner/repo` from the board scan already in
  # hand. A --repo naming no board item at all still resolves, against the default owner.
  repos="$(board_filter "$repo" "" "" "0" <<<"$board" | jq -r '[.[].repo // empty] | unique | .[]')"
  if [ -z "$repos" ] && [ -n "$repo" ]; then
    case "$repo" in */*) repos="$repo" ;; *) repos="$OWNER/$repo" ;; esac
  fi

  # NEVER PASS THE CANDIDATE SET THROUGH `argv` (#497). Both arms carry each issue's full BODY — arm
  # B reads bodies on purpose, so a touch-set costs zero extra reads — and on Linux a SINGLE argument
  # is capped at MAX_ARG_STRLEN (128 KiB), independently of the much larger total ARG_MAX. Past that,
  # `execve` returns E2BIG, `jq` never runs, and the `$( )` yields the EMPTY STRING — which the next
  # iteration of an `--argjson`-accumulator loop feeds straight back in as `--argjson acc ''`
  # ("invalid JSON text"). The org crossed 128 KiB of open-issue bodies and every claim-aware read —
  # who, reap, batch, take, inbox, widen, overlap --active — died at once.
  #
  # So the arms travel as FILES, never as arguments: arm B streams to NDJSON (one row per candidate,
  # tagged with its repo), arm A lands as the array it already is, and the merge slurps both. That is
  # the same `mktemp` + `jq -s` idiom this function already uses to collect its own rows below, and
  # it is flat in the payload — a board twice this size costs the same argv.
  #
  # NOT YET FLAT, and deliberately out of this fix's scope: ONE candidate's body still rides argv,
  # via `--argjson it` and `paths_from_body` below. GitHub caps a body at 65,536 CHARACTERS, not
  # bytes, so a CJK/emoji-heavy body can still reach ~196 KB and breach the cap on its own (#507).
  armA="$(mktemp "$CACHE/.armA.XXXXXX")"; armB="$(mktemp "$CACHE/.armB.XXXXXX")"
  TMPFILES+=("$armA" "$armB")
  printf '%s' "$inprog" >"$armA"

  local r lst
  while IFS= read -r r; do
    [ -n "$r" ] || continue
    lst="$(open_claim_candidates "$r")"      # dies on an unreadable read — never hands back junk
    # A DROPPED REPO IS A FAIL-OPEN, so this append may not fail quietly. If it did — a partial write,
    # a full $CACHE — the loop would carry on, the merge would still produce a well-formed array over
    # the SURVIVING repos, and the guard below would wave it through: a claim in the dropped repo goes
    # invisible, its touch-set is never reserved, and `batch` hands the item to a second worker.
    jq -c --arg repo "$r" '.[] | . + {repo: $repo}' <<<"$lst" >>"$armB" \
      || die "cannot assemble the claim candidates for $r — refusing to proceed on a partial lock read."
  done <<<"$repos"

  # Merge the arms. `body` rides in from arm B (free touch-set); `inProgress` remembers arm A, which
  # is the ONLY thing that licenses an `unclaimed` verdict on a markerless item.
  # `--slurpfile a` wraps arm A's single array, hence `$a[0]`; arm B is NDJSON, so `$b` IS the rows.
  #
  # `$a[0]` is deliberately NOT defaulted (`// []`). `board_filter` is a jq `map(…)`, so on SUCCESS it
  # always emits an array — `[]` at the very least. An EMPTY armA therefore means the board read
  # FAILED, and defaulting it to `[]` would quietly rebuild the claim set from arm B alone: a
  # well-formed array, missing every board-`In progress` item, sailing straight past the fail-closed
  # guard below — including the markerless `unclaimed` verdicts that ONLY arm A can produce (#257).
  # Iterating null instead ERRORS, `$cand` comes back empty, and the guard does its job.
  cand="$(jq -c -n --slurpfile a "$armA" --slurpfile b "$armB" '
    ( [ $a[0][] | select(.number != null)
        | {repo, number, title, url, body: null, inProgress: true} ]
    + [ $b[] | {repo, number, title, url, body, inProgress: false} ] )
    | group_by("\(.repo)#\(.number)")
    | map({ repo:       .[0].repo,
            number:     .[0].number,
            title:      ([ .[].title ] | map(select(. != null and . != "")) | first // ""),
            url:        ([ .[].url  ] | map(select(. != null)) | first // null),
            body:       ([ .[].body ] | map(select(. != null)) | first // null),
            inProgress: ([ .[].inProgress ] | any) })
    | sort_by(.repo, .number)')" || true
  rm -f "$armA" "$armB"

  # FAIL CLOSED ON AN UNREADABLE CLAIM SET (#461, epic #266). `[]` is a CLAIM: "I read the locks and
  # nobody holds anything." A failed scan is not entitled to make it. If the merge above produced
  # nothing — a `gh` hiccup, a rate-limited read, a transient 5xx, a malformed page — `$cand` is the
  # EMPTY STRING, and `jq 'length'` on empty input prints nothing and EXITS 0, so `set -euo pipefail`
  # never fires. `n` is then `""`, `[ 0 -lt "" ]` errors with `integer expected`, the loop body never
  # runs, and this function returns `[]` — a failed read wearing an empty set's clothes.
  #
  # Downstream, that is a fail-open on the LOCK ITSELF: `take`/`batch` would schedule an item another
  # worker is actively holding, and `widen` would report a confident DISJOINT over a real collision.
  # So an unreadable claim set is a hard error, never an empty result. `n=0` (a valid, empty array) is
  # the only way to say "nothing is claimed", and it is reachable only when the scan actually SUCCEEDED.
  if ! jq -e 'type == "array"' >/dev/null 2>&1 <<<"$cand"; then
    die "cannot read the claim set${repo:+ for '$repo'} (rate limit? network? malformed scan?) — refusing to report an empty one. An empty claim set reads as 'nobody holds anything', which would hand a held item to a second worker."
  fi
  n="$(jq 'length' <<<"$cand")"
  case "$n" in
    ''|*[!0-9]*) die "the claim set${repo:+ for '$repo'} did not yield a count (got '$n') — refusing to proceed on an unread lock." ;;
  esac

  tmp="$(mktemp "$CACHE/.claims.XXXXXX")"; TMPFILES+=("$tmp")
  while [ "$i" -lt "$n" ]; do
    local it r2 num o rp claims paths pathsjson
    it="$(jq -c ".[$i]" <<<"$cand")"; i=$((i + 1))
    r2="$(jq -r '.repo // ""' <<<"$it")"; num="$(jq -r '.number // ""' <<<"$it")"
    { [ -n "$r2" ] && [ -n "$num" ]; } || continue
    o="${r2%%/*}"; rp="${r2#*/}"
    claims="$(claims_of "$o" "$rp" "$num")"

    # An arm-B candidate with no marker is just an issue that someone commented on — NOT in-flight.
    # Only arm A (the board's own `In progress`) may report a markerless item, and then as
    # `unclaimed`. Without this, every chatty open issue in the org would read as occupied work.
    if [ "$(jq 'length' <<<"$claims")" -eq 0 ] && [ "$(jq -r '.inProgress' <<<"$it")" != "true" ]; then
      continue
    fi

    if [ "$(jq -r '.body == null' <<<"$it")" = "true" ]; then
      paths="$(paths_of "$o" "$rp" "$num")"          # arm A only (board item, closed or unlisted)
    else
      paths="$(paths_from_body "$(jq -r '.body' <<<"$it")")"
    fi
    pathsjson="$(printf '%s' "$paths" | jq -R -s -c 'split("\n") | map(select(length > 0))')"

    jq -c -n --argjson it "$it" --argjson claims "$claims" --argjson paths "$pathsjson" '
      ($claims | map(select(.stale | not)) | first) as $live
      | ($claims | first) as $any
      | { repo: $it.repo, number: $it.number, title: $it.title, url: $it.url, paths: $paths,
          worker:  ($live.worker // $any.worker // null),
          claimId: ($live.id     // $any.id     // null),
          ageSec:  ($live.ageSec // $any.ageSec // null),
          state:   (if $live then "held" elif $any then "stale" else "unclaimed" end) }' >>"$tmp"
  done
  jq -s '.' "$tmp"; rm -f "$tmp"
}

# Local worktrees, joined into `who --local` so "what is that worktree doing?" needs no forensics.
# `fsgg.worker` is stamped by `claim`; the branch name carries the item number as a fallback.
local_worktrees() {
  # `|| true`: outside a git checkout this must yield an empty join, not kill the caller via pipefail.
  { git worktree list --porcelain 2>/dev/null || true; } | awk '
    /^worktree /{ path = substr($0, 10); branch = ""; next }
    /^branch /   { branch = substr($0, 8); sub("refs/heads/", "", branch)
                   item = ""
                   if (branch ~ /^item\//) { item = branch; sub("^item/", "", item); sub("-.*", "", item) }
                   printf "{\"path\":\"%s\",\"branch\":\"%s\",\"item\":\"%s\"}\n", path, branch, item }
  ' | while read -r line; do
        local p; p="$(jq -r '.path' <<<"$line")"
        local w; w="$(git -C "$p" config --get fsgg.worker 2>/dev/null || echo "")"
        jq -c --arg w "$w" '. + {worker: $w}' <<<"$line"
      done | jq -s '.'
}

overlap_cmd() {
  local a="" b="" against_active=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --active) against_active=1; shift ;;
      -*) die "overlap: unknown flag '$1'." ;;
      *)  if   [ -z "$a" ]; then a="$1"
          elif [ -z "$b" ]; then b="$1"
          else die "overlap: unexpected argument '$1'."; fi; shift ;;
    esac
  done
  [ -n "$a" ] || die "overlap: an issue ref is required (overlap <a> <b>, or overlap <a> --active)."

  # --- <a> against every in-flight claim -----------------------------------------------------------
  if [ -n "$against_active" ]; then
    [ -z "$b" ] || die "overlap: --active takes one issue ref, not two."
    parse_ref "$a"; local ar="$R_REPO" an="$R_NUM" ao="$R_OWNER" aid="$R_OWNER/$R_REPO#$R_NUM"
    local pa; pa="$(paths_for_ref "$a")"
    [ -n "$pa" ] || { echo "overlap: no 'Paths:' touch-set declared on $ar#$an — add one to schedule it." >&2; return 2; }
    local abad; abad="$(invalid_paths "$pa")"
    if [ -n "$abad" ]; then
      echo "overlap: $ar#$an declares unmatchable touch-set token(s): $(fmt_bad_paths "$abad")" >&2
      echo "  $TOUCHSET_GRAMMAR" >&2
      echo "  refusing to answer — a token that matches nothing would read as DISJOINT against everything." >&2
      return 2
    fi

    local claims n=0 i=0 found=0
    # Scope to <a>'s own repo, for the same reason `widen` and `batch` do: `Paths:` tokens are
    # repo-relative, so a claim in another repo can never share a file with <a>, and comparing across
    # the boundary only manufactures phantom overlaps (#353). "against every in-flight claim" means
    # every claim that could actually contend for <a>'s files — which is every claim in <a>'s repo.
    claims="$(active_claims "$ao/$ar")"
    n="$(jq 'length' <<<"$claims")"
    # An in-flight claim whose own touch-set is unmatchable reserves NOTHING, so clearing <a> against
    # it would be an answer about a surface we cannot see. Refuse before comparing against any of them.
    local cbad
    cbad="$(claims_with_unmatchable_paths "$claims")"
    if [ -n "$cbad" ]; then
      echo "overlap: in-flight claim(s) declare unmatchable touch-set token(s): $cbad" >&2
      echo "  their touch-sets reserve nothing, so no answer here is trustworthy. Fix them: fsgg-coord widen <issue> --paths '<paths>'" >&2
      return 2
    fi
    while [ "$i" -lt "$n" ]; do
      local c cid pb hits
      c="$(jq -c ".[$i]" <<<"$claims")"; i=$((i + 1))
      cid="$(jq -r '"\(.repo)#\(.number)"' <<<"$c")"
      [ "$cid" = "$aid" ] && continue
      pb="$(jq -r '.paths[]?' <<<"$c")"
      hits="$(conflicts_between "$pa" "$pb")"
      [ -n "$hits" ] || continue
      found=1
      printf 'OVERLAP — %s ⇄ %s (worker %s, %s)\n' "$ar#$an" \
        "$(jq -r '.repo | sub("^[^/]+/"; "")' <<<"$c")#$(jq -r '.number' <<<"$c")" \
        "$(jq -r '.worker // "unclaimed"' <<<"$c")" "$(jq -r '.state' <<<"$c")"
      printf '  %s\n' "$hits"
    done
    if [ "$found" -eq 0 ]; then
      printf 'DISJOINT — %s may run alongside all %s in-flight claim(s).\n' "$ar#$an" "$n"
      return 0
    fi
    echo "  sequence with 'Blocked by', or coordinate: fsgg-coord say <their-issue> --to <worker> '...'" >&2
    return 1
  fi

  # --- pairwise -------------------------------------------------------------------------------------
  [ -n "$b" ] || die "overlap: two issue refs required (overlap <a> <b>), or pass --active."
  parse_ref "$a"; local ar="$R_REPO" an="$R_NUM" ao="$R_OWNER"
  parse_ref "$b"; local br="$R_REPO" bn="$R_NUM" bo="$R_OWNER"
  # `Paths:` tokens are repo-relative, so two items in DIFFERENT repos never name the same file — they
  # live in separate checkouts and can always run in parallel. Answer that directly rather than handing
  # cross-repo tokens to `conflicts_between`, which cannot see a repo and would read a shared prefix
  # (`scripts/fsgg-coord` ⇄ `scripts/fsgg-coord`) as a phantom overlap (#353). Compare the NORMALIZED
  # owner/repo, so `SDD#1` and `FS-GG/FS.GG.SDD#2` still count as one repo.
  if [ "$ao/$ar" != "$bo/$br" ]; then
    printf 'DISJOINT — %s and %s are in different repos; their touch-sets cannot overlap.\n' "$ar#$an" "$br#$bn"
    return 0
  fi
  local pa pb; pa="$(paths_for_ref "$a")"; pb="$(paths_for_ref "$b")"
  if [ -z "$pa" ] || [ -z "$pb" ]; then
    local which=""
    [ -z "$pa" ] && which="$ar#$an"
    [ -z "$pb" ] && which="${which:+$which and }$br#$bn"
    echo "overlap: no 'Paths:' touch-set declared on $which — add one (e.g. 'Paths: src/Foo/**') to schedule it." >&2
    return 2
  fi
  local abad bbad; abad="$(invalid_paths "$pa")"; bbad="$(invalid_paths "$pb")"
  if [ -n "$abad" ] || [ -n "$bbad" ]; then
    [ -n "$abad" ] && echo "overlap: $ar#$an declares unmatchable touch-set token(s): $(fmt_bad_paths "$abad")" >&2
    [ -n "$bbad" ] && echo "overlap: $br#$bn declares unmatchable touch-set token(s): $(fmt_bad_paths "$bbad")" >&2
    echo "  $TOUCHSET_GRAMMAR" >&2
    echo "  refusing to answer — a token that matches nothing would read as DISJOINT against everything." >&2
    return 2
  fi

  local hits; hits="$(conflicts_between "$pa" "$pb")"
  if [ -z "$hits" ]; then
    printf 'DISJOINT — %s and %s may run in parallel (own worktree each).\n' "$ar#$an" "$br#$bn"
    return 0
  fi
  printf 'OVERLAP — %s and %s share touch-set; sequence them (board `Blocked by`), do NOT parallelize:\n' "$ar#$an" "$br#$bn"
  printf '  %s\n' "$hits"
  return 1
}

# ---- who: the answer to "what is actually going on", without spelunking through worktrees ---------
who_cmd() {
  local repo="" json="" want_local=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)  repo="${2:?--repo needs a value}"; shift 2 ;;
      --local) want_local=1; shift ;;
      --json)  json=1; shift ;;
      -*)      die "who: unknown flag '$1'." ;;
      *)       die "who: unexpected argument '$1'." ;;
    esac
  done
  # "Is everything here already claimed?" — the recipe's own diagnosis step, and it is about THIS
  # repo (#480). /check-board passes `--repo` explicitly, so it is unaffected.
  repo="$(scope_repo "$repo")"
  [ -n "$repo" ] && repo="$(resolve_repo "$repo")"
  local claims; claims="$(active_claims "$repo")"

  if [ -n "$want_local" ]; then
    local wts; wts="$(local_worktrees)"
    claims="$(jq -c --argjson wts "$wts" '
      map(. as $c | . + { worktree: ( $wts
            | map(select((.item | tostring) == ($c.number | tostring)) | .path) | first // null ) })' <<<"$claims")"
  fi

  # #581: a bare `STALE` and `STALE (PR #433 open)` are not the same fact, and `who` is what a human
  # reads immediately before deciding to reap. Probe only the STALE rows — a held claim needs no proof
  # of life, and an unclaimed item has nothing to prove. REST, and rare.
  local nstale
  nstale="$(jq '[.[] | select(.state == "stale")] | length' <<<"$claims")"
  if [ "$nstale" -gt 0 ]; then
    local k=0 kn cwr cwn cwc cwpr cwl cwlp enriched="[]"
    kn="$(jq 'length' <<<"$claims")"
    while [ "$k" -lt "$kn" ]; do
      cwc="$(jq -c ".[$k]" <<<"$claims")"; k=$((k + 1))
      if [ "$(jq -r '.state' <<<"$cwc")" = "stale" ]; then
        cwr="$(jq -r '.repo' <<<"$cwc")"; cwn="$(jq -r '.number' <<<"$cwc")"
        cwpr="$(pr_alive "${cwr%%/*}" "${cwr#*/}" "$cwn")"
        # ...and what the PR SAYS, not merely that it exists (#697). `who` is what a human reads
        # immediately before deciding to reap, so it is exactly where "this work is FINISHED" has to
        # be visible — a bare `STALE (#715 OPEN)` reads as "somebody's abandoned branch".
        cwl=""
        if [ -n "$cwpr" ]; then
          cwlp="${cwpr%% *}"; cwlp="${cwlp#\#}"
          cwl="$(pr_landable "${cwr%%/*}" "${cwr#*/}" "$cwlp")"
        fi
        cwc="$(jq -c --arg pr "$cwpr" --arg l "$cwl" \
                 '. + { livePr: (if $pr == "" then null else $pr end),
                        prState: (if $l == "" then null else $l end) }' <<<"$cwc")"
      fi
      enriched="$(jq -c --argjson c "$cwc" '. + [$c]' <<<"$enriched")"
    done
    claims="$enriched"
  fi

  if [ -n "$json" ]; then jq '.' <<<"$claims"; return 0; fi

  if [ "$(jq 'length' <<<"$claims")" -eq 0 ]; then
    echo "fsgg-coord: nothing is in flight${repo:+ for repo '$repo'} (no claim markers, no items In progress)."
    return 0
  fi
  jq -r --arg wt "${want_local:-}" '.[]
    | ((.repo // "" | sub("^[^/]+/"; "")) + "#" + (.number | tostring)) as $item
    | (if .ageSec == null then "—" elif .ageSec < 3600 then "\(.ageSec / 60 | floor)m"
       else "\(.ageSec / 3600 | floor)h" end) as $age
    | (if .state == "held" then "ok"
       elif .state == "stale" then
         (if .livePr then
            (.livePr | split(" ")[0]) as $p
            | (if   .prState == "green"      then "STALE (\($p) OPEN — GREEN: LAND IT)"
               elif .prState == "conflicted" then "STALE (\($p) OPEN — conflicted)"
               elif .prState == "pending"    then "STALE (\($p) OPEN — checks running)"
               elif .prState == "red"        then "STALE (\($p) OPEN — not green)"
               else "STALE (\($p) OPEN)" end)
          else "STALE" end)
       else "UNCLAIMED" end) as $lease
    | ((.paths // []) | if length == 0 then "—" else join(" ") end) as $paths
    | [ (.worker // "—"), $item, $age, $lease ]
      + (if $wt != "" then [ (.worktree // "—") ] else [] end)
      + [ $paths, (.title // "") ] | @tsv' <<<"$claims" \
  | { if [ -n "$want_local" ]; then printf "WORKER\tITEM\tAGE\tLEASE\tWORKTREE\tPATHS\tTITLE\n"
      else printf "WORKER\tITEM\tAGE\tLEASE\tPATHS\tTITLE\n"; fi; cat; } | column -t -s $'\t'

  local stale unclaimed orphans
  stale="$(jq '[.[] | select(.state == "stale")] | length' <<<"$claims")"
  unclaimed="$(jq '[.[] | select(.state == "unclaimed")] | length' <<<"$claims")"
  # FINISHED work behind a dead worker gets its OWN line, and it comes first (#697). Folding it into
  # the generic "reap these" hint is how the best work on the board ends up in the bin: `reap` is a
  # destructive verb, and pointing it at a green, mergeable PR is precisely the advice this change
  # exists to delete.
  orphans="$(jq -r '[.[] | select(.state == "stale") | select(.prState == "green")]
                    | map((.repo // "" | sub("^[^/]+/"; "")) + "#" + (.number | tostring)) | join(", ")' <<<"$claims")"
  if [ -n "$orphans" ]; then
    echo "fsgg-coord: $orphans — the claim is DEAD but the PR is GREEN and MERGEABLE: that work is FINISHED." >&2
    echo "fsgg-coord:   Do NOT reap or close it. Land it:" >&2
    # NAME THE ITEM. Every other remedy in this tool interpolates the concrete ref, and friction on
    # the remedy is exactly what pushes a worker back to the destructive default.
    jq -r '.[] | select(.state == "stale") | select(.prState == "green")
           | "fsgg-coord:     fsgg-coord adopt " + (.repo // "" | sub("^[^/]+/"; "")) + "#" + (.number | tostring)' <<<"$claims" >&2
  fi
  [ "$stale" -gt 0 ] && echo "fsgg-coord: $stale claim(s) past their ${CLAIM_LEASE_MIN}m lease — 'fsgg-coord reap --apply' to release (it REFUSES any whose work is still alive)." >&2
  [ "$unclaimed" -gt 0 ] && echo "fsgg-coord: $unclaimed item(s) In progress with NO claim marker — someone is working outside the protocol." >&2
  return 0
}

# ---- reap: collect the claims of workers that died. Dry-run unless --apply. -----------------------
# A crashed agent holds its item forever, because nothing renews and nothing expires on its behalf.
# Reaping is destructive to someone else's lock, so it defaults to a report and it TELLS the worker
# (over the channel) that its claim was collected — a worker that is merely slow can then re-claim.
reap_cmd() {
  local repo="" apply=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)  repo="${2:?--repo needs a value}"; shift 2 ;;
      --apply) apply=1; shift ;;
      -*)      die "reap: unknown flag '$1'." ;;
      *)       die "reap: unexpected argument '$1'." ;;
    esac
  done
  # Scoped to the checkout like its siblings (#480) — and this is the one where it matters most.
  # `reap --apply` DESTROYS state: it deletes another worker's claim marker and unassigns them. A
  # destructive command whose bare default is THE WHOLE ORG is the scope bug at its worst — a janitor
  # run in `.github` would collect live-looking claims in five other repos it was never pointed at.
  # Every documented use already passes --repo; nothing relied on the org-wide default.
  repo="$(scope_repo "$repo")"
  [ -n "$repo" ] && repo="$(resolve_repo "$repo")"
  local stale n=0 i=0
  stale="$(active_claims "$repo" | jq -c '[.[] | select(.state == "stale")]')"
  n="$(jq 'length' <<<"$stale")"
  if [ "$n" -eq 0 ]; then
    echo "fsgg-coord: no expired claims${repo:+ for repo '$repo'} (lease ${CLAIM_LEASE_MIN}m)."
    return 0
  fi
  while [ "$i" -lt "$n" ]; do
    local c r num o rp cw cid age
    c="$(jq -c ".[$i]" <<<"$stale")"; i=$((i + 1))
    r="$(jq -r '.repo' <<<"$c")"; num="$(jq -r '.number' <<<"$c")"
    cw="$(jq -r '.worker' <<<"$c")"; cid="$(jq -r '.claimId' <<<"$c")"
    age="$(jq -r '.ageSec / 60 | floor' <<<"$c")"
    o="${r%%/*}"; rp="${r#*/}"
    # PROOF OF LIFE OUTRANKS THE LEASE (#581). This is the destructive path, and it is the one that
    # reaped the claim on #485 itself — mid-test-cycle, work uncommitted — while its worker was very
    # much alive. The work survived only because the reaping worker chose to preserve the worktree as
    # a WIP commit. That is generosity, not a guarantee, and a janitor must not depend on it.
    local alive
    alive="$(pr_alive "$o" "$rp" "$num")"
    if [ -n "$alive" ]; then
      # AND NOW READ WHAT THE PR SAYS (#697). Refusing on the PR's mere EXISTENCE is right, but the
      # remedy that used to follow — "close it, then reap" — is aimed at every open PR alike, and for
      # a green, mergeable one it is a loaded gun pointed at the best work on the board. Tell the
      # three states apart, and only ever advise closing the one that is genuinely abandoned.
      local apr aland
      apr="${alive%% *}"; apr="${apr#\#}"
      aland="$(pr_landable "$o" "$rp" "$apr")"
      if [ "$aland" = "green" ]; then
        printf 'REFUSING %s#%s  worker %s  (idle %sm) — PR %s is OPEN, GREEN and MERGEABLE.\n' \
          "$rp" "$num" "$cw" "$age" "$alive"
        printf '  This work is FINISHED. Its worker died between "green" and "merge" — the window this\n' >&2
        printf '  protocol leaves open on every single item. Do NOT close it: closing it destroys a\n' >&2
        printf '  reviewed, passing fix and makes the next worker rebuild it from nothing. LAND IT:\n' >&2
        printf '      fsgg-coord adopt %s#%s\n' "$rp" "$num" >&2
        continue
      fi
      printf 'REFUSING %s#%s  worker %s  (idle %sm) — PR %s is OPEN (%s). The lease lapsed; the WORK did not.\n' \
        "$rp" "$num" "$cw" "$age" "$alive" "$aland"
      printf '  A long build outrunning a %sm lease is the systematic false positive here, and reaping\n' "$CLAIM_LEASE_MIN" >&2
      printf '  it destroys live, uncommitted work.\n' >&2
      case "$aland" in
        pending)
          # A MERGEABLE PR WHOSE CHECKS ARE STILL RUNNING IS NOT ABANDONED — it is one CI run away
          # from being FINISHED, and telling anyone to close it is the same loaded gun this change
          # exists to remove, fired a few minutes early. "Not green YET" is not "not green".
          printf '  Its checks are STILL RUNNING, so it is not abandoned — it is UNFINISHED, and it may be\n' >&2
          printf '  minutes from green. Do NOT close it. Let CI settle and look again:\n' >&2
          printf '      fsgg-coord who --repo %s        # green? then: fsgg-coord adopt %s#%s\n' "$rp" "$rp" "$num" >&2 ;;
        unknown)
          # We could not read the PR. That is a fact about US, not about the work — and it is the one
          # state in which advising a destructive act would be advising it on a guess.
          printf '  Its state could NOT be determined (rate limit? network?). Do not close it on a guess —\n' >&2
          printf '  look at PR %s yourself before deciding anything.\n' "$apr" >&2 ;;
        *)
          printf '  If the PR really is abandoned, close it, then reap. (It is %s, so there is nothing to\n' "$aland" >&2
          printf '  land as it stands — `adopt` only lands work that is green and mergeable.)\n' >&2 ;;
      esac
      continue
    fi
    if [ -z "$apply" ]; then
      printf 'would reap  %s#%s  worker %s  (idle %sm > %sm lease)\n' "$rp" "$num" "$cw" "$age" "$CLAIM_LEASE_MIN"
      continue
    fi
    # RE-VERIFY against a fresh read. `active_claims` was a snapshot; between it and this delete the
    # worker may have heartbeated. Deleting a live lock because it *used to be* stale is the one way
    # `reap` can itself cause the double-hold it exists to clean up.
    local now_state
    now_state="$(claims_of "$o" "$rp" "$num" | jq -c --argjson id "$cid" 'map(select(.id == $id)) | first // empty')"
    if [ -z "$now_state" ]; then
      printf 'skipped %s#%s  worker %s  — marker already gone\n' "$rp" "$num" "$cw"; continue
    fi
    if [ "$(jq -r '.stale' <<<"$now_state")" != "true" ]; then
      printf 'skipped %s#%s  worker %s  — renewed since the scan (%sm), still alive\n' \
        "$rp" "$num" "$cw" "$(jq -r '.ageSec / 60 | floor' <<<"$now_state")"; continue
    fi
    # DELETE FIRST, then tell the worker. Notifying before the delete lands means a failed delete
    # leaves the worker told-to-stop while its marker still holds the item for a full lease — an
    # item that is released to its owner and held against everyone else, which nothing clears.
    if ! delete_comment "$o" "$rp" "$cid"; then
      printf 'FAILED  %s#%s  worker %s  — could not remove the marker; board left untouched, worker not notified\n' "$rp" "$num" "$cw" >&2
      continue
    fi
    notify_reaped "$o" "$rp" "$num" "$cw" "$age" "$(worker)"
    # `reap` now collects claims on items the board never had (that is the point of finding them by
    # marker), so the Status write can legitimately have nothing to write to. Report what actually
    # happened rather than asserting a board mutation we may not have performed.
    #
    # Reaping UNDOES a claim, exactly as `release` does, so it owes the board the same answer and
    # asks the same question (#331). A worker whose lease expired on an item it had marked `Blocked`
    # must not have that column reset to `Ready` on its way out.
    #
    # And it restores the claim's own column rather than guessing `Ready` for it (#481), from the
    # `prev=` the dead worker's marker recorded. `now_state` is that marker, re-read fresh a few lines
    # above — the delete has already happened, so this is the last copy of it we will ever have.
    local rnote ract rval
    IFS=$'\t' read -r ract rval < <(unclaim_status "$r#$num" "$(jq -r '.prev // ""' <<<"$now_state")")
    case "$ract" in
      # As in `release`: an exhausted budget is not "not on board" — that misdiagnosis is #418's, and
      # it was still live here. Queue the reset in that case (#510); every other failure keeps the
      # existing wording, which correctly claims no reset it did not perform.
      write) wrc=0
             board_write "$r#$num" Status "$rval" || wrc=$?
             case "$wrc" in
               0)           rnote="board: $rval" ;;
               "$EX_RATE")  rnote="$BOARD_WRITE_NOTE" ;;
               *)           rnote="not on board (marker cleared; nothing to reset)" ;;
             esac ;;
      keep)  rnote="board: $rval (preserved)" ;;
      offboard)   rnote="not on board (marker cleared; nothing to reset)" ;;
      *)          rnote="board: Status unchanged — could not read it (marker cleared)" ;;
    esac
    printf 'reaped  %s#%s  worker %s  (idle %sm)  ·  %s\n' "$rp" "$num" "$cw" "$age" "$rnote"
  done
  [ -z "$apply" ] && echo "fsgg-coord: dry run — pass --apply to release these." >&2
  return 0
}

# ---- THE SHADOW: run the typed engine beside bash, return BASH's answer, log the difference -------
# ADR-0034 Phase 2. The coordination domain is moving to a typed F# core, and the one thing that may
# not happen on the way is a big-bang cutover: this tool schedules the work that rewrites this tool.
# So the engine runs in SHADOW — both engines decide, bash's answer is the one returned, and every
# disagreement is logged. Bash stays authoritative until the divergence log is empty. If the port
# stalls, the shadow costs nothing and bash keeps running.
#
# THREE RULES, AND THEY ARE NOT NEGOTIABLE:
#
#   1. THE SHADOW MAY NOT CHANGE THE ANSWER. Not the stdout, not the stderr, not the exit code. It is
#      an observer. `shadow_run` is called for its side effect on a LOG FILE and nothing else, and it
#      swallows every failure it can have.
#   2. THE SHADOW MAY NOT BREAK A RECEIVER. This script is byte-copied into six repos whose CI has no
#      .NET step until Phase 3. A missing engine is therefore a LOGGED SKIP, never an error — the
#      shadow simply does not run there.
#   3. ...AND THEREFORE IT MUST NOT BE ABLE TO GO SILENTLY VACUOUS. Rules 1 and 2 have just built a
#      component that is *designed* to do nothing when it goes wrong, which is the exact shape of epic
#      #266 — a check that fails open and reports green. So the log records the runs it SKIPPED and
#      why, `divergence` reports them, and .github's CI asserts the shadow actually executed. "Zero
#      divergence" must mean "we compared and they agreed", never "we never looked".
#
# WHAT IT COSTS. Zero GraphQL points: the engine reads NOTHING. Bash has already paid for the board
# scan and the claim markers by the time it decides, so it hands that state over on stdin. The one
# real cost is on the REST budget — the typed core checks the touch-set BEFORE the blockers, so a
# BLOCKED candidate (which bash short-circuits without ever reading a body) needs one body read and
# one marker read to reach the same question. That is bounded by the number of blocked candidates,
# it is on the 5,000-*requests*/hr budget rather than the 5,000-*points*/hr one that dies first, and
# it is paid only when the shadow is switched on. The log counts those reads rather than assuming
# them.
# AUTO, NOT OFF — and this is the difference between a shadow and a shadow-shaped ornament.
#
# The first cut defaulted to `bash`, faithfully to the roadmap's "defaulting off". The result is a
# harness that never runs: nothing in the fleet sets FSGG_COORD_ENGINE, so nothing ever compares, the
# divergence log stays empty forever, and the exit criterion this whole phase is FOR — zero divergence
# across the live fleet for three consecutive days — can never be met, because the clock never starts.
# An observer nobody switches on is not a cautious observer. It is a decoration.
#
# (That reasoning held, and then went further than it knew: ADR-0038 found the clock could not tick even
# with the shadow ON, because a worker in a per-item worktree resolves no engine at all — #728. The
# criterion is retired; `auto` remains right, for the reason given here.)
#
# So the default is AUTO: shadow WHEREVER AN ENGINE ACTUALLY EXISTS, and plain bash everywhere else.
# That is safe because "exists" is the honest gate — the six receivers have no engine on the
# coordination path until it is published, so they are byte-for-byte unaffected and cannot be broken
# by a thing that is not there. And it is safe because the shadow has been proven unable to change
# bash's answer, its exit code, or its life: 709 assertions, including a mutation test that removes
# the containment and watches the tool die.
#
#   auto (default)  shadow iff an engine resolves; bash otherwise. No ceremony, no env var, no opt-in.
#   bash            never shadow. The escape hatch, for when you want the old thing exactly.
#   shadow          always shadow; a missing engine is a LOGGED SKIP (you asked, we could not).
#   fs              THE ENGINE'S ANSWER IS THE ANSWER (ADR-0034 Phase 3b). Bash still reads the board,
#                   assembles the snapshot and performs every write — but the DECISION is the typed
#                   core's, and there is NO FALLBACK. An engine that cannot be resolved, is stale, or
#                   reaches no verdict is FATAL here, where in every other mode it is a logged skip.
#                   "The engine could not answer, so we quietly used the other one" is precisely the
#                   substitution this port exists to make impossible — and in the ledger it would be
#                   indistinguishable from agreement.
ENGINE_MODE="${FSGG_COORD_ENGINE:-auto}"
# The engine's decision document, set by `shadow_run` iff the engine actually produced one. In `fs`
# this IS the answer. In every other mode NOTHING may read it: rule 1 of this surface is that the
# observer may not change bash's answer, its exit code, or its life.
ENGINE_DECISION=""
# `fs` is the one mode with no second engine behind it.
engine_authoritative() { [ "$ENGINE_MODE" = fs ]; }
DIVERGENCE_LOG="${FSGG_COORD_DIVERGENCE_LOG:-$CACHE/divergence.jsonl}"
# How often the shadow may push its evidence to the fleet ledger. The hot scheduling loop may not pay the
# network on every call (ADR-0034 §5), so the publish is amortised: at most one REST write per window per
# machine, covering every worker that shares this cache. 0 disables the shadow-path publish entirely.
PUBLISH_EVERY_MIN="${FSGG_COORD_PUBLISH_EVERY_MIN:-30}"
SNAPSHOT_SCHEMA='fsgg.coord.snapshot/1'
SHADOW_EXTRA_READS=0
# Candidates the shadow could not OBSERVE (an unreadable body or marker on one of the items bash
# short-circuited). Distinct from a skipped RUN: the run happened, and it compared everything else.
# Conflating the two would let one unreadable issue read as "the shadow did not run", which is the
# number whose entire job is to stop a silent no-op from passing for agreement.
SHADOW_UNOBSERVED=0

# In `auto`, the presence of an engine IS the switch. In `shadow`, the switch is the caller's word, and
# a missing engine is a skip they get told about — because they asked for a comparison and did not get
# one, which is a different fact from "this machine does not do comparisons".
# `lanes` needs the item set the SCHEDULER sees — the same scan, the same bodies, the same claims — so
# that a lane can never disagree with the batch about what exists or what it reserves (#485). It must do
# that with the shadow OFF, so the collection is switched on independently of shadowing. Collecting is
# free: it appends to a temp file and decides nothing.
LANES_COLLECT=""
shadow_collecting() { [ -n "$LANES_COLLECT" ] && return 0; shadow_enabled; }

# A REPO THAT DECLARED AN ENGINE AND CANNOT RUN IT IS BROKEN — AND IT MAY NOT SAY SO IN SILENCE.
#
# `auto` means "shadow iff an engine resolves; bash otherwise", and for a machine that never asked for an
# engine that is right: it does not participate, and a skip line on every scheduling call would be noise
# about a decision nobody made.
#
# But a receiver with `fsgg-coord-engine` in its `.config/dotnet-tools.json` DID ask. It was configured to
# shadow, Renovate keeps its version current, and the kit distributes the file. If it then cannot run the
# thing it declared, that is a BROKEN receiver — and under the old resolve-here-and-return-false it went
# quiet, producing a log byte-identical to a machine that never scheduled anything. `divergence --fleet`
# read the difference as "a day nobody looked". It could not have read it as anything else.
#
# "We could not compare" and "we did not try" are different facts, and the whole of #266 is the refusal to
# let one stand in for the other. So a repo that DECLARED an engine shadows — and if the engine will not
# run, `shadow_run` records exactly that.
engine_declared() {  # 0 iff this repo's tool manifest asks for the engine
  local top manifest
  top="$(git_toplevel)" || return 1
  [ -n "$top" ] || return 1
  manifest="$top/.config/dotnet-tools.json"
  [ -f "$manifest" ] || return 1
  jq -e '.tools | to_entries[] | select(.value.commands // [] | index("fsgg-coord-engine"))' \
     >/dev/null 2>&1 <"$manifest"
}

shadow_enabled() {
  case "$ENGINE_MODE" in
    shadow|fs) return 0 ;;
    auto)      engine_resolve && return 0
               engine_declared ;;
    *)         return 1 ;;
  esac
}

# HOW TO RUN THE ENGINE — AND IT IS AN ARGV, NOT A PATH, BECAUSE A LOCAL TOOL IS NOT ON $PATH.
#
# This is the trap that would have made the whole distribution a no-op. `dotnet tool restore` installs
# a MANIFEST-scoped ("local") tool, and a local tool is deliberately NOT placed on $PATH — it is
# invoked as `dotnet tool run <command>`. So a receiver could take the package, restore it, and have
# `command -v fsgg-coord-engine` still find NOTHING: the manifest lands, the tool restores, and the
# shadow silently never runs. The tool would be shipped, installed, and inert — which is the exact
# shape of every defect this engine exists to end, one layer beneath it.
#
# ADR-0034 §4.4 always meant the shim to resolve the tool "from `.config/dotnet-tools.json`". This is
# what that actually requires.
#
# Resolution order, most specific first:
#   1. FSGG_COORD_ENGINE_BIN   — an explicit instruction. Honoured or refused, NEVER fallen back from.
#   2. a global tool on PATH   — `dotnet tool install -g`, or any binary the operator put there.
#   3. a LOCAL tool manifest   — the receivers' shape: `.config/dotnet-tools.json` + `dotnet tool run`.
#   4. a repo-local build      — `.github` alone, which builds the engine FROM SOURCE and never
#                                depends on the feed. That asymmetry is what breaks the publish cycle:
#                                fixing coord would otherwise require publishing, and publishing would
#                                require coord to schedule the fix.
ENGINE_ARGV=()
ENGINE_RESOLVED=""
engine_resolve() {  # 0 iff an engine was found; the command lands in ENGINE_ARGV
  [ -n "$ENGINE_RESOLVED" ] && { [ "${#ENGINE_ARGV[@]}" -gt 0 ]; return; }
  ENGINE_RESOLVED=1
  ENGINE_ARGV=()
  local top candidate manifest

  # AN EXPLICIT PATH IS AN INSTRUCTION, NOT A HINT. If the caller named an engine and that engine is
  # not there, FALLING BACK to some other one is the worst available behaviour: they would be told the
  # shadow ran, and it would have run against a binary they did not choose — quite possibly a stale
  # build from a different branch, silently answering for the one they meant to test. Refuse, and let
  # the caller find out. (Same shape as `--snapshot --json` swallowing the next flag; same rule.)
  if [ -n "${FSGG_COORD_ENGINE_BIN:-}" ]; then
    [ -x "${FSGG_COORD_ENGINE_BIN}" ] && ENGINE_ARGV=("$FSGG_COORD_ENGINE_BIN")
    [ "${#ENGINE_ARGV[@]}" -gt 0 ]
    return
  fi

  if command -v fsgg-coord-engine >/dev/null 2>&1; then
    ENGINE_ARGV=("$(command -v fsgg-coord-engine)")
    return 0
  fi

  top="$(git_toplevel)"

  # THE RECEIVERS' SHAPE. A restored local tool answers to `dotnet tool run`, and to nothing else.
  # Check the MANIFEST rather than probing blindly: `dotnet tool run` on a repo that has no manifest is
  # a slow, noisy failure on every single scheduling call, and this runs in a worker's hot loop.
  if [ -n "$top" ]; then
    manifest="$top/.config/dotnet-tools.json"
    if [ -f "$manifest" ] && command -v dotnet >/dev/null 2>&1 \
       && jq -e '.tools | to_entries[] | select(.value.commands // [] | index("fsgg-coord-engine"))' \
            >/dev/null 2>&1 <"$manifest"; then
      ENGINE_ARGV=(dotnet tool run fsgg-coord-engine)

      # A MANIFEST IS A DECLARATION, NOT AN INSTALLATION — and this line read one as the other.
      #
      # `.config/dotnet-tools.json` is a WISH: it names a tool and a version. Until `dotnet tool restore`
      # runs, `dotnet tool run fsgg-coord-engine` prints *Run "dotnet tool restore" to make the
      # "fsgg-coord-engine" command available* and exits 1 — on STDERR, so `engine_version`'s stdout
      # capture came back EMPTY, became `unknown`, and `unknown` is stale by design (#655). Every
      # scheduling call in all six receivers therefore skipped, blaming a stale engine, and telling the
      # worker to `dotnet tool update` a tool they had never installed.
      #
      # Measured on 2026-07-14, against the live divergence log: 187 of 239 shadow runs skipped, and 186
      # of those 187 skips were this exact failure — `engine unknown is STALE`. The engine version was
      # recorded as `unknown` 187 times and `0.1.1.0` 52 times, and those 52 were all in `.github`, which
      # resolves the from-source build below and never touches this branch. The fleet's evidence was being
      # thrown away at the source, in every repo except the one that builds it, and the three-day clock
      # could not start.
      #
      # So PROVE the engine runs before claiming it resolved — and if the only thing missing is the
      # restore, DO the restore. Asking a worker to run it has the hit rate #656 already measured: zero.
      engine_probe && return 0
      engine_restore "$top" && engine_probe && return 0

      # It is declared, and it will not run. Not our engine, and not a version we may guess at. Record
      # WHICH failure this is: "there is no engine here" and "the engine is declared, restored and still
      # broken" are different facts, and a skip that names the wrong one sent this fleet chasing a stale
      # tool it had never installed.
      ENGINE_ARGV=()
      ENGINE_UNRESTORED=1
      return 1
    fi

    candidate="$top/src/FS.GG.Coord.Cli/bin/Release/net10.0/fsgg-coord-engine"
    if [ -x "$candidate" ]; then
      ENGINE_ARGV=("$candidate")
      return 0
    fi
  fi
  return 1
}

# One JSONL row per shadowed invocation. NEVER fails the caller: a log we cannot write is a log we
# cannot write, and it is not a reason to refuse a worker their item.
shadow_log() {  # <json object on stdin>
  mkdir -p "$(dirname "$DIVERGENCE_LOG")" 2>/dev/null || true
  cat >>"$DIVERGENCE_LOG" 2>/dev/null || true
}

# WHICH BUILD PRODUCED THIS EVIDENCE (#634). Agreement proved by 0.1.0 says NOTHING about 0.2.0, and the
# shadow exists to prove the build we are about to trust — so every row is stamped, `divergence --fleet`
# counts only the rows for the build under test, and republishing the engine legitimately restarts the
# three-day clock. Resolved ONCE per process: this runs in a worker's hot scheduling loop, and an
# `--version` fork per invocation would be a real cost for a string that cannot change mid-run.
# THE OLDEST ENGINE WHOSE EVIDENCE IS WORTH ANYTHING (#655).
#
# A global `dotnet tool` does not self-update, and the kit only ever said INSTALL. So the fleet went on
# shadowing with 0.1.0 long after it was superseded — and 0.1.0 is not merely old, it is WRONG: it strips
# the leading dot from every dotfile path (#649), so `.github/workflows/gate.yml` becomes a token that
# matches no file, conflicts with nothing, and the engine reports STARTABLE on an item a live claim is
# holding. The shadow caught it 7 times on the live board in one day.
#
# A STALE ENGINE IS WORSE THAN NO ENGINE. A worker without one contributes nothing and says so. A worker
# with a superseded one contributes DIVERGENCES FROM A BUILD NOBODY SHOULD TRUST — noise that buries the
# real findings, and, before #644 stamped the rows with a version, noise that could not even be
# attributed to the build that produced it. `Divergence.evaluate` already refuses to count it (it counts
# only reports from the build under test); this refuses to GENERATE it.
#
# Raise this whenever a republished engine changes a SCHEDULING ANSWER. It travels with the kit, so
# raising it here is what actually reaches the fleet — and `tests/fsgg-coord` asserts it never exceeds
# the version this repo builds, so the floor can never lock everybody out of shadowing.
ENGINE_MIN_VERSION="0.1.1"

# `sort -V` is the only version comparator worth using in bash, and it handles the 4-part assembly
# version the engine actually reports (`0.1.1.0`) against a 3-part floor without special-casing.
version_lt() {  # 0 iff $1 < $2
  [ "$1" = "$2" ] && return 1
  [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | head -1)" = "$1" ]
}

# An engine too old to trust. `unknown` counts as stale: an engine that cannot say what it is cannot be
# known to be current, and "I could not tell" is not "it is fine" (#266).
engine_is_stale() {
  local v; v="$(engine_version 2>/dev/null)" || return 0
  [ -n "$v" ] || return 0
  [ "$v" = "unknown" ] && return 0
  version_lt "$v" "$ENGINE_MIN_VERSION"
}

# DOES THIS ENGINE ACTUALLY RUN? `--version` is the cheapest total answer — the one call the engine must
# answer with no input, no board and no token — and the number is needed anyway, so the probe costs one
# exec and is cached. A candidate that cannot answer it is not an engine we have; it is a path we hoped
# about.
engine_probe() {  # 0 iff ENGINE_ARGV runs AND names a version. Caches it in ENGINE_VERSION.
  local out v
  # CAPTURE FIRST, SLICE AFTER — do not pipe the engine into `head`. This is the one place that tests the
  # engine's OWN exit status, and under `set -o pipefail` a pipeline reports the status of whichever stage
  # failed. `… --version | head -1` closes the pipe after one line, so an engine that ever printed a
  # second stdout line (a banner, a warning) would take SIGPIPE, the pipeline would report 141, and a
  # perfectly working engine would be declared unrunnable — the same fail-quiet this whole change exists
  # to remove. Slicing the captured string cannot fail that way.
  out="$("${ENGINE_ARGV[@]}" --version 2>/dev/null)" || return 1
  v="${out%%$'\n'*}"
  v="$(printf '%s' "$v" | tr -d '[:space:]')"
  [ -n "$v" ] || return 1
  ENGINE_VERSION="$v"
  return 0
}

# THE RESTORE THE FLEET WAS ASKED TO RUN, AND DID NOT (#656 again).
#
# Every receiver carries the engine in `.config/dotnet-tools.json` — Renovate keeps the version current,
# `sync-build-config.sh` distributes the file. What nothing does is RESTORE it, and a manifest nobody
# restored is a tool nobody has. The kit's answer was a sentence in a skip message telling the worker to
# go and run it. That sentence has the hit rate every other request in this fabric has: zero.
#
# So run it. Once per process, and at most once an hour per machine when it fails — a restore that CANNOT
# work (no feed, no network, a yanked version) may not put a multi-second round-trip in the hot loop on
# every single scheduling call. A feed comes back, so the hour expires and the next call tries again.
ENGINE_RESTORE_TRIED=""
engine_restore() {  # <repo top> — 0 iff a restore ran and reported success
  [ -n "$ENGINE_RESTORE_TRIED" ] && return 1
  ENGINE_RESTORE_TRIED=1

  local top="$1" mark="$CACHE/engine-restore.failed" now last
  now="$(date +%s)"
  if [ -f "$mark" ]; then
    last="$(cat "$mark" 2>/dev/null || echo 0)"
    case "$last" in ''|*[!0-9]*) last=0 ;; esac
    [ "$(( now - last ))" -lt 3600 ] && return 1
  fi

  mkdir -p "$CACHE" 2>/dev/null || true

  # BOUND IT. The hourly mark below only ever fires for a restore that RETURNS — and a feed that
  # blackholes TCP rather than refusing does not return. Unbounded, that wedges the scheduling call
  # this sits inside, then every other worker on the machine behind it, with no mark ever written to
  # break the cycle. A restore is bookkeeping; bookkeeping does not get to hang a worker forever.
  # (`timeout` is coreutils and is not on a stock macOS, so it is used where present and skipped where
  # not — a bound we can enforce is better than a bound we refuse to have.)
  local restore=(dotnet tool restore)
  command -v timeout >/dev/null 2>&1 && restore=(timeout 180 dotnet tool restore)

  if ( cd "$top" && "${restore[@]}" ) >/dev/null 2>&1; then
    rm -f "$mark" 2>/dev/null || true
    return 0
  fi
  # Remember the failure — a timeout included — so the next scheduling call does not pay for it again.
  echo "$now" >"$mark" 2>/dev/null || true
  return 1
}

ENGINE_VERSION=""
engine_version() {
  [ -n "$ENGINE_VERSION" ] && { printf '%s' "$ENGINE_VERSION"; return 0; }
  engine_resolve || return 1
  # `engine_resolve` probes on its way to saying yes, so the version is normally already cached here.
  [ -n "$ENGINE_VERSION" ] || engine_probe || true
  # An engine that cannot say what it is still gets recorded — as `unknown`, which matches only ANOTHER
  # engine that cannot say what it is. Refusing to log would lose the evidence; guessing a version would
  # forge it. Neither is available, so name the gap.
  [ -n "$ENGINE_VERSION" ] || ENGINE_VERSION="unknown"
  printf '%s' "$ENGINE_VERSION"
}

# WHO PRODUCED IT (#634). The row did not carry this, so the fold could not have counted fleet members
# even once the logs were collected: one worker's 500 runs and 500 workers' one run each rendered
# IDENTICALLY, and "across the live fleet" is unanswerable from rows that do not say who wrote them.
#
# Never dies, and that matters: `worker` exits non-zero when it cannot derive an id, and the shadow may
# not take a worker's item away over its own bookkeeping. An underivable id becomes `unknown-worker` —
# which COLLAPSES every such machine onto one name in the quorum count, and so can only ever make the
# criterion HARDER to meet. Fail closed, in the direction that costs evidence rather than invents it.
shadow_worker() {
  local w
  w="$(worker 2>/dev/null)" || w=""
  [ -n "$w" ] || w="unknown-worker"
  printf '%s' "$w"
}

shadow_skip() {  # <reason>
  # IN `fs` A SKIP IS A FAILURE. Everywhere else "we did not compare" is a fact worth recording and
  # bash carries on. Here there is nothing to carry on with: the caller asked the typed core to decide,
  # and handing back bash's answer while logging a skip would be a silent engine substitution — the
  # exact fail-open of epic #266, in the one place that would be hardest to ever notice.
  engine_authoritative && die "--engine=fs: $1"
  jq -c -n --arg ts "$(now_iso)" --arg reason "$1" --arg mode "$ENGINE_MODE" \
    --arg worker "$(shadow_worker)" --arg engine "$(engine_version 2>/dev/null || echo none)" \
    '{ts: $ts, mode: $mode, worker: $worker, engine: $engine, ran: false, reason: $reason}' \
    2>/dev/null | shadow_log
}

# Compare the two engines, and CLASSIFY the difference — because the two kinds are not the same news.
#
#   OUTCOME  — one engine says startable and the other does not. This is the release blocker: it is a
#              disagreement about WHETHER work may be handed out, and it is how two workers end up in
#              one file. Any of these and the flip does not happen.
#   REASON   — both agree the item is not startable, and they name a different fact. Not a bug, and
#              expected at Phase 2: the two engines check in a DIFFERENT ORDER. Bash filters blocked
#              candidates in bulk before it ever reads a lock, so a blocked-AND-held item reads as
#              "blocked by X"; the typed core checks the lock first and reads it as "held by W".
#              Both are true. Only one can be the one we print, and choosing is a DECISION for the
#              flip — recorded, not silently merged (which is precisely how #485's five predicates
#              came to disagree in the first place).
#
# Counting them together would drown the first in the second, and "zero divergence for three days"
# would never go green for a reason that was never a bug.
shadow_compare() {  # $1=bash verdict NDJSON file  $2=engine decision JSON file  $3=repo scope
  local bashf="$1" enginef="$2" repo="${3:-}"
  jq -c -n \
    --slurpfile engine "$enginef" \
    --slurpfile bash_rows "$bashf" \
    --arg ts "$(now_iso)" --arg mode "$ENGINE_MODE" --arg repo "$repo" \
    --arg worker "$(shadow_worker)" \
    --arg engine_ver "$(engine_version 2>/dev/null || echo none)" \
    --argjson extra "$SHADOW_EXTRA_READS" --argjson unobserved "$SHADOW_UNOBSERVED" '
    ($engine[0] // {}) as $e
    | ($bash_rows | map(select(. != null))) as $b
    | ($e.decisions // []) as $ed
    | ( $b | map({key: .short, value: .}) | from_entries ) as $bmap
    | ( $ed | map({key: .short, value: .}) | from_entries ) as $emap
    | ( [ ($b | map(.short)), ($ed | map(.short)) ] | add | unique ) as $ids
    | [ $ids[]
        | . as $id
        | ($bmap[$id] // null) as $bv
        | ($emap[$id] // null) as $ev
        | if $bv == null then
            {id: $id, class: "engine-only", bash: null, engine: $ev.verdict}
          elif $ev == null then
            {id: $id, class: "bash-only", bash: $bv.verdict, engine: null}
          elif ($bv.verdict == "startable") != ($ev.verdict == "startable") then
            {id: $id, class: "outcome", bash: $bv.verdict, engine: $ev.verdict,
             bashPaths: $bv.paths, enginePaths: $ev.paths, explain: $ev.explain}
          elif $bv.verdict != $ev.verdict then
            {id: $id, class: "reason", bash: $bv.verdict, engine: $ev.verdict,
             bashHolder: $bv.holder, engineHolder: $ev.collidedWith.kind}
          else
            empty
          end ]                                                        as $diffs
    # `compared` COUNTS THE PAIRS, NOT THE UNION — and the difference is a false green.
    #
    # The first cut counted `$ids | length` — the UNION of the two id sets. So an engine that decided
    # NOTHING — a RED verdict refusing the batch, or an empty `decisions` array — still produced
    # `compared: 28`, with every item classed `bash-only` and `outcome: 0`. `divergence` read that as
    # green: a confident agreement with an engine that had agreed to nothing. An id only one engine
    # ruled on was not compared; saying otherwise is the same lie as a shadow that never ran.
    | ( [ $ids[] | select($bmap[.] != null and $emap[.] != null) ] | length ) as $paired
    # $engine_ver, NOT $engine. The --slurpfile above ALREADY binds $engine, to the decision document
    # the engine emitted, and a second --arg engine beside it silently loses the collision. The
    # comparison still worked (the slurpfile won, so $engine[0] was still the decision) — but every row
    # got stamped with that whole JSON document in place of a version string, which breaks the two
    # things the stamp exists for: --publish groups by engine, and --fleet counts only the build under
    # test. The ledger would have matched nothing, forever.
    #
    # Found by reading 144 real rows, not by a test. The fixture asserted only that the field was
    # non-empty, and a JSON array is non-empty. It now asserts the TYPE and the SHAPE.
    | { ts: $ts, mode: $mode, repo: $repo, worker: $worker, engine: $engine_ver, ran: true,
        engineVerdict: ($e.verdict // "missing"),
        compared: $paired,
        extraReads: $extra,
        unobserved: $unobserved,
        outcome: ($diffs | map(select(.class == "outcome")) | length),
        reason:  ($diffs | map(select(.class == "reason"))  | length),
        unpaired: ($diffs | map(select(.class == "bash-only" or .class == "engine-only")) | length),
        divergences: $diffs }' 2>/dev/null | shadow_log
}

# The two engines' inputs and outputs travel as FILES, never as argv (#497, #507). A single issue body
# can reach ~196 KB — GitHub caps a body at 65,536 CHARACTERS, not bytes, so a CJK-heavy one blows the
# 128 KiB MAX_ARG_STRLEN cap on ONE argument — and when that happened, `execve` returned E2BIG, `jq`
# never ran, the `$( )` yielded the empty string, and every claim-aware read in the tool died at once.
# The shadow carries MANY bodies. `--rawfile` and `--slurpfile` keep all of it off the command line.
SHADOW_ITEMS=""
SHADOW_VERDICTS=""
SHADOW_SEEN=""

shadow_init() {
  shadow_collecting || return 0
  SHADOW_ITEMS="$(mktemp "$CACHE/.snap-items.XXXXXX")"
  SHADOW_VERDICTS="$(mktemp "$CACHE/.snap-verdicts.XXXXXX")"
  SHADOW_SEEN="$(mktemp "$CACHE/.snap-seen.XXXXXX")"
  TMPFILES+=("$SHADOW_ITEMS" "$SHADOW_VERDICTS" "$SHADOW_SEEN")
  SHADOW_EXTRA_READS=0
  SHADOW_UNOBSERVED=0
}

# BASH's verdict for one candidate, in the vocabulary the typed core also speaks. The tokens are the
# comparable surface; the human sentence beside them in `skipped` is not, and never was.
shadow_verdict() {  # <short> <verdict> [holder-kind] [paths(newline-separated)]
  shadow_collecting || return 0
  jq -c -n --arg short "$1" --arg verdict "$2" --arg holder "${3:-}" --arg paths "${4:-}" \
    '{short: $short, verdict: $verdict,
      holder: (if $holder == "" then null else $holder end),
      paths: ($paths | split("\n") | map(select(length > 0)))}' 2>/dev/null >>"$SHADOW_VERDICTS" || true
}

# One snapshot item — the state BASH OBSERVED, handed to the engine so that both decide from the same
# facts. Anything the engine had to fetch for itself would be a second observation of a moving board,
# and the comparison would be measuring the clock rather than the rule.
shadow_item() {  # <owner> <repo> <num> <status> <state> <body-file> <blockers-json> <claim-json> [unreadable-reason]
  shadow_collecting || return 0
  printf '%s/%s#%s\n' "$1" "$2" "$3" >>"$SHADOW_SEEN"
  # `bodyUnreadable` IS A FACT, AND `body: ""` IS A LIE. A body we failed to fetch is ABSENT, not empty
  # — and the engine's `TouchSet.parse ""` answers `Undeclared`, which is a confident OMISSION about an
  # item nobody looked at. When it is set, the engine returns `Undetermined` for the item: not startable,
  # and SAID SO, which is the one outcome an unread item may have.
  jq -c -n \
    --arg owner "$1" --arg repo "$2" --argjson number "$3" \
    --arg status "$4" --arg state "$5" --rawfile body "$6" \
    --argjson blockers "${7:-[]}" --argjson claim "${8:-null}" --arg unreadable "${9:-}" '
    { owner: $owner, repo: $repo, number: $number,
      status: (if $status == "" or $status == "null" then null else $status end),
      state: $state, body: $body, blockers: $blockers, claim: $claim }
    + (if $unreadable == "" then {} else { bodyUnreadable: $unreadable } end)' \
    2>/dev/null >>"$SHADOW_ITEMS" || true
}

# The board scan carries blockers as `{ref: "owner/repo#n", state: "OPEN"|…|"UNPARSEABLE"}`. The engine
# wants them split. An UNPARSEABLE blocker has no ref BY DEFINITION — it is prose somebody typed into a
# dependency field — so it lands as number 0. That is cosmetic: it still BLOCKS, in both engines, which
# is the only property that decides anything (#476, #266 — "I could not read it" is not "it is fine").
#
# UNDER `--ignore-blocked`, THE BLOCKER LIST IS EMPTY — because that is what bash ENFORCED.
#
# The flag is a diagnostic ("what WOULD be startable if the blockers cleared") and it relaxes the
# blocker filter and nothing else. The shadow's whole premise is that both engines decide from the
# SAME observations, so it must hand the engine the rule bash actually applied. Sending the blockers
# anyway would have the engine dutifully return `blocked-by` for every candidate bash deliberately let
# through — and each one would be logged as an OUTCOME divergence, the release-blocking class, while
# both engines were behaving exactly as designed. A diagnostic flag would then poison the one signal
# that has to stay trustworthy.
SHADOW_IGNORE_BLOCKED=""
shadow_blockers_json() {  # <item json> -> the engine's blocker array
  [ -z "$SHADOW_IGNORE_BLOCKED" ] || { printf '[]'; return 0; }
  # `capture` YIELDS NOTHING WHEN IT DOES NOT MATCH — it does not return null, it returns EMPTY. So a
  # blocker whose ref is prose ("Blocked by RESOLVED: shipped last week") constructed NO object at all,
  # the array collapsed to `[]`, and the item bash had just classified as BLOCKED was handed to the
  # engine as UNBLOCKED. In shadow that logged an outcome divergence nobody could explain. Under
  # `--engine=fs` it is a worker being handed blocked work — the exact fail-open of #266, arriving
  # through the one path built to prove #266 was over.
  #
  # `test` decides, `capture` only refines, and the RAW text always survives — because for an
  # unparseable blocker the prose is the only thing there is to show a human.
  jq -c '[ (.blockers // [])[]
           | (.ref // "") as $r
           | ($r | test("^[^/]+/[^#]+#[0-9]+$")) as $parsed
           | { raw: $r,
               state: (.state // "UNKNOWN" | ascii_downcase) }
             + (if $parsed
                then { owner:  ($r | sub("/.*$"; "")),
                       repo:   ($r | sub("^[^/]+/"; "") | sub("#[0-9]+$"; "")),
                       number: ($r | sub("^.*#"; "") | tonumber) }
                else {} end) ]' 2>/dev/null <<<"$1" || printf '[]'
}

# The claim BASH saw, and — crucially — WHAT IT CHECKED. `liveness` is not a detail: a lapsed lease is
# EVIDENCE of abandonment and never proof, so the engine must be told whether anybody actually looked
# for an open `item/<n>-*` PR. `unknown` is the case that reaped live work (#581), and it has to be
# sayable on the wire or the shadow would launder it into a confident "no PR".
shadow_claim_json() {  # <worker> <ageSec> <liveness-kind> [pr]
  # AN AGE WE DO NOT HAVE IS -1, NOT 0. `lease_window` has always read an empty/non-numeric age as
  # "lease unknown" — a marker may be hand-written or truncated and carry no timestamp. Sending 0
  # instead would hand the engine a claim that looks brand new, and it would answer "frees in ~120m":
  # a fabricated window on a claim whose age is the one thing nobody knows. That is exactly the
  # confident-but-unfounded sentence #440 and #488 were closed for, and after the flip it would be the
  # engine saying it. The engine reads any negative age as unknown.
  local worker="$1" age="${2:-}" kind="$3" pr="${4:-}"
  case "$age" in ''|*[!0-9]*) age=-1 ;; esac
  [ -n "$worker" ] || { printf 'null'; return 0; }
  jq -c -n --arg w "$worker" --argjson age "$age" --arg kind "$kind" --arg pr "${pr:-}" \
    '{ worker: $w, session: null, ageSeconds: $age, prevStatus: null,
       liveness: ({kind: $kind} + (if $pr == "" then {} else {pr: ($pr | tonumber)} end)) }' \
    2>/dev/null || printf 'null'
}

# Record ONE candidate exactly as bash saw it: the board row, the body it read (or did not), and the
# claim — including WHICH liveness question was actually asked.
shadow_observe() {  # <item json> <body> <liveness-kind|""> <worker|""> <ageSec> [pr] [unreadable-reason]
  shadow_collecting || return 0
  local it="$1" body="$2" kind="$3" worker="$4" age="${5:-0}" pr="${6:-}" unreadable="${7:-}"
  local r num owner repo status state bf claim blockers
  r="$(jq -r '.repo // ""' <<<"$it")"; num="$(jq -r '.number // ""' <<<"$it")"
  { [ -n "$r" ] && [ -n "$num" ]; } || return 0
  owner="${r%%/*}"; repo="${r#*/}"
  status="$(jq -r '.status // ""' <<<"$it")"
  # A NULL `.state` is treated as OPEN — because that is what bash's own closed-filter does
  # (`select(.state != null and .state != "OPEN")`). Mirroring it is deliberate: the shadow's job is to
  # compare the two RULES, so it must not manufacture a divergence out of a default that only one of
  # them has. That bash reads an unknown state as open is arguably its own fail-open, and it is a
  # finding for the flip — not something to fix silently inside the observer.
  state="$(jq -r '.state // "OPEN"' <<<"$it")"
  blockers="$(shadow_blockers_json "$it")"
  claim="$(shadow_claim_json "$worker" "$age" "$kind" "$pr")"
  bf="$(mktemp "$CACHE/.snap-body.XXXXXX")"; TMPFILES+=("$bf")
  printf '%s' "$body" >"$bf"
  shadow_item "$owner" "$repo" "$num" "$status" "$state" "$bf" "$blockers" "$claim" "$unreadable"
}

# Bash's verdict for every candidate a jq filter selects — the bulk pre-filters (closed, blocked),
# which never reach the per-item loop and so have no other place to be recorded.
shadow_verdict_bulk() {  # <cands json> <jq select expr> <verdict token>
  shadow_collecting || return 0
  local id
  while IFS= read -r id; do
    [ -n "$id" ] || continue
    shadow_verdict "$id" "$3"
  done < <(jq -r "[ .[] | $2 | \"\(.repo | sub(\"^[^/]+/\";\"\"))#\(.number)\" ] | .[]" <<<"$1" 2>/dev/null || true)
}

# THE CANDIDATES BASH NEVER LOOKED AT.
#
# Bash short-circuits a CLOSED or BLOCKED candidate straight off the board scan and never reads its
# body or its markers. The typed core checks the touch-set and the lock BEFORE the blockers, so it
# cannot reach the same question without them — and handing it an empty body would fabricate a
# `NoTouchSet` verdict that neither engine actually holds. That is not a divergence, it is a lie, and
# a shadow that lies is worse than no shadow.
#
# So the shadow pays for those reads itself, and COUNTS them. REST only — never the points budget that
# dies under fan-out. If this number turns out to be large in practice, that is a real argument about
# the check ORDER, and it belongs in the flip decision with evidence attached rather than in a guess.
shadow_sweep() {  # <all cands json>
  shadow_collecting || return 0
  local n i=0 it r num id body body_unreadable hold holder age stale alive kind pr
  n="$(jq 'length' <<<"$1" 2>/dev/null || echo 0)"
  while [ "$i" -lt "$n" ]; do
    it="$(jq -c ".[$i]" <<<"$1")"; i=$((i + 1))
    r="$(jq -r '.repo // ""' <<<"$it")"; num="$(jq -r '.number // ""' <<<"$it")"
    { [ -n "$r" ] && [ -n "$num" ]; } || continue
    id="${r#*/}#$num"
    grep -qxF "$r#$num" "$SHADOW_SEEN" 2>/dev/null && continue   # the loop already observed it

    # EVERY READ HERE RUNS UNDER `soft_run`, AND THAT IS NOT BELT-AND-BRACES — IT IS RULE 1.
    #
    # `live_claim_holder` and `stale_claim_worker` go through `claims_of`, which is documented "or DIE"
    # and MEANS it: a lock guessed from a failed read is the one thing a lock may never be. But `die`
    # is `kill -s TERM $$` — it takes down the TOP-LEVEL shell, and no `|| true` can catch a signal.
    # So an unguarded read here would let one transient 5xx on a BLOCKED candidate's markers abort the
    # whole tool: a worker running `--engine shadow take` would get a hard failure and no item, on a
    # run bash alone would have completed. The OBSERVER would have changed the answer.
    #
    # `soft_run` is the house containment: SOFT_DIE makes `die` exit its own subshell, and it clears
    # RC_FILE afterwards — which matters, because "FIRST die wins" and a stray code left there by the
    # shadow would be reported as the cause of the NEXT real one.
    #
    # Failing to observe a candidate is a normal outcome here, not an error. It is counted (below) and
    # it withholds that candidate from the comparison; it never withholds the item from the worker.
    # A BODY WE COULD NOT READ IS REPORTED, NOT WITHHELD.
    #
    # This used to `continue` — the candidate was counted as unobserved and simply left out of the
    # snapshot. Under the shadow that was harmless: bash owned the answer, so a missing item cost the
    # COMPARISON, not the run. Under `--engine=fs` it costs the ANSWER. The item vanishes from the
    # engine's world: it cannot be offered, and — worse — it cannot be passed over WITH A REASON, so a
    # blocked or held item silently ceases to exist and the worker is told nothing about it.
    #
    # So it goes in, flagged. `bodyUnreadable` makes its touch-set UNKNOWN (not absent), and the engine
    # answers `Undetermined` — not startable, and said so. Note what the check ORDER buys here: blockers
    # are board facts and are checked FIRST, so a blocked item still decides correctly without its body
    # ever being read. One unreadable issue cannot starve a worker.
    body_unreadable=""
    if ! body="$(gh api "repos/${r%%/*}/${r#*/}/issues/$num" --jq '.body // ""' 2>/dev/null)"; then
      body=""
      body_unreadable="the issue body could not be fetched"
      SHADOW_UNOBSERVED=$((SHADOW_UNOBSERVED + 1))
    else
      SHADOW_EXTRA_READS=$((SHADOW_EXTRA_READS + 1))
    fi

    # A FAILED MARKER READ MAKES THE CANDIDATE UNOBSERVABLE — IT DOES NOT MAKE IT UNHELD.
    #
    # `soft_run` contains the die, and containing it is what stops the tool being killed. But a
    # contained die returns the EMPTY STRING, and taking that for "nobody holds this item" would be
    # the original sin of this whole codebase reproduced inside its own remedy: an empty answer wearing
    # a failed read's clothes (#461, epic #266). The engine would then be handed `claim: null` for an
    # item that may well be locked, and would agree — or disagree — about a board nobody read.
    #
    # So the read's STATUS is checked, not its output. We could not observe this candidate; we say so,
    # we count it, and we withhold it from the comparison. What we never do is guess.
    if hold="$(soft_run live_claim_holder "${r%%/*}" "${r#*/}" "$num" 2>/dev/null)"; then
      SHADOW_EXTRA_READS=$((SHADOW_EXTRA_READS + 1))
    else
      SHADOW_UNOBSERVED=$((SHADOW_UNOBSERVED + 1)); continue
    fi

    holder="${hold%%$'\t'*}"; age="${hold##*$'\t'}"
    kind=""; pr=""
    if [ -n "$holder" ]; then
      kind="lease-held"
    else
      if stale="$(soft_run stale_claim_worker "${r%%/*}" "${r#*/}" "$num" 2>/dev/null)"; then
        :
      else
        SHADOW_UNOBSERVED=$((SHADOW_UNOBSERVED + 1)); continue
      fi
      if [ -n "$stale" ]; then
        holder="$stale"; age="${age:-0}"
        # `pr_alive` is a raw `gh` read that cannot die — but it CAN come back empty for two entirely
        # different reasons, and #581 is the story of confusing them: "no open item/<n> PR" is a fact
        # about the work, "I could not ask" is a fact about us. Only the first licenses `no-pr`.
        if alive="$(pr_alive "${r%%/*}" "${r#*/}" "$num" 2>/dev/null)"; then
          SHADOW_EXTRA_READS=$((SHADOW_EXTRA_READS + 1))
        else
          SHADOW_UNOBSERVED=$((SHADOW_UNOBSERVED + 1)); continue
        fi
        if [ -n "$alive" ]; then
          kind="lease-expired-pr-open"; pr="${alive%% *}"; pr="${pr#\#}"
        else
          kind="lease-expired-no-pr"
        fi
      fi
    fi
    case "$age" in ''|*[!0-9]*) age=-1 ;; esac
    shadow_observe "$it" "$body" "$kind" "$holder" "$age" "$pr" "$body_unreadable"
  done
}

# Assemble the snapshot and run the engine. Returns nothing, changes nothing, and is called for its
# effect on the divergence log alone. EVERY failure path here is a SKIP, never an error — see rule 1.
shadow_run() {  # <allowBacklog 0|1> <limit> <inflight-ndjson-file> <repo>
  shadow_enabled || return 0

  local allow="$1" limit="$2" inflight="$3" repo="${4:-}"
  if ! engine_resolve; then
    # Rule 2. This script is byte-copied into six repos, and a repo without the engine simply does not
    # shadow. That is a fact to RECORD, not an error to raise — it may never red a receiver's CI.
    if [ -n "${ENGINE_UNRESTORED:-}" ]; then
      shadow_skip "the engine is DECLARED in .config/dotnet-tools.json but will not run, and 'dotnet tool restore' did not fix it — this machine contributes NO evidence"
    else
      shadow_skip "no engine (install it: dotnet tool restore, or dotnet tool install -g FS.GG.Coord.Cli)"
    fi
    return 0
  fi

  # A STALE ENGINE IS WORSE THAN NO ENGINE (#655), and this is the same rule one notch stricter: it is a
  # SKIP, not an error. A receiver whose worker has an old tool must not have its CI redded over it, and
  # the skip is RECORDED — so "we did not compare" can never be mistaken for "they agreed", which is the
  # whole of #266 and the reason the skip exists at all.
  if engine_is_stale; then
    shadow_skip "engine $(engine_version) is STALE (need >= $ENGINE_MIN_VERSION) — its answers are known-wrong, so its evidence is not collected. Update: dotnet tool update -g FS.GG.Coord.Cli"
    return 0
  fi

  local snap out
  snap="$(mktemp "$CACHE/.snap.XXXXXX")"; out="$(mktemp "$CACHE/.snapout.XXXXXX")"
  TMPFILES+=("$snap" "$out")

  # THE LEASE TRAVELS WITH THE SNAPSHOT. It is configurable here (FSGG_CLAIM_LEASE_MIN), so the engine
  # may not assume it: a repo that shortened its lease, plus an engine that hard-coded 120, would agree
  # to tell every worker to wait out a window that has already closed.
  jq -n --slurpfile items "$SHADOW_ITEMS" --slurpfile inflight "$inflight" \
    --arg schema "$SNAPSHOT_SCHEMA" --argjson allow "$allow" --argjson limit "${limit:-0}" \
    --argjson lease "$CLAIM_LEASE_MIN" '
    { schema: $schema, allowBacklog: ($allow == 1), limit: $limit, leaseMinutes: $lease,
      inFlight: $inflight, items: $items }' >"$snap" 2>/dev/null \
    || { shadow_skip "could not assemble the snapshot"; return 0; }

  if ! "${ENGINE_ARGV[@]}" decide <"$snap" >"$out" 2>/dev/null; then
    # A RED verdict (exit 3) is a real answer and is logged below. Any other failure is the engine
    # being broken, which is news — but it is OUR news, not the caller's, and it may not cost them
    # their item.
    if ! jq -e '.verdict' >/dev/null 2>&1 <"$out"; then
      shadow_skip "the engine did not produce a decision (it exited non-zero with no verdict)"
      return 0
    fi
  fi

  shadow_compare "$SHADOW_VERDICTS" "$out" "$repo"

  # THE ONE THING THE SHADOW WAS NEVER ALLOWED TO DO: hand its answer back. In every mode but `fs` this
  # is written and never read — the containment assertions prove it, including a mutation test that
  # removes the guard and watches the tool die. In `fs` it is the answer, and the caller takes it.
  ENGINE_DECISION="$out"

  # The evidence exists now. Get it off this machine — `done` may never run for this item (#681, #685).
  # Throttled, silent, and it may never fail the caller: rule 1 of this whole surface is that the shadow
  # cannot change bash's answer, its exit code, or its life.
  divergence_publish_throttled || true
  return 0
}

# ---- divergence: the shadow's telemetry, and no longer the gate -----------------------------------
# ADR-0034 §5 gated the cut-over on ZERO DIVERGENCE across the live fleet for three consecutive days.
# ADR-0038 RETIRED that criterion: the clock could not tick (a worker in a per-item worktree resolves no
# engine and banks no evidence — #728), and its own taxonomy filed as "not a bug, and expected" the three
# real defects the flip would otherwise have shipped. The gate is now the DEFECT CORPUS — one case per
# historical defect, run against BOTH engines in CI.
#
# This surface still matters, and is still the right instrument for a LIVE fleet: it says whether the two
# engines agree out there, and — just as importantly — whether the question was ever actually ASKED. It
# is telemetry now. It is not what the flip waits on.
#
# The two classes are reported apart, because they are not the same news:
#
#   OUTCOME — the engines disagree about whether an item may be HANDED OUT. This is the blocker. One
#             of them is wrong, and the failure mode is two workers in one file.
#   REASON  — they agree it is not startable and name a different fact. Expected at Phase 2, because
#             they check in a different ORDER, and both statements are true. Which one to PRINT is a
#             decision for the flip; it is recorded here, not merged silently. (#485 exists because
#             five predicates were merged silently.)
#
# And the third number, which is the one that keeps this honest: SKIPPED. A shadow that never ran
# reports zero divergence, and zero divergence is exactly what success looks like. So a run that did
# not happen is logged as loudly as one that disagreed — otherwise "the engines agree" and "we never
# compared them" are the same output, which is epic #266 wearing the uniform of its own remedy.
divergence_cmd() {
  local json="" since=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)    json=1; shift ;;
      --since)   since="${2:?--since needs a value (an ISO timestamp)}"; shift 2 ;;
      --clear)   rm -f "$DIVERGENCE_LOG"; echo "fsgg-coord: cleared $DIVERGENCE_LOG"; return 0 ;;
      --publish) shift; divergence_publish "$@"; return $? ;;
      --fleet)   shift; divergence_fleet "$@"; return $? ;;
      *)         die "divergence: unknown argument '$1'." ;;
    esac
  done

  if [ ! -s "$DIVERGENCE_LOG" ]; then
    # NOT "green". An empty log is the ABSENCE of evidence, and the whole of ADR-0034 is the refusal
    # to read that as evidence of absence.
    if [ -n "$json" ]; then
      jq -c -n '{runs: 0, ran: 0, skipped: 0, outcome: 0, reason: 0, verdict: "no-verdict",
                 reason_text: "the shadow has never run — there is nothing to conclude"}'
    else
      echo "fsgg-coord: the divergence log is empty ($DIVERGENCE_LOG)." >&2
      echo "That is NOT zero divergence — it is zero EVIDENCE. Nothing has been compared." >&2
      echo "Enable the shadow with: fsgg-coord --engine shadow next   (or export FSGG_COORD_ENGINE=shadow)" >&2
    fi
    return 3
  fi

  local rows
  rows="$(jq -c -s --arg since "$since" '
    map(select($since == "" or (.ts >= $since)))
    | { runs: length,
        ran:      (map(select(.ran)) | length),
        skipped:  (map(select(.ran | not)) | length),
        compared: (map(select(.ran) | .compared // 0) | add // 0),
        extraReads: (map(select(.ran) | .extraReads // 0) | add // 0),
        unobserved: (map(select(.ran) | .unobserved // 0) | add // 0),
        outcome:  (map(select(.ran) | .outcome // 0) | add // 0),
        reason:   (map(select(.ran) | .reason // 0) | add // 0),
        unpaired: (map(select(.ran) | .unpaired // 0) | add // 0),
        # A RED engine verdict is the engine REFUSING the batch outright — an in-flight reservation
        # whose touch-set is unmatchable, so it reserves nothing while occupying files (#273). Bash
        # `die`s in that case too, so the two agree; but if bash proceeded and the engine refused,
        # they could not disagree more sharply. It was recorded and never read. Now it gates.
        engineRed: (map(select(.ran) | select((.engineVerdict // "green") != "green")) | length),
        firstTs:  (map(.ts) | min // null),
        lastTs:   (map(.ts) | max // null),
        skips:    (map(select(.ran | not) | .reason) | unique),
        outcomes: (map(select(.ran) | .divergences // [] | .[] | select(.class == "outcome"))),
        reasons:  (map(select(.ran) | .divergences // [] | .[] | select(.class == "reason"))
                   | group_by([.bash, .engine])
                   | map({bash: .[0].bash, engine: .[0].engine, count: length})) }' \
    <"$DIVERGENCE_LOG" 2>/dev/null)" || die "divergence: could not read $DIVERGENCE_LOG."

  if [ -n "$json" ]; then printf '%s\n' "$rows"; else
    local ran skipped outcome reason compared extra unpaired unobserved enginered
    ran="$(jq -r '.ran' <<<"$rows")";        skipped="$(jq -r '.skipped' <<<"$rows")"
    outcome="$(jq -r '.outcome' <<<"$rows")"; reason="$(jq -r '.reason' <<<"$rows")"
    compared="$(jq -r '.compared' <<<"$rows")"; extra="$(jq -r '.extraReads' <<<"$rows")"
    unpaired="$(jq -r '.unpaired' <<<"$rows")"; unobserved="$(jq -r '.unobserved' <<<"$rows")"
    enginered="$(jq -r '.engineRed' <<<"$rows")"
    printf 'shadow runs: %s ran, %s skipped  ·  %s item-verdicts compared  ·  %s extra REST read(s)\n' \
      "$ran" "$skipped" "$compared" "$extra"
    # WHAT WAS *NOT* COMPARED IS PART OF THE ANSWER. A number that only ever reports what it looked at
    # is how "we agreed" and "we never checked" come to print the same sentence.
    if [ "$unobserved" -gt 0 ] || [ "$unpaired" -gt 0 ] || [ "$enginered" -gt 0 ]; then
      printf '  NOT compared: %s unobservable item(s) · %s ruled on by ONE engine only · %s run(s) the engine REFUSED outright\n' \
        "$unobserved" "$unpaired" "$enginered"
    fi
    printf '  window: %s → %s\n' "$(jq -r '.firstTs // "—"' <<<"$rows")" "$(jq -r '.lastTs // "—"' <<<"$rows")"
    echo
    printf 'OUTCOME divergences (the release blocker): %s\n' "$outcome"
    jq -r '.outcomes[] | "  \(.id) — bash says \(.bash), the engine says \(.engine)"' <<<"$rows"
    echo
    printf 'REASON divergences (a decision to record, not a bug): %s\n' "$reason"
    jq -r '.reasons[] | "  \(.count)×  bash: \(.bash)  ·  engine: \(.engine)"' <<<"$rows"
    if [ "$skipped" -gt 0 ]; then
      echo
      echo "SKIPPED runs — these are NOT agreement:" >&2
      jq -r '.skips[] | "  " + .' <<<"$rows" >&2
    fi
    echo
    if [ "$ran" -eq 0 ]; then
      echo "VERDICT: no-verdict — the shadow never ran, so nothing has been compared." >&2
    elif [ "$compared" -eq 0 ]; then
      echo "VERDICT: no-verdict — the shadow ran $ran time(s) and compared ZERO item-verdicts." >&2
      echo "  A run over an empty candidate set agrees with everything, because it decided nothing." >&2
      echo "  Three days of an empty queue is not three days of agreement. Nothing is proven yet." >&2
    elif [ "$outcome" -gt 0 ]; then
      echo "VERDICT: RED — the engines disagree about what may be handed out. The flip is blocked." >&2
    elif [ "$enginered" -gt 0 ]; then
      echo "VERDICT: RED — the engine REFUSED $enginered batch(es) outright while bash proceeded. That is not" >&2
      echo "  a disagreement about one item; it is a disagreement about whether the board is safe to" >&2
      echo "  schedule from at all." >&2
    elif [ "$unpaired" -gt 0 ]; then
      echo "VERDICT: RED — $unpaired item(s) were ruled on by only ONE engine. The two did not evaluate the" >&2
      echo "  same candidate set, which is a divergence in the FOLD even when every shared verdict agrees." >&2
    else
      echo "VERDICT: green on OUTCOME. $reason reason-divergence(s) remain to be decided (ADR-0034 Phase 3)."
    fi
  fi

  # NoVerdict is NON-ZERO, always (§4.2).
  #
  # AND "RAN" IS NOT THE BAR — "COMPARED" IS. The first cut of this checked only that the shadow had
  # run, and the very first live invocation walked straight through it: the board happened to hold no
  # Ready item, so the shadow ran, compared NOTHING, and this printed `green on OUTCOME`. A run over an
  # empty candidate set agrees with every other engine in the world, because it did not decide
  # anything — and an exit code of 0 would have fed that into "zero divergence for three consecutive
  # days" as if it were evidence.
  #
  # That is epic #266 — a gate that reports green over a subject it never read — rebuilt inside the
  # tool whose entire purpose is to retire it, and it survived exactly as long as it took to run it
  # once against a real board. Which is the argument for the shadow, in miniature.
  #
  # Explicit `if`s, NOT `[ … ] && return`: this file has been bitten by that once already (see the
  # blocked-candidate branch in `batch`). A `&&` list whose left side is false returns 1, and under
  # `set -euo pipefail` that is an exit — from a function whose whole job is to report a status.
  # AND `outcome` IS NOT THE ONLY WAY TO DISAGREE. Two more were recorded in the log and read by
  # nothing, and each one could carry a green past this gate:
  #   * `engineRed`  — the engine REFUSED the batch (a reservation that reserves nothing, #273) while
  #                    bash went ahead. `decisions` is then empty, so `outcome` is 0. Sharpest possible
  #                    disagreement, scoring as agreement.
  #   * `unpaired`   — an item only ONE engine ruled on. With `-n` both engines stop at their own cap,
  #                    so a different evaluated set IS a divergence in the fold, even when every shared
  #                    verdict matches.
  local final_ran final_compared final_outcome final_unpaired final_enginered
  final_ran="$(jq -r '.ran' <<<"$rows")"
  final_compared="$(jq -r '.compared' <<<"$rows")"
  final_outcome="$(jq -r '.outcome' <<<"$rows")"
  final_unpaired="$(jq -r '.unpaired' <<<"$rows")"
  final_enginered="$(jq -r '.engineRed' <<<"$rows")"
  if [ "$final_ran" -eq 0 ]; then return 3; fi
  if [ "$final_compared" -eq 0 ]; then return 3; fi
  if [ "$final_enginered" -gt 0 ]; then return 1; fi
  if [ "$final_unpaired" -gt 0 ]; then return 1; fi
  if [ "$final_outcome" -gt 0 ]; then return 1; fi
  return 0
}

# ==================================================================================================
# THE FLEET LEDGER (#634) — where the shadow's evidence goes to become an ARGUMENT.
# ==================================================================================================
#
# Everything above this line reports on ONE MACHINE'S log, in a DISPOSABLE CACHE DIRECTORY. That was
# the whole of the evidence, and ADR-0034 §5 gates the cut-over on a sentence it cannot support:
#
#     "zero divergence across the LIVE FLEET for three consecutive days"
#
# (ADR-0038 has since retired that criterion outright — see `divergence` below. The ledger survives it,
# because "is a local cache a fleet?" was always the right question to ask of the evidence, whatever the
# evidence was FOR.)
#
# A local log is not a fleet. Nothing collected it, nothing aggregated it, the rows did not say WHO
# wrote them, and no code computed the criterion — so the flip would have been decided by a human
# reading one laptop's counters over whatever window that cache happened to survive. CI was worse than
# that: `touch-set-drift` shells out to this tool on a bare runner and its cache dies with the job, so
# 100% of everything it ever observed was thrown away.
#
# The client already refuses to call an EMPTY log green. This is that same refusal, carried to the
# three things a local log CANNOT see: a LOCAL log is not the FLEET, a CHATTY WORKER is not a QUORUM,
# and agreement by a DIFFERENT BUILD is not agreement by this one.
#
# WHY AN ISSUE, AND WHY REST. The claim lock already works exactly this way, and the reason is the one
# ADR-0034 gives for hosting the lock there: GraphQL is the first budget to die under fan-out, and a
# lock — or a ledger — may never live on the budget that dies first. Issue comments are durable,
# org-visible, and served by the 5,000-*requests*/hr REST budget. The hot scheduling loop pays NOTHING:
# it still writes locally, and publishes ONE summary at the end.
LEDGER_REPO="${FSGG_COORD_LEDGER_REPO:-FS-GG/.github}"
LEDGER_ISSUE="${FSGG_COORD_LEDGER_ISSUE:-635}"
DIVERGENCE_MARK='fsgg:divergence'
FLEET_DAYS="${FSGG_COORD_FLEET_DAYS:-3}"
FLEET_MIN_WORKERS="${FSGG_COORD_FLEET_MIN_WORKERS:-2}"

# The marker grammar, in ONE place. Written by `--publish`, read by `--fleet`, and asserted by the
# fixture — so a publisher and a reader cannot drift apart the way five startability predicates did.
DIVERGENCE_MARKER_RE="^<!--\\s*fsgg:divergence\\s+worker=(?<w>[^\\s>]+)\\s+day=(?<d>[0-9]{4}-[0-9]{2}-[0-9]{2})\\s+engine=(?<e>[^\\s>]+)\\s+ran=(?<ran>[0-9]+)\\s+skipped=(?<sk>[0-9]+)\\s+compared=(?<c>[0-9]+)\\s+outcome=(?<o>[0-9]+)\\s+unpaired=(?<u>[0-9]+)\\s+engineRed=(?<er>[0-9]+)\\s+reason=(?<rs>[0-9]+)"

# Fold the LOCAL log into one summary per (worker, engine, day).
#
# Grouped by WORKER as well as day, because the local log is not one worker's: the cache dir is SHARED
# between the N agents on a box (that sharing is what keeps them inside one GraphQL budget, #418), so a
# five-agent machine legitimately publishes five rows a day — and the quorum that then counts them is a
# real one.
#
# Grouped by ENGINE too, so that a worker who upgrades mid-day does not silently blend evidence from
# two builds into a single row that is true of neither.
divergence_summaries() {  # -> JSONL, one summary per (worker, engine, day)
  # ONLY ROWS THAT NAME A BUILD, AND NAME IT AS A VERSION.
  #
  # Before #644 the engine stamp was the ENGINE DECISION DOCUMENT — a JSON object, not a version —
  # because `--slurpfile engine` and `--arg engine` collided. Those rows are still sitting in every
  # worker local log, and folding one would emit a marker whose `engine=` field is a JSON blob full of
  # spaces and quotes. `--fleet` REFUSES to compute a verdict over a marker it cannot parse (correctly:
  # an unreadable row might be the one that diverged), so ONE bad marker would make the ledger
  # permanently unreadable for everybody.
  #
  # Evidence that cannot be attributed to a build is not evidence: `Divergence.evaluate` counts only
  # reports from the build under test and would discard it anyway. Drop it HERE, where it can still be
  # dropped quietly, rather than in the ledger, where it cannot.
  jq -c -s '
    map(select(.ran))
    | map(select((.engine | type) == "string" and (.engine | test("^[0-9]+[.][0-9]+"))))
    | group_by([(.worker // "unknown-worker"), (.engine // "unknown"), (.ts[0:10])])
    | map({ worker:   (.[0].worker // "unknown-worker"),
            engine:   (.[0].engine // "unknown"),
            day:      (.[0].ts[0:10]),
            ran:      length,
            compared: (map(.compared // 0)   | add),
            outcome:  (map(.outcome // 0)    | add),
            unpaired: (map(.unpaired // 0)   | add),
            engineRed:(map(select((.engineVerdict // "green") != "green")) | length),
            reason:   (map(.reason // 0)     | add) })
    | .[]' 2>/dev/null
}

# `skipped` is counted SEPARATELY, and deliberately not inside the group above: a skipped run has no
# engine (that is WHY it skipped), so grouping it by engine would invent a row for a build that never
# ran. It is attributed to the worker and the day, and it is never agreement.
divergence_skips_for() {  # $1=worker $2=day -> count
  jq -s --arg w "$1" --arg d "$2" \
    '[ .[] | select((.ran | not) and ((.worker // "unknown-worker") == $w) and (.ts[0:10] == $d)) ] | length' \
    2>/dev/null <"$DIVERGENCE_LOG" || echo 0
}

# THE EVIDENCE MUST LEAVE THE MACHINE EVEN WHEN `done` NEVER RUNS.
#
# #656 bolted the publish to `done` — *"the one command every worker runs when it finishes an item"*. It
# is not. An item closed by a SQUASH-MESSAGE closing keyword (#681, #685, #693) is merged, closed and
# board-Done without `done` ever being called, and that worker's evidence never leaves the machine.
#
# Be precise about what this did and did not cost, because an earlier draft of this comment was wrong and
# a comment that lies is the bug we are here to fix. The ledger (#635) is NOT empty: it held 59 rows when
# this was written, 11 of them dated 2026-07-14. The `done` hook works — for the workers that reach it.
#
# What it is not is COMPLETE, and the shape of the gap is the point. Every one of those 59 rows carries
# `skipped=0`, because the only workers that publish are the ones whose engine RESOLVED — and that is
# `.github`, the single repo which builds the engine from source. The five receivers, whose engine is
# declared-but-unrestored and therefore skips every call (see `engine_restore`), have contributed
# NOTHING, ever. So the fleet gate is not reading a fleet. It is reading one repo, and calling it the
# fleet — and ADR-0034's cut-over criterion says *"across the LIVE FLEET"*.
#
# That is #634 wearing a new coat. The lesson of #656 was that ASKING is not a mechanism; the fix chose a
# hook, and the hook sits on a path the work does not always take. A hook on ONE path is a request that
# path be taken.
#
# So publish from the SHADOW — the only path that, by construction, has just produced evidence. Nothing
# to remember, and no way to finish an item without it having run.
#
# THROTTLED, because the hot loop may not pay the network (ADR-0034 §5): one REST write per window per
# machine, amortised across every worker sharing this cache. Losing the last compare of a day to the
# window costs nothing permanent — `divergence_summaries` folds the WHOLE log, keyed on (worker, day,
# engine) and rewritten in place, so the next publish carries the missed day up with it. Late is a
# property of this ledger; lost is not.
divergence_publish_throttled() {
  [ -s "$DIVERGENCE_LOG" ] || return 0
  [ "${PUBLISH_EVERY_MIN:-0}" -gt 0 ] 2>/dev/null || return 0

  local stamp="$CACHE/divergence.published" lock="$CACHE/.divergence-publish.lock"
  local now last at
  now="$(date +%s)"
  mkdir -p "$CACHE" 2>/dev/null || true

  last="$(cat "$stamp" 2>/dev/null || echo 0)"
  case "$last" in ''|*[!0-9]*) last=0 ;; esac
  [ "$(( now - last ))" -ge "$(( PUBLISH_EVERY_MIN * 60 ))" ] || return 0

  # ATOMIC, because every worker on this box shares one cache and one log, and two racers folding the
  # same log would each find no row for worker W and each CREATE one. `mkdir` is the only atomic
  # primitive bash has.
  if ! mkdir "$lock" 2>/dev/null; then
    # AGE THE LOCK BY THE DIRECTORY'S OWN MTIME, which the kernel stamps *inside* `mkdir`.
    #
    # A separate `at` file cannot do this, and the version that used one had a hole straight through the
    # middle of it: the file is written a moment AFTER the directory appears, so a racer landing in that
    # window reads no file, ages the lock from epoch 0, decides a LIVE lock is ancient, deletes it, and
    # publishes alongside the holder. That is the exact double-publish this lock exists to prevent.
    #
    # And it would not have been rare. The throttle SYNCHRONISES the fleet: every worker on the machine
    # shares one `divergence.published` stamp, so when the window expires they do not arrive here spread
    # out — they arrive together, which is precisely when the window between `mkdir` and its follow-up
    # write is most likely to be straddled.
    at="$(mtime "$lock")"
    case "$at" in ''|*[!0-9]*) at=0 ;; esac
    # Somebody is publishing right now — not our turn. Unless they died mid-publish, in which case a
    # crashed worker's lock directory would wedge the ledger for every worker on the machine, forever.
    [ "$(( now - at ))" -gt 600 ] || return 0
    rm -rf "$lock" 2>/dev/null || true
    mkdir "$lock" 2>/dev/null || return 0
  fi

  # Stamp BEFORE the attempt. A publish that cannot work — no network, an exhausted REST budget, a ledger
  # issue somebody renamed — must cost one try per window, not one per scheduling call.
  echo "$now" >"$stamp" 2>/dev/null || true

  # Never fails its caller, and never speaks. This runs inside a worker's scheduling command: a publish is
  # bookkeeping, and bookkeeping may not fail an item or clutter the output that carries the verdict.
  soft_run divergence_publish >/dev/null 2>&1 || true
  rm -rf "$lock" 2>/dev/null || true
  return 0
}

divergence_publish() {
  local dry=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry=1; shift ;;
      *) die "divergence --publish: unknown argument '$1'." ;;
    esac
  done

  [ -s "$DIVERGENCE_LOG" ] || {
    # Publishing nothing is not an error — a worker whose shadow never ran has nothing to say, and
    # saying it loudly would be noise. But it is NOT success either: it contributes no evidence, and
    # the clock does not move for it. Say so, and exit 3 like every other no-verdict in this tool.
    echo "fsgg-coord: nothing to publish — the local divergence log is empty ($DIVERGENCE_LOG)." >&2
    echo "  Your runs contributed NO evidence, so the three-day clock did not move. If you meant to" >&2
    echo "  shadow, check that an engine resolves: fsgg-coord divergence  (and see ADR-0034 §5)." >&2
    return 3
  }

  local o="${LEDGER_REPO%%/*}" r="${LEDGER_REPO##*/}"
  local summaries; summaries="$(divergence_summaries <"$DIVERGENCE_LOG")" \
    || die "divergence --publish: could not fold $DIVERGENCE_LOG."

  [ -n "$summaries" ] || {
    echo "fsgg-coord: the log holds only SKIPPED runs — the shadow never actually compared anything." >&2
    echo "  That is not agreement, so there is nothing to publish and the clock did not move." >&2
    return 3
  }

  # Read the ledger's existing markers ONCE, not once per row. A worker publishing three days of
  # backlog must not pay three paginated reads for them.
  local existing=""
  if [ -z "$dry" ]; then
    existing="$(issue_comments "$o" "$r" "$LEDGER_ISSUE")" \
      || die "divergence --publish: cannot read the ledger ($LEDGER_REPO#$LEDGER_ISSUE) — refusing to post a duplicate row over evidence I could not see."
  fi

  local n=0
  while IFS= read -r row; do
    [ -n "$row" ] || continue
    local w d e ran cmp out unp erd rsn skipped body id
    w="$(jq -r '.worker'    <<<"$row")"; d="$(jq -r '.day'       <<<"$row")"
    e="$(jq -r '.engine'    <<<"$row")"; ran="$(jq -r '.ran'     <<<"$row")"
    cmp="$(jq -r '.compared'<<<"$row")"; out="$(jq -r '.outcome' <<<"$row")"
    unp="$(jq -r '.unpaired'<<<"$row")"; erd="$(jq -r '.engineRed'<<<"$row")"
    rsn="$(jq -r '.reason'  <<<"$row")"
    skipped="$(divergence_skips_for "$w" "$d")"

    body="$(printf '<!-- %s worker=%s day=%s engine=%s ran=%s skipped=%s compared=%s outcome=%s unpaired=%s engineRed=%s reason=%s -->\n' \
      "$DIVERGENCE_MARK" "$w" "$d" "$e" "$ran" "$skipped" "$cmp" "$out" "$unp" "$erd" "$rsn")
**$w** · $d · engine \`$e\`

| ran | skipped | compared | outcome | unpaired | engineRed | reason |
|----:|--------:|---------:|--------:|---------:|----------:|-------:|
| $ran | $skipped | $cmp | **$out** | **$unp** | **$erd** | $rsn |

\`compared\` is the unit of evidence: item-verdicts on which BOTH engines ruled. A run that compared
nothing agrees with nothing. Read this ledger with \`fsgg-coord divergence --fleet\`, never by eye."

    if [ -n "$dry" ]; then
      printf '%s\n' "$body"; n=$((n + 1)); continue
    fi

    # IDEMPOTENT BY (worker, engine, day). A worker publishes many times a day — after every loop, in
    # some harnesses — and appending would turn the ledger into a transcript that double-counts its own
    # evidence. So the worker-day-engine row is REWRITTEN in place, and the ledger stays a set of facts
    # rather than a log of them.
    #
    # The row is found by CAPTURING the marker and comparing the fields for EQUALITY — never by testing
    # the body against a regex built out of the values. An engine version is `0.1.0`, and in a regex
    # those dots match any character: `engine=0.1.0\s` would happily claim a row reading `engine=0x1x0`.
    # A near-miss here does not fail loudly; it PATCHES SOMEBODY ELSE'S EVIDENCE, which is the one thing
    # a ledger may never do.
    id="$(jq -r --arg re "$DIVERGENCE_MARKER_RE" --arg w "$w" --arg d "$d" --arg e "$e" '
      map(select(.body | test("^<!--\\s*fsgg:divergence\\s")))
      | map({id: .id, m: ((.body | [capture($re)] | first) // null)})
      | map(select(.m != null and .m.w == $w and .m.d == $d and .m.e == $e))
      | (.[0].id // empty)' <<<"$existing" 2>/dev/null)" || id=""

    if [ -n "$id" ]; then
      patch_comment "$o" "$r" "$id" "$body" \
        || die "divergence --publish: could not update the $w/$d row on the ledger."
    else
      post_comment "$o" "$r" "$LEDGER_ISSUE" "$body" >/dev/null \
        || die "divergence --publish: could not post the $w/$d row to the ledger."
    fi
    n=$((n + 1))
  done <<<"$summaries"

  if [ -n "$dry" ]; then
    echo "fsgg-coord: --dry-run — $n row(s) would be published to $LEDGER_REPO#$LEDGER_ISSUE." >&2
  else
    echo "fsgg-coord: published $n row(s) to the fleet ledger ($LEDGER_REPO#$LEDGER_ISSUE)."
    echo "  Read the fleet's verdict with: fsgg-coord divergence --fleet"
  fi
  return 0
}

# Fold the LEDGER into ADR-0034 §5's cut-over verdict — in the ENGINE, which is the only place this
# rule is allowed to exist. Bash reads (one paginated REST call); the typed core decides.
divergence_fleet() {
  local json="" want_engine="" days="$FLEET_DAYS" min_workers="$FLEET_MIN_WORKERS"
  while [ $# -gt 0 ]; do
    case "$1" in
      --json)        json=1; shift ;;
      --engine-version) want_engine="${2:?--engine-version needs a value}"; shift 2 ;;
      --days)        days="${2:?--days needs a value}"; shift 2 ;;
      --min-workers) min_workers="${2:?--min-workers needs a value}"; shift 2 ;;
      *) die "divergence --fleet: unknown argument '$1'." ;;
    esac
  done

  # THE VERDICT IS THE ENGINE'S, SO THERE MUST BE ONE. Computing "are the two engines agreeing?" with
  # no engine present is the shape of the whole defect record: an answer produced by a thing that is
  # not there. Refuse, and say how to fix it.
  if ! engine_resolve; then
    echo "fsgg-coord: no engine resolves, so the fleet verdict cannot be computed." >&2
    echo "  The criterion is a function in the typed core, and the core is what is missing." >&2
    echo "  Install it:  dotnet tool install -g FS.GG.Coord.Cli" >&2
    return 3
  fi

  [ -n "$want_engine" ] || want_engine="$(engine_version)"

  local o="${LEDGER_REPO%%/*}" r="${LEDGER_REPO##*/}"
  local raw; raw="$(issue_comments "$o" "$r" "$LEDGER_ISSUE")" \
    || die "divergence --fleet: cannot read the ledger ($LEDGER_REPO#$LEDGER_ISSUE) — refusing to compute a verdict over evidence I could not read."

  # AN UNREADABLE MARKER IS NOT AN ABSENT ONE. A `fsgg:divergence` comment we cannot parse might be the
  # one carrying the divergence, and dropping it would turn a broken publisher into a green fleet. So
  # the two counts must agree, or there is no verdict. (This is #461's lesson — a failed scan reading as
  # "nothing is claimed" — applied to the ledger before it can bite.)
  local total parsed reports
  total="$(jq '[ .[] | select(.body | test("^<!--\\s*fsgg:divergence\\s")) ] | length' <<<"$raw")"
  reports="$(jq -c --arg re "$DIVERGENCE_MARKER_RE" '
    map(select(.body | test("^<!--\\s*fsgg:divergence\\s")))
    | map((.body | [capture($re)] | first) // null)
    | map(select(. != null))
    | map({ worker: .w, day: .d, engine: .e,
            ran: (.ran | tonumber), skipped: (.sk | tonumber), compared: (.c | tonumber),
            outcome: (.o | tonumber), unpaired: (.u | tonumber),
            engineRed: (.er | tonumber), reason: (.rs | tonumber) })' <<<"$raw")" \
    || die "divergence --fleet: could not parse the ledger's markers."
  parsed="$(jq 'length' <<<"$reports")"

  if [ "$total" -ne "$parsed" ]; then
    echo "fsgg-coord: $((total - parsed)) of $total marker(s) on the ledger are UNREADABLE." >&2
    echo "  One of them may be the one that diverged, so there is no verdict — an unparseable row is" >&2
    echo "  not an absent one, and reading it as absent is how a failed scan becomes a green fleet." >&2
    return 3
  fi

  local doc out rc=0
  doc="$(jq -c -n --arg engine "$want_engine" --argjson days "$days" \
    --argjson min "$min_workers" --arg today "$(date -u +%Y-%m-%d)" --argjson reports "$reports" \
    '{schema: "fsgg.coord.ledger/1", engine: $engine, requiredDays: $days,
      minWorkers: $min, today: $today, reports: $reports}')" \
    || die "divergence --fleet: could not build the ledger document."

  if [ -n "$json" ]; then
    out="$(printf '%s' "$doc" | "${ENGINE_ARGV[@]}" fleet --json 2>/dev/null)" || rc=$?
    printf '%s\n' "$out"
  else
    printf '%s' "$doc" | "${ENGINE_ARGV[@]}" fleet --text || rc=$?
  fi

  # TRANSLATE THE ENGINE'S CODES INTO THE CLIENT'S. They are deliberately different alphabets (the
  # engine's `--help` says so), and collapsing them would be the last place left to lose a no-verdict.
  #   engine 0 green      -> 0   the criterion is MET
  #   engine 3 red        -> 1   the engines disagreed. The flip is blocked.
  #   engine 4 no-verdict -> 3   we did not establish it. NEVER zero.
  #   engine 1 error / 2 defect -> 3. A malformed ledger or a broken engine is not a clean fleet; it is
  #                                   an answer we could not reach, which is exactly what 3 means here.
  case "$rc" in
    0) return 0 ;;
    3) return 1 ;;
    4) return 3 ;;
    *) echo "fsgg-coord: the engine could not fold the ledger (exit $rc) — no verdict." >&2; return 3 ;;
  esac
}

# KEEPING TABS: tell a worker which lane it just entered, and who else is in it (#428).
#
# The claim already says WHAT you took. This says WHERE — because a lane is the set of items your
# touch-set can contend with, and the two facts a worker actually needs are: is anybody else in here with
# me, and what else is in here that I will probably want next? (Follow-up findings land in the files you
# were just standing in, which is the same lane, which is why this is worth printing at all.)
#
# Advisory, and never fatal. A lane is a nicety; a claim is a lock. If the partition cannot be computed —
# no engine, a scan that did not collect — the claim stands exactly as before and this says nothing.
lane_note() {  # <owner/repo#n>
  engine_resolve >/dev/null 2>&1 || return 0
  [ -s "${SHADOW_ITEMS:-}" ] || return 0

  local snap part id
  id="${1#*/}"                                 # owner/repo#n -> repo#n, the form the engine prints
  snap="$(mktemp "$CACHE/.lanenote.XXXXXX")"; TMPFILES+=("$snap")
  jq -n --slurpfile items "$SHADOW_ITEMS" --arg schema "$SNAPSHOT_SCHEMA" \
    '{ schema: $schema, allowBacklog: true, limit: 0, inFlight: [], items: $items }' >"$snap" 2>/dev/null || return 0
  part="$("${ENGINE_ARGV[@]}" lanes --json <"$snap" 2>/dev/null)" || return 0

  jq -r --arg id "$id" '
    ( .partition[] | select(.items[].ref == $id) ) as $lane
    | if $lane == null then empty
      else
        "  lane:     \($lane.id)  ·  \($lane.items | length) item(s) share files with this one"
        + ( if ($lane.heldBy | length) > 0
            then "\n  SHARING:  \($lane.heldBy | join(", ")) " +
                 "— you are NOT alone in this lane. Your touch-sets may still be disjoint (batch proved " +
                 "this item is), but a `widen` here can collide. Say so early: fsgg-coord say <issue> --to <worker>"
            else "\n  yours:    nobody else is in this lane — your follow-ups here will not be locked out"
            end )
      end' <<<"$part" 2>/dev/null || true
}

# Prefer a FREE lane — a lane nobody is standing in (#428).
#
# THIS MAKES NO SAFETY CLAIM, AND IT CANNOT. Every id handed to it is one `batch` has ALREADY proven
# startable and disjoint from every live claim and from every other id in the set. This only chooses
# WHICH of those equally-safe items to hand over. If it picks wrong, a worker gets a safe item in a busy
# lane — a preference missed, never a collision. That distinction is the whole reason this is allowed to
# be a heuristic at all: the moment an ordering could make an unsafe pick, it would have to move into the
# typed core and be proven, and it does not.
#
# WHY PREFER A FREE LANE. Two items in the SAME lane may still be pairwise disjoint (A—B, B—C leaves A
# and C disjoint), so the scheduler is right to offer both, and forbidding it would UNDER-schedule. But a
# worker dropped into an occupied lane is one `widen` away from a collision, and — the part that actually
# bites — its own FOLLOW-UP findings land in the files it was just standing in, i.e. the same lane, where
# somebody else is now holding the lock. That is #533's shape one level up: the recipe reliably produces
# an item its own author is locked out of.
#
# Degrades to today's behaviour with no engine: the partition is computed in the typed core, and a
# receiver without one simply gets the batch's own order, exactly as before.
lane_prefer() {  # <json array of ids, batch order> -> the same ids, free-lane ones first
  local ids="$1"
  [ "$(jq 'length' <<<"$ids" 2>/dev/null || echo 0)" -gt 1 ] || { printf '%s' "$ids"; return 0; }
  engine_resolve || { printf '%s' "$ids"; return 0; }
  [ -s "${SHADOW_ITEMS:-}" ] || { printf '%s' "$ids"; return 0; }

  local snap part
  snap="$(mktemp "$CACHE/.lanepref.XXXXXX")"; TMPFILES+=("$snap")
  jq -n --slurpfile items "$SHADOW_ITEMS" --arg schema "$SNAPSHOT_SCHEMA"     '{ schema: $schema, allowBacklog: true, limit: 0, inFlight: [], items: $items }' >"$snap" 2>/dev/null     || { printf '%s' "$ids"; return 0; }

  part="$("${ENGINE_ARGV[@]}" lanes --json <"$snap" 2>/dev/null)" || { printf '%s' "$ids"; return 0; }

  # A STABLE PARTITION, not a re-sort: `batch`'s order is deterministic and two workers depend on
  # agreeing about it, so free-lane ids keep their relative order and the rest follow in theirs.
  jq -c --argjson ids "$ids" '
    [ .partition[] | select(.free) | .items[].ref ] as $freeRefs
    | ( $ids | map(select(. as $i | $freeRefs | index($i))) ) as $preferred
    | ( $ids | map(select(. as $i | $freeRefs | index($i) | not)) ) as $rest
    | $preferred + $rest' <<<"$part" 2>/dev/null || printf '%s' "$ids"
}

# ---- lanes: the partition of the board into work that can NEVER collide (#428) --------------------
#
# `batch` answers "what may run RIGHT NOW, given what is in flight?" — a question about this instant,
# recomputed every call. A LANE is the structural fact underneath it: two items whose touch-sets do not
# overlap, and which are not joined by any CHAIN of items that do, can never contend for a file no
# matter who claims what or in which order. So a lane is a connected component of the item-overlap
# graph, and items in different lanes are PROVABLY safe to run concurrently.
#
# DERIVED, NEVER ASSERTED. Nobody declares that two items are safe together — not an agent, not a human,
# not a label on an issue. Safety is COMPUTED, in the typed core, by the same `TouchSet.conflicts` the
# scheduler already reserves against, so a lane cannot disagree with the batch about what collides
# (#485: one question, five implementations, agreeing in none). An agent's job is to improve the INPUT —
# to give an undeclared item an honest touch-set — never to pronounce on the OUTPUT. If it could, a
# confident wrong answer would put two workers in one file, which is the failure this whole protocol
# exists to prevent (#273, #461).
#
# WHAT IT BUYS over `batch`:
#   THE CEILING     the number of free lanes is how many workers this board can actually absorb. Fan out
#                   wider and the extra workers are handed NOTHING — and `take` reports an empty queue
#                   over a board full of work (#440's shape), which is indistinguishable from "no work".
#   THE CHOKEPOINT  a lane that swallows the board is not a scheduling accident; it is ONE over-broad
#                   touch-set gluing unrelated work together. `scripts/fsgg-coord` is exactly that, and
#                   it serialises four open items (#428). The partition makes it a STRUCTURE you can see
#                   rather than a series of surprises.
#   THE CHORE       the items that cannot be laned at all — the ones invisible to every worker who asks
#                   for work. That list is the agent chore's whole input.
lanes_cmd() {
  local repo="" json="" want_backlog=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)            repo="${2:?--repo needs a value}"; shift 2 ;;
      --json)            json=1; shift ;;
      --include-backlog) want_backlog=1; shift ;;
      *) die "lanes: unknown argument '$1'." ;;
    esac
  done

  # THE PARTITION IS THE ENGINE'S, SO THERE MUST BE ONE. Computing "which items can never collide?" with
  # no engine present would mean reimplementing the conflict closure in jq — a SIXTH place that answers
  # a question already answered in five (#485). Refuse, and say how to fix it.
  if ! engine_resolve; then
    echo "fsgg-coord: no engine resolves, so lanes cannot be computed." >&2
    echo "  A lane is a claim about SAFETY, and it is computed in the typed core — not guessed at here." >&2
    echo "  Install it:  dotnet tool install -g FS.GG.Coord.Cli" >&2
    return 3
  fi

  # A STALE ENGINE MAY NOT PARTITION THE BOARD (#655). Unlike the shadow — where a stale engine merely
  # produces evidence nobody should count — here its answer is USED. Engines before 0.1.1 strip the
  # leading dot from every dotfile path (#649), so `.github/workflows/**` becomes a token that matches no
  # file: it conflicts with nothing, and the lane it belongs to is wrong. A wrong lane is not a bad
  # suggestion, it is a corrupted lock — it tells a worker two items are safe to run together when they
  # are not. Refuse, loudly, and say exactly how to fix it.
  if engine_is_stale; then
    echo "fsgg-coord: the engine ($(engine_version)) is STALE — need >= $ENGINE_MIN_VERSION." >&2
    echo "  Engines before 0.1.1 mis-parse every dotfile path (.github/, .agents/, .claude/), so the" >&2
    echo "  partition they compute is WRONG — and a wrong lane says two items are safe to run together" >&2
    echo "  when they are not (#649, #273). Refusing to print one." >&2
    echo "  Update:  dotnet tool update -g FS.GG.Coord.Cli" >&2
    return 3
  fi

  # THE SCHEDULER'S OWN SCAN. `batch` populates the snapshot as a side effect of deciding, so lanes and
  # the batch see the SAME items, the SAME bodies and the SAME claims by construction. Recomputing the
  # candidate set here would be a second observation of a moving board — and a lane that disagreed with
  # the batch about what exists is worse than no lane at all.
  LANES_COLLECT=1
  local rc=0
  batch_cmd ${repo:+--repo "$repo"} --include-backlog --json >/dev/null 2>&1 || rc=$?
  # rc is the BATCH's verdict (75 = budget, 1 = refused). A refused batch still observed the board, so
  # the partition is computable; only an unreadable board is not.
  if [ "$rc" -eq 75 ]; then
    die_rate
  fi
  [ -s "$SHADOW_ITEMS" ] || {
    echo "fsgg-coord: the board scan produced no items — refusing to report an empty partition." >&2
    echo "  An empty board and an unread board are not the same thing (#266)." >&2
    return 3
  }

  local snap; snap="$(mktemp "$CACHE/.lanes.XXXXXX")"; TMPFILES+=("$snap")
  jq -n --slurpfile items "$SHADOW_ITEMS" --arg schema "$SNAPSHOT_SCHEMA"     --argjson allow "$([ -n "$want_backlog" ] && echo true || echo false)" '
    { schema: $schema, allowBacklog: $allow, limit: 0, inFlight: [], items: $items }' >"$snap"     || die "lanes: could not assemble the board snapshot."

  if [ -n "$json" ]; then
    "${ENGINE_ARGV[@]}" lanes --json <"$snap" || die "lanes: the engine could not partition the board."
  else
    "${ENGINE_ARGV[@]}" lanes --text <"$snap" || die "lanes: the engine could not partition the board."
  fi
}

# ---- batch: THE scheduler. A maximal set of items that may run at once. --------------------------
# ADR-0021 shipped a pairwise `overlap` and told the scheduler to loop over candidate pairs by hand.
# That is O(n²) of a human's attention, and it silently ignores the items already in flight. `batch`
# answers the question a fan-out actually asks: given what is RUNNING, which Ready items can I hand
# to N workers right now? An item is schedulable iff its touch-set is disjoint from every live claim
# AND from every item already chosen for this batch. Greedy by issue number, so it is deterministic.
#
# Items with no declared `Paths:` are NOT scheduled and are reported — an undeclared touch-set is
# unschedulable by construction, and silently dropping it would look like "there is no work".
#
# Unlike `widen` and `overlap --active`, `batch` is legitimately MULTI-REPO: with no `--repo` it
# schedules across the whole board, so its reservation set mixes touch-sets from different repos. But
# `Paths:` tokens are repo-relative — `scripts/foo` in one repo and `scripts/foo` in another name two
# different files in two different worktrees — and `conflicts_between` cannot see a repo, so comparing
# them bare invents a phantom collision and under-schedules a candidate that nothing is actually
# holding (#312). #353 fixed the single-item comparers by SCOPING their input to one repo; `batch`
# cannot do that (spanning repos is the point), so instead it TAGS every reserved token with its
# owning repo (`owner/repo<TAB>token`) and projects out just the same-repo tokens before each
# comparison — honouring `conflicts_between`'s same-repo contract without collapsing the batch to one
# repo. `tag_repo` tags a token list; `reserved_in` reads one repo's tokens back out.
tag_repo() {  # $1=token list (newline-separated)  $2=owner/repo -> `owner/repo<TAB>token` lines
  printf '%s\n' "$1" | awk -v r="$2" 'NF { print r "\t" $0 }'
}
reserved_in() {  # $1=repo-tagged lines  $2=owner/repo -> the bare tokens reserved in THAT repo
  printf '%s\n' "$1" | awk -F'\t' -v r="$2" 'NF >= 2 && $1 == r { print $2 }'
}
batch_cmd() {
  local repo="" want=0 json="" include_backlog="" ignore_blocked=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)   repo="${2:?--repo needs a value}"; shift 2 ;;
      -n)       want="${2:?-n needs a value}"; shift 2 ;;
      --json)   json=1; shift ;;
      --include-backlog) include_backlog=1; shift ;;
      # A DIAGNOSTIC, never a scheduling mode (#485 leg a). `next --ignore-blocked` exists to answer
      # "what WOULD be startable if the blockers cleared", and `next` is now this function's
      # presentation layer, so the flag has to live here. It relaxes the blocker filter and NOTHING
      # else: touch-sets, unmatchable tokens and live claims are still enforced, because those are
      # collisions rather than sequencing — no flag may hand out an item two workers would fight over.
      --ignore-blocked)  ignore_blocked=1; shift ;;
      -*)       die "batch: unknown flag '$1'." ;;
      *)        die "batch: unexpected argument '$1'." ;;
    esac
  done
  # The engine `take` schedules from — it must answer for the same scope (#480). A read, so an
  # undetectable checkout falls back to the org rather than dying; `take` is the one that refuses.
  repo="$(scope_repo "$repo")"
  [ -n "$repo" ] && repo="$(resolve_repo "$repo")"
  case "$want" in ''|*[!0-9]*) die "batch: -n must be a number." ;; esac

  local items cands active
  # The CALLER decides whether this is a scheduling read or a truth read, and it says so by exporting
  # CACHED (#418). `take` — the worker loop's entry point, and the reason the budget ever ran out —
  # sets CACHED=1, so five workers polling for work cost ONE board scan a window between them. A human
  # running `batch` directly gets the fresh board they came for. Either way `active_claims` reads its
  # markers over REST, uncached: the schedule may be 90s stale, the LOCK never is.
  items="$(board_items)"
  active="$(active_claims "$repo")"
  cands="$(board_filter "$repo" "Ready" "" "0" <<<"$items")"
  if [ -n "$include_backlog" ]; then
    cands="$(jq -c -s 'add' <(printf '%s' "$cands") <(board_filter "$repo" "Backlog" "" "0" <<<"$items"))"
  fi

  # ADR-0034 Phase 2. The typed engine decides the SAME candidate set, from the SAME observations, and
  # its answer is thrown away — only the disagreement is kept. `all_cands` is snapshotted here, before
  # the closed/blocked filters below drop candidates from bash's view: those filters are exactly where
  # the two engines' check ORDER differs, so a shadow that never saw the dropped items would be blind
  # to the one class of divergence it is most likely to find.
  shadow_init
  # The engine must be told the rule bash APPLIED, not the rule bash knows — see shadow_blockers_json.
  SHADOW_IGNORE_BLOCKED="$ignore_blocked"
  local all_cands="$cands"
  # A BLOCKED candidate is dropped here — but it must not be dropped SILENTLY (#488). It never reaches
  # the skip-reason loop below, so before that fix it contributed nothing to `$skipped`, `take`'s stderr
  # came back empty, and `take` concluded from that emptiness that there were "no open board items at
  # all — an empty queue, not a blocked one". The one state most likely to starve a queue was the one
  # state that left no trace. `blocked` is a REASON, and reasons are what `batch` exists to report.
  #
  # It is also where `next` gets its blocker diagnostic from now (#485 leg a): `next` used to compute
  # and print this itself, with its own idea of what "startable" meant. It no longer has one — `batch`
  # is the predicate, so the reason has to be produced HERE or it is lost.
  local blocked_out skipped=""
  # The subset of `skipped` that a LIVE CLAIM is responsible for, as `worker<TAB>ageSec` rows (#428).
  # Kept apart from `skipped` because it answers a different question: that list says why each ITEM is
  # not startable, this says whether the QUEUE is worth waiting for — and only a lease can say that.
  local queued=""

  # THE SIXTH DISAGREEMENT (#520, the residue of #485). Candidate selection reads the board `Status`
  # column and NOTHING ELSE — so a CLOSED issue whose column was never flipped to `Done` stays a
  # candidate forever. `board_items` has carried `.state` all along (1327); nothing ever read it.
  #
  # This is not theoretical. FS.GG.Rendering#502 was handed to a worker TWO HOURS after it was closed
  # as completed — and then, when that worker released the claim, #481's restore-the-column logic
  # promoted it `Backlog` -> `Ready`, re-arming it for the next one. The board column is a PROJECTION
  # of the work; the issue's state is the WORK. When they disagree, the issue wins.
  #
  # `lint` has always known this (`select(.state == "OPEN")`, 1796) — the scheduler simply never
  # asked. #520 said the guard belongs in "the one surviving leg" once #485 landed. #485 landed. This
  # is that guard, and it is here rather than in `board_filter` because `ready --all` must still be
  # able to SHOW a closed item; only the SCHEDULER may refuse to hand it out.
  local closed_out
  closed_out="$(jq -r '
    .[] | select(.number != null) | select(.state != null and .state != "OPEN")
    | "  \(.repo | sub("^[^/]+/";""))#\(.number) — the issue is \(.state | ascii_downcase) (the board column says \(.status // "unset"); /check-board reconciles it)"' <<<"$cands")"
  if [ -n "$closed_out" ]; then skipped="$skipped$closed_out"$'\n'; fi
  shadow_verdict_bulk "$cands" 'select(.number != null) | select(.state != null and .state != "OPEN")' 'issue-closed'
  cands="$(jq -c 'map(select(.state == null or .state == "OPEN"))' <<<"$cands")"

  if [ -z "$ignore_blocked" ]; then
    # Name the blocker's STATE too. A MERGED blocker is RESOLVED (#485 leg e), so it can never be why
    # an item is blocked — listing it among the reasons would send a reader to look at finished work.
    blocked_out="$(jq -r "$JQ_BLOCKER_RULE"'
      .[] | select(.number != null) | select(.blocked)
      | ( [ (.blockers // [])[] | unresolved
            | "\(.ref | sub("^[^/]+/";"")) (\(.state | ascii_downcase))" ]
          | if length == 0 then "an unnamed blocker" else join(", ") end ) as $b
      | "  \(.repo | sub("^[^/]+/";""))#\(.number) — blocked by \($b)"' <<<"$cands")"
    # An `&&` statement here would return 1 when there are NO blocked candidates — the common case —
    # and `set -euo pipefail` would exit the script on it, silently. Use an explicit `if`.
    if [ -n "$blocked_out" ]; then skipped="$skipped$blocked_out"$'\n'; fi
    shadow_verdict_bulk "$cands" 'select(.number != null) | select(.blocked)' 'blocked-by'
    cands="$(jq -c 'map(select(.blocked | not) | select(.number != null)) | sort_by(.number)' <<<"$cands")"
  else
    # `--ignore-blocked` is a DIAGNOSTIC, never a scheduling mode (#485 leg a): it answers "what WOULD
    # be startable if the blockers cleared". It relaxes the blocker filter and NOTHING else — touch-sets,
    # unmatchable tokens and live claims are still enforced, because those are COLLISIONS rather than
    # sequencing, and no flag may hand out an item two workers would fight over.
    cands="$(jq -c 'map(select(.number != null)) | sort_by(.number)' <<<"$cands")"
  fi

  # Touch-sets already spoken for by in-flight work. `active_claims` finds a claim by its MARKER, so
  # this reserves the touch-sets of items the board has lost track of (a failed `Status` flip, or an
  # item never added to the board) — which the column-seeded version silently left free to schedule.
  # Each token carries its owning repo (`owner/repo<TAB>token`); every comparison below projects out
  # just the candidate's own repo first, because a cross-repo token names a different file (#312).
  local active_paths; active_paths="$(jq -r '.[] | .repo as $r | .paths[]? | "\($r)\t\(.)"' <<<"$active")"

  # A held item whose touch-set is unmatchable RESERVES NOTHING: every candidate would clear it, and
  # `batch` would hand a second worker the very files it is holding. We cannot see that item's real
  # surface, so we cannot schedule anything against it — refuse, exactly as `paths_of` refuses to
  # schedule against a touch-set it could not read.
  local active_bad
  active_bad="$(claims_with_unmatchable_paths "$active")"
  [ -z "$active_bad" ] || die "batch: in-flight claim(s) declare unmatchable touch-set token(s) and therefore reserve nothing: $active_bad — refusing to schedule against an unknown touch-set. Fix with: fsgg-coord widen <issue> --paths '<paths>'"

  local -a chosen_ids=() chosen_paths=() chosen_repos=()
  local n i=0                    # NB: `skipped` is declared ABOVE — it is pre-seeded with the blocked
  n="$(jq 'length' <<<"$cands")" # candidates (#488). Re-declaring it here would silently drop them.
  while [ "$i" -lt "$n" ]; do
    local it r num id p hits j clash holder body hold age
    it="$(jq -c ".[$i]" <<<"$cands")"; i=$((i + 1))
    r="$(jq -r '.repo' <<<"$it")"; num="$(jq -r '.number' <<<"$it")"
    id="${r#*/}#$num"
    # Read the LOCK, not the board column: a claim whose Status flip failed still owns the item. And
    # a claimed item does not merely drop out of the batch — its touch-set is OCCUPIED, so it must
    # also be added to `active_paths`. Skipping without reserving would happily schedule a candidate
    # that overlaps the very item another worker is holding.
    #
    # ONE body read, two questions (#496): the touch-set, and whether it is the `Paths: none` sentinel.
    body="$(body_of "${r%%/*}" "${r#*/}" "$num")"
    p="$(paths_from_body "$body")"
    # ONE marker read, holder AND age (#428) — the age is what turns "go away" into "wait ~12m".
    hold="$(live_claim_holder "${r%%/*}" "${r#*/}" "$num")"
    holder="${hold%%$'\t'*}"; age="${hold##*$'\t'}"
    if [ -n "$holder" ]; then
      shadow_observe "$it" "$body" "lease-held" "$holder" "$age"
      shadow_verdict "$id" "held-by" "live-claim" "$p"
      # Same rule as the `active` pre-check, for a claim that never reached the board: an unmatchable
      # touch-set reserves nothing, so its holder's files are invisible to every later comparison.
      [ -z "$(invalid_paths "$p")" ] || die "batch: $id is claimed by worker $holder but declares unmatchable touch-set token(s): $(fmt_bad_paths "$(invalid_paths "$p")") — it reserves nothing, so refusing to schedule against an unknown touch-set. Fix with: fsgg-coord widen $id --paths '<paths>'"
      active_paths="$active_paths${active_paths:+$'\n'}$(tag_repo "$p" "$r")"
      skipped="$skipped  $id — already claimed by worker $holder ($(lease_window "$age"))"$'\n'
      queued="$queued$holder"$'\t'"$age"$'\n'
      continue
    fi

    # AN EXPIRED LEASE IS NOT PROOF OF ABANDONMENT (#581). `live_claim_worker` ignores an expired
    # marker — correctly, an expired lease is not a lock — and that is exactly how this item gets
    # handed to a second worker while the first is still on it. Before offering it, ASK THE SERVER:
    # an open PR whose head is `item/<n>-*` is the worktree protocol's own artifact, and it is proof
    # of life the lease cannot see.
    #
    # Cost is bounded by construction: only a candidate carrying an EXPIRED marker reaches this, which
    # is rare — and the probe is REST, on a different budget from the one that is routinely gone.
    #
    # Note the item is still RESERVED, not merely skipped. Its worker is alive and in those files.
    local stale_holder alive
    stale_holder="$(stale_claim_worker "${r%%/*}" "${r#*/}" "$num")"
    if [ -n "$stale_holder" ]; then
      alive="$(pr_alive "${r%%/*}" "${r#*/}" "$num")"
      if [ -n "$alive" ]; then
        local alive_pr; alive_pr="${alive%% *}"; alive_pr="${alive_pr#\#}"
        shadow_observe "$it" "$body" "lease-expired-pr-open" "$stale_holder" "0" "$alive_pr"
        shadow_verdict "$id" "held-by-live-work" "live-claim" "$p"
        [ -z "$(invalid_paths "$p")" ] || die "batch: $id has an expired claim by worker $stale_holder whose work is still live (PR $alive), but it declares unmatchable touch-set token(s): $(fmt_bad_paths "$(invalid_paths "$p")") — it reserves nothing. Fix with: fsgg-coord widen $id --paths '<paths>'"
        active_paths="$active_paths${active_paths:+$'\n'}$(tag_repo "$p" "$r")"
        skipped="$skipped  $id — lease EXPIRED, but PR $alive is open: worker $stale_holder is demonstrably still working it (#581). Not offering it; its touch-set stays reserved."$'\n'
        continue
      fi
    fi

    shadow_observe "$it" "$body" "" "" "0"

    if [ -z "$p" ]; then
      # Two very different states used to print one sentence (#496). Neither is schedulable, but only
      # one is a BUG: `Paths: none` is a decision somebody made, an absent line is an omission nobody
      # noticed. Say which — the worker reading this list is the person who can fix the second.
      if declares_no_touchset "$body"; then
        shadow_verdict "$id" "deliberately-no-touch-set"
        skipped="$skipped  $id — 'Paths: none' (deliberately has no touch-set; not schedulable by design)"$'\n'
      else
        shadow_verdict "$id" "no-touch-set"
        skipped="$skipped  $id — no 'Paths:' declared (cannot schedule — this is an OMISSION; declare one, or 'Paths: none' if it truly has no touch-set)"$'\n'
      fi
      continue
    fi
    # A candidate is merely unschedulable, not fatal: pass it over with the reason, as an undeclared
    # touch-set is. Never let it fall through to `conflicts_between`, which would clear it against all.
    if [ -n "$(invalid_paths "$p")" ]; then
      # NAME THE CAUSE (#485 leg b). This used to print the tokens and stop, so an author whose only
      # sin was writing the line in markdown saw their item vanish from the queue and were told
      # nothing they could act on. Backticks are now stripped at parse, so anything still flagged here
      # is a REAL author error — and the grammar is the one thing that says which.
      shadow_verdict "$id" "unusable-touch-set" "" "$p"
      skipped="$skipped  $id — unmatchable 'Paths:' token(s): $(fmt_bad_paths "$(invalid_paths "$p")") (cannot schedule; $TOUCHSET_GRAMMAR)"$'\n'; continue
    fi
    hits="$(conflicts_between "$p" "$(reserved_in "$active_paths" "$r")")"
    if [ -n "$hits" ]; then
      # NAME THE HOLDER, NOT JUST THE FILES (#428). This line used to report the colliding PATHS and
      # stop — which tells a worker that they are blocked, and withholds the one fact every remedy in
      # the protocol needs: WHO. Waiting, `say`, and "is this worth waiting for at all" are decisions
      # about a worker and a lease; a pair of paths cannot inform any of them, so the worker's only
      # move was to go read `who` and join the two lists by hand.
      #
      # `conflicts_between` prints `candidate  ⇄  reserved`, so the RESERVED side is the token some
      # live claim is holding — the key that joins this collision back to its owner.
      local hit1 rtok owner_rec oworker oitem oage
      hit1="$(printf '%s' "$hits" | head -1)"
      rtok="${hit1##*  ⇄  }"
      owner_rec="$(claim_reserving "$active" "$r" "$rtok")"
      if [ -n "$owner_rec" ]; then
        # IFS=US, never TAB: an empty leading field must survive the split — see `claim_reserving`.
        IFS=$'\x1f' read -r oworker oitem oage <<<"$owner_rec"
        if [ -n "$oworker" ]; then
          shadow_verdict "$id" "overlaps-in-flight" "live-claim" "$p"
          skipped="$skipped  $id — overlaps in-flight work held by $oworker on $oitem ($(lease_window "$oage")): $hit1"$'\n'
          queued="$queued$oworker"$'\t'"$oage"$'\n'
        else
          shadow_verdict "$id" "overlaps-in-flight" "unowned" "$p"
          # RESERVED, BUT BY NOBODY THE PROTOCOL CAN NAME: the board says $oitem is `In progress` and
          # no marker backs it, so its touch-set is held by someone working outside the protocol. It
          # is deliberately NOT counted into `queued`: there is no lease to wait out and no worker to
          # `say` to, and folding it into "queued behind live claims … soonest frees in ~Nm" would
          # advertise a wait that nothing will ever end. `who` already flags the item; point there.
          skipped="$skipped  $id — overlaps $oitem, which the board says is In progress with NO claim marker (someone is working outside the protocol — there is no lease to wait out; see: fsgg-coord who): $hit1"$'\n'
        fi
      else
        # Belt and braces: the reserved token came FROM the claim set, so a miss here means the two
        # went out of step. Report the collision we can prove rather than inventing an owner for it.
        shadow_verdict "$id" "overlaps-in-flight" "unknown" "$p"
        skipped="$skipped  $id — overlaps in-flight work: $hit1"$'\n'
      fi
      continue
    fi
    clash=""
    for ((j = 0; j < ${#chosen_paths[@]}; j++)); do
      # Two chosen items in different repos share no file (different worktrees) — never compare them.
      [ "${chosen_repos[j]}" = "$r" ] || continue
      hits="$(conflicts_between "$p" "${chosen_paths[j]}")"
      [ -n "$hits" ] && { clash="${chosen_ids[j]} ($(printf '%s' "$hits" | head -1))"; break; }
    done
    if [ -n "$clash" ]; then
      # The typed core reports this as `overlaps-in-flight` too, and distinguishes it by WHO holds the
      # tokens — `collidedWith.kind = batch-member` rather than `live-claim`. So the verdict TOKEN
      # agrees and the holder is compared separately: a batch member frees at the end of this run and
      # has no lease, which is a different instruction to an operator than "wait ~12m for worker w-x".
      shadow_verdict "$id" "overlaps-in-flight" "batch-member" "$p"
      skipped="$skipped  $id — overlaps batch member $clash"$'\n'; continue
    fi
    shadow_verdict "$id" "startable" "" "$p"
    chosen_ids+=("$id"); chosen_paths+=("$p"); chosen_repos+=("$r")
    [ "$want" -gt 0 ] && [ "${#chosen_ids[@]}" -ge "$want" ] && break
  done

  # THE SHADOW RUNS HERE — after bash has decided, and before bash prints. It observes the candidates
  # bash short-circuited (see `shadow_sweep`), hands the engine the state bash saw, and records the
  # disagreement. It cannot reach any of the variables printed below, and it is the last thing that
  # could ever be allowed to.
  if shadow_enabled; then
    local infl; infl="$(mktemp "$CACHE/.snap-inflight.XXXXXX")"; TMPFILES+=("$infl")
    # The reservation set, as bash built it: every live claim, with the repo its tokens belong to.
    # Tokens are repo-relative (#312), and a reservation that loses its repo invents collisions.
    # `.ageSec // -1`, NOT `// 0`: an age we do not have is UNKNOWN, and 0 would read as a claim taken
    # seconds ago — so the engine would answer "lease frees in ~120m" about a marker carrying no
    # timestamp at all. See shadow_claim_json.
    jq -c '.[] | select(.paths != null and (.paths | length) > 0)
           | { owner: (.repo | split("/")[0]), repo: (.repo | split("/")[1:] | join("/")),
               paths: .paths,
               holder: (if (.worker // "") == "" then {kind: "unowned"}
                        else {kind: "live-claim", worker: .worker, ageSeconds: (.ageSec // -1)} end
                        + { owner: (.repo | split("/")[0]),
                            repo: (.repo | split("/")[1:] | join("/")),
                            number: .number }) }' <<<"$active" >"$infl" 2>/dev/null || true
    shadow_sweep "$all_cands"
    shadow_run "$([ -n "$include_backlog" ] && echo 1 || echo 0)" "$want" "$infl" "$repo"
  fi

  # ---- THE FLIP (ADR-0034 Phase 3b) -------------------------------------------------------------
  #
  # In `fs`, the engine's decision REPLACES bash's. Everything above still ran: bash read the board,
  # assembled the snapshot, computed its own answer, and the divergence log still records both — so a
  # disagreement is still evidence, and `--engine bash` still reproduces the old behaviour byte for
  # byte. What changes is only WHOSE ANSWER THE CALLER GETS.
  #
  # The reasons are RELAYED, not restated. The engine already emits `explain` per decision, in the one
  # place a coordination rule is allowed to exist; rebuilding that prose here would re-create the very
  # projection ADR-0034 deletes — a rule stated twice is a rule that will disagree with itself, which
  # is #485 (one question, five implementations, agreeing in none) reopened by the fix for #485.
  #
  # Every failure here is FATAL. Falling back to bash after asking for the typed core would be a silent
  # engine substitution — invisible in the ledger, and indistinguishable from agreement.
  if engine_authoritative; then
    [ -n "$ENGINE_DECISION" ] || die "--engine=fs: the engine reached no decision, and bash's is not on offer"

    # THE UNREADABLE CANDIDATE IS THE ENGINE'S PROBLEM NOW, AND IT HAS THE VOCABULARY FOR IT.
    #
    # The first cut of this made an unobserved candidate FATAL here — "we did not read the board, so we
    # do not decide". The corpus rejected it, and it was right to: `shadow_sweep` fails to read the body
    # of every BLOCKED candidate, routinely, because bash short-circuits blocked items before it ever
    # fetches a body and so those bodies were never fixtures to begin with. Dying on that would starve
    # every worker on the board over one item they could never have been given anyway — the exact hazard
    # the uncapped-batch fallback exists for.
    #
    # The right answer was in the type system all along: such an item now travels with `bodyUnreadable`,
    # its touch-set is `Unreadable` (UNKNOWN, not absent), and the engine returns `Undetermined` — not
    # startable, and SAID SO. Blockers are checked BEFORE the touch-set, so a blocked item still decides
    # correctly without its body ever being read. Nothing is silently dropped, and nothing is invented.
    local ev
    ev="$(jq -r '.verdict // "-"' <"$ENGINE_DECISION" 2>/dev/null)" || ev="-"
    case "$ev" in
      green) ;;
      red)
        { echo "REFUSED — the batch cannot be scheduled:"
          jq -r '.reasons[]? | "  " + .' <"$ENGINE_DECISION" 2>/dev/null; } >&2
        die "--engine=fs: the engine REFUSED the batch (see the reasons above)"
        ;;
      no-verdict)
        die "--engine=fs: UNDETERMINED — $(jq -r '.reason // "the engine gave no reason"' <"$ENGINE_DECISION" 2>/dev/null)"
        ;;
      *)
        die "--engine=fs: the engine's decision carries no verdict this client understands ('$ev')"
        ;;
    esac

    chosen_ids=()
    mapfile -t chosen_ids < <(jq -r '.chosen[]?.short // empty' <"$ENGINE_DECISION" 2>/dev/null)

    # `skipped` was pre-seeded with BASH's blocked candidates (#488) and grown by bash's touch-set
    # loop. Those are bash's words about bash's answer. Replace them wholesale — printing bash's
    # explanation beside the engine's decision is how a worker gets told a true sentence about the
    # wrong question.
    skipped=""
    local xline
    while IFS= read -r xline; do
      [ -n "$xline" ] && skipped="$skipped  $xline"$'\n'
    done < <(jq -r '.decisions[]? | select(.verdict != "startable") | .explain // empty' \
               <"$ENGINE_DECISION" 2>/dev/null)
  fi

  if [ -n "$json" ]; then
    printf '%s\n' "${chosen_ids[@]+"${chosen_ids[@]}"}" | jq -R -s -c 'split("\n") | map(select(length > 0))'
  else
    if [ "${#chosen_ids[@]}" -eq 0 ]; then
      echo "fsgg-coord: nothing schedulable${repo:+ for repo '$repo'} right now."
    else
      printf 'schedulable in parallel (%s):\n' "${#chosen_ids[@]}"
      printf '  → %s\n' "${chosen_ids[@]}"
    fi
  fi
  # The passed-over reasons go to stderr in BOTH modes (#440). They ARE the answer to "why is there
  # nothing to do", and `take` — which calls this with --json — used to throw them away and print a
  # fixed sentence naming four causes instead, none of which had to be true. stdout still carries
  # only the JSON, so no consumer is disturbed.
  # Blocked candidates are passed over BEFORE the touch-set loop runs, so their reasons are collected
  # separately — but they are the same answer to the same question, and a worker should not have to
  # know which stage rejected their item to find out why (#485 leg a).
  [ -n "$skipped" ] && { echo "passed over:"; printf '%s' "$skipped"; } >&2

  # THE OPERATOR LINE (#428), and ONLY when the worker got nothing — that is the moment the question
  # changes. The per-item list above answers "why is this item not startable". A worker standing in
  # front of a queue that handed them nothing is asking something else entirely: "is there anything
  # coming, and should I wait for it?" That question is about LEASES, and until now the answer was
  # spread across `next`, `who` and a mental join between them.
  #
  # It is the difference #428 was filed on: "nothing schedulable" and "4 items are queued behind a
  # claim held by <worker>, lease frees in ~96m" are the same fact and two completely different
  # operator instructions. The first reads as an empty queue and sends a worker home; only the second
  # says the repo is BUSY, names who to talk to, and gives a number to decide against.
  #
  # The SOONEST lease to free is the OLDEST claim — max age, not min. Getting that backwards would
  # advertise the longest wait as the shortest, which is worse than saying nothing.
  if [ -n "$queued" ] && [ "${#chosen_ids[@]}" -eq 0 ]; then
    local qn qworkers qoldest qexpired
    qn="$(printf '%s' "$queued" | grep -c . || true)"
    qworkers="$(printf '%s' "$queued" | cut -f1 | sort -u | paste -sd',' - | sed 's/,/, /g')"
    qoldest="$(printf '%s' "$queued" | cut -f2 | grep -E '^[0-9]+$' | sort -n | tail -1 || true)"
    qexpired="$(printf '%s' "$queued" | cut -f2 | grep -E '^[0-9]+$' \
                | awk -v lease="$CLAIM_LEASE_MIN" '$1 / 60 >= lease' | grep -c . || true)"
    {
      echo "$qn item(s) are QUEUED BEHIND LIVE CLAIMS held by: $qworkers — soonest: $(lease_window "${qoldest:-}")."
      echo "  this queue is BUSY, not empty. wait for the lease, take work in another repo (--repo <r>),"
      echo "  or talk to the holder:  fsgg-coord say <issue> --to <worker> '<message>'"
      # A dead holder is not a wait, and it is the one case a worker can clear THEMSELVES.
      # An `&&` one-liner here would be the LAST command of this group: on the (common) zero-expired
      # path it returns 1, and under `set -e` that would take the whole scan down at the finish line.
      if [ "${qexpired:-0}" -gt 0 ]; then
        echo "  $qexpired of those lease(s) have EXPIRED — collect them: fsgg-coord reap${repo:+ --repo $repo} --apply"
      fi
    } >&2
  fi
  return 0
}

# ---- assert_blockers_clear: the scheduler's last word before it points a worker at an item --------
#
# The board scan says an item is startable. This asks the SERVER whether that is still true, for the
# ONE item about to be claimed. It exists because #485 leg (f) is an observed fail-open whose mechanism
# was never pinned: `batch` handed out an item whose blocker was open, with `blocked=false`.
#
# Deliberately NOT a re-derivation from the same scan — that would re-read the input that was already
# wrong. It goes to the source. Cost is bounded by the picked item's blocker count (almost always
# zero, occasionally one or two), and it spends REST, which is not the budget under pressure.
#
# REST answers both kinds in one endpoint: `/issues/N` serves pull requests too, and a MERGED PR is
# `state: closed` there — so "still blocking" is exactly `state == "open"`, for issues and PRs alike.
# A lookup that FAILS leaves the ref unresolved, and an unresolved blocker blocks: the safe direction.
assert_blockers_clear() {
  local pick="$1" item refs ref o r n st open="" failed=""
  item="$(CACHED=1 board_items \
          | jq -c --arg id "$pick" 'map(select(((.repo // "" | sub("^[^/]+/";"")) + "#" + ((.number // 0)|tostring)) == $id)) | .[0] // empty')"
  [ -n "$item" ] || return 0
  refs="$(jq -r '.blockers[]?.ref // empty' <<<"$item" 2>/dev/null || true)"
  [ -n "$refs" ] || return 0                       # the common case: no blockers, no calls, no cost
  while IFS= read -r ref; do
    [ -n "$ref" ] || continue
    o="${ref%%/*}"; r="${ref#*/}"; n="${r##*#}"; r="${r%%#*}"
    # A ref we cannot PARSE is not a ref we have cleared. This used to `continue` — silently DROPPING
    # it — which is fail-OPEN in the one function whose entire purpose is to distrust the scan and go
    # ask the server. `board_annotate` counts an UNPARSEABLE ref as blocking (its own comment: "an
    # unresolvable blocker blocks: the safe direction"), and every other read in this file dies rather
    # than guess. This one agreed with neither. "I could not look" is not "I looked and it is fine"
    # (#266) — and this is the LAST check before a worker is pointed at the item.
    case "$n" in ''|*[!0-9]*) failed="$failed $ref"; continue ;; esac
    if st="$(gh api "repos/$o/$r/issues/$n" --jq '.state' 2>/dev/null)"; then
      [ "$st" = "open" ] && open="$open $ref"
    else
      failed="$failed $ref"                        # could not read it -> cannot claim it resolved
    fi
  done <<<"$refs"
  [ -z "$open" ] || die "take: refusing to claim $pick — its blocker(s) are OPEN right now:$open. The board scan called this item startable and the server disagrees, so the board is lying about a dependency (.github#485 leg f). Claiming it would put you on work another item still owns. Re-run with --fresh, and if it persists, run /check-board."
  [ -z "$failed" ] || die "take: refusing to claim $pick — could not read its blocker(s):$failed. An unverifiable blocker is not a cleared one, and this is the last check before a worker is pointed at the item."
  return 0
}

# ---- take: pick + claim in one step, retrying a lost race. ---------------------------------------
# ADR-0021's loop was `next || exit 0; claim || exit 0` — a worker that lost a race simply went home,
# leaving startable work on the board. `take` re-schedules instead: on a lost race the board has moved,
# so recompute the batch and try the next item. Claiming is what resolves the race, so we never
# pre-filter on "looks unclaimed" — we just try, and let the CAS decide.
take_cmd() {
  local repo="" tries=3
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)  repo="${2:?--repo needs a value}"; shift 2 ;;
      --tries) tries="${2:?--tries needs a value}"; shift 2 ;;
      -*)      die "take: unknown flag '$1'." ;;
      *)       die "take: unexpected argument '$1'." ;;
    esac
  done
  case "$tries" in ''|*[!0-9]*) die "take: --tries must be a number." ;; esac
  # Default to the repo you are standing in (#480). `take` is the one command here that ACTS — it
  # claims an item and prints a worktree command against THIS checkout's origin — so an undetectable
  # scope is a hard error, not a quiet fall back to the whole org. Falling back is what handed a
  # `.github` worker an FS.GG.Game item and a worktree command that would have built it in the wrong
  # repository. A read can afford to guess wide; a claim cannot.
  repo="$(scope_repo "$repo")"
  [ -n "$repo" ] || die "take: --repo required (no git remote here, so 'the repo you are standing in' is undefined)."
  worker >/dev/null; local w="$WORKER_ID"
  autoflush                                    # a queued board write drains here, not on a human's memory
  local -a repoflag=(--repo "$repo")
  local attempt=1
  while [ "$attempt" -le "$tries" ]; do
    local pick
    # The FIRST look may ride the shared scan cache (that is the whole point — N workers, one scan).
    # A RETRY may not: we just lost a race, which means the cached scan is demonstrably behind the
    # board, and re-reading it would re-pick the item we just lost, burn the retries, and idle the
    # worker. So a retry pays for a fresh scan — the one case where the 7 points are worth it (#418).
    [ "$attempt" -gt 1 ] && export FRESH=1
    local berr from_backlog=""
    berr="$(mktemp "$CACHE/.batch-err.XXXXXX")"
    # PREFER A FREE LANE (#428) — a lane nobody is standing in. This asks `batch` for the WHOLE
    # startable set rather than just its first member, because `-n 1` makes the lane invisible:
    # whatever the batch happened to order first is the only thing on offer.
    #
    # IT IS A PREFERENCE OVER AN ALREADY-SAFE SET, and it makes no safety claim of its own. Every id in
    # that set is one `batch` has proven startable, disjoint from every live claim, and disjoint from
    # every other id in it. Choosing differently among them can miss a preference; it cannot cause a
    # collision. That is the only reason this is allowed to be a heuristic instead of a proof.
    local ids="[]" lrc=0
    LANES_COLLECT=1
    ids="$(CACHED=1 batch_cmd "${repoflag[@]+"${repoflag[@]}"}" --json 2>"$berr")" || lrc=$?
    [ "$lrc" -eq 0 ] && [ -n "$ids" ] || ids="[]"
    if [ "$(jq 'length' <<<"$ids" 2>/dev/null || echo 0)" -eq 0 ]; then
      lrc=0
      ids="$(CACHED=1 batch_cmd "${repoflag[@]+"${repoflag[@]}"}" --include-backlog --json 2>"$berr")" || lrc=$?
      [ "$lrc" -eq 0 ] && [ -n "$ids" ] || ids="[]"
      [ "$(jq 'length' <<<"$ids" 2>/dev/null || echo 0)" -gt 0 ] && from_backlog=1
    fi
    pick="$(jq -r '.[0] // empty' <<<"$(lane_prefer "$ids")")"

    # THE FALLBACK, AND IT IS NOT OPTIONAL. `batch` fails CLOSED on a touch-set it could not read — it
    # refuses to schedule against a body it never saw, and that is correct (it is the whole Red leg).
    # But `-n 1` STOPPED AT THE FIRST PICK, so it never reached a later unreadable item; asking for the
    # WHOLE set walks straight into one. A single unreadable issue body anywhere on the board would then
    # leave `take` with NOTHING — a lane preference costing a worker their item, which is exactly
    # backwards. Measured: the fixture's FS.GG.Governance#203 does this, and the uncapped read returns
    # an empty batch where the capped one returns #202.
    #
    # A PREFERENCE MAY NEVER SUBTRACT. If the wide read failed for any reason, fall back to precisely
    # the pick `take` made before lanes existed. The worker loses the preference and keeps the work.
    if [ -z "$pick" ]; then
      from_backlog=""
      pick="$(CACHED=1 batch_cmd "${repoflag[@]+"${repoflag[@]}"}" -n 1 --json 2>"$berr" | jq -r '.[0] // empty')"
      # READY, ELSE BACKLOG — the same rule `next` already follows (#440). `take` used to stop at
      # `Ready`, so a board with zero Ready items and a queue of startable Backlog ones reported
      # "nothing to do" while a worker stood idle in front of it. The two commands a worker treats as
      # "what do I do next" must agree about what EXISTS; this is the line that makes them.
      if [ -z "$pick" ]; then
        pick="$(CACHED=1 batch_cmd "${repoflag[@]+"${repoflag[@]}"}" --include-backlog -n 1 --json 2>"$berr" \
                | jq -r '.[0] // empty')"
        [ -n "$pick" ] && from_backlog=1
      fi
    fi
    if [ -z "$pick" ]; then
      # Say what is TRUE, and let `batch` say WHY — per item, in its own words. The old sentence
      # ("every candidate is blocked, claimed, overlapping, or undeclared") was a guess dressed as a
      # finding: on the board that produced #440, all four clauses were false and the real reason —
      # the item was in Backlog — was not among them. A worker that believes such a message stops.
      echo "fsgg-coord: nothing schedulable${repo:+ for repo '$repo'} — no Ready or Backlog item is startable." >&2
      # `batch`'s stderr carries the per-item skip REASONS — and also anything else it writes there,
      # `dbg` included. The old branch asked `[ -s "$berr" ]`: "did batch write ANY byte to stderr?"
      # That is not the question, and it is wrong in both directions. With FSGG_COORD_DEBUG=1 a single
      # "scan cache HIT" line made `$berr` non-empty, so the whole diagnosis below was skipped — the
      # branch that explains a starved queue, suppressed by a debug line. Key on the reasons: `passed
      # over:` is the header `batch` prints when, and only when, it actually has some.
      if [ -s "$berr" ]; then cat "$berr" >&2; fi   # `&&` here would exit on an empty $berr (set -e)
      if ! grep -q '^passed over:' "$berr" 2>/dev/null; then
        # COUNT IT. DO NOT INFER IT FROM AN EMPTY STDERR (#488).
        #
        # This branch used to assert the strongest available negative — "no open board item at all —
        # this is an empty queue, not a blocked one" — on the sole evidence that `batch` wrote nothing
        # to stderr. An empty stderr is not an empty board. Nothing here counted anything, and the
        # sentence stated as fact something the code never established.
        #
        # It was the same defect #440 was closed for, sitting directly beneath #440's own comment
        # warning against it ("a guess dressed as a finding … A worker that believes such a message
        # stops"). And it pointed the worker AWAY from the true cause: it does not merely omit
        # "blocked", it rules it out.
        #
        # The scan is the one `batch` just paid for (CACHED=1), so counting is FREE — no extra
        # GraphQL, which is why there was never a good reason to guess.
        # `$repo` here is what `scope_repo` produced — a registry short-id (`audio`), NOT the repo name
        # the board carries (`FS-GG/FS.GG.Audio`). `batch` resolves it internally; this count has to do
        # the same, or `board_filter` matches nothing and every queue reads as empty — which is the very
        # lie being fixed, reintroduced by the fix.
        local open_items n_open rrepo=""
        [ -n "$repo" ] && rrepo="$(resolve_repo "$repo" 2>/dev/null || printf '%s' "$repo")"
        open_items="$(CACHED=1 board_items 2>/dev/null | board_filter "$rrepo" "" "" 1 2>/dev/null)" || open_items=''
        n_open="$(jq 'length' <<<"${open_items:-}" 2>/dev/null || true)"
        case "${n_open:-}" in
          '' | *[!0-9]*)
            # A failed count is NOT an empty queue. "I could not look" and "I looked, and it is empty"
            # must not produce the same sentence (#266's ratified rule).
            echo "  (could not read the board to say WHY — so this is 'no verdict', not 'an empty queue'. Retry, or run: fsgg-coord ready --repo '${repo:-<repo>}' --all)" >&2
            ;;
          0)
            echo "  (no open board item${repo:+ for '$repo'} at all — this is an empty queue, not a blocked one.)" >&2
            ;;
          *)
            echo "  $n_open open board item(s)${repo:+ for '$repo'}, and NONE of them is startable — a BLOCKED queue, not an empty one:" >&2
            jq -r 'group_by(.status // "(no Status)")
                   | map("    \(length) × \(.[0].status // "(no Status)")") | .[]' <<<"$open_items" >&2
            jq -r "$JQ_BLOCKER_RULE"'.[] | select(.blocked)
                   | ( [ (.blockers // [])[] | unresolved | (.ref | sub("^[^/]+/";"")) ]
                       | if length == 0 then "an unnamed blocker" else join(", ") end ) as $b
                   | "    \(.repo | sub("^[^/]+/";""))#\(.number) — blocked by \($b)"' <<<"$open_items" >&2
            echo "  See them all: fsgg-coord ready --repo '${repo:-<repo>}' --all" >&2
            ;;
        esac
      fi
      rm -f "$berr"
      return 0
    fi
    rm -f "$berr"
    [ -n "$from_backlog" ] && \
      echo "fsgg-coord: no Ready item${repo:+ for '$repo'}; taking $pick from Backlog." >&2
    # DO NOT TRUST THE ANNOTATED BOOLEAN AT THE MOMENT OF CLAIMING (#485 leg f, was #343).
    #
    # `batch` once handed out FS.GG.Game#75 with `blockedBy=…#74, …#84` and `blocked=false` while #84
    # was demonstrably OPEN — and #75 and #84 overlap on two files. Two workers would have been editing
    # the same source with no `Blocked by` between them; it was caught only because the reporter had
    # just claimed #84 by hand. The jq is provably correct on those exact rows, so the bad input came
    # from somewhere in the scan (a stale `content.state` on some page, or a last-wins `from_entries`
    # collision) and the mechanism is STILL NOT PINNED.
    #
    # An unexplained fail-open is not a reason to keep trusting the cached flag. Ask the SERVER about
    # this one item's blockers, at the instant we are about to claim it — a handful of REST calls, on a
    # budget that is not the scarce one — and refuse if any is still open. That converts the silent
    # double-assignment into a refusal that names the disagreement, which is what a scheduler owes a
    # worker it is about to point at a collision. It stays correct whatever leg (f) turns out to be.
    assert_blockers_clear "$pick"
    # claim in a subshell: its `die` (a lost race) must end the attempt, not `take`. SOFT_DIE=1 keeps
    # that `die` local under #344's fatal-die rule — the board read that must fail closed already
    # happened in `batch_cmd` above, before we ever get a `$pick` to claim.
    local rc=0
    soft_run claim_cmd "$pick" || rc=$?
    [ "$rc" -eq 0 ] && { unset FRESH; return 0; }
    # An exhausted budget is not a lost race, and retrying it 3× just spends REST calls confirming
    # the same 403. Surface it as the back-off signal it is (#418): EX_RATE, with the reset time.
    if [ "$rc" -eq "$EX_RATE" ]; then
      unset FRESH
      echo "fsgg-coord: worker $w cannot take work — GraphQL budget exhausted, resets in $(rate_reset_in)." >&2
      echo "  Back off until then (do not loop). REST-only work — reading issues, pushing, opening a PR" >&2
      echo "  via 'gh api' — still runs on its own budget." >&2
      return "$EX_RATE"
    fi
    echo "fsgg-coord: worker $w lost $pick (attempt $attempt/$tries) — rescheduling." >&2
    attempt=$((attempt + 1))
  done
  unset FRESH
  echo "fsgg-coord: worker $w gave up after $tries attempt(s); the board is contended. Retry, or widen --repo." >&2
  return 0
}

# ---- say / inbox: the channel between workers whose work touches -----------------------------------
# ADR-0021 gave workers a way to DETECT overlap and no way to TALK about it, so the only remedy was to
# sequence — even when the right answer was "you take the interface, I'll take the impl". Messages are
# issue comments carrying an `fsgg:msg` marker addressed to a worker id (or `*`, meaning whoever holds
# the item). They ride the item they concern, so the conversation is next to the work, GitHub notifies
# the assignee for free, and nothing new has to be stood up. Same reason ADR-0001 chose issues over a
# file mailbox: git is history, not a queue.
say_cmd() {
  local ref="" to="*" msg=""
  while [ $# -gt 0 ]; do
    case "$1" in
      # SLUG the target. Worker ids are always slug()'d at creation, and `inbox` matches `.to` by exact
      # string, so an unslugged `--to Finch-A3F` posts a message that its recipient can never see.
      # `*` (anyone holding the item) is the one literal that is not a worker id.
      --to) to="${2:?--to needs a value}"
            if [ "$to" != '*' ]; then
              local slugged; slugged="$(slug "$to")"
              [ -n "$slugged" ] || die "say: --to '$to' is not a usable worker id."
              [ "$slugged" = "$to" ] || echo "fsgg-coord: addressing worker '$slugged' (normalized from '$to')." >&2
              to="$slugged"
            fi
            shift 2 ;;
      -*)   die "say: unknown flag '$1'." ;;
      *)    if [ -z "$ref" ]; then ref="$1"; else msg="${msg:+$msg }$1"; fi; shift ;;
    esac
  done
  [ -n "$ref" ] || die "say: <issue> required."
  [ -n "$msg" ] || die "say: a message is required (say <issue> [--to worker] <message>)."
  parse_ref "$ref"
  worker >/dev/null; local w="$WORKER_ID"
  local body
  body="$(printf '<!-- %s from=%s to=%s -->\n**%s → %s**\n\n%s\n' "$MSG_MARK" "$w" "$to" "$w" "$to" "$msg")"
  post_comment "$R_OWNER" "$R_REPO" "$R_NUM" "$body" >/dev/null
  printf 'said on %s: %s → %s\n' "$R_REPO#$R_NUM" "$w" "$to"

  # Talking about an item we hold is activity: renew the lease rather than let `reap` collect us.
  # Renew only a LIVE marker of ours: `say` must not resurrect an expired claim (see heartbeat_cmd).
  local mine
  mine="$(claims_of "$R_OWNER" "$R_REPO" "$R_NUM" \
          | jq -c --arg w "$w" 'map(select(.stale | not) | select(.worker == $w)) | first // empty')"
  [ -n "$mine" ] && heartbeat_comment "$R_OWNER" "$R_REPO" "$R_NUM" "$(jq -r '.id' <<<"$mine")" "$w" "$ref" \
    "$(jq -r '.prev // ""' <<<"$mine")"
  return 0
}

# Messages addressed to this worker, across every in-flight claim (both parties to a collision are
# In progress, so that set is exactly where cross-work talk lives). A per-worker cursor makes `inbox`
# show only what is new; --peek leaves the cursor alone.
inbox_cmd() {
  local repo="" peek="" json=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --repo) repo="${2:?--repo needs a value}"; shift 2 ;;
      --peek) peek=1; shift ;;
      --json) json=1; shift ;;
      -*)     die "inbox: unknown flag '$1'." ;;
      *)      die "inbox: unexpected argument '$1'." ;;
    esac
  done
  [ -n "$repo" ] && repo="$(resolve_repo "$repo")"
  worker >/dev/null; local w="$WORKER_ID"
  local cursorfile="$CACHE/inbox-$(slug "$w")"
  local since=0; [ -f "$cursorfile" ] && since="$(cat "$cursorfile")"
  case "$since" in ''|*[!0-9]*) since=0 ;; esac   # a truncated cursor must not reach --argjson

  local claims n i=0 tmp maxid="$since"
  claims="$(active_claims "$repo")"
  n="$(jq 'length' <<<"$claims")"
  tmp="$(mktemp "$CACHE/.inbox.XXXXXX")"; : >"$tmp"
  while [ "$i" -lt "$n" ]; do
    local c r num o rp msgs top
    c="$(jq -c ".[$i]" <<<"$claims")"; i=$((i + 1))
    r="$(jq -r '.repo' <<<"$c")"; num="$(jq -r '.number' <<<"$c")"
    o="${r%%/*}"; rp="${r#*/}"
    msgs="$(issue_comments "$o" "$rp" "$num" | parse_msgs)"   # a failed read here is a lost message, not a lost lock
    top="$(jq -r 'map(.id) | max // 0' <<<"$msgs")"
    [ "$top" -gt "$maxid" ] && maxid="$top"
    jq -c --arg w "$w" --arg item "$rp#$num" --argjson since "$since" '
      .[] | select(.id > $since) | select(.from != $w) | select(.to == $w or .to == "*")
      | { item: $item } + .' <<<"$msgs" >>"$tmp"
  done

  local out; out="$(jq -s '.' "$tmp")"; rm -f "$tmp"
  [ -z "$peek" ] && printf '%s' "$maxid" >"$cursorfile"

  if [ -n "$json" ]; then jq '.' <<<"$out"; return 0; fi
  if [ "$(jq 'length' <<<"$out")" -eq 0 ]; then
    printf 'no new messages for worker %s.\n' "$w"; return 0
  fi
  jq -r '.[] | "── \(.item)  \(.from) → \(.to)  (\(.at))\n\(.text)\n"' <<<"$out"
  [ -n "$peek" ] && echo "fsgg-coord: --peek — cursor not advanced." >&2
  return 0
}

# ---- widen: re-declare a touch-set mid-flight, and TELL whoever it now collides with --------------
# ADR-0021: "a worker that must widen its touch-set re-declares and re-checks overlap before
# continuing." It never said how, so in practice nobody did. This does all three in one call: rewrite
# the `Paths:` line, re-check against every live claim, and — the part a worker cannot do alone —
# notify the workers whose items now overlap, on their own issues.
widen_cmd() {
  local ref="" newpaths=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --paths) newpaths="${2:?--paths needs a value}"; shift 2 ;;
      -*)      die "widen: unknown flag '$1'." ;;
      *)       [ -z "$ref" ] && ref="$1" || die "widen: unexpected argument '$1'."; shift ;;
    esac
  done
  [ -n "$ref" ] || die "widen: <issue> required."
  [ -n "$newpaths" ] || die "widen: --paths '<paths>' required."
  parse_ref "$ref"
  worker >/dev/null; local w="$WORKER_ID"
  local self="$R_OWNER/$R_REPO#$R_NUM" sr="$R_REPO" sn="$R_NUM" so="$R_OWNER"

  # Validate BEFORE the read and the PATCH. `widen`'s whole job is to re-check a touch-set against
  # live claims and shout about collisions; widening to a token that matches nothing gets the cleanest
  # possible answer for the worst possible reason. Refuse while the body is still untouched, so a
  # rejected widen leaves no trace and the old declaration keeps reserving its files.
  die_on_invalid_paths "$(paths_from_body "Paths: $newpaths")" "widen: --paths for $sr#$sn"

  # Rewrite the `Paths:` line in place (or append one), then PATCH the body back.
  local bodyfile newfile
  bodyfile="$(mktemp "$CACHE/.body.XXXXXX")"; newfile="$(mktemp "$CACHE/.body.XXXXXX")"
  gh api "repos/$so/$sr/issues/$sn" --jq '.body // ""' >"$bodyfile" 2>/dev/null \
    || { rm -f "$bodyfile" "$newfile"; die "widen: cannot read $sr#$sn."; }
  # Rewrite the lines `paths_from_body` would READ (unfenced, ≤3-space indent) — never a quoted one
  # inside a fence, which would leave the real declaration standing and reserve nothing (#277).
  #
  # The reader UNIONS every surviving declaration, so replacing just the first would leave the rest
  # still reserving their old tokens and `widen` would not have widened to what it printed. The first
  # becomes the new declaration and the others are DROPPED, which is also how a body that accumulated
  # a stray bare quotation gets repaired.
  #
  # `repl` travels via the environment, NOT `-v`: awk applies escape processing to a `-v` value, so a
  # token containing a backslash would be PATCHed as something other than the string we validated with
  # `die_on_invalid_paths` and printed back to the worker (`src/a\tb` -> a real tab -> two tokens).
  #
  # And when the body ENDS inside an unclosed fence there is no declaration to patch, so we append —
  # but appending after an unterminated fence puts the new line *inside* it, where the reader will not
  # see it. widen would then report a confident `widened …` over an item that still declares nothing,
  # which is precisely the body a worker runs widen to repair. Close the fence first.
  FSGG_REPL="Paths: $newpaths" awk "$FENCE_AWK"'
    BEGIN { repl = ENVIRON["FSGG_REPL"] }
    { if (fence_delim($0)) { print; next } }
    !IN_FENCE && /^ {0,3}[Pp]aths:/ { if (!done) { print repl; done = 1 } ; next }
    { print }
    END {
      if (!done) {
        if (IN_FENCE) { closer = ""; for (i = 0; i < FENCE_N; i++) closer = closer FENCE_CH; print closer }
        print ""; print repl
      }
    }' "$bodyfile" >"$newfile"
  gh api -X PATCH "repos/$so/$sr/issues/$sn" -F body=@"$newfile" >/dev/null \
    || { rm -f "$bodyfile" "$newfile"; die "widen: cannot update the body of $sr#$sn."; }
  rm -f "$bodyfile" "$newfile"
  printf 'widened %s → Paths: %s\n' "$sr#$sn" "$newpaths"

  # Declaration time is the cheap moment to learn that editing a kit source obliges a re-digest (#469).
  # The alternative is learning it from a red `main` after the merge, which is how this was found.
  kit_digest_warn "$(printf '%s' "$newpaths" | tr ',' '\n' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')" \
                  "the touch-set you just declared on $sr#$sn"

  # Re-check against everything in flight, and notify each worker we now collide with.
  local pa claims n i=0 found=0
  pa="$(paths_of "$so" "$sr" "$sn")"
  # Scope to THIS item's repo, exactly as `batch` does (`active_claims "$repo"`). `Paths:` tokens are
  # repo-relative, so comparing `self`'s tokens against a claim in ANOTHER repo compares two strings
  # that name files in two different repositories — `conflicts_between` sees a shared prefix and
  # invents a collision, which stops a worker who has nothing to stop for and posts a false
  # "sequence one behind the other" notice onto a stranger's item (#353). A cross-repo claim can
  # never share a (repo-relative) file with this item, so it is correct to leave it out of the scan;
  # doing so also makes `widen` coherent with `batch`, which would schedule the very pair `widen`
  # otherwise insists collides.
  claims="$(active_claims "$so/$sr")"
  n="$(jq 'length' <<<"$claims")"
  # The widen itself has landed (that is `widen`'s job, and it is how a bad declaration gets FIXED —
  # including on an item that is itself held). But the re-check against in-flight work is only as
  # trustworthy as the touch-sets it compares against: a legacy holder whose own tokens are
  # unmatchable reserves nothing, clears everything, and would hand us a `DISJOINT` that means only
  # "we cannot see their files". Screen the OTHER claims (never `self`) and refuse to answer instead.
  local obad
  obad="$(claims_with_unmatchable_paths "$claims" "$self")"
  if [ -n "$obad" ]; then
    echo "fsgg-coord: widen: in-flight claim(s) declare unmatchable touch-set token(s): $obad" >&2
    echo "  they reserve nothing, so this widen cannot be re-checked against them — refusing to report DISJOINT." >&2
    echo "  fix theirs first: fsgg-coord widen <issue> --paths '<paths>'" >&2
    return 2
  fi
  while [ "$i" -lt "$n" ]; do
    local c cr cn cw co crp hits
    c="$(jq -c ".[$i]" <<<"$claims")"; i=$((i + 1))
    cr="$(jq -r '.repo' <<<"$c")"; cn="$(jq -r '.number' <<<"$c")"
    [ "$cr#$cn" = "$self" ] && continue
    cw="$(jq -r '.worker // "*"' <<<"$c")"
    hits="$(conflicts_between "$pa" "$(jq -r '.paths[]?' <<<"$c")")"
    [ -n "$hits" ] || continue
    found=1
    co="${cr%%/*}"; crp="${cr#*/}"
    printf 'OVERLAP — now collides with %s#%s (worker %s)\n' "$crp" "$cn" "$cw" >&2
    printf '  %s\n' "$hits" >&2
    post_comment "$co" "$crp" "$cn" \
      "$(printf '<!-- %s from=%s to=%s -->\n**%s → %s** — heads up: I widened `%s` to `Paths: %s`, which now overlaps your touch-set here:\n\n```\n%s\n```\n\nWe cannot run these in parallel as declared. Sequence one behind the other (`Blocked by`), or split the touch-set — reply here.\n' \
         "$MSG_MARK" "$w" "$cw" "$w" "$cw" "$self" "$newpaths" "$hits")" >/dev/null
    printf '  notified worker %s on %s#%s\n' "$cw" "$crp" "$cn" >&2
  done

  if [ "$found" -eq 0 ]; then
    printf 'DISJOINT — the widened touch-set clears all %s in-flight claim(s).\n' "$n"
    return 0
  fi
  echo "fsgg-coord: widening introduced a collision — do NOT keep editing the shared paths until it is resolved." >&2
  return 1
}

# ---- verify-paths: did the PR stay inside the touch-set its issue declared? -----------------------
# The touch-set is a DECLARATION, not an enforced boundary (ADR-0021), and it stays that way: this
# reports drift, it does not prevent it. But an undetected drift is what turns two "disjoint" items
# into a merge conflict, so CI runs this in --warn mode and posts what it found. The declaration is
# only worth as much as the check that reads it back.
# ---- the kit-digest coupling (#469) --------------------------------------------------------------
# `registry/repos.yml` pins a CONTENT DIGEST of every coordination-kit source (ADR-0019: the kit is
# content-addressed). So editing a kit source — `scripts/fsgg-coord`, or ANY `.claude/skills/<kit>/`
# — invalidates that digest, and `repos-registry` reds `main` until it is regenerated. The obligation
# is invisible: it is not in the item, not in `widen`, and `verify-paths` cannot see it either, because
# `verify-paths` only asks "did the PR stay INSIDE what you declared" — never "was your declaration
# SUFFICIENT for what you touched". A touch-set of `scripts/fsgg-coord` alone passes, and reds main.
# That is the #266 shape: the gate is most reassuring exactly when it is least informed.
#
# So: name the obligation the moment a kit source appears in a file list. Advisory, never fatal — the
# authority is `repos-registry`, and this only stops it being a surprise. Silent where there is no
# registry to read (a receiver repo mirrors the kit but not `registry/repos.yml`).
# POST-#527 THE OBLIGATION IS A FACT YOU CAN GO AND LOOK AT — SO GO AND LOOK (#563, #588).
#
# This used to ask "is `registry/repos.yml` in your touch-set?" and call the obligation MET if it was.
# #527 then moved the digests OUT of the authored `repos.yml` and INTO the generated `repos.lock`, and
# neither this warning nor the four SKILL.md moved with it. The result was not a stale string:
#
#   1. IT FAILED OPEN. Declare `repos.yml` and the warning returned SILENTLY — while `repos.lock` was
#      still stale and `repos-registry-selftest` still red `main`. Mute exactly where it was needed.
#      That is epic #266's shape, inside the tool written to name #266-class obligations.
#      The SKILL ROOTS half hung off the same early return, so declaring `repos.yml` silently
#      suppressed BOTH obligations at once.
#   2. ITS ADVICE BROKE #309. It told you to declare `repos.yml` in the touch-set — which is the
#      three-worker serialisation deadlock (#428) that #527 was merged to REMOVE — and to run
#      `scripts/repos.sh digest`, which still exists but no longer WRITES anything. A command that
#      runs, reports success, and does nothing: epic #416, in the advice for fixing epic #266.
#
# The cure is not a better string. A DECLARATION is not the obligation; a MATCHING DIGEST is. So this
# no longer infers the obligation from what you declared — it recomputes the digest and looks. The
# warning goes quiet exactly when the work is actually done, and never before.
#
# Silent where there is no lock to read: a receiver mirrors the kit but not the registry.
kit_digest_stale() {  # -> each kit source whose ACTUAL digest differs from registry/repos.lock
  local root lock want src path have
  # FSGG_KIT_ROOT exists so the fixture can stand up a throwaway tree and make a digest genuinely
  # stale. Without it the only observable subject is this repo, which is (correctly) never stale — and
  # a test whose subject cannot be made to fail is the #436 shape.
  root="${FSGG_KIT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null)}" || return 0
  [ -n "$root" ] || return 0
  lock="${FSGG_REPOS_LOCK:-$root/registry/repos.lock}"
  [ -f "$lock" ] || return 0
  command -v sha256sum >/dev/null 2>&1 || return 0
  while read -r want src; do
    case "$want" in ''|'#'*) continue ;; esac
    [ -n "$src" ] || continue
    path="$root/$src"
    # A skill kit is content-addressed on its SKILL.md; a client kit on the file itself (repos.sh).
    [ -d "$path" ] && path="$path/SKILL.md"
    [ -f "$path" ] || continue
    have="$(sha256sum "$path" | cut -d' ' -f1)"
    [ "$have" = "$want" ] || printf '%s\n' "$src"
  done < "$lock"
}

# Every agent-skill root carries the BYTE-IDENTICAL union (ADR-0011/0014), so a skill edited in one
# root and not the other reds the `roots` gate. Same discipline: OBSERVE the divergence rather than
# infer it from a file list.
kit_roots_diverged() {  # -> each skill dir whose roots are not byte-identical
  local root d name other
  root="${FSGG_KIT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null)}" || return 0
  [ -n "$root" ] || return 0
  [ -d "$root/.claude/skills" ] && [ -d "$root/.agents/skills" ] || return 0
  for d in "$root"/.claude/skills/*/; do
    [ -f "$d/SKILL.md" ] || continue
    name="$(basename "$d")"
    other="$root/.agents/skills/$name/SKILL.md"
    if [ ! -f "$other" ] || ! cmp -s "$d/SKILL.md" "$other"; then
      printf '%s\n' "$name"
    fi
  done
}

kit_digest_warn() {  # ($1 file list, $2 context label — kept for call-site compatibility; unused now:
                     #  the facts are OBSERVED, not inferred from what the caller declared)
  local stale roots name
  stale="$(kit_digest_stale)"
  roots="$(kit_roots_diverged)"

  if [ -n "$stale" ]; then
    printf '\nfsgg-coord: KIT DIGEST — a content-addressed kit source is STALE in `registry/repos.lock`:\n' >&2
    printf '%s\n' "$stale" | sed 's/^/  /' >&2
    printf '`repos-registry-selftest` reds `main` until it is regenerated (ADR-0019, #469). Run:\n' >&2
    printf '  scripts/repos.sh relock\n' >&2
    printf 'Then name `registry/repos.lock` as EXPECTED DRIFT in the PR — do NOT reserve it in the\n' >&2
    printf 'touch-set. It is a GENERATED, CI-GATED artifact, so a collision in it is a REBASE, not a\n' >&2
    printf 'decision (#309). Reserving it is the three-worker deadlock #527 removed (#428).\n' >&2
  fi

  if [ -n "$roots" ]; then
    printf '\nfsgg-coord: SKILL ROOTS — a skill kit must stay BYTE-IDENTICAL across every root\n' >&2
    printf '(ADR-0011/0014), or the `roots` gate reds `main`. These have diverged:\n' >&2
    while IFS= read -r name; do
      [ -n "$name" ] || continue
      printf '  cp .claude/skills/%s/SKILL.md .agents/skills/%s/SKILL.md\n' "$name" "$name" >&2
    done <<<"$roots"
  fi
  return 0
}

verify_paths_cmd() {
  local pr="" repo="" issue="" warn=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --pr)    pr="${2:?--pr needs a value}"; shift 2 ;;
      --repo)  repo="${2:?--repo needs a value}"; shift 2 ;;
      --issue) issue="${2:?--issue needs a value}"; shift 2 ;;
      --warn)  warn=1; shift ;;
      -*)      die "verify-paths: unknown flag '$1'." ;;
      *)       die "verify-paths: unexpected argument '$1'." ;;
    esac
  done
  [ -n "$pr" ] || die "verify-paths: --pr N required."
  case "$pr" in *[!0-9]*) die "verify-paths: --pr must be a number." ;; esac

  # WHICH REPO IS THE PR IN? `--pr` used to resolve against the repo you were STANDING IN while
  # `--issue` carried a repo of its own — so a PR in one repo was diffed against a touch-set in
  # another, and a confident FSGG-PATHS verdict was printed on a subject nobody had looked at
  # (.github#479). The `--issue` ref already NAMES the repo; the answer was in the arguments.
  # Precedence: an explicit --repo, else the issue's repo, else the checkout. The checkout is a
  # fallback, never evidence that overrides a ref the caller spelled out.
  local io="" ir="" o="" r=""
  if [ -n "$issue" ]; then
    parse_ref "$issue"; io="$R_OWNER"; ir="$R_REPO"   # read R_* IMMEDIATELY (#389)
    issue="$io/$ir#$R_NUM"          # canonical, so the verdict names the repo it actually checked
  fi
  if [ -z "$repo" ] && [ -z "$issue" ]; then
    # THE REMOTE IS ON DISK — ASK IT FIRST (#430). This used to derive the repo from `gh repo view`,
    # a GraphQL call, and read its empty result as proof of "not inside a GitHub checkout". But an
    # empty result does not mean that. It means the call did not succeed, and the reason had just
    # been thrown away by `2>/dev/null || true` — so the line asserted a cause it never established.
    #
    # The cause it was usually hiding: an EXHAUSTED GraphQL budget. Which is not an exotic state here.
    # It is the steady state of the N-agents-on-one-account fan-out this kit exists to serve, and it
    # lands on `verify-paths` at the MERGE BOUNDARY — the moment a worker is most likely to shrug and
    # skip an advisory check they cannot get to run. They were sent to debug their checkout instead.
    #
    # `scope_repo` reads `remote.origin.url`. It is free, offline, and cannot be rate-limited — which
    # is exactly why it is the primary and `gh` is the fallback, rather than the other way round.
    repo="$(scope_repo)"
    if [ -z "$repo" ]; then
      # No usable `origin`. `gh` may still know the repo (a checkout whose remote is named otherwise),
      # so it stays — as the fallback it should always have been. What changes is that its failure is
      # now EVIDENCE rather than something to discard and then diagnose around.
      # stderr to a file, NOT `2>&1` into the same capture: this call's stdout IS the value we keep,
      # so a `gh` notice on stderr during a SUCCESSFUL call would otherwise be spliced into the repo
      # name. `gql` can merge the two because its stdout is JSON it parses; ours is a bare string.
      #
      # But on FAILURE `is_rate_limited` gets the WHOLE combined text, which is the contract it
      # documents and the shape `gql`/`project_write` already feed it. Narrowing that (to, say, the
      # last line of stderr) would let a rate limit that is not gh's final word fall through to the
      # generic arm — the worker would get exit 1 instead of EX_RATE and their loop would not back
      # off. Diagnosing from a PARTIAL error is the same mistake as diagnosing from a discarded one.
      local errf ghout gherr rc=0; errf="$(mktemp "$CACHE/.gh-err.XXXXXX")"
      ghout="$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>"$errf")" || rc=$?
      gherr="$(cat "$errf" 2>/dev/null)"; rm -f "$errf"
      if [ "$rc" -ne 0 ]; then
        # Name the rate limit AS a rate limit and exit EX_RATE (75) — the code a worker loop already
        # backs off on. Reporting it as some generic failure would still beat the old lie, but it
        # would leave the reader to work out that waiting is the remedy.
        is_rate_limited "$ghout
$gherr" && die_rate
        printf '%s\n' "$gherr" >&2          # re-emit, so nothing is swallowed (as `gql` does)
        die "verify-paths: could not determine which repo this PR is in — 'gh repo view' failed (exit $rc, see above), and no 'origin' remote was readable from disk either.
  Pass it explicitly: fsgg-coord verify-paths --pr $pr --repo FS-GG/<repo>"
      fi
      repo="$ghout"
      # gh SUCCEEDED and still said nothing. Now — and only now — "not a checkout" is a conclusion
      # this code has actually established, rather than one it inferred from a discarded error.
      [ -n "$repo" ] || die "verify-paths: --repo owner/repo required (not inside a GitHub checkout)."
    fi
  fi
  if [ -n "$repo" ]; then
    case "$repo" in */*) o="${repo%%/*}" ;; *) o="$OWNER" ;; esac
    r="$(resolve_repo "$repo")"     # a registry short-id (`audio`) resolves like it does everywhere else
  else
    o="$io"; r="$ir"
  fi
  # A disagreement is an ERROR, not a preference. Silently preferring one of the two is exactly how a
  # PR in repo A earned a verdict from repo B's touch-set. Compare case-insensitively — GitHub repo
  # names are, and `--repo fs.gg.audio` agreeing with `FS.GG.Audio#42` must not read as a conflict.
  if [ -n "$issue" ] && { [ "${o,,}" != "${io,,}" ] || [ "${r,,}" != "${ir,,}" ]; }; then
    die "verify-paths: --repo names $o/$r but --issue names $io/$ir — a PR in one repo cannot be verified against a touch-set in another. The touch-set was NOT checked."
  fi

  # Which issue does this PR implement? Explicit wins; else the `item/<n>-…` branch ADR-0021 mandates;
  # else the PR's own closing reference. Refusing to guess is better than checking the wrong touch-set.
  if [ -z "$issue" ]; then
    # Capture the rc; do NOT `|| echo ""`. An empty head ref must mean "the API answered, and the
    # branch is not item/<n>-…" — never "the API did not answer". Collapsing the two lets a transient
    # 502 fall through to the closing-reference fallback, which then reports healthily that the PR
    # closes no issue, and `verify-paths` prints SKIP with rc=0: a verdict invented from an
    # unanswered query (.github#322). `die` is right even under --warn — --warn downgrades the drift
    # VERDICT to advisory, and "I could not check" is not a verdict. The touch-set-drift gate keeps
    # this rc precisely so it can fail closed on it.
    local head rc=0
    head="$(gh api "repos/$o/$r/pulls/$pr" --jq '.head.ref' 2>/dev/null)" || rc=$?
    [ "$rc" -eq 0 ] || die "verify-paths: cannot read PR #$pr's head ref (gh exited $rc) — refusing to guess which issue it implements. The touch-set was NOT checked."
    if [[ "$head" =~ ^item/([0-9]+) ]]; then
      issue="$o/$r#${BASH_REMATCH[1]}"
    else
      local q='query($owner:String!, $repo:String!, $num:Int!){
        repository(owner:$owner, name:$repo){ pullRequest(number:$num){
          closingIssuesReferences(first:5){ nodes{ number repository{ nameWithOwner } } } } }
        rateLimit{ cost remaining }
      }'
      local out; out="$(gql "$q" -f owner="$o" -f repo="$r" -F num="$pr")"
      issue="$(jq -r '.data.repository.pullRequest.closingIssuesReferences.nodes[0]
                      | select(. != null) | "\(.repository.nameWithOwner)#\(.number)"' <<<"$out")"
    fi
  fi
  # Three verdicts, not two. A PR with nothing to verify against is SKIP — never a silent pass, or CI
  # would stamp "stays inside its touch-set" on a PR that never declared one.
  if [ -z "$issue" ]; then
    [ -n "$warn" ] && { printf 'FSGG-PATHS SKIP — cannot tell which issue PR #%s implements (branch is not item/<n>-…, and it closes no issue).\n' "$pr"; return 0; }
    die "verify-paths: cannot tell which issue PR #$pr implements (branch is not item/<n>-…, and it closes no issue). Pass --issue."
  fi
  # The boundary again, from the other side. GitHub lets a PR close an issue in ANOTHER repo, so the
  # closing-reference fallback can hand back a ref that walks straight back across the line the
  # explicit check above just refused to cross (.github#479). The caller did nothing wrong here — this
  # is not an error, it is simply nothing we can check — but it is emphatically NOT a verdict: repo B's
  # touch-set says nothing about repo A's files. Re-check the DERIVED ref, not just the explicit one.
  parse_ref "$issue"; local xo="$R_OWNER" xr="$R_REPO" xn="$R_NUM"   # read R_* IMMEDIATELY (#389)
  if [ "${xo,,}" != "${o,,}" ] || [ "${xr,,}" != "${r,,}" ]; then
    local xmsg="PR #$pr is in $o/$r but closes $xo/$xr#$xn, in another repo — a touch-set declared there says nothing about the files changed here, so there is nothing to verify against."
    [ -n "$warn" ] && { printf 'FSGG-PATHS SKIP — %s\n' "$xmsg"; return 0; }
    echo "verify-paths: $xmsg" >&2
    return 2
  fi

  local declared; declared="$(paths_for_ref "$issue")"
  if [ -z "$declared" ]; then
    [ -n "$warn" ] && { printf 'FSGG-PATHS SKIP — %s declares no '"'"'Paths:'"'"' touch-set; nothing to verify against.\n' "$issue"; return 0; }
    echo "verify-paths: $issue declares no 'Paths:' touch-set — nothing to verify against." >&2
    return 2
  fi
  # A fourth verdict. An unmatchable token covers no file, so every changed file would be reported as
  # drift "outside the touch-set" — technically true, and useless: the touch-set is the broken thing.
  # Say so, rather than burying the cause under a file list.
  local badtok; badtok="$(invalid_paths "$declared")"
  if [ -n "$badtok" ]; then
    local msg="$issue declares unmatchable touch-set token(s): $(fmt_bad_paths "$badtok") — they match no file, so nothing can be verified against them."
    [ -n "$warn" ] && { printf 'FSGG-PATHS INVALID — %s\n  %s\n' "$msg" "$TOUCHSET_GRAMMAR"; return 0; }
    printf 'FSGG-PATHS INVALID — %s\n  %s\n' "$msg" "$TOUCHSET_GRAMMAR" >&2
    return 2
  fi

  local changed; changed="$(gh api "repos/$o/$r/pulls/$pr/files?per_page=100" --paginate --jq '.[].filename' 2>/dev/null)"
  [ -n "$changed" ] || { printf 'FSGG-PATHS OK — PR #%s changes no files.\n' "$pr"; return 0; }

  local -a decl; mapfile -t decl <<<"$declared"
  local f t covered drift=""
  while read -r f; do
    [ -n "$f" ] || continue
    covered=""
    for t in "${decl[@]}"; do
      [ -n "$t" ] || continue
      if [ "$f" = "$t" ] || [ "${f#"$t"/}" != "$f" ]; then covered=1; break; fi
    done
    [ -n "$covered" ] || drift="$drift$f"$'\n'
  done <<<"$changed"

  # The kit-digest obligation is checked against what the PR CHANGED, not against what it declared —
  # a PR that edits a kit source and never re-digests reds `main` whether or not it drifted, so an
  # `OK` verdict must not imply it is safe to merge (#469).
  kit_digest_warn "$changed" "PR #$pr"

  if [ -z "$drift" ]; then
    printf 'FSGG-PATHS OK — PR #%s stays inside the touch-set declared by %s.\n' "$pr" "$issue"
    return 0
  fi
  printf 'FSGG-PATHS DRIFT — PR #%s touches %s file(s) outside the touch-set declared by %s:\n' \
    "$pr" "$(printf '%s' "$drift" | grep -c .)" "$issue"
  printf '%s' "$drift" | sed 's/^/  /'
  printf '\ndeclared:\n'; printf '%s\n' "$declared" | sed 's/^/  /'
  printf '\nRe-declare and re-check against in-flight work:\n  fsgg-coord widen %s --paths "<paths>"\n' "$issue"
  [ -n "$warn" ] && return 0
  return 1
}

# The usage block is the header comment down to (but not including) the Env section. Deriving the
# range from a marker rather than hardcoded line numbers means adding a subcommand cannot silently
# truncate `--help`.
usage() {
  sed -n '2,/^# Env:/p' "$0" | sed '$d' | sed 's/^# \{0,1\}//; s/^#$//'
}

# ---- dispatch -----------------------------------------------------------------------------------
# A global `--worker <id>` may precede the subcommand, so an orchestrator can name each agent it
# spawns without exporting an env var into it.
if [ "${1:-}" = "--worker" ]; then
  WORKER_OVERRIDE="${2:?--worker needs a value}"; shift 2
fi

# ...and a global `--engine`, for the same reason (ADR-0034 Phase 2). DEFAULTS TO `auto` — see the
# ENGINE_MODE default above: shadow wherever an engine resolves, plain bash everywhere else, and in
# BOTH cases BASH'S ANSWER IS THE ONE RETURNED. The flip opened `fs`; it did not move the default.
#
# `shadow` is the mode that fed the flip — both engines decide, BASH'S ANSWER IS RETURNED, and the
# disagreement is logged. `fs` IS the flip, and it is accepted here (ADR-0038): the engine's answer is
# the answer, and there is no fallback. What is refused is an UNKNOWN mode, rather than quietly
# accepted, because an option that is accepted and ignored is indistinguishable from one that was
# honoured — and a worker who believed they were running the typed engine would be reading bash's
# answer and calling it evidence.
while [ $# -gt 0 ]; do
  case "${1:-}" in
    --engine)   ENGINE_MODE="${2:?--engine needs a value (auto|bash|shadow|fs)}"; shift 2 ;;
    --engine=*) ENGINE_MODE="${1#--engine=}"; shift ;;
    *) break ;;
  esac
done
case "$ENGINE_MODE" in
  # `fs` is OPEN (ADR-0034 Phase 3b). It was held shut on a three-day fleet-divergence clock, and that
  # clock could not tick: workers run in per-item worktrees, worktree workers resolved no engine, and a
  # worker who banks no evidence cannot be one of the "two distinct workers" the criterion needs (#728).
  # The gate now is the DEFECT CORPUS — tests/fsgg-coord/cases/, one case per historical defect, run
  # against BOTH engines in CI. Three days of two workers agreeing covers whatever items happened to
  # float by; the corpus covers every path that has actually broken. It is the stronger gate, and unlike
  # the clock it does not depend on a fleet that structurally cannot feed it.
  auto|bash|shadow|fs) ;;
  *)  die "--engine: unknown mode '$ENGINE_MODE' (auto|bash|shadow|fs)." ;;
esac

cmd="${1:-}"; [ $# -gt 0 ] && shift || true
case "$cmd" in
  bootstrap) case "${1:-}" in --refresh) bootstrap 1 ;; "") bootstrap ;; *) die "bootstrap: unknown arg '$1'." ;; esac ;;
  board)     case "${1:-}" in --refresh) bootstrap 1 ;; "") ensure_board >/dev/null ;; *) die "board: unknown arg '$1'." ;; esac; cat "$BOARD_FILE" ;;
  field-id)  [ $# -ge 1 ] || die "field-id: <Field> required.";  field_id "$1" ;;
  option-id) [ $# -ge 2 ] || die "option-id: <Field> <Option> required."; option_id "$1" "$2" ;;
  item-id)   [ $# -ge 1 ] || die "item-id: <issue> required.";  item_id "$1" "${2:-}" ;;
  add)       [ $# -ge 1 ] || die "add: <issue> required (URL, owner/repo#n, or repo#n)."; autoflush; add_item "$1" ;;
  # #510: this used to call set_field directly, so an exhausted budget printed die_rate's "Board
  # WRITES are queued" and queued NOTHING. It goes through the one board write now, which really does.
  set-field) autoflush
             sf_rc=0
             if [ "${1:-}" = "--batch" ]; then
               # set-field --batch <issue> Field=Value [Field=Value…] [--refresh]
               shift
               [ $# -ge 2 ] || die "set-field --batch: <issue> Field=Value [Field=Value …] required."
               sf_ref="$1"; shift
               sf_refresh=""; sf_pairs=()
               for sf_a in "$@"; do
                 case "$sf_a" in
                   --refresh) sf_refresh=1 ;;
                   *)         sf_pairs+=("$sf_a") ;;
                 esac
               done
               [ "${#sf_pairs[@]}" -ge 1 ] || die "set-field --batch: at least one Field=Value pair required."
               board_write_batch "$sf_ref" "$sf_refresh" "${sf_pairs[@]}" || sf_rc=$?
             else
               [ $# -ge 3 ] || die "set-field: <issue> <Field> <Value> required (or: set-field --batch <issue> Field=Value …)."
               board_write "$1" "$2" "$3" "${4:-}" || sf_rc=$?
             fi
             if [ "$sf_rc" != 0 ]; then
               # set_field's OWN message first — it is the precise one ("'none' is not a ref", "no
               # field named X"). Swallowing it and printing a generic note is how a refusal becomes
               # a mystery.
               [ -n "$BOARD_WRITE_ERR" ] && printf '%s\n' "$BOARD_WRITE_ERR" >&2
               echo "fsgg-coord: $BOARD_WRITE_NOTE" >&2
             fi
             exit "$sf_rc" ;;
  flush)     flush_cmd "$@" ;;
  issues)    issues "$@" ;;
  ready)     ready "$@" ;;
  next)      next "$@" ;;
  lint)      lint "$@" ;;
  child)     child_cmd "$@" ;;
  done)      autoflush; done_cmd "$@" ;;
  whoami)    whoami_cmd "$@" ;;
  claim)     autoflush; claim_cmd "$@" ;;
  adopt)     autoflush; adopt_cmd "$@" ;;
  heartbeat) heartbeat_cmd "$@" ;;
  release)   release_cmd "$@" ;;
  who)       who_cmd "$@" ;;
  landable)  landable_cmd "$@" ;;
  reap)      reap_cmd "$@" ;;
  take)      take_cmd "$@" ;;
  batch)     batch_cmd "$@" ;;
  lanes)     lanes_cmd "$@" ;;
  overlap)   overlap_cmd "$@" ;;
  widen)     widen_cmd "$@" ;;
  say)       say_cmd "$@" ;;
  inbox)     inbox_cmd "$@" ;;
  verify-paths) verify_paths_cmd "$@" ;;
  divergence) divergence_cmd "$@" ;;
  budget)    budget ;;
  -h|--help|help|"") usage ;;
  *)         die "unknown command '$cmd' (try: fsgg-coord --help)." ;;
esac
